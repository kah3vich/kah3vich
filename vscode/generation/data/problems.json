{
  // 🟢 Problems

  // 🇷🇺 - Определяет, должно ли представление «Проблемы» автоматически отображать файлы при их открытии.
  // 🇺🇸 - Controls whether Problems view should automatically reveal files when opening them.
  "problems.autoReveal": true,

  // 🇷🇺 - Показать ошибки и предупреждения для файлов и папок.
  // 🇺🇸 - Show Errors & Warnings on files and folder.
  "problems.decorations.enabled": true,

  // 🇷🇺 - Управляет режимом просмотра по умолчанию для представления «Проблемы».
  // 🇺🇸 - Controls the default view mode of the Problems view.
  "problems.defaultViewMode": "tree",

  // 🇷🇺 - При включении показывает текущую проблему в строке состояния.
  // 🇺🇸 - When enabled shows the current problem in the status bar.
  "problems.showCurrentInStatus": false,

  // 🇷🇺 - Управляет порядком, в котором перемещаются проблемы.
  // 🇺🇸 - Controls the order in which problems are navigated.
  "problems.sortOrder": "severity"
}
