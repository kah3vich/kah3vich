{
  // 🟢 Сhecker Spell

  // 🇷🇺 - Виды языков.
  // 🇺🇸 - Types of languages.
  "cSpell.language": "en,ru",

  // 🇷🇺 - Список слов исключения.
  // 🇺🇸 - Exception word list.
  "cSpell.userWords": [],

  // 🇷🇺 - Включить в определенных языка.
  // 🇺🇸 - Enable in certain languages.
  "cSpell.enabled": true,

  // 🇷🇺 - Список расширений файлов, в которых будет работать cSpell.
  // 🇺🇸 - List of file extensions in which cSpell.
  "cSpell.enableFiletypes": ["jsx", "js", "css", "scss", "pug", "html", "php"]
}
