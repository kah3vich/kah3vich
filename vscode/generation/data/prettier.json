{
  // 🟢 Prettier

  // 🇷🇺 - Правило устанавливает в конце выражений добавляется точка с запятой.
  // 🇺🇸 - The rule sets a semicolon is added at the end of expressions.
  "prettier.semi": true,

  // 🇷🇺 - Делайте отступы с помощью табуляции вместо пробелов.
  // 🇺🇸 - Indent with tabs instead of spaces.
  "prettier.useTabs": true,

  // 🇷🇺 - Это правило для символа ">" в многострочных JSX-элементах будет помещён в последней строке.
  // 🇺🇸 - This rule for the ">" character in multiline JSX elements will be placed on the last line.
  "prettier.jsxBracketSameLine": false,

  // 🇷🇺 - Отвечает за вставку пробелов между телом объекта и фигурными скобками в объектных литералах.
  // 🇺🇸 - Responsible for inserting spaces between the object body and curly braces in object literals.
  "prettier.bracketSpacing": true,

  // 🇷🇺 - Обеспечивает наличие запятой после последнего свойства объекта.
  // 🇺🇸 - Ensures that there is a comma after the last object property.
  "prettier.trailingComma": "all",

  // 🇷🇺 - Все двойные кавычки будут преобразованы в одинарные.
  // 🇺🇸 - All double quotes will be converted to single quotes.
  "prettier.singleQuote": true,

  // 🇷🇺 - Все двойные кавычки будут преобразованы в одинарные для формата файлов jsx.
  // 🇺🇸 - All double quotes will be converted to single quotes for the jsx file format.
  "prettier.jsxSingleQuote": true,

  // 🇷🇺 - Включите круглые скобки вокруг единственного параметра функции стрелки.
  // 🇺🇸 - Include parentheses around the single parameter of the arrow function.
  "prettier.arrowParens": "avoid",

  // 🇷🇺 - Задаёт количество пробелов на один уровень выравнивания.
  // 🇺🇸 - Specifies the number of spaces per alignment level.
  "prettier.tabWidth": 2,

  // 🇷🇺 - Длина строки не должна превышать 100 символов.
  // 🇺🇸 - The string length must not exceed 100 characters.
  "prettier.printWidth": 100
}
