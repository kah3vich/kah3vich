{
  // 🟢 Import At Top

  // 🇷🇺 - Конфигурация параметров в "import-at-top".
  // 🇺🇸 - Config params in "import-at-top".
  "import-at-top.config": [
    {
      // 🇷🇺 -
      // 🇺🇸 -
      "importDefault": ["React"],
      // 🇷🇺 -
      // 🇺🇸 -
      "importExport": [
        "useState",
        "useEffect",
        "useContext",
        "useReducer",
        "useCallback",
        "useMemo",
        "useRef",
        "useId",
        "useImperativeHandle",
        "useLayoutEffect",
        "useDebugValue"
      ],
      // 🇷🇺 - Пакет из которого будет импортировано зависимость.
      // 🇺🇸 - The package from which the dependency will be imported.
      "package": "react"
    },
    {
      "importDefault": [],
      "importExport": ["createStore"],
      "package": "redux"
    }
  ]
}
