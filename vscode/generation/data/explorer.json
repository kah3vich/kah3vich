{
  // 🟢 Explorer

  // 🇷🇺 - Убираем алерты с предупреждениями при удалении и перетаскивании файлов и директорий.
  // 🇺🇸 - We remove alerts with warnings when deleting and dragging files and directories.
  "explorer.confirmDelete": false,

  // 🇷🇺 - Отображение дочерних папок в компактной форме.
  // 🇺🇸 - Display child folders in a compact form.
  "explorer.compactFolders": false,

  // 🇷🇺 - Убираем алерты с предупреждениями при удалении и перетаскивании файлов и директорий.
  // 🇺🇸 - We remove alerts with warnings when deleting and dragging files and directories.
  "explorer.confirmDragAndDrop": true,

  // 🇷🇺 - Определяет, должен ли проводник автоматически отображать и выбирать файлы при их открытии.
  // 🇺🇸 - Controls whether the Explorer should automatically reveal and select files when opening them.
  "explorer.autoReveal": true,

  // 🇷🇺 - Настройте шаблоны глобусов для исключения файлов и папок из раскрытия и выбора в проводнике при их открытии.
  // 🇺🇸 - Configure glob patterns for excluding files and folders from being revealed and selected in the Explorer when they are opened.
  "explorer.autoRevealExclude": {
    "**/node_modules": true,
    "**/bower_components": true
  },

  // 🇷🇺 - Определяет, должен ли проводник запрашивать подтверждение при отмене.
  // 🇺🇸 - Controls whether the Explorer should ask for confirmation when undoing.
  "explorer.confirmUndo": "default",

  // 🇷🇺 - Символ разделителя пути, используемый при копировании относительных путей к файлам.
  // 🇺🇸 - The path separation character used when copying relative file paths.
  "explorer.copyRelativePathSeparator": "auto",

  // 🇷🇺 - Определяет, должны ли украшения файлов использовать значки.
  // 🇺🇸 - Controls whether file decorations should use badges.
  "explorer.decorations.badges": true,

  // 🇷🇺 - Определяет, должны ли украшения файлов использовать цвета.
  // 🇺🇸 - Controls whether file decorations should use colors.
  "explorer.decorations.colors": true,

  // 🇷🇺 - Определяет, должен ли проводник разрешать перемещение файлов и папок с помощью перетаскивания. Этот параметр влияет только на перетаскивание внутри проводника.
  // 🇺🇸 - Controls whether the Explorer should allow to move files and folders via drag and drop. This setting only effects drag and drop from inside the Explorer.
  "explorer.enableDragAndDrop": true,

  // 🇷🇺 - Определяет, должен ли Проводник поддерживать отмену операций с файлами и папками.
  // 🇺🇸 - Controls whether the Explorer should support undoing file and folder operations.
  "explorer.enableUndo": true,

  // 🇷🇺 - Определяет, следует ли анализировать записи в .gitignore и исключать их из проводника. Похоже на `files.exclude`.
  // 🇺🇸 - Controls whether entries in .gitignore should be parsed and excluded from the Explorer. Similar to `files.exclude`.
  "explorer.excludeGitIgnore": false,

  // 🇷🇺 - Определяет, должен ли Проводник расширять многокорневые рабочие пространства, содержащие только одну папку, во время инициализации.
  // 🇺🇸 - Controls whether the Explorer should expand multi-root workspaces containing only one folder during initialization.
  "explorer.expandSingleFolderWorkspaces": true,

  // 🇷🇺 - Определяет, включена ли вложенность файлов в проводнике. Вложенность файлов позволяет визуально сгруппировать связанные файлы в каталоге в одном родительском файле.
  // 🇺🇸 - Controls whether file nesting is enabled in the Explorer. File nesting allows for related files in a directory to be visually grouped together under a single parent file.
  "explorer.fileNesting.enabled": false,

  // 🇷🇺 - Управляет автоматическим развертыванием вложенных файлов. `explorer.file Nesting.enabled` должен быть установлен, чтобы это вступило в силу.
  // 🇺🇸 - Controls whether file nests are automatically expanded. `explorer.fileNesting.enabled` must be set for this to take effect.
  "explorer.fileNesting.expand": true,

  // 🇷🇺 - Управляет вложенностью файлов в проводнике. `explorer.fileNesting.enabled` должен быть установлен, чтобы это вступило в силу. Каждый __Item__ представляет родительский шаблон и может содержать один символ `*`, соответствующий любой строке. Каждое __Value__ представляет собой список разделенных запятыми дочерних шаблонов, которые должны отображаться вложенными под данным родителем. Дочерние шаблоны могут содержать несколько специальных токенов:
  // 🇺🇸 - Controls nesting of files in the Explorer. `explorer.fileNesting.enabled` must be set for this to take effect. Each __Item__ represents a parent pattern and may contain a single `*` character that matches any string. Each __Value__ represents a comma separated list of the child patterns that should be shown nested under a given parent. Child patterns may contain several special tokens:
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml"
  },

  // 🇷🇺 - Определяет, какую стратегию именования использовать при присвоении нового имени дублированному элементу проводника при вставке.
  // 🇺🇸 - Controls what naming strategy to use when a giving a new name to a duplicated Explorer item on paste.
  "explorer.incrementalNaming": "simple",

  // 🇷🇺 - Минимальное количество слотов редактора, отображаемое на панели «Открыть редакторы». Если установлено значение 0, размер панели «Открыть редакторы» будет динамически изменяться в зависимости от количества редакторов.
  // 🇺🇸 - The minimum number of editor slots shown in the Open Editors pane. If set to 0 the Open Editors pane will dynamically resize based on the number of editors.
  "explorer.openEditors.minVisible": 0,

  // 🇷🇺 - Управляет порядком сортировки редакторов на панели «Открыть редакторы».
  // 🇺🇸 - Controls the sorting order of editors in the Open Editors pane.
  "explorer.openEditors.sortOrder": "editorOrder",

  // 🇷🇺 - Максимальное количество редакторов, отображаемых на панели «Открыть редакторы». Установка этого параметра на 0 скрывает панель «Открытые редакторы».
  // 🇺🇸 - The maximum number of editors shown in the Open Editors pane. Setting this to 0 hides the Open Editors pane.
  "explorer.openEditors.visible": 9,

  // 🇷🇺 - Управляет сортировкой файлов и папок в проводнике на основе свойств.
  // 🇺🇸 - Controls the property-based sorting of files and folders in the Explorer.
  "explorer.sortOrder": "default",

  // 🇷🇺 - Управляет лексикографической сортировкой имен файлов и папок в Проводнике.
  // 🇺🇸 - Controls the lexicographic sorting of file and folder names in the Explorer.
  "explorer.sortOrderLexicographicOptions": "default"
}
