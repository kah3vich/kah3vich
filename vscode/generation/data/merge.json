{
  // 🟢 Merge Conflict

  // 🇷🇺 - Следует ли автоматически переходить к следующему конфликту слияния после разрешения конфликта слияния.
  // 🇺🇸 - Whether to automatically navigate to the next merge conflict after resolving a merge conflict.
  "merge-conflict.autoNavigateNextConflict.enabled": false,

  // 🇷🇺 - Создайте CodeLens для блоков конфликтов слияния в редакторе.
  // 🇺🇸 - Create a CodeLens for merge conflict blocks within editor.
  "merge-conflict.codeLens.enabled": true,

  // 🇷🇺 - Создайте декораторы для блоков конфликтов слияния в редакторе.
  // 🇺🇸 - Create decorators for merge conflict blocks within editor.
  "merge-conflict.decorators.enabled": true,

  // 🇷🇺 - Определяет, где должно открываться представление различий при сравнении изменений в конфликтах слияния.
  // 🇺🇸 - Controls where the diff view should be opened when comparing changes in merge conflicts.
  "merge-conflict.diffViewPosition": "Current"
}
