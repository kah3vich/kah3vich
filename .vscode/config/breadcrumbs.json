{
	//! ✅ Breadcrumbs

	//* 💡 ru - Рендеринг элементов навигации с помощью значков.
	//* 💡 en - Rendering navigation elements using icons.
	"breadcrumbs.icons": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы `ключей`.
	//* 💡 en - When breadcrumbs are enabled, `key` symbols are displayed.
	"breadcrumbs.showKeys": false,

	//* 💡 ru - Когда хлебные крошки включены, они показывают символы `file`.
	//* 💡 en - When enabled, breadcrumbs show the `file` characters.
	"breadcrumbs.showFiles": false,

	//* 💡 ru - Управляет тем, отображаются ли символы в представлении навигационных крошек и каким образом.
	//* 💡 en - Controls whether and how symbols are displayed in the navigation crumbs view.
	"breadcrumbs.symbolPath": "off",

	//* 💡 ru - Когда хлебные крошки включены, они показывают символы массива.
	//* 💡 en - When breadcrumbs are enabled, they show array characters.
	"breadcrumbs.showArrays": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы «события».
	//* 💡 en - When breadcrumbs are turned on, "event" symbols are displayed.
	"breadcrumbs.showEvents": false,

	//* 💡 ru - При включении хлебные крошки показывают символы `поля`.
	//* 💡 en - When enabled, breadcrumbs show `field` symbols.
	"breadcrumbs.showFields": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы класса.
	//* 💡 en - When breadcrumbs are enabled, class symbols are displayed.
	"breadcrumbs.showClasses": false,

	//* 💡 ru - Когда хлебные крошки включены, они показывают `метод` - символы.
	//* 💡 en - When breadcrumbs are enabled, they show the `method` symbols.
	"breadcrumbs.showMethods": false,

	//* 💡 ru - Когда хлебные крошки включены, они показывают логические символы.
	//* 💡 en - When breadcrumbs are on, they show boolean symbols.
	"breadcrumbs.showBooleans": false,

	//* 💡 ru - Когда хлебные крошки включены, они показывают `функциональные` - символы.
	//* 💡 en - When breadcrumbs are enabled, they show `functional` symbols.
	"breadcrumbs.showFunctions": false,

	//* 💡 ru - При включении хлебных крошек отображаются `постоянные` - символы.
	//* 💡 en - When breadcrumbs are enabled, `permanent` characters are displayed.
	"breadcrumbs.showConstants": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы `enumMember`.
	//* 💡 en - When breadcrumbs are enabled, `enumMember` characters are displayed.
	"breadcrumbs.showEnumMembers": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы-конструкторы.
	//* 💡 en - When breadcrumbs are enabled, constructor symbols are displayed.
	"breadcrumbs.showConstructors": false,

	//* 💡 ru - бета
	//* 💡 en - Enable/disable navigation breadcrumbs.
	"breadcrumbs.enabled": true,

	//* 💡 ru - бета
	//* 💡 en - Controls whether and how file paths are shown in the breadcrumbs view.
	"breadcrumbs.filePath": "on",

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `enum`-symbols.
	"breadcrumbs.showEnums": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `interface`-symbols.
	"breadcrumbs.showInterfaces": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `module`-symbols.
	"breadcrumbs.showModules": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `namespace`-symbols.
	"breadcrumbs.showNamespaces": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `null`-symbols.
	"breadcrumbs.showNull": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `number`-symbols.
	"breadcrumbs.showNumbers": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `object`-symbols.
	"breadcrumbs.showObjects": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `operator`-symbols.
	"breadcrumbs.showOperators": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `package`-symbols.
	"breadcrumbs.showPackages": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `property`-symbols.
	"breadcrumbs.showProperties": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `string`-symbols.
	"breadcrumbs.showStrings": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `struct`-symbols.
	"breadcrumbs.showStructs": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `typeParameter`-symbols.
	"breadcrumbs.showTypeParameters": true,

	//* 💡 ru - бета
	//* 💡 en - When enabled breadcrumbs show `variable`-symbols.
	"breadcrumbs.showVariables": true,

	//* 💡 ru - бета
	//* 💡 en - Controls how symbols are sorted in the breadcrumbs outline view.
	"breadcrumbs.symbolSortOrder": "position"
}
