	"typescript.workspaceSymbols.scope": "allOpenProjects",

	//! ✅ JSON

	//* 💡 ru - Включить/отключить средство форматирования JSON по умолчанию.
	//* 💡 en - Enable/disable default JSON formatter.
	"json.format.enable": true,

	//* 💡 ru - Сохраняйте все существующие новые строки при форматировании.
	//* 💡 en - Keep all existing new lines when formatting.
	"json.format.keepLines": false,

	//* 💡 ru - Максимальное вычисленное количество контурных символов и областей сгиба (ограничено по соображениям производительности).
	//* 💡 en - The maximum number of outline symbols and folding regions computed (limited for performance reasons).
	"json.maxItemsComputed": 5000,

	//* 💡 ru - Если этот параметр включен, схемы JSON можно получать из местоположений http и https.
	//* 💡 en - When enabled, JSON schemas can be fetched from http and https locations.
	"json.schemaDownload.enable": true,

	//* 💡 ru - Свяжите схемы с файлами JSON в текущем проекте.
	//* 💡 en - Associate schemas to JSON files in the current project.
	"json.schemas": [],

	//* 💡 ru - Отслеживает связь между VS Code и языковым сервером JSON.
	//* 💡 en - Traces the communication between VS Code and the JSON language server.
	"json.trace.server": "off",

	//* 💡 ru - Включить/отключить проверку JSON.
	//* 💡 en - Enable/disable JSON validation.,
	"json.validate.enable": true,

	//! ✅ Keyboard

	//* 💡 ru - Управляет логикой диспетчеризации для нажатий клавиш, чтобы использовать либо `code` (рекомендуется), либо `keyCode`.
	//* 💡 en - Controls the dispatching logic for key presses to use either `code` (recommended) or `keyCode`.
	"keyboard.dispatch": "code",

	//* 💡 ru - Включает кнопки сенсорной панели Mac на клавиатуре, если они доступны.
	//* 💡 en - Enables the macOS touchbar buttons on the keyboard if available.
	"keyboard.touchbar.enabled": true,

	//* 💡 ru - Набор идентификаторов для записей на сенсорной панели, которые не должны отображаться (например, `workbench.action.navigateBack`).
	//* 💡 en - A set of identifiers for entries in the touchbar that should not show up (for example `workbench.action.navigateBack`).,
	"keyboard.touchbar.ignored": [],

	//! ✅ LESS

	//* 💡 ru - Вставьте точку с запятой в конце строки при заполнении свойств CSS.
	//* 💡 en - Insert semicolon at end of line when completing CSS properties.
	"less.completion.completePropertyWithSemicolon": true,

	//* 💡 ru - По умолчанию VS Code инициирует завершение значения свойства после выбора свойства CSS. Используйте этот параметр, чтобы отключить это поведение.
	//* 💡 en - By default, VS Code triggers property value completion after selecting a CSS property. Use this setting to disable this behavior.
	"less.completion.triggerPropertyValueCompletion": true,

	//* 💡 ru - Ставьте фигурные скобки на той же строке, что и правила (`collapse`), или ставьте фигурные скобки на отдельной строке (`expand`).
	//* 💡 en - Put braces on the same line as rules (`collapse`) or put braces on own line (`expand`).
	"less.format.braceStyle": "collapse",

	//* 💡 ru - Включить/отключить средство форматирования LESS по умолчанию.
	//* 💡 en - Enable/disable default LESS formatter.
	"less.format.enable": true,

	//* 💡 ru - Максимальное количество разрывов строк, которое должно быть сохранено в одном фрагменте, когда включен параметр `less.format.preserveNewLines`.
	//* 💡 en - Maximum number of line breaks to be preserved in one chunk, when `less.format.preserveNewLines` is enabled.
	"less.format.maxPreserveNewLines": null,

	//* 💡 ru - Разделяйте наборы правил пустой строкой.
	//* 💡 en - Separate rulesets by a blank line.
	"less.format.newlineBetweenRules": true,

	//* 💡 ru - Разделяйте селекторы новой строкой.
	//* 💡 en - Separate selectors with a new line.
	"less.format.newlineBetweenSelectors": true,

	//* 💡 ru - Следует ли сохранять существующие разрывы строк перед элементами.
	//* 💡 en - Whether existing line breaks before elements should be preserved.
	"less.format.preserveNewLines": true,

	//* 💡 ru - Обеспечьте наличие пробела вокруг разделителей селекторов '>', '+', '~' (например, `a > b`).
	//* 💡 en - Ensure a space character around selector separators '>', '+', '~' (e.g. `a > b`).
	"less.format.spaceAroundSelectorSeparator": false,

	//* 💡 ru - Показать документацию по тегам и атрибутам при наведении МЕНЬШЕ.
	//* 💡 en - Show tag and attribute documentation in LESS hovers.
	"less.hover.documentation": true,

	//* 💡 ru - Показывать ссылки на MDN при наведении LESS.
	//* 💡 en - Show references to MDN in LESS hovers.
	"less.hover.references": true,

	//* 💡 ru - Недопустимое количество параметров.
	//* 💡 en - Invalid number of parameters.
	"less.lint.argumentsInColorFunction": "error",

	//* 💡 ru - Не используйте `width` или `height` при использовании `padding` или `border`.
	//* 💡 en - Do not use `width` or `height` when using `padding` or `border`.
	"less.lint.boxModel": "ignore",

	//* 💡 ru - При использовании префикса, специфичного для поставщика, не забудьте также включить все другие свойства, зависящие от поставщика.
	//* 💡 en - When using a vendor-specific prefix make sure to also include all other vendor-specific properties.
	"less.lint.compatibleVendorPrefixes": "ignore",

	//* 💡 ru - Не используйте повторяющиеся определения стилей.
	//* 💡 en - Do not use duplicate style definitions.
	"less.lint.duplicateProperties": "ignore",

	//* 💡 ru - Не используйте пустые наборы правил.
	//* 💡 en - Do not use empty rulesets.
	"less.lint.emptyRules": "warning",

	//* 💡 ru - Избегайте использования `float`. Поплавки приводят к хрупкому CSS, который легко сломать, если изменится один аспект макета.
	//* 💡 en - Avoid using `float`. Floats lead to fragile CSS that is easy to break if one aspect of the layout changes.
	"less.lint.float": "ignore",

	//* 💡 ru - Правило `@font-face` должно определять свойства `src` и `font-family`.
	//* 💡 en - `@font-face` rule must define `src` and `font-family` properties.
	"less.lint.fontFaceProperties": "warning",

	//* 💡 ru - Шестнадцатеричные цвета должны состоять из трех или шести шестнадцатеричных чисел.
	//* 💡 en - Hex colors must consist of three or six hex numbers.
	"less.lint.hexColorLength": "error",

	//* 💡 ru - Селекторы не должны содержать идентификаторы, потому что эти правила слишком тесно связаны с HTML.
	//* 💡 en - Selectors should not contain IDs because these rules are too tightly coupled with the HTML.
	"less.lint.idSelector": "ignore",

	//* 💡 ru - Взломы IE необходимы только при поддержке IE7 и старше.
	//* 💡 en - IE hacks are only necessary when supporting IE7 and older.
	"less.lint.ieHack": "ignore",

	//* 💡 ru - Избегайте использования `!important`. Это указывает на то, что специфика всего CSS вышла из-под контроля и нуждается в рефакторинге.
	//* 💡 en - Avoid using `!important`. It is an indication that the specificity of the entire CSS has gotten out of control and needs to be refactored.
	"less.lint.important": "ignore",

	//* 💡 ru - Операторы импорта не загружаются параллельно.
	//* 💡 en - Import statements do not load in parallel.
	"less.lint.importStatement": "ignore",

	//* 💡 ru - Свойство игнорируется из-за отображения. Например. с display: inline свойства width, height, margin-top, margin-bottom и float не действуют.
	//* 💡 en - Property is ignored due to the display. E.g. with `display: inline`, the `width`, `height`, `margin-top`, `margin-bottom`, and `float` properties have no effect.
	"less.lint.propertyIgnoredDueToDisplay": "warning",

	//* 💡 ru - Известно, что универсальный селектор (`*`) медленный.
	//* 💡 en - The universal selector (`*`) is known to be slow.
	"less.lint.universalSelector": "ignore",

	//* 💡 ru - Неизвестное at-правило.
	//* 💡 en - Unknown at-rule.
	"less.lint.unknownAtRules": "warning",

	//* 💡 ru - Неизвестное свойство.
	//* 💡 en - Unknown property.
	"less.lint.unknownProperties": "warning",

	//* 💡 ru - Свойство неизвестного поставщика.
	//* 💡 en - Unknown vendor specific property.
	"less.lint.unknownVendorSpecificProperties": "ignore",

	//* 💡 ru - Список свойств, которые не проверяются на соответствие правилу `unknownProperties`.
	//* 💡 en - A list of properties that are not validated against the `unknownProperties` rule.
	"less.lint.validProperties": [],

	//* 💡 ru - При использовании префикса, зависящего от поставщика, также включите стандартное свойство.
	//* 💡 en - When using a vendor-specific prefix, also include the standard property.
	"less.lint.vendorPrefix": "warning",

	//* 💡 ru - Единица для нуля не нужна.
	//* 💡 en - No unit for zero needed.
	"less.lint.zeroUnits": "ignore",

	//* 💡 ru - Включает или отключает все проверки.
	//* 💡 en - Enables or disables all validations.,
	"less.validate": true,

	//! ✅ Markdown

	//* 💡 ru - Включите перетаскивание файлов в редактор Markdown, удерживая Shift. Требуется включить `editor.dropIntoEditor.enabled`.
	//* 💡 en - Enable dropping files into a Markdown editor while holding Shift. Requires enabling `editor.dropIntoEditor.enabled`.
	"markdown.editor.drop.enabled": true,

	//* 💡 ru - Определяет, где должны открываться ссылки в файлах Markdown.
	//* 💡 en - Controls where links in Markdown files should be opened.
	"markdown.links.openLocation": "currentGroup",

	//* 💡 ru - Включить выделение вхождений ссылок в текущем документе.
	//* 💡 en - Enable highlighting link occurrences in the current document.
	"markdown.occurrencesHighlight.enabled": false,

	//* 💡 ru - Устанавливает способ отображения разрывов строк в предварительном просмотре Markdown. Установка значения «true» создает <br> для новой строки внутри абзаца.
	//* 💡 en - Sets how line-breaks are rendered in the Markdown preview. Setting it to 'true' creates a <br> for newlines inside paragraphs.
	"markdown.preview.breaks": false,

	//* 💡 ru - Дважды щелкните в предварительном просмотре Markdown, чтобы переключиться в редактор.
	//* 💡 en - Double click in the Markdown preview to switch to the editor.
	"markdown.preview.doubleClickToSwitchToEditor": true,

	//* 💡 ru - Управляет семейством шрифтов, используемым в предварительном просмотре Markdown.
	//* 💡 en - Controls the font family used in the Markdown preview.
	"markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",

	//* 💡 ru - Управляет размером шрифта в пикселях, используемым в предварительном просмотре Markdown.
	//* 💡 en - Controls the font size in pixels used in the Markdown preview.
	"markdown.preview.fontSize": 14,

	//* 💡 ru - Управляет высотой строки, используемой в предварительном просмотре Markdown. Это число зависит от размера шрифта.
	//* 💡 en - Controls the line height used in the Markdown preview. This number is relative to the font size.
	"markdown.preview.lineHeight": 1.6,

	//* 💡 ru - Преобразуйте текст, похожий на URL, в ссылки в предварительном просмотре Markdown.
	//* 💡 en - Convert URL-like text to links in the Markdown preview.
	"markdown.preview.linkify": true,

	//* 💡 ru - Отметьте текущий выбор редактора в предварительном просмотре Markdown.
	//* 💡 en - Mark the current editor selection in the Markdown preview.
	"markdown.preview.markEditorSelection": true,

	//* 💡 ru - Определяет, как должны открываться ссылки на другие файлы Markdown в предварительном просмотре Markdown.
	//* 💡 en - Controls how links to other Markdown files in the Markdown preview should be opened.
	"markdown.preview.openMarkdownLinks": "inPreview",

	//* 💡 ru - Когда предварительный просмотр Markdown прокручивается, обновите вид редактора.
	//* 💡 en - When a Markdown preview is scrolled, update the view of the editor.
	"markdown.preview.scrollEditorWithPreview": true,

	//* 💡 ru - При прокрутке редактора Markdown обновите представление предварительного просмотра.
	//* 💡 en - When a Markdown editor is scrolled, update the view of the preview.
	"markdown.preview.scrollPreviewWithEditor": true,

	//* 💡 ru - Включите некоторую независимую от языка замену и украшение кавычек в предварительном просмотре Markdown.
	//* 💡 en - Enable some language-neutral replacement and quotes beautification in the Markdown preview.
	"markdown.preview.typographer": false,

	//* 💡 ru - Список URL-адресов или локальных путей к таблицам стилей CSS для использования в предварительном просмотре Markdown. Относительные пути интерпретируются относительно папки, открытой в Проводнике. Если нет открытой папки, они интерпретируются относительно местоположения файла Markdown. Все '\' нужно записывать как '\\'.
	//* 💡 en - A list of URLs or local paths to CSS style sheets to use from the Markdown preview. Relative paths are interpreted relative to the folder open in the Explorer. If there is no open folder, they are interpreted relative to the location of the Markdown file. All '\' need to be written as '\\'.
	"markdown.styles": [],

	//* 💡 ru - Включите предложения пути при написании ссылок в файлах Markdown.
	//* 💡 en - Enable path suggestions while writing links in Markdown files.
	"markdown.suggest.paths.enabled": true,

	//* 💡 ru - Включите ведение журнала отладки для расширения Markdown.
	//* 💡 en - Enable debug logging for the Markdown extension.
	"markdown.trace.extension": "off",

	//* 💡 ru - Попробуйте обновить ссылки в файлах Markdown, когда файл переименовывается/перемещается в рабочей области. Используйте `markdown.updateLinksOnFileMove.include`, чтобы указать, какие файлы вызывают обновление ссылок.
	//* 💡 en - Try to update links in Markdown files when a file is renamed/moved in the workspace. Use `markdown.updateLinksOnFileMove.include` to configure which files trigger link updates.
	"markdown.updateLinksOnFileMove.enabled": "never",

	//* 💡 ru - Включите обновление ссылок при перемещении или переименовании каталога в рабочей области.
	//* 💡 en - Enable updating links when a directory is moved or renamed in the workspace.
	"markdown.updateLinksOnFileMove.enableForDirectories": true,

	//* 💡 ru - Шаблоны универсальных объектов, определяющие файлы, запускающие автоматическое обновление ссылок. См. `markdown.updateLinksOnFileMove.enabled` для получения подробной информации об этой функции.
	//* 💡 en - Glob patterns that specifies files that trigger automatic link updates. See `markdown.updateLinksOnFileMove.enabled` for details about this feature.
	"markdown.updateLinksOnFileMove.include": [
		"**/*.{md,mkd,mdwn,mdown,markdown,markdn,mdtxt,mdtext,workbook}",
		"**/*.{jpg,jpe,jpeg,png,bmp,gif,ico,webp,avif,tiff,svg,mp4}"
	],

	//* 💡 ru - Проверить повторяющиеся определения в текущем файле.
	//* 💡 en - Validate duplicated definitions in the current file.
	"markdown.validate.duplicateLinkDefinitions.enabled": "warning",

	//* 💡 ru - Включите все отчеты об ошибках в файлах Markdown.
	//* 💡 en - Enable all error reporting in Markdown files.
	"markdown.validate.enabled": false,

	//* 💡 ru - Проверяйте ссылки на другие файлы в файлах Markdown, например `[link](/path/to/file.md)`. Это проверяет, что целевые файлы существуют. Требуется включить `markdown.validate.enabled`.
	//* 💡 en - Validate links to other files in Markdown files, for example `[link](/path/to/file.md)`. This checks that the target files exists. Requires enabling `markdown.validate.enabled`.
	"markdown.validate.fileLinks.enabled": "warning",

	//* 💡 ru - Проверяйте фрагментную часть ссылок на заголовки в других файлах в файлах Markdown, например `[ссылка](/путь/к/файлу.md#header)`. Наследует значение параметра от `markdown.validate.fragmentLinks.enabled` по умолчанию.
	//* 💡 en - Validate the fragment part of links to headers in other files in Markdown files, for example `[link](/path/to/file.md#header)`. Inherits the setting value from `markdown.validate.fragmentLinks.enabled` by default.
	"markdown.validate.fileLinks.markdownFragmentLinks": "inherit",

	//* 💡 ru - Проверить ссылки фрагментов на заголовки в текущем файле Markdown, например `[link](#_header)`. Требуется включить `markdown.validate.enabled`.
	//* 💡 en - Validate fragment links to headers in the current Markdown file, for example `[link](#_header)`. Requires enabling `markdown.validate.enabled`.
	"markdown.validate.fragmentLinks.enabled": "warning",

	//* 💡 ru - Настройте ссылки, которые не должны проверяться. Например, добавление `/about` не будет проверять ссылку `[about](/about)`, в то время как glob `/assets/**/*.svg` позволит вам пропустить проверку любой ссылки на файлы `.svg` в каталоге `assets`.
	//* 💡 en - Configure links that should not be validated. For example adding `/about` would not validate the link `[about](/about)`, while the glob `/assets/**/*.svg` would let you skip validation for any link to `.svg` files under the `assets` directory.
	"markdown.validate.ignoredLinks": [],

	//* 💡 ru - Проверяйте справочные ссылки в файлах Markdown, например `[ссылка][ref]`. Требуется включить `markdown.validate.enabled`.
	//* 💡 en - Validate reference links in Markdown files, for example `[link][ref]`. Requires enabling `markdown.validate.enabled`.
	"markdown.validate.referenceLinks.enabled": "warning",

	//* 💡 ru - Проверить определения ссылок, которые не используются в текущем файле.
	//* 💡 en - Validate link definitions that are unused in the current file.,
	"markdown.validate.unusedLinkDefinitions.enabled": "hint",

	//! ✅ Merge Conflict

	//* 💡 ru - Следует ли автоматически переходить к следующему конфликту слияния после разрешения конфликта слияния.
	//* 💡 en - Whether to automatically navigate to the next merge conflict after resolving a merge conflict.
	"merge-conflict.autoNavigateNextConflict.enabled": false,

	//* 💡 ru - Создайте CodeLens для блоков конфликтов слияния в редакторе.
	//* 💡 en - Create a CodeLens for merge conflict blocks within editor.
	"merge-conflict.codeLens.enabled": true,

	//* 💡 ru - Создайте декораторы для блоков конфликтов слияния в редакторе.
	//* 💡 en - Create decorators for merge conflict blocks within editor.
	"merge-conflict.decorators.enabled": true,

	//* 💡 ru - Определяет, где должно открываться представление различий при сравнении изменений в конфликтах слияния.
	//* 💡 en - Controls where the diff view should be opened when comparing changes in merge conflicts.,
	"merge-conflict.diffViewPosition": "Current",

	//! ✅ Merge Editor

	//* 💡 ru - Контролирует, должны ли удаления в базе или одном из входных данных обозначаться вертикальной чертой.
	//* 💡 en - Controls if deletions in base or one of the inputs should be indicated by a vertical bar.,
	"mergeEditor.showDeletionMarkers": true,

	//! ✅ Notebooks

	//* 💡 ru - Определяет, свернуты ли ячейки кода в интерактивном окне по умолчанию.
	//* 💡 en - Controls whether code cells in the interactive window are collapsed by default.
	"interactiveWindow.collapseCellInputCode": "fromEditor",

	//* 💡 ru - Если включена навигационная цепочка записной книжки, она содержит ячейки с кодом.
	//* 💡 en - When enabled notebook breadcrumbs contain code cells.
	"notebook.breadcrumbs.showCodeCells": true,

	//* 💡 ru - Определяет, где отображается индикатор фокуса: вдоль границ ячейки или в левом поле.
	//* 💡 en - Controls where the focus indicator is rendered, either along the cell borders or on the left gutter.
	"notebook.cellFocusIndicator": "gutter",

	//* 💡 ru - Где должна отображаться панель инструментов ячейки или должна ли она быть скрыта.
	//* 💡 en - Where the cell toolbar should be shown, or whether it should be hidden.
	"notebook.cellToolbarLocation": {
		"default": "right"
	},

	//* 💡 ru - Должна ли панель инструментов ячейки появляться при наведении или щелчке.
	//* 💡 en - Whether the cell toolbar should appear on hover or click.
	"notebook.cellToolbarVisibility": "click",

	//* 💡 ru - Контролируйте, должен ли редактор записной книжки отображаться в компактной форме. Например, при включении он уменьшит ширину левого поля.
	//* 💡 en - Control whether the notebook editor should be rendered in a compact form. For example, when turned on, it will decrease the left margin width.
	"notebook.compactView": true,

	//* 💡 ru - Контролируйте, должно ли действие вывода отображаться на панели инструментов вывода.
	//* 💡 en - Control whether outputs action should be rendered in the output toolbar.
	"notebook.consolidatedOutputButton": true,

	//* 💡 ru - Контролируйте, отображаются ли дополнительные действия в раскрывающемся списке рядом с кнопкой запуска.
	//* 💡 en - Control whether extra actions are shown in a dropdown next to the run button.
	"notebook.consolidatedRunButton": false,

	//* 💡 ru - Использовать ли расширенный текстовый редактор для блокнота.
	//* 💡 en - Whether to use the enhanced text diff editor for notebook.
	"notebook.diff.enablePreview": true,

	//* 💡 ru - Скрыть различия метаданных.
	//* 💡 en - Hide Metadata Differences.
	"notebook.diff.ignoreMetadata": false,

	//* 💡 ru - Скрыть различия выходов.
	//* 💡 en - Hide Outputs Differences.
	"notebook.diff.ignoreOutputs": false,

	//* 💡 ru - Список приоритетов для выходных mime-типов.
	//* 💡 en - Priority list for output mime types.
	"notebook.displayOrder": [],

	//* 💡 ru - Контролируйте, должен ли редактор блокнота разрешать перемещение ячеек с помощью перетаскивания.
	//* 💡 en - Control whether the notebook editor should allow moving cells through drag and drop.
	"notebook.dragAndDropEnabled": true,

	//* 💡 ru - Настройки редакторов кода, используемых в блокнотах. Это можно использовать для настройки большинства параметров editor.*.
	//* 💡 en - Settings for code editors used in notebooks. This can be used to customize most editor.* settings.
	"notebook.editorOptionsCustomizations": {},

	//* 💡 ru - Контролируйте, отображать ли глобальную панель инструментов в редакторе записной книжки.
	//* 💡 en - Control whether to render a global toolbar inside the notebook editor.
	"notebook.globalToolbar": true,

	//* 💡 ru - Контролируйте, должны ли действия на панели инструментов блокнота отображать метку или нет.
	//* 💡 en - Control whether the actions on the notebook toolbar should render label or not.
	"notebook.globalToolbarShowLabel": "always",

	//* 💡 ru - Контролируйте, где должны отображаться действия вставки ячеек.
	//* 💡 en - Control where the insert cell actions should appear.
	"notebook.insertToolbarLocation": "both",

	//* 💡 ru - Управляет отображением номеров строк в редакторе ячеек.
	//* 💡 en - Controls the display of line numbers in the cell editor.
	"notebook.lineNumbers": "off",

	//* 💡 ru - Управляет размером шрифта в пикселях визуализируемой разметки в блокнотах. Если установлено значение «0», используется 120% размера «editor.fontSize».
	//* 💡 en - Controls the font size in pixels of rendered markup in notebooks. When set to `0`, 120% of `editor.fontSize` is used.
	"notebook.markup.fontSize": 0,

	//* 💡 ru - Когда включено, курсор может переходить к следующей/предыдущей ячейке, когда текущий курсор в редакторе ячеек находится в первой/последней строке.
	//* 💡 en - When enabled cursor can navigate to the next/previous cell when the current cursor in the cell editor is at the first/last line.
	"notebook.navigation.allowNavigateToSurroundingCells": true,

	//* 💡 ru - Когда включена схема записной книжки, отображаются ячейки кода.
	//* 💡 en - When enabled notebook outline shows code cells.
	"notebook.outline.showCodeCells": false,

	//* 💡 ru - Контролируйте, сколько строк текста в текстовом выводе отображается.
	//* 💡 en - Control how many lines of text in a text output is rendered.
	"notebook.output.textLineLimit": 30,

	//* 💡 ru - Семейство шрифтов для вывода текста для ячеек записной книжки. Если установлено пустое, используется `editor.fontFamily`.
	//* 💡 en - The font family for the output text for notebook cells. When set to empty, the `editor.fontFamily` is used.
	"notebook.outputFontFamily": "",

	//* 💡 ru - Размер шрифта для вывода текста для ячеек блокнота. При значении 0 используется `editor.fontSize`.
	//* 💡 en - Font size for the output text for notebook cells. When set to 0, `editor.fontSize` is used.
	"notebook.outputFontSize": 0,

	//* 💡 ru - Высота строки выходного текста для ячеек записной книжки.
	//* 💡 en - Line height of the output text for notebook cells.
	"notebook.outputLineHeight": 22,

	//* 💡 ru - Должна ли отображаться строка состояния ячейки.
	//* 💡 en - Whether the cell status bar should be shown.
	"notebook.showCellStatusBar": "visible",

	//* 💡 ru - Определяет, когда отображается стрелка сворачивания заголовка Markdown.
	//* 💡 en - Controls when the Markdown header folding arrow is shown.
	"notebook.showFoldingControls": "mouseover",

	//* 💡 ru - Использовать ли отдельный стек отмены/повтора для каждой ячейки.
	//* 💡 en - Whether to use separate undo/redo stack for each cell.,
	"notebook.undoRedoPerCell": true,

	//! ✅ Npm

	//* 💡 ru - Определяет, должны ли скрипты npm автоматически обнаруживаться.
	//* 💡 en - Controls whether npm scripts should be automatically detected.
	"npm.autoDetect": "on",

	//* 💡 ru - Включите выполнение сценариев npm, содержащихся в папке, из контекстного меню Проводника.
	//* 💡 en - Enable running npm scripts contained in a folder from the Explorer context menu.
	"npm.enableRunFromFolder": false,

	//* 💡 ru - Проводник сценариев NPM теперь доступен в меню «Виды» проводника во всех папках. Включите представление проводника для сценариев npm, если нет файла package.json верхнего уровня.
	//* 💡 en - The NPM Script Explorer is now available in 'Views' menu in the Explorer in all folders. Enable an explorer view for npm scripts when there is no top-level 'package.json' file.
	"npm.enableScriptExplorer": false,

	//* 💡 ru - Настройте шаблоны универсальных объектов для папок, которые следует исключить из автоматического обнаружения сценариев.
	//* 💡 en - Configure glob patterns for folders that should be excluded from automatic script detection.
	"npm.exclude": "",

	//* 💡 ru - Получите данные с hregistry.npmjs.org и hregistry.bower.io, чтобы предоставить автозаполнение и информацию о функциях наведения на зависимости npm.
	//* 💡 en - Fetch data from hregistry.npmjs.org and hregistry.bower.io to provide auto-completion and information on hover features on npm dependencies.
	"npm.fetchOnlinePackageInfo": true,

	//* 💡 ru - Менеджер пакетов, используемый для запуска сценариев.
	//* 💡 en - The package manager used to run scripts.
	"npm.packageManager": "auto",

	//* 💡 ru - Запускайте команды npm с параметром --silent.
	//* 💡 en - Run npm commands with the `--silent` option.
	"npm.runSilent": false,

	//* 💡 ru - Действие щелчка по умолчанию, используемое в обозревателе сценариев NPM: «открыть» или «запустить», по умолчанию — «открыть».
	//* 💡 en - The default click action used in the NPM Scripts Explorer: `open` or `run`, the default is `open`.
	"npm.scriptExplorerAction": "open",

	//* 💡 ru - Массив регулярных выражений, указывающих, какие скрипты следует исключить из представления скриптов NPM.
	//* 💡 en - An array of regular expressions that indicate which scripts should be excluded from the NPM Scripts view.
	"npm.scriptExplorerExclude": [],

	//* 💡 ru - Отображение наведения с командами «Выполнить» и «Отладка» для сценариев.
	//* 💡 en - Display hover with 'Run' and 'Debug' commands for scripts.,
	"npm.scriptHover": true,

	//! ✅ Outline

	//* 💡 ru - Определяет, будут ли элементы Outline свернуты или развернуты.
	//* 💡 en - Controls whether Outline items are collapsed or expanded.
	"outline.collapseItems": "alwaysExpand",

	//* 💡 ru - Визуализировать элементы Outline с помощью значков.
	//* 💡 en - Render Outline elements with icons.
	"outline.icons": true,

	//* 💡 ru - Используйте значки для ошибок и предупреждений в элементах Outline.
	//* 💡 en - Use badges for errors and warnings on Outline elements.
	"outline.problems.badges": true,

	//* 💡 ru - Используйте цвета для ошибок и предупреждений в элементах Outline.
	//* 💡 en - Use colors for errors and warnings on Outline elements.
	"outline.problems.colors": true,

	//* 💡 ru - Показывать ошибки и предупреждения в элементах Outline.
	//* 💡 en - Show errors and warnings on Outline elements.
	"outline.problems.enabled": true,

	//* 💡 ru - Когда включено, Outline показывает `массив`-символов.
	//* 💡 en - When enabled, Outline shows `array`-symbols.
	"outline.showArrays": true,

	//* 💡 ru - Когда включено, Outline показывает `boolean`-символы.
	//* 💡 en - When enabled, Outline shows `boolean`-symbols.
	"outline.showBooleans": true,

	//* 💡 ru - Когда включено, Outline показывает `class`-символы.
	//* 💡 en - When enabled, Outline shows `class`-symbols.
	"outline.showClasses": true,

	//* 💡 ru - Когда включено, Outline показывает «постоянные» символы.
	//* 💡 en - When enabled, Outline shows `constant`-symbols.
	"outline.showConstants": true,

	//* 💡 ru - Когда включено, Outline показывает символы `конструктора`.
	//* 💡 en - When enabled, Outline shows `constructor`-symbols.
	"outline.showConstructors": true,

	//* 💡 ru - Когда включено, Outline показывает `enumMember`-символы.
	//* 💡 en - When enabled, Outline shows `enumMember`-symbols.
	"outline.showEnumMembers": true,

	//* 💡 ru - Когда включено, Outline показывает `enum`-символы.
	//* 💡 en - When enabled, Outline shows `enum`-symbols.
	"outline.showEnums": true,

	//* 💡 ru - Когда включено, Outline показывает `события`-символы.
	//* 💡 en - When enabled, Outline shows `event`-symbols.
	"outline.showEvents": true,

	//* 💡 ru - Когда включено, Outline показывает символы `поля`.
	//* 💡 en - When enabled, Outline shows `field`-symbols.
	"outline.showFields": true,

	//* 💡 ru - Когда включено, Outline показывает `file`-символы.
	//* 💡 en - When enabled, Outline shows `file`-symbols.
	"outline.showFiles": true,

	//* 💡 ru - Когда включено, Outline показывает `функциональные`-символы.
	//* 💡 en - When enabled, Outline shows `function`-symbols.
	"outline.showFunctions": true,

	//* 💡 ru - Когда включено, Outline показывает `интерфейсные`-символы.
	//* 💡 en - When enabled, Outline shows `interface`-symbols.
	"outline.showInterfaces": true,

	//* 💡 ru - Когда включено, Outline показывает `key`-символы.
	//* 💡 en - When enabled, Outline shows `key`-symbols.
	"outline.showKeys": true,

	//* 💡 ru - Когда включено, Outline показывает `метод`-символы.
