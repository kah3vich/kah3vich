	//! ✅ ESLint

	//* 💡 ru - Включение eslint форматор.
	//* 💡 en - Enable eslint formatter.
	"eslint.format.enable": true,

	//* 💡 ru - 123
	//* 💡 en - SCM

	//* 💡 ru - 123
	//* 💡 en - Controls whether inline actions are always visible in the Source Control view.
	"scm.alwaysShowActions": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether repositories should always be visible in the Source Control view.
	"scm.alwaysShowRepositories": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the Source Control view should automatically reveal and select files when opening them.
	"scm.autoReveal": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the count badge on the Source Control icon on the Activity Bar.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - all: Show the sum of all Source Control Provider count badges.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - focused: Show the count badge of the focused Source Control Provider.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Disable the Source Control count badge.
	"scm.countBadge": "all",

	//* 💡 ru - 123
	//* 💡 en - Controls the default Source Control repository view mode.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - tree: Show the repository changes as a tree.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - list: Show the repository changes as a list.
	"scm.defaultViewMode": "list",

	//* 💡 ru - 123
	//* 💡 en - Controls the default Source Control repository changes sort order when viewed as a list.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - name: Sort the repository changes by file name.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - path: Sort the repository changes by path.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - status: Sort the repository changes by Source Control status.
	"scm.defaultViewSortKey": "path",

	//* 💡 ru - 123
	//* 💡 en - Controls diff decorations in the editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - all: Show the diff decorations in all available locations.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - gutter: Show the diff decorations only in the editor gutter.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - overview: Show the diff decorations only in the overview ruler.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - minimap: Show the diff decorations only in the minimap.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - none: Do not show the diff decorations.
	"scm.diffDecorations": "all",

	//* 💡 ru - 123
	//* 💡 en - Controls the behavior of Source Control diff gutter decorations.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - diff: Show the inline diff Peek view on click.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - none: Do nothing.
	"scm.diffDecorationsGutterAction": "diff",

	//* 💡 ru - 123
	//* 💡 en - Controls whether a pattern is used for the diff decorations in gutter.
	"scm.diffDecorationsGutterPattern": {
		"added": false,
		"modified": true
	},

	//* 💡 ru - 123
	//* 💡 en - Controls the visibility of the Source Control diff decorator in the gutter.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Show the diff decorator in the gutter at all times.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - hover: Show the diff decorator in the gutter only on hover.
	"scm.diffDecorationsGutterVisibility": "always",

	//* 💡 ru - 123
	//* 💡 en - Controls the width(px) of diff decorations in gutter (added & modified).
	"scm.diffDecorationsGutterWidth": 3,

	//* 💡 ru - 123
	//* 💡 en - Controls whether leading and trailing whitespace is ignored in Source Control diff gutter decorations.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - true: Ignore leading and trailing whitespace.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - false: Do not ignore leading and trailing whitespace.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - inherit: Inherit from `diffEditor.ignoreTrimWhitespace`.
	"scm.diffDecorationsIgnoreTrimWhitespace": "false",

	//* 💡 ru - 123
	//* 💡 en - Controls the font for the input message. Use `default` for the workbench user interface font family, `editor` for the `editor.fontFamily`'s value, or a custom font family.
	"scm.inputFontFamily": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls the font size for the input message in pixels.
	"scm.inputFontSize": 13,

	//* 💡 ru - 123
	//* 💡 en - Controls the count badges on Source Control Provider headers. These headers only appear when there is more than one provider.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - hidden: Hide Source Control Provider count badges.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Only show count badge for Source Control Provider when non-zero.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - visible: Show Source Control Provider count badges.
	"scm.providerCountBadge": "hidden",

	//* 💡 ru - 123
	//* 💡 en - Controls the sort order of the repositories in the source control repositories view.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - discovery time: Repositories in the Source Control Repositories view are sorted by discovery time. Repositories in the Source Control view are sorted in the order that they were selected.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - name: Repositories in the Source Control Repositories and Source Control views are sorted by repository name.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - path: Repositories in the Source Control Repositories and Source Control views are sorted by repository path.
	"scm.repositories.sortOrder": "discovery time",

	//* 💡 ru - 123
	//* 💡 en - Controls how many repositories are visible in the Source Control Repositories section. Set to 0, to be able to manually resize the view.
	"scm.repositories.visible": 10,

	//* 💡 ru - 123
	//* 💡 en - Controls whether an action button can be shown in the Source Control view.
	"scm.showActionButton": true,

	//* 💡 ru - 123
	//* 💡 en - Security

	//* 💡 ru - 123
	//* 💡 en - Controls when the restricted mode banner is shown.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Show the banner every time an untrusted workspace is open.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - untilDismissed: Show the banner when an untrusted workspace is opened until dismissed.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Do not show the banner when an untrusted workspace is open.
	"security.workspace.trust.banner": "untilDismissed",

	//* 💡 ru - 123
	//* 💡 en - Controls whether or not the empty window is trusted by default within VS Code. When used with `security.workspace.trust.untrustedFiles`, you can enable the full functionality of VS Code without prompting in an empty window.
	"security.workspace.trust.emptyWindow": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether or not Workspace Trust is enabled within VS Code.
	"security.workspace.trust.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls when the startup prompt to trust a workspace is shown.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Ask for trust every time an untrusted workspace is opened.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - once: Ask for trust the first time an untrusted workspace is opened.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Do not ask for trust when an untrusted workspace is opened.
	"security.workspace.trust.startupPrompt": "once",

	//* 💡 ru - 123
	//* 💡 en - Controls how to handle opening untrusted files in a trusted workspace. This setting also applies to opening files in an empty window which is trusted via `security.workspace.trust.emptyWindow`.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - prompt: Ask how to handle untrusted files for each workspace. Once untrusted files are introduced to a trusted workspace, you will not be prompted again.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - open: Always allow untrusted files to be introduced to a trusted workspace without prompting.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - newWindow: Always open untrusted files in a separate window in restricted mode without prompting.
	"security.workspace.trust.untrustedFiles": "prompt",

	//* 💡 ru - 123
	//* 💡 en - Workbench

	//* 💡 ru - 123
	//* 💡 en - Controls the behavior of clicking an activity bar icon in the workbench.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - toggle: Hide the side bar if the clicked item is already visible.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - focus: Focus side bar if the clicked item is already visible.
	"workbench.activityBar.iconClickBehavior": "toggle",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to automatically resume available working changes stored in the cloud for the current workspace.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onReload: Automatically resume available working changes from the cloud on window reload.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Never attempt to resume working changes from the cloud.
	"workbench.cloudChanges.autoResume": "onReload",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to prompt the user to store working changes in the cloud when using Continue Working On.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - prompt: Prompt the user to sign in to store working changes in the cloud with Continue Working On.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Do not store working changes in the cloud with Continue Working On unless the user has already turned on Cloud Changes.
	"workbench.cloudChanges.continueOn": "prompt",

	//* 💡 ru - 123
	//* 💡 en - Overrides colors from the currently selected color theme.
	"workbench.colorCustomizations": {},

	//* 💡 ru - 123
	//* 💡 en - Controls the number of recently used commands to keep in history for the command palette. Set to 0 to disable command history.
	"workbench.commandPalette.history": 50,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the last typed input to the command palette should be restored when opening it the next time.
	"workbench.commandPalette.preserveInput": false,

	//* 💡 ru - 123
	//* 💡 en - If an editor matching one of the listed types is opened as the first in an editor group and more than one group is open, the group is automatically locked. Locked groups will only be used for opening editors when explicitly chosen by a user gesture (for example drag and drop), but not by default. Consequently, the active editor in a locked group is less likely to be replaced accidentally with a different editor.
	"workbench.editor.autoLockGroups": {
		"default": false,
		"workbench.editorinputs.searchEditorInput": false,
		"jupyter-notebook": false,
		"imagePreview.previewEditor": false,
		"vscode.audioPreview": false,
		"vscode.videoPreview": false,
		"jsProfileVisualizer.cpuprofile.table": false,
		"jsProfileVisualizer.heapprofile.table": false,
		"terminalEditor": true,
		"workbench.input.interactive": false,
		"mainThreadWebview-markdown.preview": false
	},

	//* 💡 ru - 123
	//* 💡 en - Controls if the centered layout should automatically resize to maximum width when more than one group is open. Once only one group is open it will resize back to the original centered width.
	"workbench.editor.centeredLayoutAutoResize": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the behavior of empty editor groups when the last tab in the group is closed. When enabled, empty groups will automatically close. When disabled, empty groups will remain part of the grid.
	"workbench.editor.closeEmptyGroups": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether editors showing a file that was opened during the session should close automatically when getting deleted or renamed by some other process. Disabling this will keep the editor open  on such an event. Note that deleting from within the application will always close the editor and that editors with unsaved changes will never close to preserve your data.
	"workbench.editor.closeOnFileDelete": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether editor file decorations should use badges.
	"workbench.editor.decorations.badges": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether editor file decorations should use colors.
	"workbench.editor.decorations.colors": true,

	//* 💡 ru - 123
	//* 💡 en - The default editor for files detected as binary. If undefined, the user will be presented with a picker.
	"workbench.editor.defaultBinaryEditor": "",

	//* 💡 ru - 123
	//* 💡 en - Controls whether opened editors show as preview editors. Preview editors do not stay open, are reused until explicitly set to be kept open (via double click or editing), and show file names in italics.
	"workbench.editor.enablePreview": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether editors remain in preview when a code navigation is started from them. Preview editors do not stay open, and are reused until explicitly set to be kept open (via double click or editing). This value is ignored when `workbench.editor.enablePreview` is disabled.
	"workbench.editor.enablePreviewFromCodeNavigation": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether editors opened from Quick Open show as preview editors. Preview editors do not stay open, and are reused until explicitly set to be kept open (via double click or editing). This value is ignored when `workbench.editor.enablePreview` is disabled.
	"workbench.editor.enablePreviewFromQuickOpen": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether tabs are closed in most recently used order or from left to right.
	"workbench.editor.focusRecentEditorAfterClose": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether a top border is drawn on tabs for editors that have unsaved changes. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.highlightModifiedTabs": false,

	//* 💡 ru - 123
	//* 💡 en - Enables use of editor history in language detection. This causes automatic language detection to favor languages that have been recently opened and allows for automatic language detection to operate with smaller inputs.
	"workbench.editor.historyBasedLanguageDetection": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the format of the label for an editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Show the name of the file. When tabs are enabled and two files have the same name in one group the distinguishing sections of each file's path are added. When tabs are disabled, the path relative to the workspace folder is shown if the editor is active.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - short: Show the name of the file followed by its directory name.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - medium: Show the name of the file followed by its path relative to the workspace folder.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - long: Show the name of the file followed by its absolute path.
	"workbench.editor.labelFormat": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the language in a text editor is automatically detected unless the language has been explicitly set by the language picker. This can also be scoped by language so you can specify which languages you do not want to be switched off of. This is useful for languages like Markdown that often contain other languages that might trick language detection into thinking it's the embedded language and not Markdown.
	"workbench.editor.languageDetection": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled, shows a Status bar Quick Fix when the editor language doesn't match detected content language.
	"workbench.editor.languageDetectionHints": {
		"untitledEditors": true,
		"notebookEditors": true
	},

	//* 💡 ru - 123
	//* 💡 en - Controls if the number of opened editors should be limited or not. When enabled, less recently used editors will close to make space for newly opening editors.
	"workbench.editor.limit.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - Controls if the maximum number of opened editors should exclude dirty editors for counting towards the configured limit.
	"workbench.editor.limit.excludeDirty": false,

	//* 💡 ru - 123
	//* 💡 en - Controls if the limit of maximum opened editors should apply per editor group or across all editor groups.
	"workbench.editor.limit.perEditorGroup": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the maximum number of opened editors. Use the `workbench.editor.limit.perEditorGroup` setting to control this limit per editor group or across all groups.
	"workbench.editor.limit.value": 10,

	//* 💡 ru - 123
	//* 💡 en - Enables the use of mouse buttons four and five for commands 'Go Back' and 'Go Forward'.
	"workbench.editor.mouseBackForwardToNavigate": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the scope of history navigation in editors for commands such as 'Go Back' and 'Go Forward'.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Navigate across all opened editors and editor groups.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - editorGroup: Navigate only in editors of the active editor group.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - editor: Navigate only in the active editor.
	"workbench.editor.navigationScope": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls where editors open. Select `left` or `right` to open editors to the left or right of the currently active one. Select `first` or `last` to open editors independently from the currently active one.
	"workbench.editor.openPositioning": "right",

	//* 💡 ru - 123
	//* 💡 en - Controls the default direction of editors that are opened side by side (for example, from the Explorer). By default, editors will open on the right hand side of the currently active one. If changed to `down`, the editors will open below the currently active one.
	"workbench.editor.openSideBySideDirection": "right",

	//* 💡 ru - 123
	//* 💡 en - Controls the sizing of pinned editor tabs. Pinned tabs are sorted to the beginning of all opened tabs and typically do not close until unpinned. This value is ignored when `workbench.editor.showTabs` is disabled.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - normal: A pinned tab inherits the look of non pinned tabs.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - compact: A pinned tab will show in a compact form with only icon or first letter of the editor name.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - shrink: A pinned tab shrinks to a compact fixed size showing parts of the editor name.
	"workbench.editor.pinnedTabSizing": "normal",

	//* 💡 ru - 123
	//* 💡 en - When enabled, a language detection model that takes into account editor history will be given higher precedence.
	"workbench.editor.preferHistoryBasedLanguageDetection": true,

	//* 💡 ru - 123
	//* 💡 en - Restores the last editor view state (such as scroll position) when re-opening editors after they have been closed. Editor view state is stored per editor group and discarded when a group closes. Use the `workbench.editor.sharedViewState` setting to use the last known view state across all editor groups in case no previous view state was found for a editor group.
	"workbench.editor.restoreViewState": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether an editor is revealed in any of the visible groups if opened. If disabled, an editor will prefer to open in the currently active editor group. If enabled, an already opened editor will be revealed instead of opened again in the currently active editor group. Note that there are some cases where this setting is ignored, such as when forcing an editor to open in a specific group or to the side of the currently active group.
	"workbench.editor.revealIfOpen": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether scrolling over tabs will open them or not. By default tabs will only reveal upon scrolling, but not open. You can press and hold the Shift-key while scrolling to change this behavior for that duration. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.scrollToSwitchTabs": false,

	//* 💡 ru - 123
	//* 💡 en - Preserves the most recent editor view state (such as scroll position) across all editor groups and restores that if no specific editor view state is found for the editor group.
	"workbench.editor.sharedViewState": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether opened editors should show with an icon or not. This requires a file icon theme to be enabled as well.
	"workbench.editor.showIcons": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether opened editors should show in tabs or not.
	"workbench.editor.showTabs": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the layout for when an editor is split in an editor group to be either vertical or horizontal.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - vertical: Editors are positioned from top to bottom.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - horizontal: Editors are positioned from left to right.
	"workbench.editor.splitInGroupLayout": "horizontal",

	//* 💡 ru - 123
	//* 💡 en - Controls if editor groups can be split from drag and drop operations by dropping an editor or file on the edges of the editor area.
	"workbench.editor.splitOnDragAndDrop": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the sizing of editor groups when splitting them.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - distribute: Splits all the editor groups to equal parts.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - split: Splits the active editor group to equal parts.
	"workbench.editor.splitSizing": "distribute",

	//* 💡 ru - 123
	//* 💡 en - Controls the position of the editor's tabs close buttons, or disables them when set to 'off'. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.tabCloseButton": "right",

	//* 💡 ru - 123
	//* 💡 en - Controls the height of the scrollbars used for tabs and breadcrumbs in the editor title area.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: The default size.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - large: Increases the size, so it can be grabbed more easily with the mouse.
	"workbench.editor.titleScrollbarSizing": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls if the untitled text hint should be visible in the editor.
	"workbench.editor.untitled.hint": "text",

	//* 💡 ru - 123
	//* 💡 en - Controls the format of the label for an untitled editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - content: The name of the untitled file is derived from the contents of its first line unless it has an associated file path. It will fallback to the name in case the line is empty or contains no word characters.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - name: The name of the untitled file is not derived from the contents of the file.
	"workbench.editor.untitled.labelFormat": "content",

	//* 💡 ru - 123
	//* 💡 en - Controls whether tabs should be wrapped over multiple lines when exceeding available space or whether a scrollbar should appear instead. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.wrapTabs": false,

	//* 💡 ru - 123
	//* 💡 en - Configure the opener to use for external URIs (http, https).
	"workbench.externalUriOpeners": {},

	//* 💡 ru - 123
	//* 💡 en - Controls font aliasing method in the workbench.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Sub-pixel font smoothing. On most non-retina displays this will give the sharpest text.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - antialiased: Smooth the font on the level of the pixel, as opposed to the subpixel. Can make the font appear lighter overall.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - none: Disables font smoothing. Text will show with jagged sharp edges.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Applies `default` or `antialiased` automatically based on the DPI of displays.
	"workbench.fontAliasing": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls the delay in milliseconds after which the hover is shown for workbench items (ex. some extension provided tree view items). Already visible items may require a refresh before reflecting this setting change.
	"workbench.hover.delay": 500,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the layout control is shown in the custom title bar. This setting only has an effect when `window.titleBarStyle` is set to `custom`.
	"workbench.layoutControl.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the layout control in the custom title bar is displayed as a single menu button or with multiple UI toggles.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - menu: Shows a single button with a dropdown of layout options.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - toggles: Shows several buttons for toggling the visibility of the panels and side bar.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - both: Shows both the dropdown and toggle buttons.
	"workbench.layoutControl.type": "both",

	//* 💡 ru - 123
	//* 💡 en - Controls the default find mode for lists and trees in the workbench.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - highlight: Highlight elements when searching. Further up and down navigation will traverse only the highlighted elements.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - filter: Filter elements when searching.
	"workbench.list.defaultFindMode": "highlight",

	//* 💡 ru - 123
	//* 💡 en - Scrolling speed multiplier when pressing `Alt`.
	"workbench.list.fastScrollSensitivity": 5,

	//* 💡 ru - 123
	//* 💡 en - Controls whether lists and trees support horizontal scrolling in the workbench. Warning: turning on this setting has a performance implication.
	"workbench.list.horizontalScrolling": false,

	//* 💡 ru - 123
	//* 💡 en - A multiplier to be used on the `deltaX` and `deltaY` of mouse wheel scroll events.
	"workbench.list.mouseWheelScrollSensitivity": 1,

	//* 💡 ru - 123
	//* 💡 en - The modifier to be used to add an item in trees and lists to a multi-selection with the mouse (for example in the explorer, open editors and scm view). The 'Open to Side' mouse gestures - if supported - will adapt such that they do not conflict with the multiselect modifier.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - ctrlCmd: Maps to `Control` on Windows and Linux and to `Command` on macOS.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - alt: Maps to `Alt` on Windows and Linux and to `Option` on macOS.
	"workbench.list.multiSelectModifier": "ctrlCmd",

	//* 💡 ru - 123
	//* 💡 en - Controls how to open items in trees and lists using the mouse (if supported). Note that some trees and lists might choose to ignore this setting if it is not applicable.
	"workbench.list.openMode": "singleClick",

	//* 💡 ru - 123
	//* 💡 en - Controls whether lists and trees have smooth scrolling.
	"workbench.list.smoothScrolling": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether local file history is enabled. When enabled, the file contents of an editor that is saved will be stored to a backup location to be able to restore or review the contents later. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Configure glob patterns for excluding files from the local file history. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.exclude": {},

	//* 💡 ru - 123
	//* 💡 en - Controls the maximum number of local file history entries per file. When the number of local file history entries exceeds this number for a file, the oldest entries will be discarded.
	"workbench.localHistory.maxFileEntries": 50,

	//* 💡 ru - 123
	//* 💡 en - Controls the maximum size of a file (in KB) to be considered for local file history. Files that are larger will not be added to the local file history. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.maxFileSize": 256,

	//* 💡 ru - 123
	//* 💡 en - Configure an interval in seconds during which the last entry in local file history is replaced with the entry that is being added. This helps reduce the overall number of entries that are added, for example when auto save is enabled. This setting is only applied to entries that have the same source of origin. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.mergeWindow": 10,

	//* 💡 ru - 123
	//* 💡 en - Controls the default location of the panel (Terminal, Debug Console, Output, Problems) in a new workspace. It can either show at the bottom, right, or left of the editor area.
	"workbench.panel.defaultLocation": "bottom",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the panel opens maximized. It can either always open maximized, never open maximized, or open to the last state it was in before being closed.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always maximize the panel when opening it.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never maximize the panel when opening it. The panel will open un-maximized.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - preserve: Open the panel to the state that it was in, before it was closed.
	"workbench.panel.opensMaximized": "preserve",

	//* 💡 ru - 123
	//* 💡 en - Specifies the preferred color theme for dark OS appearance when `window.autoDetectColorScheme` is enabled.
	"workbench.preferredDarkColorTheme": "Default Dark+",

	//* 💡 ru - 123
	//* 💡 en - Specifies the preferred color theme used in high contrast dark mode when `window.autoDetectHighContrast` is enabled.
	"workbench.preferredHighContrastColorTheme": "Default High Contrast",

	//* 💡 ru - 123
	//* 💡 en - Specifies the preferred color theme used in high contrast light mode when `window.autoDetectHighContrast` is enabled.
	"workbench.preferredHighContrastLightColorTheme": "Default High Contrast Light",

	//* 💡 ru - 123
	//* 💡 en - Specifies the preferred color theme for light OS appearance when `window.autoDetectColorScheme` is enabled.
	"workbench.preferredLightColorTheme": "Default Light+",

	//* 💡 ru - 123
	//* 💡 en - Specifies the product icon theme used.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - Default: Default
	"workbench.productIconTheme": "Default",

	//* 💡 ru - 123
	//* 💡 en - Controls whether Quick Open should close automatically once it loses focus.
	"workbench.quickOpen.closeOnFocusLost": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the last typed input to Quick Open should be restored when opening it the next time.
	"workbench.quickOpen.preserveInput": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the workbench should render with fewer animations.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Always render with reduced motion.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Do not render with reduced motion
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Render with reduced motion based on OS configuration.
	"workbench.reduceMotion": "auto",

	//* 💡 ru - 123
	//* 💡 en - Controls the hover feedback delay in milliseconds of the dragging area in between views/editors.
	"workbench.sash.hoverDelay": 300,

	//* 💡 ru - 123
	//* 💡 en - Controls the feedback area size in pixels of the dragging area in between views/editors. Set it to a larger value if you feel it's hard to resize views using the mouse.
	"workbench.sash.size": 4,

	//* 💡 ru - 123
	//* 💡 en - Determines which settings editor to use by default.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - ui: Use the settings UI editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - json: Use the JSON file editor.
	"workbench.settings.editor": "ui",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to enable the natural language search mode for settings. The natural language search is provided by a Microsoft online service.
	"workbench.settings.enableNaturalLanguageSearch": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether opening keybinding settings also opens an editor showing all default keybindings.
	"workbench.settings.openDefaultKeybindings": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether opening settings also opens an editor showing all default settings.
	"workbench.settings.openDefaultSettings": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the behavior of the settings editor Table of Contents while searching.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - hide: Hide the Table of Contents while searching.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - filter: Filter the Table of Contents to just categories that have matching settings. Clicking a category will filter the results to that category.
	"workbench.settings.settingsSearchTocBehavior": "filter",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to use the split JSON editor when editing settings as JSON.
	"workbench.settings.useSplitJSON": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the location of the primary side bar and activity bar. They can either show on the left or right of the workbench. The secondary side bar will show on the opposite side of the workbench.
	"workbench.sideBar.location": "left",

	//* 💡 ru - 123
	//* 💡 en - Controls the visibility of the status bar at the bottom of the workbench.
	"workbench.statusBar.visible": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled, will show the watermark tips when no editor is open.
	"workbench.tips.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls how tree folders are expanded when clicking the folder names. Note that some trees and lists might choose to ignore this setting if it is not applicable.
	"workbench.tree.expandMode": "singleClick",

	//* 💡 ru - 123
	//* 💡 en - Controls tree indentation in pixels.
	"workbench.tree.indent": 8,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the tree should render indent guides.
	"workbench.tree.renderIndentGuides": "onHover",

	//* 💡 ru - 123
	//* 💡 en - When enabled, trusted domain prompts will appear when opening links in trusted workspaces.
	"workbench.trustedDomains.promptInTrustedWorkspace": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the visibility of view header actions. View header actions may either be always visible, or only visible when that view is focused or hovered over.
	"workbench.view.alwaysShowHeaderActions": false,

	//* 💡 ru - 123
	//* 💡 en - When enabled, an extension's walkthrough will open upon install of the extension.
	"workbench.welcomePage.walkthroughs.openOnInstall": true,

	//* 💡 ru - 123
	//* 💡 en - Window

	//* 💡 ru - 123
	//* 💡 en - If set, automatically switch to the preferred color theme based on the OS appearance. If the OS appearance is dark, the theme specified at `workbench.preferredDarkColorTheme` is used, for light `workbench.preferredLightColorTheme`.
	"window.autoDetectColorScheme": false,

	//* 💡 ru - 123
	//* 💡 en - If enabled, will automatically change to high contrast theme if the OS is using a high contrast theme. The high contrast theme to use is specified by `workbench.preferredHighContrastColorTheme` and `workbench.preferredHighContrastLightColorTheme`.
	"window.autoDetectHighContrast": true,

	//* 💡 ru - 123
	//* 💡 en - If enabled, clicking on an inactive window will both activate the window and trigger the element under the mouse if it is clickable. If disabled, clicking anywhere on an inactive window will activate it only and a second click is required on the element.
	"window.clickThroughInactive": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether closing the last editor should also close the window. This setting only applies for windows that do not show folders.
	"window.closeWhenEmpty": false,

	//* 💡 ru - 123
	//* 💡 en - Show command launcher together with the window title.
	"window.commandCenter": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show a confirmation dialog before closing the window or quitting the application.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always ask for confirmation.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - keyboardOnly: Only ask for confirmation if a keybinding was used.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never explicitly ask for confirmation.
	"window.confirmBeforeClose": "never",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the menu bar will be focused by pressing the Alt-key. This setting has no effect on toggling the menu bar with the Alt-key.
	"window.customMenuBarAltFocus": true,

	//* 💡 ru - 123
	//* 💡 en - Adjust the appearance of dialog windows.
	"window.dialogStyle": "native",

	//* 💡 ru - 123
	//* 💡 en - If enabled, double clicking the application icon in the title bar will close the window and the window cannot be dragged by the icon. This setting only has an effect when `window.titleBarStyle` is set to `custom`.
	"window.doubleClickIconToClose": false,

	//* 💡 ru - 123
	//* 💡 en - Controls if native full-screen should be used on macOS. Disable this option to prevent macOS from creating a new space when going full-screen.
	"window.nativeFullScreen": true,

	//* 💡 ru - 123
	//* 💡 en - Enables macOS Sierra window tabs. Note that changes require a full restart to apply and that native tabs will disable a custom title bar style if configured.
	"window.nativeTabs": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the main menus can be opened via Alt-key shortcuts. Disabling mnemonics allows to bind these Alt-key shortcuts to editor commands instead.
	"window.enableMenuBarMnemonics": true,

	//* 💡 ru - 123
	//* 💡 en - Control the visibility of the menu bar. A setting of 'toggle' means that the menu bar is hidden and a single press of the Alt key will show it. A setting of 'compact' will move the menu into the side bar.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - classic: Menu is displayed at the top of the window and only hidden in full screen mode.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - visible: Menu is always visible at the top of the window even in full screen mode.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - toggle: Menu is hidden but can be displayed at the top of the window via the Alt key.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - hidden: Menu is always hidden.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - compact: Menu is displayed as a compact button in the side bar. This value is ignored when `window.titleBarStyle` is `native`.
	"window.menuBarVisibility": "classic",

	//* 💡 ru - 123
	//* 💡 en - Controls the dimensions of opening a new window when at least one window is already opened. Note that this setting does not have an impact on the first window that is opened. The first window will always restore the size and location as you left it before closing.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Open new windows in the center of the screen.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - inherit: Open new windows with same dimension as last active one.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - offset: Open new windows with same dimension as last active one with an offset position.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - maximized: Open new windows maximized.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - fullscreen: Open new windows in full screen mode.
	"window.newWindowDimensions": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls whether folders should open in a new window or replace the last active window.
	//* 💡 ru - 123
	//* 💡 en - 123
	//Note that there can still be cases where this setting is ignored (e.g. when using the `--new-window` or `--reuse-window` command line option).
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Folders will open in a new window.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Folders will replace the last active window.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Folders will open in a new window unless a folder is picked from within the application (e.g. via the File menu).
	"window.openFoldersInNewWindow": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls whether a new empty window should open when starting a second instance without arguments or if the last running instance should get focus.
	//* 💡 ru - 123
	//* 💡 en - 123
	//Note that there can still be cases where this setting is ignored (e.g. when using the `--new-window` or `--reuse-window` command line option).
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Open a new empty window.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Focus the last active running instance.
	"window.openWithoutArgumentsInNewWindow": "on",

	//* 💡 ru - 123
	//* 💡 en - Controls whether a window should restore to full screen mode if it was exited in full screen mode.
	"window.restoreFullscreen": false,

	//* 💡 ru - 123
	//* 💡 en - Controls how windows are being reopened after starting for the first time. This setting has no effect when the application is already running.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - preserve: Always reopen all windows. If a folder or workspace is opened (e.g. from the command line) it opens as a new window unless it was opened before. If files are opened they will open in one of the restored windows.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - all: Reopen all windows unless a folder, workspace or file is opened (e.g. from the command line).
	//* 💡 ru - 123
	//* 💡 en - 123
	// - folders: Reopen all windows that had folders or workspaces opened unless a folder, workspace or file is opened (e.g. from the command line).
	//* 💡 ru - 123
	//* 💡 en - 123
	// - one: Reopen the last active window unless a folder, workspace or file is opened (e.g. from the command line).
	//* 💡 ru - 123
	//* 💡 en - 123
	// - none: Never reopen a window. Unless a folder or workspace is opened (e.g. from the command line), an empty window will appear.
	"window.restoreWindows": "all",

	//* 💡 ru - 123
	//* 💡 en - Controls the window title based on the active editor.
	"window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${appName}",

	//* 💡 ru - 123
	//* 💡 en - Adjust the appearance of the window title bar. On Linux and Windows, this setting also affects the application and context menu appearances. Changes require a full restart to apply.
	"window.titleBarStyle": "custom",

	//* 💡 ru - 123
	//* 💡 en - Separator used by `window.title`.
	"window.titleSeparator": " - ",

	//* 💡 ru - 123
	//* 💡 en - Files

	//* 💡 ru - 123
	//* 💡 en - Configure file associations to languages (for example `"*.extension": "html"`). These have precedence over the default associations of the languages installed.
	"files.associations": {},

	//* 💡 ru - 123
	//* 💡 en - When enabled, the editor will attempt to guess the character set encoding when opening files. This setting can also be configured per language. Note, this setting is not respected by text search. Only `files.encoding` is respected.
	"files.autoGuessEncoding": false,

	//* 💡 ru - 123
	//* 💡 en - Controls auto save of editors that have unsaved changes.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: An editor with changes is never automatically saved.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - afterDelay: An editor with changes is automatically saved after the configured `files.autoSaveDelay`.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onFocusChange: An editor with changes is automatically saved when the editor loses focus.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onWindowChange: An editor with changes is automatically saved when the window loses focus.
	"files.autoSave": "off",

	//* 💡 ru - 123
	//* 💡 en - Controls the delay in milliseconds after which an editor with unsaved changes is saved automatically. Only applies when `files.autoSave` is set to `afterDelay`.
	"files.autoSaveDelay": 1000,

	//* 💡 ru - 123
	//* 💡 en - The default language identifier that is assigned to new files. If configured to `${activeEditorLanguage}`, will use the language identifier of the currently active text editor if any.
	"files.defaultLanguage": "",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Moves files/folders to the OS trash (recycle bin on Windows) when deleting. Disabling this will delete files/folders permanently.
	"files.enableTrash": true,

	//* 💡 ru - 123
	//* 💡 en - The default character set encoding to use when reading and writing files. This setting can also be configured per language.
	"files.encoding": "utf8",

	//* 💡 ru - 123
	//* 💡 en - The default end of line character.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - \n: LF
	//* 💡 ru - 123
	//* 💡 en - 123
	// - \r\n: CRLF
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Uses operating system specific end of line character.
	"files.eol": "auto",

	//* 💡 ru - 123
	//* 💡 en - Configure glob patterns for excluding files and folders. For example, the File Explorer decides which files and folders to show or hide based on this setting. Refer to the `search.exclude` setting to define search-specific excludes.
	"files.exclude": {
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/CVS": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true
	},

	//* 💡 ru - 123
	//* 💡 en - Controls whether unsaved files are remembered between sessions, allowing the save prompt when exiting the editor to be skipped.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Disable hot exit. A prompt will show when attempting to close a window with editors that have unsaved changes.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onExit: Hot exit will be triggered when the last window is closed on Windows/Linux or when the `workbench.action.quit` command is triggered (command palette, keybinding, menu). All windows without folders opened will be restored upon next launch. A list of previously opened windows with unsaved files can be accessed via `File > Open Recent > More...`
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onExitAndWindowClose: Hot exit will be triggered when the last window is closed on Windows/Linux or when the `workbench.action.quit` command is triggered (command palette, keybinding, menu), and also for any window with a folder opened regardless of whether it's the last window. All windows without folders opened will be restored upon next launch. A list of previously opened windows with unsaved files can be accessed via `File > Open Recent > More...`
	"files.hotExit": "onExit",

	//* 💡 ru - 123
	//* 💡 en - When enabled, insert a final new line at the end of the file when saving it.
	"files.insertFinalNewline": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the memory available to VS Code after restart when trying to open large files. Same effect as specifying `--max-memory=NEWSIZE` on the command line.
	"files.maxMemoryForLargeFilesMB": 4096,

	//* 💡 ru - 123
	//* 💡 en - Timeout in milliseconds after which file participants for create, rename, and delete are cancelled. Use `0` to disable participants.
	"files.participants.timeout": 60000,

	//* 💡 ru - 123
	//* 💡 en - Controls if files that were part of a refactoring are saved automatically
	"files.refactoring.autoSave": true,

	//* 💡 ru - 123
	//* 💡 en - Restore the undo stack when a file is reopened.
	"files.restoreUndoStack": true,

	//* 💡 ru - 123
	//* 💡 en - A save conflict can occur when a file is saved to disk that was changed by another program in the meantime. To prevent data loss, the user is asked to compare the changes in the editor with the version on disk. This setting should only be changed if you frequently encounter save conflict errors and may result in data loss if used without caution.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - askUser: Will refuse to save and ask for resolving the save conflict manually.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - overwriteFileOnDisk: Will resolve the save conflict by overwriting the file on disk with the changes in the editor.
	"files.saveConflictResolution": "askUser",

	//* 💡 ru - 123
	//* 💡 en - Enables the simple file dialog. The simple file dialog replaces the system file dialog when enabled.
	"files.simpleDialog.enable": false,

	//* 💡 ru - 123
	//* 💡 en - When enabled, will trim all new lines after the final new line at the end of the file when saving it.
	"files.trimFinalNewlines": false,

	//* 💡 ru - 123
	//* 💡 en - When enabled, will trim trailing whitespace when saving a file.
	"files.trimTrailingWhitespace": false,

	//* 💡 ru - 123
	//* 💡 en - Configure paths or glob patterns to exclude from file watching.
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/node_modules/*/**": true,
		"**/.hg/store/**": true
	},

	//* 💡 ru - 123
	//* 💡 en - Configure extra paths to watch for changes inside the workspace.
	"files.watcherInclude": [],

	//* 💡 ru - 123
	//* 💡 en - Screencast Mode

	//* 💡 ru - 123
	//* 💡 en - Controls the font size (in pixels) of the screencast mode keyboard.
	"screencastMode.fontSize": 56,

	//* 💡 ru - 123
	//* 💡 en - Controls how long (in milliseconds) the keyboard overlay is shown in screencast mode.
	"screencastMode.keyboardOverlayTimeout": 800,

	//* 💡 ru - 123
	//* 💡 en - Controls what is displayed in the keyboard overlay when showing shortcuts.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - keys: Keys.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - command: Command title.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - commandWithGroup: Command title prefixed by its group.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - commandAndKeys: Command title and keys.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - commandWithGroupAndKeys: Command title and keys, with the command prefixed by its group.
	"screencastMode.keyboardShortcutsFormat": "commandAndKeys",

	//* 💡 ru - 123
	//* 💡 en - Controls the color in hex (#_RGB, #RGBA, #RRGGBB or #RRGGBBAA) of the mouse indicator in screencast mode.
	"screencastMode.mouseIndicatorColor": "#FF0000",

	//* 💡 ru - 123
	//* 💡 en - Controls the size (in pixels) of the mouse indicator in screencast mode.
	"screencastMode.mouseIndicatorSize": 20,

	//* 💡 ru - 123
	//* 💡 en - Only show keyboard shortcuts in screencast mode.
	"screencastMode.onlyKeyboardShortcuts": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the vertical offset of the screencast mode overlay from the bottom as a percentage of the workbench height.
	"screencastMode.verticalOffset": 20,

	//* 💡 ru - 123
	//* 💡 en - Zen Mode

	//* 💡 ru - 123
	//* 💡 en - Controls whether turning on Zen Mode also centers the layout.
	"zenMode.centerLayout": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether turning on Zen Mode also puts the workbench into full screen mode.
	"zenMode.fullScreen": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether turning on Zen Mode also hides the activity bar either at the left or right of the workbench.
	"zenMode.hideActivityBar": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether turning on Zen Mode also hides the editor line numbers.
	"zenMode.hideLineNumbers": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether turning on Zen Mode also hides the status bar at the bottom of the workbench.
	"zenMode.hideStatusBar": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether turning on Zen Mode also hides workbench tabs.
	"zenMode.hideTabs": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether a window should restore to Zen Mode if it was exited in Zen Mode.
	"zenMode.restore": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether notifications do not disturb mode should be enabled while in Zen Mode. If true, only error notifications will pop out.
	"zenMode.silentNotifications": true,

	//* 💡 ru - 123
	//* 💡 en - File Explorer

	//* 💡 ru - 123
	//* 💡 en - Controls whether the Explorer should automatically reveal and select files when opening them.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - true: Files will be revealed and selected.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - false: Files will not be revealed and selected.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - focusNoScroll: Files will not be scrolled into view, but will still be focused.
	"explorer.autoReveal": true,

	//* 💡 ru - 123
	//* 💡 en - Configure glob patterns for excluding files and folders from being revealed and selected in the Explorer when they are opened.
	"explorer.autoRevealExclude": {
		"**/node_modules": true,
		"**/bower_components": true
	},

	//* 💡 ru - 123
	//* 💡 en - Controls whether the Explorer should ask for confirmation when undoing.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - verbose: Explorer will prompt before all undo operations.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Explorer will prompt before destructive undo operations.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - light: Explorer will not prompt before undo operations when focused.
	"explorer.confirmUndo": "default",

	//* 💡 ru - 123
	//* 💡 en - The path separation character used when copying relative file paths.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - /: Use slash as path separation character.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - \: Use backslash as path separation character.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Uses operating system specific path separation character.
	"explorer.copyRelativePathSeparator": "auto",

	//* 💡 ru - 123
	//* 💡 en - Controls whether file decorations should use badges.
	"explorer.decorations.badges": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether file decorations should use colors.
	"explorer.decorations.colors": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the Explorer should allow to move files and folders via drag and drop. This setting only effects drag and drop from inside the Explorer.
	"explorer.enableDragAndDrop": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the Explorer should support undoing file and folder operations.
	"explorer.enableUndo": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether entries in .gitignore should be parsed and excluded from the Explorer. Similar to `files.exclude`.
	"explorer.excludeGitIgnore": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the Explorer should expand multi-root workspaces containing only one folder during initialization
	"explorer.expandSingleFolderWorkspaces": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether file nesting is enabled in the Explorer. File nesting allows for related files in a directory to be visually grouped together under a single parent file.
	"explorer.fileNesting.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether file nests are automatically expanded. `explorer.fileNesting.enabled` must be set for this to take effect.
	"explorer.fileNesting.expand": true,

	//* 💡 ru - 123
	//* 💡 en - Controls nesting of files in the Explorer. `explorer.fileNesting.enabled` must be set for this to take effect. Each __Item__ represents a parent pattern and may contain a single `*` character that matches any string. Each __Value__ represents a comma separated list of the child patterns that should be shown nested under a given parent. Child patterns may contain several special tokens:
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${capture}`: Matches the resolved value of the `*` from the parent pattern
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${basename}`: Matches the parent file's basename, the `file` in `file.ts`
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${extname}`: Matches the parent file's extension, the `ts` in `file.ts`
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${dirname}`: Matches the parent file's directory name, the `src` in `src/file.ts`
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `*`:  Matches any string, may only be used once per child pattern
	"explorer.fileNesting.patterns": {
		"*.ts": "${capture}.js",
		"*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
		"*.jsx": "${capture}.js",
		"*.tsx": "${capture}.ts",
		"tsconfig.json": "tsconfig.*.json",
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml"
	},

	//* 💡 ru - 123
	//* 💡 en - Controls what naming strategy to use when a giving a new name to a duplicated Explorer item on paste.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - simple: Appends the word "copy" at the end of the duplicated name potentially followed by a number.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - smart: Adds a number at the end of the duplicated name. If some number is already part of the name, tries to increase that number.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - disabled: Disables incremental naming.
	"explorer.incrementalNaming": "simple",

	//* 💡 ru - 123
	//* 💡 en - The minimum number of editor slots shown in the Open Editors pane. If set to 0 the Open Editors pane will dynamically resize based on the number of editors.
	"explorer.openEditors.minVisible": 0,

	//* 💡 ru - 123
	//* 💡 en - Controls the sorting order of editors in the Open Editors pane.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - editorOrder: Editors are ordered in the same order editor tabs are shown.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - alphabetical: Editors are ordered alphabetically by tab name inside each editor group.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - fullPath: Editors are ordered alphabetically by full path inside each editor group.
	"explorer.openEditors.sortOrder": "editorOrder",

	//* 💡 ru - 123
	//* 💡 en - The maximum number of editors shown in the Open Editors pane. Setting this to 0 hides the Open Editors pane.
	"explorer.openEditors.visible": 9,

	//* 💡 ru - 123
	//* 💡 en - Controls the property-based sorting of files and folders in the Explorer.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Files and folders are sorted by their names. Folders are displayed before files.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - mixed: Files and folders are sorted by their names. Files are interwoven with folders.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - filesFirst: Files and folders are sorted by their names. Files are displayed before folders.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - type: Files and folders are grouped by extension type then sorted by their names. Folders are displayed before files.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - modified: Files and folders are sorted by last modified date in descending order. Folders are displayed before files.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - foldersNestsFiles: Files and folders are sorted by their names. Folders are displayed before files. Files with nested children are displayed before other files.
	"explorer.sortOrder": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls the lexicographic sorting of file and folder names in the Explorer.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Uppercase and lowercase names are mixed together.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - upper: Uppercase names are grouped together before lowercase names.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - lower: Lowercase names are grouped together before uppercase names.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - unicode: Names are sorted in Unicode order.
	"explorer.sortOrderLexicographicOptions": "default",

	//* 💡 ru - 123
	//* 💡 en - Search

	//* 💡 ru - 123
	//* 💡 en - Controls the positioning of the actionbar on rows in the search view.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Position the actionbar to the right when the search view is narrow, and immediately after the content when the search view is wide.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - right: Always position the actionbar to the right.
	"search.actionsPosition": "right",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the search results will be collapsed or expanded.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Files with less than 10 results are expanded. Others are collapsed.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - alwaysCollapse
	//* 💡 ru - 123
	//* 💡 en - 123
	// - alwaysExpand
	"search.collapseResults": "alwaysExpand",

	//* 💡 ru - 123
	//* 💡 en - Controls whether search file decorations should use badges.
	"search.decorations.badges": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether search file decorations should use colors.
	"search.decorations.colors": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the default search result view mode.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - tree: Shows search results as a tree.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - list: Shows search results as a list.
	"search.defaultViewMode": "list",

	//* 💡 ru - 123
	//* 💡 en - Configure glob patterns for excluding files and folders in fulltext searches and quick open. Inherits all glob patterns from the `files.exclude` setting.
	"search.exclude": {
		"**/node_modules": true,
		"**/bower_components": true,
		"**/*.code-search": true
	},

	//* 💡 ru - 123
	//* 💡 en - Controls whether to follow symlinks while searching.
	"search.followSymlinks": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the search view should read or modify the shared find clipboard on macOS.
	"search.globalFindClipboard": false,

	//* 💡 ru - 123
	//* 💡 en - Controls where new `Search: Find in Files` and `Find in Folder` operations occur: either in the search view, or in a search editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - view: Search in the search view, either in the panel or side bars.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - reuseEditor: Search in an existing search editor if present, otherwise in a new search editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - newEditor: Search in a new search editor.
	"search.mode": "view",

	//* 💡 ru - 123
	//* 💡 en - Controls sorting order of editor history in quick open when filtering.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: History entries are sorted by relevance based on the filter value used. More relevant entries appear first.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - recency: History entries are sorted by recency. More recently opened entries appear first.
	"search.quickOpen.history.filterSortOrder": "default",

	//* 💡 ru - 123
	//* 💡 en - Whether to include results from recently opened files in the file results for Quick Open.
	"search.quickOpen.includeHistory": true,

	//* 💡 ru - 123
	//* 💡 en - Whether to include results from a global symbol search in the file results for Quick Open.
	"search.quickOpen.includeSymbols": false,

	//* 💡 ru - 123
	//* 💡 en - The default number of surrounding context lines to use when creating new Search Editors. If using `search.searchEditor.reusePriorSearchConfiguration`, this can be set to `null` (empty) to use the prior Search Editor's configuration.
	"search.searchEditor.defaultNumberOfContextLines": 1,

	//* 💡 ru - 123
	//* 💡 en - Configure effect of double clicking a result in a search editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - selectWord: Double clicking selects the word under the cursor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - goToLocation: Double clicking opens the result in the active editor group.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - openLocationToSide: Double clicking opens the result in the editor group to the side, creating one if it does not yet exist.
	"search.searchEditor.doubleClickBehaviour": "goToLocation",

	//* 💡 ru - 123
	//* 💡 en - When enabled, new Search Editors will reuse the includes, excludes, and flags of the previously opened Search Editor.
	"search.searchEditor.reusePriorSearchConfiguration": false,

	//* 💡 ru - 123
	//* 💡 en - Search all files as you type.
	"search.searchOnType": true,

	//* 💡 ru - 123
	//* 💡 en - When `search.searchOnType` is enabled, controls the timeout in milliseconds between a character being typed and the search starting. Has no effect when `search.searchOnType` is disabled.
	"search.searchOnTypeDebouncePeriod": 300,

	//* 💡 ru - 123
	//* 💡 en - Update the search query to the editor's selected text when focusing the search view. This happens either on click or when triggering the `workbench.views.search.focus` command.
	"search.seedOnFocus": false,

	//* 💡 ru - 123
	//* 💡 en - Enable seeding search from the word nearest the cursor when the active editor has no selection.
	"search.seedWithNearestWord": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show line numbers for search results.
	"search.showLineNumbers": false,

	//* 💡 ru - 123
	//* 💡 en - Search case-insensitively if the pattern is all lowercase, otherwise, search case-sensitively.
	"search.smartCase": false,

	//* 💡 ru - 123
	//* 💡 en - Controls sorting order of search results.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Results are sorted by folder and file names, in alphabetical order.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - fileNames: Results are sorted by file names ignoring folder order, in alphabetical order.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - type: Results are sorted by file extensions, in alphabetical order.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - modified: Results are sorted by file last modified date, in descending order.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - countDescending: Results are sorted by count per file, in descending order.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - countAscending: Results are sorted by count per file, in ascending order.
	"search.sortOrder": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to use global `.gitignore` and `.ignore` files when searching for files. Requires `search.useIgnoreFiles` to be enabled.
	"search.useGlobalIgnoreFiles": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to use `.gitignore` and `.ignore` files when searching for files.
	"search.useIgnoreFiles": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to use `.gitignore` and `.ignore` files in parent directories when searching for files. Requires `search.useIgnoreFiles` to be enabled.
	"search.useParentIgnoreFiles": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to open Replace Preview when selecting or replacing a match.
	"search.useReplacePreview": true,

	//* 💡 ru - 123
	//* 💡 en - HTTP

	//* 💡 ru - 123
	//* 💡 en - The proxy setting to use. If not set, will be inherited from the `http_proxy` and `https_proxy` environment variables.
	"http.proxy": "",

	//* 💡 ru - 123
	//* 💡 en - The value to send as the `Proxy-Authorization` header for every network request.
	"http.proxyAuthorization": null,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the proxy server certificate should be verified against the list of supplied CAs.
	"http.proxyStrictSSL": true,

	//* 💡 ru - 123
	//* 💡 en - Use the proxy support for extensions.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Disable proxy support for extensions.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Enable proxy support for extensions.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - fallback: Enable proxy support for extensions, fall back to request options, when no proxy found.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - override: Enable proxy support for extensions, override request options.
	"http.proxySupport": "override",

	//* 💡 ru - 123
	//* 💡 en - Controls whether CA certificates should be loaded from the OS. (On Windows and macOS, a reload of the window is required after turning this off.)
	"http.systemCertificates": true,

	//* 💡 ru - 123
	//* 💡 en - Keyboard

	//* 💡 ru - 123
	//* 💡 en - Controls the dispatching logic for key presses to use either `code` (recommended) or `keyCode`.
	"keyboard.dispatch": "code",

	//* 💡 ru - 123
	//* 💡 en - Enables the macOS touchbar buttons on the keyboard if available.
	"keyboard.touchbar.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - A set of identifiers for entries in the touchbar that should not show up (for example `workbench.action.navigateBack`).
	"keyboard.touchbar.ignored": [],

	//* 💡 ru - 123
	//* 💡 en - Update

	//* 💡 ru - 123
	//* 💡 en - Enable to download and install new VS Code versions in the background on Windows.
	"update.enableWindowsBackgroundUpdates": true,

	//* 💡 ru - 123
	//* 💡 en - Configure whether you receive automatic updates. Requires a restart after change. The updates are fetched from a Microsoft online service.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - none: Disable updates.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - manual: Disable automatic background update checks. Updates will be available if you manually check for updates.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - start: Check for updates only on startup. Disable automatic background update checks.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Enable automatic update checks. Code will check for updates automatically and periodically.
	"update.mode": "default",

	//* 💡 ru - 123
	//* 💡 en - Show Release Notes after an update. The Release Notes are fetched from a Microsoft online service.
	"update.showReleaseNotes": true,

	//* 💡 ru - 123
	//* 💡 en - Debug

	//* 💡 ru - 123
	//* 💡 en - Allow setting breakpoints in any file.
	"debug.allowBreakpointsEverywhere": false,

	//* 💡 ru - 123
	//* 💡 en - Automatically show values for variables that are lazily resolved by the debugger, such as getters.
	"debug.autoExpandLazyVariables": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to confirm when the window closes if there are active debug sessions.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never confirm.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always confirm if there are debug sessions.
	"debug.confirmOnExit": "never",

	//* 💡 ru - 123
	//* 💡 en - Controls whether suggestions should be accepted on Enter in the Debug Console. Enter is also used to evaluate whatever is typed in the Debug Console.
	"debug.console.acceptSuggestionOnEnter": "off",

	//* 💡 ru - 123
	//* 💡 en - Controls if the Debug Console should be automatically closed when the debug session ends.
	"debug.console.closeOnEnd": false,

	//* 💡 ru - 123
	//* 💡 en - Controls if the Debug Console should collapse identical lines and show a number of occurrences with a badge.
	"debug.console.collapseIdenticalLines": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the font family in the Debug Console.
	"debug.console.fontFamily": "default",

	//* 💡 ru - 123
	//* 💡 en - Controls the font size in pixels in the Debug Console.
	"debug.console.fontSize": 14,

	//* 💡 ru - 123
	//* 💡 en - Controls if the Debug Console should suggest previously typed input.
	"debug.console.historySuggestions": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the line height in pixels in the Debug Console. Use 0 to compute the line height from the font size.
	"debug.console.lineHeight": 0,

	//* 💡 ru - 123
	//* 💡 en - Controls if the lines should wrap in the Debug Console.
	"debug.console.wordWrap": true,

	//* 💡 ru - 123
	//* 💡 en - Show Source Code in Disassembly View.
	"debug.disassemblyView.showSourceCode": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the editor should be focused when the debugger breaks.
	"debug.focusEditorOnBreak": true,

	//* 💡 ru - 123
	//* 💡 en - Show variable values inline in editor while debugging.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Always show variable values inline in editor while debugging.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Never show variable values inline in editor while debugging.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Show variable values inline in editor while debugging when the language supports inline value locations.
	"debug.inlineValues": "auto",

	//* 💡 ru - 123
	//* 💡 en - Controls when the internal Debug Console should open.
	"debug.internalConsoleOptions": "openOnFirstSessionStart",

	//* 💡 ru - 123
	//* 💡 en - Controls what to do when errors are encountered after running a preLaunchTask.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - debugAnyway: Ignore task errors and start debugging.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - showErrors: Show the Problems view and do not start debugging.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - prompt: Prompt user.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - abort: Cancel debugging.
	"debug.onTaskErrors": "prompt",

	//* 💡 ru - 123
	//* 💡 en - Controls when the debug view should open.
	"debug.openDebug": "openOnDebugBreak",

	//* 💡 ru - 123
	//* 💡 en - Automatically open the explorer view at the end of a debug session.
	"debug.openExplorerOnEnd": false,

	//* 💡 ru - 123
	//* 💡 en - Controls what editors to save before starting a debug session.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - allEditorsInActiveGroup: Save all editors in the active group before starting a debug session.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - nonUntitledEditorsInActiveGroup: Save all editors in the active group except untitled ones before starting a debug session.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - none: Don't save any editors before starting a debug session.
	"debug.saveBeforeStart": "allEditorsInActiveGroup",

	//* 💡 ru - 123
	//* 💡 en - Controls when the debug Status bar should be visible.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never show debug in Status bar
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always show debug in Status bar
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onFirstSessionStart: Show debug in Status bar only after debug was started for the first time
	"debug.showInStatusBar": "onFirstSessionStart",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the debug sub-sessions are shown in the debug tool bar. When this setting is false the stop command on a sub-session will also stop the parent session.
	"debug.showSubSessionsInToolBar": false,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Before starting a new debug session in an integrated or external terminal, clear the terminal.
	"debug.terminal.clearBeforeReusing": false,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Global debug launch configuration. Should be used as an alternative to 'launch.json' that is shared across workspaces.
	"launch": {
		"configurations": [],
		"compounds": []
	},

	//* 💡 ru - 123
	//* 💡 en - HTML

	//* 💡 ru - 123
	//* 💡 en - Enable/disable autoclosing of HTML tags.
	"html.autoClosingTags": true,

	//* 💡 ru - 123
	//* 💡 en - Enable/disable auto creation of quotes for HTML attribute assignment. The type of quotes can be configured by `html.completion.attributeDefaultValue`.
	"html.autoCreateQuotes": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the default value for attributes when completion is accepted.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - doublequotes: Attribute value is set to "".
	//* 💡 ru - 123
	//* 💡 en - 123
	// - singlequotes: Attribute value is set to ''.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - empty: Attribute value is not set.
	"html.completion.attributeDefaultValue": "doublequotes",

	//* 💡 ru - 123
	//* 💡 en - A list of relative file paths pointing to JSON files following the custom data format.
	//* 💡 ru - 123
	//* 💡 en - 123
	//VS Code loads custom data on startup to enhance its HTML support for the custom HTML tags, attributes and attribute values you specify in the JSON files.
	//* 💡 ru - 123
	//* 💡 en - The file paths are relative to workspace and only workspace folder settings are considered.
	"html.customData": [],

	//* 💡 ru - 123
	//* 💡 en - List of tags, comma separated, where the content shouldn't be reformatted. `null` defaults to the `pre` tag.
	"html.format.contentUnformatted": "pre,code,textarea",

	//* 💡 ru - 123
	//* 💡 en - Enable/disable default HTML formatter.
	"html.format.enable": true,

	//* 💡 ru - 123
	//* 💡 en - List of tags, comma separated, that should have an extra newline before them. `null` defaults to `"head, body, /html"`.
	"html.format.extraLiners": "head, body, /html",

	//* 💡 ru - 123
	//* 💡 en - Format and indent ``.
	"html.format.indentHandlebars": false,

	//* 💡 ru - 123
	//* 💡 en - Indent `<head>` and `<body>` sections.
	"html.format.indentInnerHtml": false,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Maximum number of line breaks to be preserved in one chunk. Use `null` for unlimited.
	"html.format.maxPreserveNewLines": null,

	//* 💡 ru - 123
	//* 💡 en - Controls whether existing line breaks before elements should be preserved. Only works before elements, not inside tags or for text.
	"html.format.preserveNewLines": true,

	//* 💡 ru - 123
	//* 💡 en - Honor django, erb, handlebars and php templating language tags.
	"html.format.templating": false,

	//* 💡 ru - 123
	//* 💡 en - List of tags, comma separated, that shouldn't be reformatted.
	"html.format.unformatted": "wbr",

	//* 💡 ru - 123
	//* 💡 en - Keep text content together between this string.
	"html.format.unformattedContentDelimiter": "",

	//* 💡 ru - 123
	//* 💡 en - Wrap attributes.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Wrap attributes only when line length is exceeded.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - force: Wrap each attribute except first.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - force-aligned: Wrap each attribute except first and keep aligned.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - force-expand-multiline: Wrap each attribute.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - aligned-multiple: Wrap when line length is exceeded, align attributes vertically.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - preserve: Preserve wrapping of attributes.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - preserve-aligned: Preserve wrapping of attributes but align.
	"html.format.wrapAttributes": "auto",

	//* 💡 ru - 123
	//* 💡 en - Indent wrapped attributes to after N characters. Use `null` to use the default indent size. Ignored if `html.format.wrapAttributes` is set to 'aligned'.
	"html.format.wrapAttributesIndentSize": null,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Maximum amount of characters per line (0 = disable).
	"html.format.wrapLineLength": 120,

	//* 💡 ru - 123
	//* 💡 en - Show tag and attribute documentation in hover.
	"html.hover.documentation": true,

	//* 💡 ru - 123
	//* 💡 en - Show references to MDN in hover.
	"html.hover.references": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the built-in HTML language support suggests HTML5 tags, properties and values.
	"html.suggest.html5": true,

	//* 💡 ru - 123
	//* 💡 en - Traces the communication between VS Code and the HTML language server.
	"html.trace.server": "off",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the built-in HTML language support validates embedded scripts.
	"html.validate.scripts": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the built-in HTML language support validates embedded styles.
	"html.validate.styles": true,

	//* 💡 ru - 123
	//* 💡 en - 123
	//JSON

	//* 💡 ru - 123
	//* 💡 en - Enable/disable default JSON formatter
	"json.format.enable": true,

	//* 💡 ru - 123
	//* 💡 en - Keep all existing new lines when formatting.
	"json.format.keepLines": false,

	//* 💡 ru - 123
	//* 💡 en - The maximum number of outline symbols and folding regions computed (limited for performance reasons).
	"json.maxItemsComputed": 5000,

	//* 💡 ru - 123
	//* 💡 en - When enabled, JSON schemas can be fetched from http and https locations.
	"json.schemaDownload.enable": true,

	//* 💡 ru - 123
	//* 💡 en - Associate schemas to JSON files in the current project.
	"json.schemas": [],

	//* 💡 ru - 123
	//* 💡 en - Traces the communication between VS Code and the JSON language server.
	"json.trace.server": "off",

	//* 💡 ru - 123
	//* 💡 en - Enable/disable JSON validation.
	"json.validate.enable": true,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Markdown

	//* 💡 ru - 123
	//* 💡 en - Enable dropping files into a Markdown editor while holding Shift. Requires enabling `editor.dropIntoEditor.enabled`.
	"markdown.editor.drop.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls where links in Markdown files should be opened.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - currentGroup: Open links in the active editor group.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - beside: Open links beside the active editor.
	"markdown.links.openLocation": "currentGroup",

	//* 💡 ru - 123
	//* 💡 en - Enable highlighting link occurrences in the current document.
	"markdown.occurrencesHighlight.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - Sets how line-breaks are rendered in the Markdown preview. Setting it to 'true' creates a <br> for newlines inside paragraphs.
	"markdown.preview.breaks": false,

	//* 💡 ru - 123
	//* 💡 en - Double click in the Markdown preview to switch to the editor.
	"markdown.preview.doubleClickToSwitchToEditor": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the font family used in the Markdown preview.
	"markdown.preview.fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe WPC', 'Segoe UI', system-ui, 'Ubuntu', 'Droid Sans', sans-serif",

	//* 💡 ru - 123
	//* 💡 en - Controls the font size in pixels used in the Markdown preview.
	"markdown.preview.fontSize": 14,

	//* 💡 ru - 123
	//* 💡 en - Controls the line height used in the Markdown preview. This number is relative to the font size.
	"markdown.preview.lineHeight": 1.6,

	//* 💡 ru - 123
	//* 💡 en - Convert URL-like text to links in the Markdown preview.
	"markdown.preview.linkify": true,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Mark the current editor selection in the Markdown preview.
	"markdown.preview.markEditorSelection": true,

	//* 💡 ru - 123
	//* 💡 en - Controls how links to other Markdown files in the Markdown preview should be opened.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - inPreview: Try to open links in the Markdown preview.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - inEditor: Try to open links in the editor.
	"markdown.preview.openMarkdownLinks": "inPreview",

	//* 💡 ru - 123
	//* 💡 en - When a Markdown preview is scrolled, update the view of the editor.
	"markdown.preview.scrollEditorWithPreview": true,

	//* 💡 ru - 123
	//* 💡 en - When a Markdown editor is scrolled, update the view of the preview.
	"markdown.preview.scrollPreviewWithEditor": true,

	//* 💡 ru - 123
	//* 💡 en - Enable some language-neutral replacement and quotes beautification in the Markdown preview.
	"markdown.preview.typographer": false,

	//* 💡 ru - 123
	//* 💡 en - A list of URLs or local paths to CSS style sheets to use from the Markdown preview. Relative paths are interpreted relative to the folder open in the Explorer. If there is no open folder, they are interpreted relative to the location of the Markdown file. All '\' need to be written as '\\'.
	"markdown.styles": [],

	//* 💡 ru - 123
	//* 💡 en - Enable path suggestions while writing links in Markdown files.
	"markdown.suggest.paths.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Enable debug logging for the Markdown extension.
	"markdown.trace.extension": "off",

	//* 💡 ru - 123
	//* 💡 en - Try to update links in Markdown files when a file is renamed/moved in the workspace. Use `markdown.updateLinksOnFileMove.include` to configure which files trigger link updates.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - prompt: Prompt on each file move.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always update links automatically.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never try to update link and don't prompt.
	"markdown.updateLinksOnFileMove.enabled": "never",

	//* 💡 ru - 123
	//* 💡 en - Enable updating links when a directory is moved or renamed in the workspace.
	"markdown.updateLinksOnFileMove.enableForDirectories": true,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Glob patterns that specifies files that trigger automatic link updates. See `markdown.updateLinksOnFileMove.enabled` for details about this feature.
	"markdown.updateLinksOnFileMove.include": [
		"**/*.{md,mkd,mdwn,mdown,markdown,markdn,mdtxt,mdtext,workbook}",
		"**/*.{jpg,jpe,jpeg,png,bmp,gif,ico,webp,avif,tiff,svg,mp4}"
	],

	//* 💡 ru - 123
	//* 💡 en - 123
	//Validate duplicated definitions in the current file.
	"markdown.validate.duplicateLinkDefinitions.enabled": "warning",

	//* 💡 ru - 123
	//* 💡 en - Enable all error reporting in Markdown files.
	"markdown.validate.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Validate links to other files in Markdown files, for example `[link](/path/to/file.md)`. This checks that the target files exists. Requires enabling `markdown.validate.enabled`.
	"markdown.validate.fileLinks.enabled": "warning",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Validate the fragment part of links to headers in other files in Markdown files, for example `[link](/path/to/file.md#header)`. Inherits the setting value from `markdown.validate.fragmentLinks.enabled` by default.
	"markdown.validate.fileLinks.markdownFragmentLinks": "inherit",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Validate fragment links to headers in the current Markdown file, for example `[link](#_header)`. Requires enabling `markdown.validate.enabled`.
	"markdown.validate.fragmentLinks.enabled": "warning",

	//* 💡 ru - 123
	//* 💡 en - Configure links that should not be validated. For example adding `/about` would not validate the link `[about](/about)`, while the glob `/assets/**/*.svg` would let you skip validation for any link to `.svg` files under the `assets` directory.
	"markdown.validate.ignoredLinks": [],

	//* 💡 ru - 123
	//* 💡 en - 123
	//Validate reference links in Markdown files, for example `[link][ref]`. Requires enabling `markdown.validate.enabled`.
	"markdown.validate.referenceLinks.enabled": "warning",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Validate link definitions that are unused in the current file.
	"markdown.validate.unusedLinkDefinitions.enabled": "hint",

	//* 💡 ru - 123
	//* 💡 en - PHP

	//* 💡 ru - 123
	//* 💡 en - Controls whether the built-in PHP language suggestions are enabled. The support suggests PHP globals and variables.
	"php.suggest.basic": true,

	//* 💡 ru - 123
	//* 💡 en - Enable/disable built-in PHP validation.
	"php.validate.enable": true,

	//* 💡 ru - 123
	//* 💡 en - Points to the PHP executable.
	"php.validate.executablePath": null,

	//* 💡 ru - 123
	//* 💡 en - Whether the linter is run on save or on type.
	"php.validate.run": "onSave",

	//* 💡 ru - 123
	//* 💡 en - TypeScript

	//* 💡 ru - 123
	//* 💡 en - Enable/disable automatic closing of JSX tags.
	"javascript.autoClosingTags": true,

	//* 💡 ru - 123
	//* 💡 en - Enable/disable default JavaScript formatter.
	"javascript.format.enable": true,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after a comma delimiter.
	"javascript.format.insertSpaceAfterCommaDelimiter": true,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after the constructor keyword.
	"javascript.format.insertSpaceAfterConstructor": false,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after function keyword for anonymous functions.
	"javascript.format.insertSpaceAfterFunctionKeywordForAnonymousFunctions": true,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after keywords in a control flow statement.
	"javascript.format.insertSpaceAfterKeywordsInControlFlowStatements": true,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after opening and before closing empty braces.
	"javascript.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": true,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after opening and before closing JSX expression braces.
	"javascript.format.insertSpaceAfterOpeningAndBeforeClosingJsxExpressionBraces": false,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after opening and before closing non-empty braces.
	"javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after opening and before closing non-empty brackets.
	"javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": false,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after opening and before closing non-empty parenthesis.
	"javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyParenthesis": false,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after opening and before closing template string braces.
	"javascript.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": false,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after a semicolon in a for statement.
	"javascript.format.insertSpaceAfterSemicolonInForStatements": true,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling after a binary operator.
	"javascript.format.insertSpaceBeforeAndAfterBinaryOperators": true,

	//* 💡 ru - 123
	//* 💡 en - Defines space handling before function argument parentheses.
	"javascript.format.insertSpaceBeforeFunctionParenthesis": false,

	//* 💡 ru - 123
	//* 💡 en - Defines whether an open brace is put onto a new line for control blocks or not.
	"javascript.format.placeOpenBraceOnNewLineForControlBlocks": false,

	//* 💡 ru - 123
	//* 💡 en - Defines whether an open brace is put onto a new line for functions or not.
	"javascript.format.placeOpenBraceOnNewLineForFunctions": false,

	//* 💡 ru - 123
	//* 💡 en - Defines handling of optional semicolons.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - ignore: Don't insert or remove any semicolons.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - insert: Insert semicolons at statement ends.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - remove: Remove unnecessary semicolons.
	"javascript.format.semicolons": "ignore",

	//* 💡 ru - 123
	//* 💡 en - Enable/disable inlay hints for member values in enum declarations:
	"javascript.inlayHints.enumMemberValues.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - Enable/disable inlay hints for implicit return types on function signatures:
	"javascript.inlayHints.functionLikeReturnTypes.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - Enable/disable inlay hints for parameter names:
	"javascript.inlayHints.parameterNames.enabled": "none",

	//* 💡 ru - 123
	//* 💡 en - Suppress parameter name hints on arguments whose text is identical to the parameter name.
	"javascript.inlayHints.parameterNames.suppressWhenArgumentMatchesName": true,

	//* 💡 ru - 123
	//* 💡 en - Enable/disable inlay hints for implicit parameter types:
	"javascript.inlayHints.parameterTypes.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - Enable/disable inlay hints for implicit types on property declarations:
	"javascript.inlayHints.propertyDeclarationTypes.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - Enable/disable inlay hints for implicit variable types:
