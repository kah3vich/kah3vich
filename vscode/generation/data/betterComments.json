{
  // 🟢 Better

  // 🇷🇺 - Таги для комментариев.
  // 🇺🇸 - Tags for comments.
  "better-comments.tags": [
    {
      // 🇷🇺 - Тег для вкл расширения.
      // 🇺🇸 - Tag to enable the extension.
      "tag": "!",

      // 🇷🇺 - Цвет строки.
      // 🇺🇸 - Line color.
      "color": "#FF2D00",

      // 🇷🇺 - Зачеркнутый текст.
      // 🇺🇸 - Strikethrough text.
      "strikethrough": false,

      // 🇷🇺 - Нижние подчеркивание.
      // 🇺🇸 - Underscores.
      "underline": false,

      // 🇷🇺 - Задний цвет.
      // 🇺🇸 - Back color.
      "backgroundColor": "transparent",

      // 🇷🇺 - Жирное начертание.
      // 🇺🇸 - Bold font.
      "bold": false,

      // 🇷🇺 - Стиль шрифта.
      // 🇺🇸 - Font style.
      "italic": false
    },
    {
      "tag": "|",
      "color": "#0FFD00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "?",
      "color": "#3498DB",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "//",
      "color": "#474747",
      "strikethrough": true,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "todo",
      "color": "#FF8C00",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    },
    {
      "tag": "*",
      "color": "#98C379",
      "strikethrough": false,
      "underline": false,
      "backgroundColor": "transparent",
      "bold": false,
      "italic": false
    }
  ],

  // 🇷🇺 - Этот параметр определяет, оформляются ли комментарии в текстовом файле с использованием тегов аннотаций. При значении true теги (по умолчанию: ! * ? //) будут обнаружены, если они являются первым символом в строке.
  // 🇺🇸 - This setting determines whether comments in a text file are formatted using annotation tags. If set to true, tags (default: ! * ? //) will be detected if they are the first character in the string.
  "better-comments.highlightPlainText": true
}
