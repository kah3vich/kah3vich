	//* 💡 en - Defines space handling after opening and before closing template string braces.
	"typescript.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": false,

	//* 💡 ru - Определяет обработку пробелов после точки с запятой в операторе for.
	//* 💡 en - Defines space handling after a semicolon in a for statement.
	"typescript.format.insertSpaceAfterSemicolonInForStatements": true,

	//* 💡 ru - Определяет обработку пробелов после утверждений типа в TypeScript.
	//* 💡 en - Defines space handling after type assertions in TypeScript.
	"typescript.format.insertSpaceAfterTypeAssertion": false,

	//* 💡 ru - Определяет обработку пробелов после бинарного оператора.
	//* 💡 en - Defines space handling after a binary operator.
	"typescript.format.insertSpaceBeforeAndAfterBinaryOperators": true,

	//* 💡 ru - Определяет обработку пробелов перед скобками аргумента функции.
	//* 💡 en - Defines space handling before function argument parentheses.
	"typescript.format.insertSpaceBeforeFunctionParenthesis": false,

	//* 💡 ru - Определяет, ставится ли открывающая скобка на новую строку для управляющих блоков или нет.
	//* 💡 en - Defines whether an open brace is put onto a new line for control blocks or not.
	"typescript.format.placeOpenBraceOnNewLineForControlBlocks": false,

	//* 💡 ru - Определяет, ставится ли открывающая скобка на новую строку для функций или нет.
	//* 💡 en - Defines whether an open brace is put onto a new line for functions or not.
	"typescript.format.placeOpenBraceOnNewLineForFunctions": false,

	//* 💡 ru - Определяет обработку необязательных точек с запятой.
