	//* 💡 ru - 123
	//* 💡 en - Remote

	//* 💡 ru - 123
	//* 💡 en - The name under which the remote tunnel access is registered. If not set, the host name is used.
	"remote.tunnels.access.hostNameOverride": "",

	//* 💡 ru - 123
	//* 💡 en - When enabled, new running processes are detected and ports that they listen on are automatically forwarded. Disabling this setting will not prevent all ports from being forwarded. Even when disabled, extensions will still be able to cause ports to be forwarded, and opening some URLs will still cause ports to forwarded.
	"remote.autoForwardPorts": true,

	//* 💡 ru - 123
	//* 💡 en - Sets the source from which ports are automatically forwarded when `remote.autoForwardPorts` is true. On Windows and Mac remotes, the `process` option has no effect and `output` will be used. Requires a reload to take effect.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - process: Ports will be automatically forwarded when discovered by watching for processes that are started and include a port.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - output: Ports will be automatically forwarded when discovered by reading terminal and debug output. Not all processes that use ports will print to the integrated terminal or debug console, so some ports will be missed. Ports forwarded based on output will not be "un-forwarded" until reload or until the port is closed by the user in the Ports view.
	"remote.autoForwardPortsSource": "process",

	//* 💡 ru - 123
	//* 💡 en - When enabled extensions are downloaded locally and installed on remote.
	"remote.downloadExtensionsLocally": false,

	//* 💡 ru - 123
	//* 💡 en - Override the kind of an extension. `ui` extensions are installed and run on the local machine while `workspace` extensions are run on the remote. By overriding an extension's default kind using this setting, you specify if that extension should be installed and enabled locally or remotely.
	"remote.extensionKind": {
		"pub.name": ["ui"]
	},

	//* 💡 ru - 123
	//* 💡 en - Specifies the local host name that will be used for port forwarding.
	"remote.localPortHost": "localhost",

	//* 💡 ru - 123
	//* 💡 en - Set default properties that are applied to all ports that don't get properties from the setting `remote.portsAttributes`.
	"remote.otherPortsAttributes": {},

	//* 💡 ru - 123
	//* 💡 en - Set properties that are applied when a specific port number is forwarded.
	"remote.portsAttributes": {},

	//* 💡 ru - 123
	//* 💡 en - Restores the ports you forwarded in a workspace.
	"remote.restoreForwardedPorts": true,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Merge Editor

	//* 💡 ru - 123
	//* 💡 en - Controls if deletions in base or one of the inputs should be indicated by a vertical bar.
	"mergeEditor.showDeletionMarkers": true,

	//* 💡 ru - 123
	//* 💡 en - Emmet

	//* 💡 ru - 123
	//* 💡 en - An array of languages where Emmet abbreviations should not be expanded.
	"emmet.excludeLanguages": ["markdown"],

	//* 💡 ru - 123
	//* 💡 en - An array of paths, where each path can contain Emmet syntaxProfiles and/or snippet files.
	//* 💡 ru - 123
	//* 💡 en - In case of conflicts, the profiles/snippets of later paths will override those of earlier paths.
	"emmet.extensionsPath": [],

	//* 💡 ru - 123
	//* 💡 en - Enable Emmet abbreviations in languages that are not supported by default. Add a mapping here between the language and Emmet supported language.
	//* 💡 ru - 123
	//* 💡 en - 123
	// For example: `{"vue-html": "html", "javascript": "javascriptreact"}`
	"emmet.includeLanguages": {},

	//* 💡 ru - 123
	//* 💡 en - When set to `false`, the whole file is parsed to determine if current position is valid for expanding Emmet abbreviations. When set to `true`, only the content around the current position in CSS/SCSS/Less files is parsed.
	"emmet.optimizeStylesheetParsing": true,

	//* 💡 ru - 123
	//* 💡 en - Preferences used to modify behavior of some actions and resolvers of Emmet.
	"emmet.preferences": {},

	//* 💡 ru - 123
	//* 💡 en - Shows possible Emmet abbreviations as suggestions. Not applicable in stylesheets or when emmet.showExpandedAbbreviation is set to `"never"`.
	"emmet.showAbbreviationSuggestions": true,

	//* 💡 ru - 123
	//* 💡 en - Shows expanded Emmet abbreviations as suggestions.
	//* 💡 ru - 123
	//* 💡 en - The option `"inMarkupAndStylesheetFilesOnly"` applies to html, haml, jade, slim, xml, xsl, css, scss, sass, less and stylus.
	//* 💡 ru - 123
	//* 💡 en - The option `"always"` applies to all parts of the file regardless of markup/css.
	"emmet.showExpandedAbbreviation": "always",

	//* 💡 ru - 123
	//* 💡 en - If `true`, then Emmet suggestions will show up as snippets allowing you to order them as per `editor.snippetSuggestions` setting.
	"emmet.showSuggestionsAsSnippets": false,

	//* 💡 ru - 123
	//* 💡 en - Define profile for specified syntax or use your own profile with specific rules.
	"emmet.syntaxProfiles": {},

	//* 💡 ru - 123
	//* 💡 en - If `true`, Emmet will use inline completions to suggest expansions.
	"emmet.useInlineCompletions": false,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Variables to be used in Emmet snippets.
	"emmet.variables": {},

	//* 💡 ru - 123
	//* 💡 en - 123
	//Git

	//* 💡 ru - 123
	//* 💡 en - Controls whether force push (with or without lease) is enabled.
	"git.allowForcePush": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether commits without running pre-commit and commit-msg hooks are allowed.
	"git.allowNoVerifyCommit": false,

	//* 💡 ru - 123
	//* 💡 en - Always show the Staged Changes resource group.
	"git.alwaysShowStagedChangesResourceGroup": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the signoff flag for all commits.
	"git.alwaysSignOff": false,

	//* 💡 ru - 123
	//* 💡 en - When set to true, commits will automatically be fetched from the default remote of the current Git repository. Setting to `all` will fetch from all remotes.
	"git.autofetch": false,

	//* 💡 ru - 123
	//* 💡 en - Duration in seconds between each automatic git fetch, when `git.autofetch` is enabled.
	"git.autofetchPeriod": 180,

	//* 💡 ru - 123
	//* 💡 en - Whether auto refreshing is enabled.
	"git.autorefresh": true,

	//* 💡 ru - 123
	//* 💡 en - Configures when repositories should be automatically detected.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - true: Scan for both subfolders of the current opened folder and parent folders of open files.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - false: Disable automatic repository scanning.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - subFolders: Scan for subfolders of the currently opened folder.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - openEditors: Scan for parent folders of open files.
	"git.autoRepositoryDetection": true,

	//* 💡 ru - 123
	//* 💡 en - Stash any changes before pulling and restore them after successful pull.
	"git.autoStash": false,

	//* 💡 ru - 123
	//* 💡 en - Prefix used when creating a new branch.
	"git.branchPrefix": "",

	//* 💡 ru - 123
	//* 💡 en - List of protected branches. By default, a prompt is shown before changes are committed to a protected branch. The prompt can be controlled using the `git.branchProtectionPrompt`  setting.
	"git.branchProtection": [],

	//* 💡 ru - 123
	//* 💡 en - Controls whether a prompt is being shown before changes are committed to a protected branch.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - alwaysCommit: Always commit changes to the protected branch.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - alwaysCommitToNewBranch: Always commit changes to a new branch.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - alwaysPrompt: Always prompt before changes are committed to a protected branch.
	"git.branchProtectionPrompt": "alwaysPrompt",

	//* 💡 ru - 123
	//* 💡 en - List of dictionaries used for the randomly generated branch name. Each value represents the dictionary used to generate the segment of the branch name. Supported dictionaries: `adjectives`, `animals`, `colors` and `numbers`.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - adjectives: A random adjective
	//* 💡 ru - 123
	//* 💡 en - 123
	// - animals: A random animal name
	//* 💡 ru - 123
	//* 💡 en - 123
	// - colors: A random color name
	//* 💡 ru - 123
	//* 💡 en - 123
	// - numbers: A random number between 100 and 999
	"git.branchRandomName.dictionary": ["adjectives", "animals"],

	//* 💡 ru - 123
	//* 💡 en - Controls whether a random name is generated when creating a new branch.
	"git.branchRandomName.enable": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the sort order for branches.
	"git.branchSortOrder": "committerdate",

	//* 💡 ru - 123
	//* 💡 en - A regular expression to validate new branch names.
	"git.branchValidationRegex": "",

	//* 💡 ru - 123
	//* 💡 en - The character to replace whitespace in new branch names, and to separate segments of a randomly generated branch name.
	"git.branchWhitespaceChar": "-",

	//* 💡 ru - 123
	//* 💡 en - Controls what type of git refs are listed when running `Checkout to...`.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - local: Local branches
	//* 💡 ru - 123
	//* 💡 en - 123
	// - tags: Tags
	//* 💡 ru - 123
	//* 💡 en - 123
	// - remote: Remote branches
	"git.checkoutType": ["local", "remote", "tags"],

	//* 💡 ru - 123
	//* 💡 en - Controls whether the diff editor should be automatically closed when changes are stashed, committed, discarded, staged, or unstaged.
	"git.closeDiffOnOperation": false,

	//* 💡 ru - 123
	//* 💡 en - List of git commands (ex: commit, push) that would have their `stdout` logged to the git output. If the git command has a client-side hook configured, the client-side hook's `stdout` will also be logged to the git output.
	"git.commandsToLog": [],

	//* 💡 ru - 123
	//* 💡 en - Always confirm the creation of empty commits for the 'Git: Commit Empty' command.
	"git.confirmEmptyCommits": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to ask for confirmation before force-pushing.
	"git.confirmForcePush": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to ask for confirmation before committing without verification.
	"git.confirmNoVerifyCommit": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the Git count badge.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - all: Count all changes.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - tracked: Count only tracked changes.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Turn off counter.
	"git.countBadge": "all",

	//* 💡 ru - 123
	//* 💡 en - Controls whether Git contributes colors and badges to the Explorer and the Open Editors view.
	"git.decorations.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - The default location to clone a git repository.
	"git.defaultCloneDirectory": null,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to automatically detect git submodules.
	"git.detectSubmodules": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the limit of git submodules detected.
	"git.detectSubmodulesLimit": 10,

	//* 💡 ru - 123
	//* 💡 en - Enables commit signing with GPG or X.509.
	"git.enableCommitSigning": false,

	//* 💡 ru - 123
	//* 💡 en - Whether git is enabled.
	"git.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Commit all changes when there are no staged changes.
	"git.enableSmartCommit": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the Git Sync command appears in the status bar.
	"git.enableStatusBarSync": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled, fetch all branches when pulling. Otherwise, fetch just the current one.
	"git.fetchOnPull": false,

	//* 💡 ru - 123
	//* 💡 en - Follow push all tags when running the sync command.
	"git.followTagsWhenSync": false,

	//* 💡 ru - 123
	//* 💡 en - List of git repositories to ignore.
	"git.ignoredRepositories": [],

	//* 💡 ru - 123
	//* 💡 en - Ignores the legacy Git warning.
	"git.ignoreLegacyWarning": false,

	//* 💡 ru - 123
	//* 💡 en - Ignores the warning when there are too many changes in a repository.
	"git.ignoreLimitWarning": false,

	//* 💡 ru - 123
	//* 💡 en - Ignores the warning when Git is missing.
	"git.ignoreMissingGitWarning": false,

	//* 💡 ru - 123
	//* 💡 en - Ignores the warning when it looks like the branch might have been rebased when pulling.
	"git.ignoreRebaseWarning": false,

	//* 💡 ru - 123
	//* 💡 en - Ignore modifications to submodules in the file tree.
	"git.ignoreSubmodules": false,

	//* 💡 ru - 123
	//* 💡 en - Ignores the warning when Git 2.25 - 2.26 is installed on Windows.
	"git.ignoreWindowsGit27Warning": false,

	//* 💡 ru - 123
	//* 💡 en - Controls when to show commit message input validation.
	"git.inputValidation": "warn",

	//* 💡 ru - 123
	//* 💡 en - Controls the commit message length threshold for showing a warning.
	"git.inputValidationLength": 72,

	//* 💡 ru - 123
	//* 💡 en - Controls the commit message subject length threshold for showing a warning. Unset it to inherit the value of `config.inputValidationLength`.
	"git.inputValidationSubjectLength": 50,

	//* 💡 ru - 123
	//* 💡 en - Open the merge editor for files that are currently under conflict.
	"git.mergeEditor": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to open a repository automatically after cloning.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always open in current window.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - alwaysNewWindow: Always open in a new window.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - whenNoFolderOpen: Only open in current window when no folder is opened.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - prompt: Always prompt for action.
	"git.openAfterClone": "prompt",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the diff editor should be opened when clicking a change. Otherwise the regular editor will be opened.
	"git.openDiffOnClick": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to optimistically update the state of the Source Control view after running git commands.
	"git.optimisticUpdate": true,

	//* 💡 ru - 123
	//* 💡 en - Path and filename of the git executable, e.g. `C:\Program Files\Git\bin\git.exe` (Windows). This can also be an array of string values containing multiple paths to look up.
	"git.path": null,

	//* 💡 ru - 123
	//* 💡 en - Run a git command after a successful commit.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - none: Don't run any command after a commit.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - push: Run 'git push' after a successful commit.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - sync: Run 'git pull' and 'git push' after a successful commit.
	"git.postCommitCommand": "none",

	//* 💡 ru - 123
	//* 💡 en - Controls whether Git should check for unsaved files before committing.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Check for any unsaved files.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - staged: Check only for unsaved staged files.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Disable this check.
	"git.promptToSaveFilesBeforeCommit": "always",

	//* 💡 ru - 123
	//* 💡 en - Controls whether Git should check for unsaved files before stashing changes.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Check for any unsaved files.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - staged: Check only for unsaved staged files.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Disable this check.
	"git.promptToSaveFilesBeforeStash": "always",

	//* 💡 ru - 123
	//* 💡 en - Prune when fetching.
	"git.pruneOnFetch": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether a branch that does not have outgoing commits is fast-forwarded before it is checked out.
	"git.pullBeforeCheckout": false,

	//* 💡 ru - 123
	//* 💡 en - Fetch all tags when pulling.
	"git.pullTags": true,

	//* 💡 ru - 123
	//* 💡 en - Force git to use rebase when running the sync command.
	"git.rebaseWhenSync": false,

	//* 💡 ru - 123
	//* 💡 en - Remember the last git command that ran after a commit.
	"git.rememberPostCommitCommand": false,

	//* 💡 ru - 123
	//* 💡 en - List of folders that are ignored while scanning for Git repositories when `git.autoRepositoryDetection` is set to `true` or `subFolders`.
	"git.repositoryScanIgnoredFolders": ["node_modules"],

	//* 💡 ru - 123
	//* 💡 en - Controls the depth used when scanning workspace folders for Git repositories when `git.autoRepositoryDetection` is set to `true` or `subFolders`. Can be set to `-1` for no limit.
	"git.repositoryScanMaxDepth": 1,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to require explicit Git user configuration or allow Git to guess if missing.
	"git.requireGitUserConfig": true,

	//* 💡 ru - 123
	//* 💡 en - List of paths to search for git repositories in.
	"git.scanRepositories": [],

	//* 💡 ru - 123
	//* 💡 en - Controls whether an action button is shown in the Source Control view.
	"git.showActionButton": {
		"commit": true,
		"publish": true,
		"sync": true
	},

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show the commit input in the Git source control panel.
	"git.showCommitInput": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show an inline Open File action in the Git changes view.
	"git.showInlineOpenFileAction": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether git actions should show progress.
	"git.showProgress": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show a notification when a push is successful.
	"git.showPushSuccessNotification": false,

	//* 💡 ru - 123
	//* 💡 en - Control which changes are automatically staged by Smart Commit.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - all: Automatically stage all changes.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - tracked: Automatically stage tracked changes only.
	"git.smartCommitChanges": "all",

	//* 💡 ru - 123
	//* 💡 en - Controls how to limit the number of changes that can be parsed from Git status command. Can be set to 0 for no limit.
	"git.statusLimit": 10000,

	//* 💡 ru - 123
	//* 💡 en - Suggests to enable smart commit (commit all changes when there are no staged changes).
	"git.suggestSmartCommit": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether a notification comes up when running the Sync action, which allows the user to cancel the operation.
	"git.supportCancellation": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to enable VS Code to be the authentication handler for Git processes spawned in the Integrated Terminal. Note: Terminals need to be restarted to pick up a change in this setting.
	"git.terminalAuthentication": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to enable VS Code to be the Git editor for Git processes spawned in the integrated terminal. Note: Terminals need to be restarted to pick up a change in this setting.
	"git.terminalGitEditor": false,

	//* 💡 ru - 123
	//* 💡 en - Controls which date to use for items in the Timeline view.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - committed: Use the committed date
	//* 💡 ru - 123
	//* 💡 en - 123
	// - authored: Use the authored date
	"git.timeline.date": "committed",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show the commit author in the Timeline view.
	"git.timeline.showAuthor": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show uncommitted changes in the Timeline view.
	"git.timeline.showUncommitted": false,

	//* 💡 ru - 123
	//* 💡 en - Controls how untracked changes behave.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - mixed: All changes, tracked and untracked, appear together and behave equally.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - separate: Untracked changes appear separately in the Source Control view. They are also excluded from several actions.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - hidden: Untracked changes are hidden and excluded from several actions.
	"git.untrackedChanges": "mixed",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to use the message from the commit input box as the default stash message.
	"git.useCommitInputAsStashMessage": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether a full text editor will be used to author commit messages, whenever no message is provided in the commit input box.
	"git.useEditorAsCommitInput": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether force pushing uses the safer force-with-lease variant.
	"git.useForcePushWithLease": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether GIT_ASKPASS should be overwritten to use the integrated version.
	"git.useIntegratedAskPass": true,

	//* 💡 ru - 123
	//* 💡 en - Enable verbose output when `git.useEditorAsCommitInput` is enabled.
	"git.verboseCommit": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to enable automatic GitHub authentication for git commands within VS Code.
	"github.gitAuthentication": true,

	//* 💡 ru - 123
	//* 💡 en - Controls which protocol is used to clone a GitHub repository
	"github.gitProtocol": "https",

	//* 💡 ru - 123
	//* 💡 en - 123
	//GitHub Enterprise Server URI
	"github-enterprise.uri": "",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Grunt

	//* 💡 ru - 123
	//* 💡 en - Controls enablement of Grunt task detection. Grunt task detection can cause files in any open workspace to be executed.
	"grunt.autoDetect": "off",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Gulp

	//* 💡 ru - 123
	//* 💡 en - Controls enablement of Gulp task detection. Gulp task detection can cause files in any open workspace to be executed.
	"gulp.autoDetect": "off",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Jake

	//* 💡 ru - 123
	//* 💡 en - Controls enablement of Jake task detection. Jake task detection can cause files in any open workspace to be executed.
	"jake.autoDetect": "off",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Merge Conflict

	//* 💡 ru - 123
	//* 💡 en - Whether to automatically navigate to the next merge conflict after resolving a merge conflict.
	"merge-conflict.autoNavigateNextConflict.enabled": false,

	//* 💡 ru - 123
	//* 💡 en - Create a CodeLens for merge conflict blocks within editor.
	"merge-conflict.codeLens.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Create decorators for merge conflict blocks within editor.
	"merge-conflict.decorators.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls where the diff view should be opened when comparing changes in merge conflicts.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - Current: Open the diff view in the current editor group.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - Beside: Open the diff view next to the current editor group.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - Below: Open the diff view below the current editor group.
	"merge-conflict.diffViewPosition": "Current",

	//* 💡 ru - 123
	//* 💡 en - 123
	//JavaScript Debugger

	//* 💡 ru - 123
	//* 💡 en - Configures which processes to automatically attach and debug when `debug.node.autoAttach` is on. A Node process launched with the `--inspect` flag will always be attached to, regardless of this setting.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Auto attach to every Node.js process launched in the terminal.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - smart: Auto attach when running scripts that aren't in a node_modules folder.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onlyWithFlag: Only auto attach when the `--inspect` is given.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - disabled: Auto attach is disabled and not shown in status bar.
	"debug.javascript.autoAttachFilter": "disabled",

	//* 💡 ru - 123
	//* 💡 en - Configures glob patterns for determining when to attach in "smart" `debug.javascript.autoAttachFilter` mode. `$KNOWN_TOOLS$` is replaced with a list of names of common test and code runners.
	"debug.javascript.autoAttachSmartPattern": [
		"${workspaceFolder}/**",
		"!**/node_modules/**",
		"**/$KNOWN_TOOLS$/**"
	],

	//* 💡 ru - 123
	//* 💡 en - When debugging a remote web app, configures whether to automatically tunnel the remote server to your local machine.
	"debug.javascript.automaticallyTunnelRemoteServer": true,

	//* 💡 ru - 123
	//* 💡 en - Whether to stop when conditional breakpoints throw an error.
	"debug.javascript.breakOnConditionalError": false,

	//* 💡 ru - 123
	//* 💡 en - Where a "Run" and "Debug" code lens should be shown in your npm scripts. It may be on "all", scripts, on "top" of the script section, or "never".
	"debug.javascript.codelens.npmScripts": "top",

	//* 💡 ru - 123
	//* 💡 en - Options used when debugging open links clicked from inside the JavaScript Debug Terminal. Can be set to "off" to disable this behavior, or "always" to enable debugging in all terminals.
	"debug.javascript.debugByLinkOptions": "on",

	//* 💡 ru - 123
	//* 💡 en - The default `runtimeExecutable` used for launch configurations, if unspecified. This can be used to config custom paths to Node.js or browser installations.
	"debug.javascript.defaultRuntimeExecutable": {
		"pwa-node": "node"
	},

	//* 💡 ru - 123
	//* 💡 en - Default options used when debugging a process through the `Debug: Attach to Node.js Process` command.
	"debug.javascript.pickAndAttachOptions": {},

	//* 💡 ru - 123
	//* 💡 en - Request options to use when loading resources, such as source maps, in the debugger. You may need to configure this if your sourcemaps require authentication or use a self-signed certificate, for instance. Options are used to create a request using the `got` library.
	//* 💡 ru - 123
	//* 💡 en - A common case to disable certificate verification can be done by passing `{ "https": { "rejectUnauthorized": false } }`.
	"debug.javascript.resourceRequestOptions": {},

	//* 💡 ru - 123
	//* 💡 en - Default launch options for the JavaScript debug terminal and npm scripts.
	"debug.javascript.terminalOptions": {},

	//* 💡 ru - 123
	//* 💡 en - Configures whether sourcemapped file where the original file can't be read will automatically be unmapped. If this is false (default), a prompt is shown.
	"debug.javascript.unmapMissingSources": false,

	//* 💡 ru - 123
	//* 💡 en - 123
	//Npm

	//* 💡 ru - 123
	//* 💡 en - Controls whether npm scripts should be automatically detected.
	"npm.autoDetect": "on",

	//* 💡 ru - 123
	//* 💡 en - Enable running npm scripts contained in a folder from the Explorer context menu.
	"npm.enableRunFromFolder": false,

	//* 💡 ru - 123
	//* 💡 en - The NPM Script Explorer is now available in 'Views' menu in the Explorer in all folders.
	//* 💡 ru - 123
	//* 💡 en - Enable an explorer view for npm scripts when there is no top-level 'package.json' file.
	"npm.enableScriptExplorer": false,

	//* 💡 ru - 123
	//* 💡 en - Configure glob patterns for folders that should be excluded from automatic script detection.
	"npm.exclude": "",

	//* 💡 ru - 123
	//* 💡 en - Fetch data from hregistry.npmjs.org and hregistry.bower.io to provide auto-completion and information on hover features on npm dependencies.
	"npm.fetchOnlinePackageInfo": true,

	//* 💡 ru - 123
	//* 💡 en - The package manager used to run scripts.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Auto-detect which package manager to use for running scripts based on lock files and installed package managers.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - npm: Use npm as the package manager for running scripts.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - yarn: Use yarn as the package manager for running scripts.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - pnpm: Use pnpm as the package manager for running scripts.
	"npm.packageManager": "auto",

	//* 💡 ru - 123
	//* 💡 en - Run npm commands with the `--silent` option.
	"npm.runSilent": false,

	//* 💡 ru - 123
	//* 💡 en - The default click action used in the NPM Scripts Explorer: `open` or `run`, the default is `open`.
	"npm.scriptExplorerAction": "open",

	//* 💡 ru - 123
	//* 💡 en - An array of regular expressions that indicate which scripts should be excluded from the NPM Scripts view.
	"npm.scriptExplorerExclude": [],

	//* 💡 ru - 123
	//* 💡 en - Display hover with 'Run' and 'Debug' commands for scripts.
	"npm.scriptHover": true,

	//* 💡 ru - 123
	//* 💡 en - References Search View

	//* 💡 ru - 123
	//* 💡 en - Controls whether 'Peek References' or 'Find References' is invoked when selecting CodeLens references.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - peek: Show references in peek editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - view: Show references in separate view.
	"references.preferredLocation": "peek"
}
