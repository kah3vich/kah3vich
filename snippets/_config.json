{

	//| scss

	"✅Snippet: SCSS Flex Mixin": {
		"prefix": "scss-flex",
		"body": [
			"@include flexStyle(${1:flex-start}, ${2:flex-start}, ${3:row}, ${4:0px});",
			"$0"
		],
		"description": "✅Snippet: SCSS Flex Mixin",
	},

	"✅Snippet: SCSS Font Mixin": {
		"prefix": "scss-font",
		"body": [
			"@include fontStyle(${1:16px}, ${2:400}, ${3:20px}, ${4:#ffffff});",
			"$0"
		],
		"description": "✅Snippet: SCSS Font Mixin",
	},

	"✅Snippet: SCSS Img Mixin": {
		"prefix": "scss-img",
		"body": [
			"@include imgFullSize();",
			"$0"
		],
		"description": "✅Snippet: SCSS Img Mixin",
	},

	"✅Snippet: SCSS Grid Mixin": {
		"prefix": "scss-grid",
		"body": [
			"@include gridStyle(${1:auto}, ${2:auto}, ${3:0px});",
			"$0"
		],
		"description": "✅Snippet: SCSS Grid Mixin",
	},

	"✅Snippet: SCSS Transition Mixin": {
		"prefix": "scss-transition",
		"body": [
			"@include transitionStyle(${1:0.5s}, ${2:ease});",
			"$0"
		],
		"description": "✅Snippet: SCSS Transition Mixin",
	},

	//| typescript

	"✅Snippet: TypeScript Type": {
		"prefix": "type",
		"body": ["export type T${1:Name} = {", "    ${2:code}", "}", "$0"],
		"description": "✅Snippet: TypeScript Type",
	},

	"✅Snippet: TypeScript Interface ": {
		"prefix": "interface",
		"body": ["export interface I${1:Name} {", "    ${2:code}", "}", "$0"],
		"description": "✅Snippet: TypeScript Interface ",
	},

	"✅Snippet: TypeScript Enum": {
		"prefix": "enum",
		"body": ["export enum E${1:Name} {", "    ${2:code}", "}", "$0"],
		"description": "✅Snippet: TypeScript Enum",
	},

	//| jquery

	"✅Snippet: Jquery Add Class": {
		"prefix": "jq-add",
		"body": ["$('${1:name}').addClass('${2:class}');", "$0"],
		"description": "✅Snippet: Jquery Add Class",
	},

	"✅Snippet: Jquery Ready": {
		"prefix": "jq-ready",
		"body": ["$(document).ready(function () {", "\t${1:code}", "});", "$0"],
		"description": "✅Snippet: Jquery Ready",
	},

	"✅Snippet: Jquery On": {
		"prefix": "jq-on",
		"body": [
			"$('${1:name}').on('${2:params}', function (e) {",
			"\t${3:code}",
			"});",
			"$0"
		],
		"description": "✅Snippet: Jquery On",
	},

	"✅Snippet: Jquery Remove Class": {
		"prefix": "jq-remove",
		"body": ["$('${1:name}').removeClass('${2:class}');", "$0"],
		"description": "✅Snippet: Jquery Remove Class",
	},

	//| pug

	"✅Snippet: Pug Video": {
		"prefix": "pug-video",
		"body": [
			"video(poster=\"${1:image}\" autoplay=\"autoplay\" loop=\"loop\" controls=\"controls\" tabindex=\"0\")",
			"\tsource(src=\"${2:path}.webm\" type='video/webm; codecs=\"vp8, vorbis\"')",
			"\tsource(src=\"${2:path}.mp4\" type='video/mp4; codecs=\"avc1.42E01E, mp4a.40.2\"')",
			"\tsource(src=\"${2:path}.ogv\" type='video/ogg; codecs=\"theora, vorbis\"') ",
			"$0"
		],
		"description": "✅Snippet: Pug Video",
	},

	"✅Snippet: Pug Img": {
		"prefix": "pug-img",
		"body": ["img(src=\"${1:path}\" alt=\"${2:alt}\")", "$0"],
		"description": "✅Snippet: Pug Img",
	},

	"✅Snippet: Pug Optimization Image": {
		"prefix": "pug-opi",
		"body": [
			"picture",
			"\tsource(type=\"image/webp\" srcset=\"${1:path}.webp 1x, ${1:path}@2x.webp 2x\" media=\"(min-width: 1440px)\")",
			"\tsource(srcset=\"${1:path}.png 1x, ${1:path}@2x.png 2x\" media=\"(min-width: 1440px)\")",
			"\tsource(",
			"\t\ttype=\"image/webp\"",
			"\t\tsrcset=\"${1:path}-medium.webp 1x, ${1:path}-medium@2x.webp 2x\"",
			"\t\tmedia=\"(min-width: 1024px)\")",
			"\tsource(",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-medium.png\t1x,",
			"\t\t\t${1:path}-medium@2x.png 2x",
			"\t\t\"",
			"\t\tmedia=\"(min-width: 1024px)\")",
			"\tsource(",
			"\t\ttype=\"image/webp\"",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-small.webp\t1x,",
			"\t\t\t${1:path}-small@2x.webp 2x",
			"\t\t\"",
			"\t\tmedia=\"(min-width: 768px)\")",
			"\tsource(",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-small.png\t1x,",
			"\t\t\t${1:path}-small@2x.png 2x",
			"\t\t\"",
			"\t\tmedia=\"(min-width: 768px)\")",
			"\tsource(",
			"\t\ttype=\"image/webp\"",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-xsmall.webp\t1x,",
			"\t\t\t${1:path}-xsmall@2x.webp 2x",
			"\t\t\"",
			"\t\tmedia=\"(max-width: 767px)\")",
			"\tsource(",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-xsmall.png\t1x,",
			"\t\t\t${1:path}-xsmall@2x.png 2x",
			"\t\t\"",
			"\t\tmedia=\"(max-width: 767px)\")",
			"\timg(src=\"${1:path}.png\" srcset=\"${1:path}.png 1x, ${1:path}@2x.png 2x\" alt=\"image\")",
			"$0"
		],
		"description": "✅Snippet: Pug Optimization Image",
	},

	"✅Snippet: Pug Swiper": {
		"prefix": "pug-swiper",
		"body": [
			".swiper.${1:nameSlider}Swiper",
			"\t.swiper-wrapper",
			"\t\t.swiper-slide Slide",
			"\t.swiper-controls",
			"\t\t.swiper-button-next",
			"\t\t.swiper-button-prev",
			"\t\t.swiper-pagination",
			"$0"
		],
		"description": "✅Snippet: Pug Swiper",
	},

	"✅Snippet: Pug Loop": {
		"prefix": "pug-loop",
		"body": ["each _, i in Array(${1:count})", "$0"],
		"description": "✅Snippet: Pug Loop",
	},

	//| html

	"✅Snippet: HTML Video": {
		"prefix": "html-video",
		"body": [
			"<video poster=\"${1:image}\" autoplay=\"autoplay\" loop=\"loop\" controls=\"controls\" tabindex=\"0\">",
			"\t<source src=\"${2:path}.webm\" type='video/webm; codecs=\"vp8, vorbis\"' />",
			"\t<source src=\"${2:path}.mp4\" type='video/mp4; codecs=\"avc1.42E01E, mp4a.40.2\"' />",
			"\t<source src=\"${2:path}.ogv\" type='video/ogg; codecs=\"theora, vorbis\"' />",
			"</video>",
			"$0"
		],
		"description": "✅Snippet: HTML Video",
	},

	"✅Snippet: HTML Optimization Image": {
		"prefix": "html-opi",
		"body": [
			"<picture>",
			"\t<source",
			"\t\ttype=\"image/webp\"",
			"\t\tsrcset=\"${1:path}.webp 1x, ${1:path}@2x.webp 2x\"",
			"\t\tmedia=\"(min-width: 1440px)\" />",
			"\t<source srcset=\"${1:path}.png 1x, ${1:path}@2x.png 2x\" media=\"(min-width: 1440px)\" />",
			"\t<source",
			"\t\ttype=\"image/webp\"",
			"\t\tsrcset=\"${1:path}-medium.webp 1x, ${1:path}-medium@2x.webp 2x\"",
			"\t\tmedia=\"(min-width: 1024px)\" />",
			"\t<source",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-medium.png    1x,",
			"\t\t\t${1:path}-medium@2x.png 2x",
			"\t\t\"",
			"\t\tmedia=\"(min-width: 1024px)\" />",
			"\t<source",
			"\t\ttype=\"image/webp\"",
			"\tsrcset=\"",
			"\t\t\t${1:path}-small.webp    1x,",
			"\t\t\t${1:path}-small@2x.webp 2x",
			"\t\t\"",
			"\t\tmedia=\"(min-width: 768px)\" />",
			"\t<source",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-small.png    1x,",
			"\t\t\t${1:path}-small@2x.png 2x",
			"\t\t\"",
			"\t\tmedia=\"(min-width: 768px)\" />",
			"\t<source",
			"\t\ttype=\"image/webp\"",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-xsmall.webp    1x,",
			"\t\t\t${1:path}-xsmall@2x.webp 2x",
			"\t\t\"",
			"\t\tmedia=\"(max-width: 767px)\" />",
			"\t<source",
			"\t\tsrcset=\"",
			"\t\t\t${1:path}-xsmall.png    1x,",
			"\t\t\t${1:path}-xsmall@2x.png 2x",
			"\t\t\"",
			"\t\tmedia=\"(max-width: 767px)\" />",
			"\t<img",
			"\t\tsrc=\"${1:path}.png\"",
			"\t\tsrcset=\"${1:path}.png 1x, ${1:path}@2x.png 2x\"",
			"\t\talt=\"image\"",
			"\t/>",
			"</picture>",
			"$0"
		],
		"description": "✅Snippet: HTML Optimization Image",
	},

	"✅Snippet: HTML Swiper": {
		"prefix": "html-swiper",
		"body": [
			"<div class=\"swiper ${1:nameSlider}Swiper\">",
			"\t<div class=\"swiper-wrapper\">",
			"\t\t<div class=\"swiper-slide\">Slide</div>",
			"\t</div>",
			"\t<div class=\"swiper-controls\">",
			"\t\t<div class=\"swiper-button-next\"></div>",
			"\t\t<div class=\"swiper-button-prev\"></div>",
			"\t\t<div class=\"swiper-pagination\"></div>",
			"\t</div>",
			"</div>",
			"$0"
		],
		"description": "✅Snippet: HTML Swiper",
	},

	"✅Snippet: HTML Start": {
		"prefix": "html-start",
		"body": [
			"<!DOCTYPE html>",
            "<html lang=\"ru\">",
            "\t<head>",
            "\t\t<meta charset=\"utf-8\">",
            "\t\t<meta http-equiv=\"X-UA-Compatible\" content=\"IE=edge\">",
            "\t\t<title>HTML Title</title>",
            "\t\t<meta name=\"theme-color\" content=\"#ffffff\">",
            "\t\t<meta name=\"viewport\" content=\"width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0\">",
            "\t\t<link rel=\"stylesheet\" href=\"css/style.css\">",
            "\t</head>",
            "\t<body>",
            "\t\t",
            "\t\t<script src=\"js/main.js\"></script>",
            "\t</body>",
            "</html>",
			"$0"
		],
		"description": "✅Snippet: HTML Start",
	},

	"✅Snippet: HTML Img": {
		"prefix": "html-img",
		"body": ["<img src=\"${1:path}\" alt=\"${2:alt}\" />", "$0"],
		"description": "✅Snippet: HTML Img",
	},

	//| style

	"✅Snippet: Style Text Limit": {
		"prefix": "style-tl",
		"body": [
			"overflow: hidden;",
			"text-overflow: ellipsis;",
			"display: -webkit-box;",
			"-webkit-line-clamp: ${1:limit number};",
			"-webkit-box-orient: vertical;",
			"$0"
		],
		"description": "✅Snippet: Style Text Limit",
	},

	"✅Snippet: Style Flex Scheme": {
		"prefix": "style-flex",
		"body": [
			"display: flex;",
			"flex-direction: ${1:row};",
			"align-items: ${2:flex-start};",
			"justify-content: ${3:flex-start};",
			"gap: ${4:0px};",
			"flex-wrap: ${5:no-wrap};",
			"$0"
		],
		"description": "✅Snippet: Style Flex Scheme",
	},

	"✅Snippet: Style Before": {
		"prefix": "style-before",
		"body": [
			":before {",
			"\tcontent: '';",
			"\tposition: absolute;",
			"\ttop: ${1:top};",
			"\tleft: ${2:left};",
			"\t$0",
			"}",
			""
		],
		"description": "✅Snippet: Style Before",
	},

	"✅Snippet: Style Transparent Text": {
		"prefix": "style-tt",
		"body": [
			"-webkit-text-fill-color: transparent;",
			"-webkit-text-stroke: ${1:size}px ${2:color};",
			"$0"
		],
		"description": "✅Snippet: Style Transparent Text",
	},

	"✅Snippet: Style Text Wrap": {
		"prefix": "style-tw",
		"body": [
			"overflow-wrap: break-word;",
			"word-wrap: break-word;",
			"-webkit-hyphens: auto;",
			"-ms-hyphens: auto;",
			"-moz-hyphens: auto;",
			"hyphens: auto;",
			"$0"
		],
		"description": "✅Snippet: Style Text Wrap",
	},

	"✅Snippet: Style Transition": {
		"prefix": "style-trans",
		"body": ["transition: all ${1:time}s ${2:ease};", "$0"],
		"description": "✅Snippet: Style Transition",
	},

    "✅Snippet: Style After": {
        "prefix": "style-after",
        "body": [
            ":after {",
            "\tcontent: '';",
            "\tposition: absolute;",
            "\ttop: ${1:top};",
            "\tleft: ${2:left};",
            "\t$0",
            "}",
            ""
        ],
        "description": "✅Snippet: Style After",
    },

	"✅Snippet: Style Base": {
		"prefix": "style-base",
		"body": [
			"*,",
			"*::before,",
			"*::after {",
			"\tbox-sizing: border-box;",
			"\tpadding: 0;",
			"\tmargin: 0;",
			"\tuser-select: text;",
			"\toutline:none;",
			"}",
			"",
			"body {",
			"\twidth: 100%;",
			"\tfont-family: Roboto;",
			"\tfont-size: 16px;",
			"}",
			"",
			"a {",
			"\ttext-decoration: none;",
			"}",
			"",
			"ul {",
			"\tlist-style: none;",
			"}",
			"",
			"input, textarea {",
			"\toutline:none;",
			"\t-webkit-appearance: none;",
			"\t-webkit-border-radius: 0;",
			"}",
			"",
			"input:focus, textarea:focus {",
			"\toutline:none;",
			"}",
			"",
			"input {",
			"\tpadding: 0;",
			"\tmargin: 0;",
			"\tborder: none;",
			"\toutline: none;",
			"}",
			"",
			"textarea {",
			"\tresize: none;",
			"}",
			"",
			"button {",
			"\tpadding: 0;",
			"\tborder: none;",
			"\tcursor: pointer;",
			"\toutline: none;",
			"}",
			"",
			"ol,",
			"ul {",
			"\tpadding-left: 0;",
			"}",
			"",
			"dl,",
			"ol,",
			"ul {",
			"\tmargin-top: 0;",
			"\tmargin-bottom: 0;",
			"}",
			"",
			"p {",
			"\tmargin-top: 0;",
			"\tmargin-bottom: 0;",
			"}",
			"",
			".h1,",
			".h2,",
			".h3,",
			".h4,",
			".h5,",
			".h6,",
			"h1,",
			"h2,",
			"h3,",
			"h4,",
			"h5,",
			"h6 {",
			"\tmargin-top: 0;",
			"\tmargin-bottom: 0;",
			"}",
			"",
			".containers {",
			"\tmax-width: 1440px;",
			"\tpadding: 0 165px;",
			"\tmargin: 0 auto;",
			"\twidth: 100%;",
			"}",
			"",
			".display-n {",
			"\tdisplay: none !important;",
			"}",
			"",
			"opacity-h {",
			"\topacity: 0 !important;",
			"}",
			"",
			"$0"
		],
		"description": "✅Snippet: Style Base",
	},

	//| javascript

    "✅Snippet: console.log": {
        "prefix": "log",
        "body": ["console.log('${1:element}    ', ${1:element})", "$0"],
        "description": "✅Snippet: console.log",
    },

	"✅Snippet: Debugger": {
		"prefix": "debugger",
		"body": ["debugger; // TODO: debugger", "$0"],
		"description": "✅Snippet: Debugger - for the snippet to work correctly, you need to use the extension - 'Todo Tree'",
	},

	"✅Snippet: Try Catch": {
		"prefix": "try",
		"body": [
			"try {",
			"\t${1:code}",
			"} catch (e) {",
			"\tconsole.error('Error', e)",
			"}",
			"$0"
		],
		"description": "✅Snippet: Try Catch",
	},

	"✅Snippet: JavaScript Swiper": {
		"prefix": "js-swiper",
		"body": [
			"const ${1:nameSlider}Swiper = new Swiper(\".${1:nameSlider}Swiper\", {",
			"\tnavigation: {",
			"\t\tnextEl: \".${1:nameSlider}Swiper .swiper-controls .swiper-button-next\",",
			"\t\tprevEl: \".${1:nameSlider}Swiper .swiper-controls .swiper-button-prev\",",
			"\t},",
			"\tpagination: {",
			"\t\tel: \".${1:nameSlider}Swiper .swiper-controls .swiper-pagination\",",
			"\t},",
			"});",
			"$0"
		],
		"description": "✅Snippet: JavaScript Swiper",
	},

    "✅Snippet: setTimeout": {
        "prefix": "settime",
        "body": [
            "setTimeout(() => {",
            "\t${1:code}",
            "}, ${2:timeout});",
            "$0"
        ],
        "description": "✅Snippet: setTimeout",
    },

	//| react

    "✅Snippet: React Hook useCallback - memosations of function": {
        "prefix": "useCallback",
        "body": ["useCallback(() => ${1:code}, [${2:dependencies}])", "$0"],
        "description": "✅Snippet: React Hook useCallback - memosations of function",
    },

    "✅Snippet: React Hook useState": {
        "prefix": "useState",
        "body": ["const [${1:value}, set${2:Change}] = useState(null);", "$0"],
        "description": "✅Snippet: React Hook useState",
    },

	"✅Snippet: React Hook useId": {
		"prefix": "useId",
		"body": ["const id${1:Name} = useId()", "$0"],
		"description": "✅Snippet: React Hook useId",
	},

	"✅Snippet: Memo Functional Component": {
		"prefix": "mfc",
		"body": [
			"import React from 'react'",
			"",
			"const _${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}} = ({ data }) => {",
			"\treturn <>{data}</>",
			"}",
			"",
			"export const ${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}} = React.memo(_${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}})",
			"$0"
		],
		"description": "✅Snippet: Memo Functional Component",
	},

    "✅Snippet: React Hook useImperativeHandle": {
        "prefix": "useImperativeHandle",
        "body": [ 
            "useImperativeHandle(${1:ref}, () => ({",
            "\t${2:code}",
            "}));",
            "$0"
        ],
        "description": "✅Snippet: React Hook useImperativeHandle",
    },

    "✅Snippet: Memo TypeScript Functional Component": {
        "prefix": "mtfc",
        "body": [
            "import React from 'react'",
            "",
            "export type T${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}}Props = {",
            "\tdata: string;",
            "}",
            "",
            "const _${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}} = ({ data }: T${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}}Props) => {",
            "\treturn <>{data}</>",
            "}",
            "",
            "export const ${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}} = React.memo(_${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}})",
            "$0"
        ],
        "description": "✅Snippet: Memo TypeScript Functional Component",
    },

    "✅Snippet: React Hook useEffect": {
        "prefix": "useEffect",
        "body": [ 
            "useEffect(() => {",
            "\t${1:code}",
            "}, [${2:dependencies}]);",
            "$0"
        ],
        "description": "✅Snippet: React Hook useEffect",
    },

	"✅Snippet: React Hook useRef": {
		"prefix": "useRef",
		"body": ["const ref${1:Name} = useRef(null)", "$0"],
		"description": "✅Snippet: React Hook useRef",
	},

    "✅Snippet: useEffect -> console.log": {
        "prefix": "uselog",
        "body": [
            "useEffect(() => {",
            "\tconsole.log('${1:element}    ', ${1:element})",
            "}, [${1:element}])",
            "$0"
        ],
        "description": "✅Snippet: useEffect -> console.log",
    },

    "✅Snippet: TypeScript Functional Component": {
        "prefix": "tfc",
        "body": [
            "import React from 'react'",
            "",
            "export type T${1:${TM_DIRECTORY/^.+[\\/\\\\]+(.*)$/$1/}}Props = {",
            "\tchildren: React.ReactNode;",
            "}",
