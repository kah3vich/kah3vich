{
  // 🟢 Tasks

  // 🇷🇺 - Включите автоматические задачи.
  // 🇺🇸 - Enable automatic tasks.
  "task.allowAutomaticTasks": "on",

  // 🇷🇺 - Управляет включением `provideTasks` для всех расширений поставщика задач. Если команда «Задачи: выполнить задачу» работает медленно, может помочь отключение автоматического определения поставщиков задач. Отдельные расширения также могут предоставлять настройки, отключающие автоматическое обнаружение.
  // 🇺🇸 - Controls enablement of `provideTasks` for all task provider extension. If the Tasks: Run Task command is slow, disabling auto detect for task providers may help. Individual extensions may also provide settings that disable auto detection.
  "task.autoDetect": "on",

  // 🇷🇺 - Настраивает, показывать ли подсказку средства сопоставления проблем при выполнении задачи. Установите значение «true», чтобы никогда не запрашивать, или используйте словарь типов задач, чтобы отключить запросы только для определенных типов задач.
  // 🇺🇸 - Configures whether to show the problem matcher prompt when running a task. Set to `true` to never prompt, or use a dictionary of task types to turn off prompting only for specific task types.
  "task.problemMatchers.neverPrompt": false,

  // 🇷🇺 - Определяет, показывать ли сведения о задаче для задач, сведения о которых есть в быстром выборе задачи, например «Выполнить задачу».
  // 🇺🇸 - Controls whether to show the task detail for tasks that have a detail in task quick picks, such as Run Task.
  "task.quickOpen.detail": true,

  // 🇷🇺 - Управляет количеством последних элементов, отслеживаемых в диалоговом окне быстрого открытия задачи.
  // 🇺🇸 - Controls the number of recent items tracked in task quick open dialog.
  "task.quickOpen.history": 30,

  // 🇷🇺 - Приводит к тому, что команда «Задачи: выполнить задачу» использует более медленное поведение «показать все» вместо более быстрого двухуровневого средства выбора, в котором задачи группируются по поставщику.
  // 🇺🇸 - Causes the Tasks: Run Task command to use the slower "show all" behavior instead of the faster two level picker where tasks are grouped by provider.
  "task.quickOpen.showAll": false,

  // 🇷🇺 - Определяет, пропускается ли быстрый выбор задачи, когда есть только одна задача, из которой можно выбрать.
  // 🇺🇸 - Controls whether the task quick pick is skipped when there is only one task to pick from.
  "task.quickOpen.skip": false,

  // 🇷🇺 - При перезагрузке окна повторно подключитесь к задачам, в которых есть средства сопоставления проблем.
  // 🇺🇸 - On window reload, reconnect to tasks that have problem matchers.
  "task.reconnection": true,

  // 🇷🇺 - Сохраните все грязные редакторы перед запуском задачи.
  // 🇺🇸 - Save all dirty editors before running a task.
  "task.saveBeforeRun": "always",

  // 🇷🇺 - Показывает украшения в точках интереса в буфере терминала, такие как первая проблема, обнаруженная с помощью задачи наблюдения.
  // 🇺🇸 - Shows decorations at points of interest in the terminal buffer such as the first problem found via a watch task.
  "task.showDecorations": true,

  // 🇷🇺 - Настраивает, будет ли отображаться предупреждение, когда провайдер работает медленно.
  // 🇺🇸 - Configures whether a warning is shown when a provider is slow.
  "task.slowProviderWarning": true
}
