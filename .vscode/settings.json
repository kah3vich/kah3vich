	//* 💡 ru - 123
	//* 💡 en - Extensions

	//* 💡 ru - 123
	//* 💡 en - When enabled, automatically checks extensions for updates. If an extension has an update, it is marked as outdated in the Extensions view. The updates are fetched from a Microsoft online service.
	"extensions.autoCheckUpdates": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the automatic update behavior of extensions. The updates are fetched from a Microsoft online service.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - true: Download and install updates automatically for all extensions.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onlyEnabledExtensions: Download and install updates automatically only for enabled extensions. Disabled extensions will not be updated automatically.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - false: Extensions are not automatically updated.
	"extensions.autoUpdate": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled, editors with extension details will be automatically closed upon navigating away from the Extensions View.
	"extensions.closeExtensionDetailsOnViewChange": false,

	//* 💡 ru - 123
	//* 💡 en - When an extension is listed here, a confirmation prompt will not be shown when that extension handles a URI.
	"extensions.confirmedUriHandlerExtensionIds": [],

	//* 💡 ru - 123
	//* 💡 en - When enabled, the notifications for extension recommendations will not be shown.
	"extensions.ignoreRecommendations": false,

	//* 💡 ru - 123
	//* 💡 en - Override the untrusted workspace support of an extension. Extensions using `true` will always be enabled. Extensions using `limited` will always be enabled, and the extension will hide functionality that requires trust. Extensions using `false` will only be enabled only when the workspace is trusted.
	"extensions.supportUntrustedWorkspaces": {},

	//* 💡 ru - 123
	//* 💡 en - Override the virtual workspaces support of an extension.
	"extensions.supportVirtualWorkspaces": {},

	//* 💡 ru - 123
	//* 💡 en - Output

	//* 💡 ru - 123
	//* 💡 en - Enable/disable the ability of smart scrolling in the output view. Smart scrolling allows you to lock scrolling automatically when you click in the output view and unlocks when you click in the last line.
	"output.smartScroll.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Settings Sync

	//* 💡 ru - 123
	//* 💡 en - List of extensions to be ignored while synchronizing. The identifier of an extension is always `${publisher}.${name}`. For example: `vscode.csharp`.
	"settingsSync.ignoredExtensions": [],

	//* 💡 ru - 123
	//* 💡 en - Configure settings to be ignored while synchronizing.
	"settingsSync.ignoredSettings": [],

	//* 💡 ru - 123
	//* 💡 en - Synchronize keybindings for each platform.
