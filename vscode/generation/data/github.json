{
  // 🟢 GitHub

  // 🇷🇺 - Определяет, следует ли включать автоматическую аутентификацию GitHub для команд git в VS Code.
  // 🇺🇸 - Controls whether to enable automatic GitHub authentication for git commands within VS Code.
  "github.gitAuthentication": true,

  // 🇷🇺 - Определяет, какой протокол используется для клонирования репозитория GitHub.
  // 🇺🇸 - Controls which protocol is used to clone a GitHub repository.
  "github.gitProtocol": "https",

  // 🇷🇺 - URI корпоративного сервера GitHub.
  // 🇺🇸 - GitHub Enterprise Server URI.
  "github-enterprise.uri": ""
}
