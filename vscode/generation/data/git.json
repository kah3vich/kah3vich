{
  // 🟢 Git

  // 🇷🇺 - Подтвердите перед синхронизацией репозиториев git.
  // 🇺🇸 - Confirm before syncing git repositories.
  "git.confirmSync": false,

  // 🇷🇺 - Определяет, включена ли принудительная отправка (с арендой или без нее).
  // 🇺🇸 - Controls whether force push (with or without lease) is enabled.
  "git.allowForcePush": false,

  // 🇷🇺 - Определяет, разрешены ли коммиты без запуска перехватчиков pre-commit и commit-msg.
  // 🇺🇸 - Controls whether commits without running pre-commit and commit-msg hooks are allowed.
  "git.allowNoVerifyCommit": false,

  // 🇷🇺 - Всегда показывать группу ресурсов поэтапных изменений.
  // 🇺🇸 - Always show the Staged Changes resource group.
  "git.alwaysShowStagedChangesResourceGroup": false,

  // 🇷🇺 - Управляет флагом выхода для всех коммитов.
  // 🇺🇸 - Controls the signoff flag for all commits.
  "git.alwaysSignOff": false,

  // 🇷🇺 - Если установлено значение true, коммиты будут автоматически извлекаться из удаленного по умолчанию текущего репозитория Git. Установка на «все» будет получать данные со всех пультов.
  // 🇺🇸 - When set to true, commits will automatically be fetched from the default remote of the current Git repository. Setting to `all` will fetch from all remotes.
  "git.autofetch": false,

  // 🇷🇺 - Продолжительность в секундах между каждой автоматической выборкой git, когда `git.autofetch` включен.
  // 🇺🇸 - Duration in seconds between each automatic git fetch, when `git.autofetch` is enabled.
  "git.autofetchPeriod": 180,

  // 🇷🇺 - Включено ли автоматическое обновление.
  // 🇺🇸 - Whether auto refreshing is enabled.
  "git.autorefresh": true,

  // 🇷🇺 - Настраивает, когда репозитории должны автоматически обнаруживаться.
  // 🇺🇸 - Configures when repositories should be automatically detected.
  "git.autoRepositoryDetection": true,

  // 🇷🇺 - Спрячьте любые изменения перед извлечением и восстановите их после успешного извлечения.
  // 🇺🇸 - Stash any changes before pulling and restore them after successful pull.
  "git.autoStash": false,

  // 🇷🇺 - Префикс, используемый при создании новой ветки.
  // 🇺🇸 - Prefix used when creating a new branch.
  "git.branchPrefix": "",

  // 🇷🇺 - Список защищенных ветвей. По умолчанию перед фиксацией изменений в защищенной ветке отображается запрос. Подсказкой можно управлять с помощью параметра «Подсказка защиты git.branch».
  // 🇺🇸 - List of protected branches. By default, a prompt is shown before changes are committed to a protected branch. The prompt can be controlled using the `git.branchProtectionPrompt`  setting.
  "git.branchProtection": [],

  // 🇷🇺 - Управляет отображением подсказки перед фиксацией изменений в защищенной ветке.
  // 🇺🇸 - Controls whether a prompt is being shown before changes are committed to a protected branch.
  "git.branchProtectionPrompt": "alwaysPrompt",

  // 🇷🇺 - Список словарей, используемых для случайно сгенерированного названия ветки. Каждое значение представляет словарь, используемый для создания сегмента имени ветки. Поддерживаемые словари: «прилагательные», «животные», «цвета» и «числа».
  // 🇺🇸 - List of dictionaries used for the randomly generated branch name. Each value represents the dictionary used to generate the segment of the branch name. Supported dictionaries: `adjectives`, `animals`, `colors` and `numbers`.
  "git.branchRandomName.dictionary": ["adjectives", "animals"],

  // 🇷🇺 - Определяет, генерируется ли случайное имя при создании новой ветки.
  // 🇺🇸 - Controls whether a random name is generated when creating a new branch.
  "git.branchRandomName.enable": false,

  // 🇷🇺 - Управляет порядком сортировки ветвей.
  // 🇺🇸 - Controls the sort order for branches.
  "git.branchSortOrder": "committerdate",

  // 🇷🇺 - Регулярное выражение для проверки имен новых ветвей.
  // 🇺🇸 - A regular expression to validate new branch names.
  "git.branchValidationRegex": "",

  // 🇷🇺 - Символ для замены пробелов в новых именах веток и для разделения сегментов случайно сгенерированного имени ветки.
  // 🇺🇸 - The character to replace whitespace in new branch names, and to separate segments of a randomly generated branch name.
  "git.branchWhitespaceChar": "-",

  // 🇷🇺 - Определяет, какой тип git refs будет отображаться при запуске Checkout to....
  // 🇺🇸 - Controls what type of git refs are listed when running `Checkout to...`.
  "git.checkoutType": ["local", "remote", "tags"],

  // 🇷🇺 - Определяет, должен ли редактор различий автоматически закрываться при сохранении, фиксации, отбрасывании, промежуточном или неустановленном изменении.
  // 🇺🇸 - Controls whether the diff editor should be automatically closed when changes are stashed, committed, discarded, staged, or unstaged.
  "git.closeDiffOnOperation": false,

  // 🇷🇺 - Список команд git (например: commit, push), `stdout` которых будет записан в вывод git. Если для команды git настроен хук на стороне клиента, `stdout` этого хука на стороне клиента также будет записан в вывод git.
  // 🇺🇸 - List of git commands (ex: commit, push) that would have their `stdout` logged to the git output. If the git command has a client-side hook configured, the client-side hook's `stdout` will also be logged to the git output.
  "git.commandsToLog": [],

  // 🇷🇺 - Всегда подтверждайте создание пустых коммитов для команды «Git: Commit Empty».
  // 🇺🇸 - Always confirm the creation of empty commits for the 'Git: Commit Empty' command.
  "git.confirmEmptyCommits": true,

  // 🇷🇺 - Определяет, запрашивать ли подтверждение перед принудительной отправкой.
  // 🇺🇸 - Controls whether to ask for confirmation before force-pushing.
  "git.confirmForcePush": true,

  // 🇷🇺 - Определяет, запрашивать ли подтверждение перед фиксацией без проверки.
  // 🇺🇸 - Controls whether to ask for confirmation before committing without verification.
  "git.confirmNoVerifyCommit": true,

  // 🇷🇺 - Управляет значком счетчика Git.
  // 🇺🇸 - Controls the Git count badge.
  "git.countBadge": "all",

  // 🇷🇺 - Определяет, добавляет ли Git цвета и значки в проводник и представление открытых редакторов.
  // 🇺🇸 - Controls whether Git contributes colors and badges to the Explorer and the Open Editors view.
  "git.decorations.enabled": true,

  // 🇷🇺 - Расположение по умолчанию для клонирования репозитория git.
  // 🇺🇸 - The default location to clone a git repository.
  "git.defaultCloneDirectory": null,

  // 🇷🇺 - Определяет, следует ли автоматически обнаруживать подмодули git.
  // 🇺🇸 - Controls whether to automatically detect git submodules.
  "git.detectSubmodules": true,

  // 🇷🇺 - Управляет пределом обнаруженных подмодулей git.
  // 🇺🇸 - Controls the limit of git submodules detected.
  "git.detectSubmodulesLimit": 10,

  // 🇷🇺 - Включает подписание фиксации с помощью GPG или X.509.
  // 🇺🇸 - Enables commit signing with GPG or X.509.
  "git.enableCommitSigning": false,

  // 🇷🇺 - Включен ли git.
  // 🇺🇸 - Whether git is enabled.
  "git.enabled": true,

  // 🇷🇺 - Зафиксируйте все изменения, если нет поэтапных изменений.
  // 🇺🇸 - Commit all changes when there are no staged changes.
  "git.enableSmartCommit": false,

  // 🇷🇺 - Определяет, отображается ли команда Git Sync в строке состояния.
  // 🇺🇸 - Controls whether the Git Sync command appears in the status bar.
  "git.enableStatusBarSync": true,

  // 🇷🇺 - Если включено, извлекать все ветки при извлечении. В противном случае выберите только текущий.
  // 🇺🇸 - When enabled, fetch all branches when pulling. Otherwise, fetch just the current one.
  "git.fetchOnPull": false,

  // 🇷🇺 - Следуйте push all tags при выполнении команды синхронизации.
  // 🇺🇸 - Follow push all tags when running the sync command.
  "git.followTagsWhenSync": false,

  // 🇷🇺 - Список репозиториев git, которые следует игнорировать.
  // 🇺🇸 - List of git repositories to ignore.
  "git.ignoredRepositories": [],

  // 🇷🇺 - Игнорирует устаревшее предупреждение Git.
  // 🇺🇸 - Ignores the legacy Git warning.
  "git.ignoreLegacyWarning": false,

  // 🇷🇺 - Игнорирует предупреждение, когда в репозитории слишком много изменений.
  // 🇺🇸 - Ignores the warning when there are too many changes in a repository.
  "git.ignoreLimitWarning": false,

  // 🇷🇺 - Игнорирует предупреждение, когда Git отсутствует.
  // 🇺🇸 - Ignores the warning when Git is missing.
  "git.ignoreMissingGitWarning": false,

  // 🇷🇺 - Игнорирует предупреждение, когда кажется, что ветвь могла быть перебазирована при извлечении.
  // 🇺🇸 - Ignores the warning when it looks like the branch might have been rebased when pulling.
  "git.ignoreRebaseWarning": false,

  // 🇷🇺 - Игнорировать изменения подмодулей в дереве файлов.
  // 🇺🇸 - Ignore modifications to submodules in the file tree.
  "git.ignoreSubmodules": false,

  // 🇷🇺 - Игнорирует предупреждение, если Git 2.25–2.26 установлен в Windows.
  // 🇺🇸 - Ignores the warning when Git 2.25 - 2.26 is installed on Windows.
  "git.ignoreWindowsGit27Warning": false,

  // 🇷🇺 - Определяет, когда отображать подтверждение ввода сообщения фиксации.
  // 🇺🇸 - Controls when to show commit message input validation.
  "git.inputValidation": "warn",

  // 🇷🇺 - Управляет порогом длины сообщения фиксации для отображения предупреждения.
  // 🇺🇸 - Controls the commit message length threshold for showing a warning.
  "git.inputValidationLength": 72,

  // 🇷🇺 - Управляет порогом длины темы сообщения фиксации для отображения предупреждения. Снимите его, чтобы унаследовать значение `config.input Validation Length`.
  // 🇺🇸 - Controls the commit message subject length threshold for showing a warning. Unset it to inherit the value of `config.inputValidationLength`.
  "git.inputValidationSubjectLength": 50,

  // 🇷🇺 - Откройте редактор слияния для файлов, которые в данный момент конфликтуют.
  // 🇺🇸 - Open the merge editor for files that are currently under conflict.
  "git.mergeEditor": false,

  // 🇷🇺 - Определяет, открывать ли репозиторий автоматически после клонирования.
  // 🇺🇸 - Controls whether to open a repository automatically after cloning.
  "git.openAfterClone": "prompt",

  // 🇷🇺 - Определяет, должен ли открываться редактор различий при нажатии на изменение. В противном случае будет открыт обычный редактор.
  // 🇺🇸 - Controls whether the diff editor should be opened when clicking a change. Otherwise the regular editor will be opened.
  "git.openDiffOnClick": true,

  // 🇷🇺 - Определяет, следует ли оптимистично обновлять состояние представления системы управления версиями после выполнения команд git.
  // 🇺🇸 - Controls whether to optimistically update the state of the Source Control view after running git commands.
  "git.optimisticUpdate": true,

  // 🇷🇺 - Путь и имя исполняемого файла git, например. `C:\Program Files\Git\bin\git.exe` (Windows). Это также может быть массив строковых значений, содержащий несколько путей для поиска.
  // 🇺🇸 - Path and filename of the git executable, e.g. `C:\Program Files\Git\bin\git.exe` (Windows). This can also be an array of string values containing multiple paths to look up.
  "git.path": null,

  // 🇷🇺 - Запустите команду git после успешной фиксации.
  // 🇺🇸 - Run a git command after a successful commit.
  "git.postCommitCommand": "none",

  // 🇷🇺 - Определяет, должен ли Git проверять несохраненные файлы перед фиксацией.
  // 🇺🇸 - Controls whether Git should check for unsaved files before committing.
  "git.promptToSaveFilesBeforeCommit": "always",

  // 🇷🇺 - Определяет, должен ли Git проверять наличие несохраненных файлов перед сохранением изменений.
  // 🇺🇸 - Controls whether Git should check for unsaved files before stashing changes.
  "git.promptToSaveFilesBeforeStash": "always",

  // 🇷🇺 - Обрезать при извлечении.
  // 🇺🇸 - Prune when fetching.
  "git.pruneOnFetch": false,

  // 🇷🇺 - Определяет, будет ли ветвь, не имеющая исходящих коммитов, перемотаться вперед перед ее извлечением.
  // 🇺🇸 - Controls whether a branch that does not have outgoing commits is fast-forwarded before it is checked out.
  "git.pullBeforeCheckout": false,

  // 🇷🇺 - Получить все теги при вытягивании.
  // 🇺🇸 - Fetch all tags when pulling.
  "git.pullTags": true,

  // 🇷🇺 - Заставьте git использовать rebase при выполнении команды синхронизации.
  // 🇺🇸 - Force git to use rebase when running the sync command.
  "git.rebaseWhenSync": false,

  // 🇷🇺 - Вспомните последнюю команду git, которая выполнялась после коммита.
  // 🇺🇸 - Remember the last git command that ran after a commit.
  "git.rememberPostCommitCommand": false,

  // 🇷🇺 - Список папок, которые игнорируются при сканировании репозиториев Git в git.auto Repository Detection, имеет значение true или subFolders.
  // 🇺🇸 - List of folders that are ignored while scanning for Git repositories when `git.autoRepositoryDetection` is set to `true` or `subFolders`.
  "git.repositoryScanIgnoredFolders": ["node_modules"],

  // 🇷🇺 - Управляет глубиной, используемой при сканировании папок рабочей области для репозиториев Git, когда для параметра «Обнаружение репозитория git.auto» установлено значение «true» или «подпапки». Может быть установлено на `-1` без ограничений.
  // 🇺🇸 - Controls the depth used when scanning workspace folders for Git repositories when `git.autoRepositoryDetection` is set to `true` or `subFolders`. Can be set to `-1` for no limit.
  "git.repositoryScanMaxDepth": 1,

  // 🇷🇺 - Определяет, требуется ли явная пользовательская конфигурация Git или позволяет Git угадывать ее отсутствие.
  // 🇺🇸 - Controls whether to require explicit Git user configuration or allow Git to guess if missing.
  "git.requireGitUserConfig": true,

  // 🇷🇺 - Список путей для поиска git-репозиториев.
  // 🇺🇸 - List of paths to search for git repositories in.
  "git.scanRepositories": [],

  // 🇷🇺 - Определяет, отображается ли кнопка действия в представлении системы управления версиями.
  // 🇺🇸 - Controls whether an action button is shown in the Source Control view.
  "git.showActionButton": {
    "commit": true,
    "publish": true,
    "sync": true
  },

  // 🇷🇺 - Определяет, отображать ли ввод фиксации в панели управления исходным кодом Git.
  // 🇺🇸 - Controls whether to show the commit input in the Git source control panel.
  "git.showCommitInput": true,

  // 🇷🇺 - Определяет, отображать ли встроенное действие «Открыть файл» в представлении изменений Git.
  // 🇺🇸 - Controls whether to show an inline Open File action in the Git changes view.
  "git.showInlineOpenFileAction": true,

  // 🇷🇺 - Определяет, должны ли действия git отображать ход выполнения.
  // 🇺🇸 - Controls whether git actions should show progress.
  "git.showProgress": true,

  // 🇷🇺 - Определяет, отображать ли уведомление при успешной отправке.
  // 🇺🇸 - Controls whether to show a notification when a push is successful.
  "git.showPushSuccessNotification": false,

  // 🇷🇺 - Управляйте тем, какие изменения автоматически размещаются с помощью Smart Commit.
  // 🇺🇸 - Control which changes are automatically staged by Smart Commit.
  "git.smartCommitChanges": "all",

  // 🇷🇺 - Определяет, как ограничить количество изменений, которые можно проанализировать с помощью команды Git status. Можно установить на 0 без ограничений.
  // 🇺🇸 - Controls how to limit the number of changes that can be parsed from Git status command. Can be set to 0 for no limit.
  "git.statusLimit": 10000,

  // 🇷🇺 - Предлагает включить умную фиксацию (фиксировать все изменения, когда нет поэтапных изменений).
  // 🇺🇸 - Suggests to enable smart commit (commit all changes when there are no staged changes).
  "git.suggestSmartCommit": true,

  // 🇷🇺 - Определяет, появляется ли уведомление при выполнении действия синхронизации, которое позволяет пользователю отменить операцию.
  // 🇺🇸 - Controls whether a notification comes up when running the Sync action, which allows the user to cancel the operation.
  "git.supportCancellation": false,

  // 🇷🇺 - Определяет, следует ли включить VS Code в качестве обработчика аутентификации для процессов Git, созданных во встроенном терминале. Примечание. Терминалы необходимо перезапустить, чтобы изменения в этом параметре вступили в силу.
  // 🇺🇸 - Controls whether to enable VS Code to be the authentication handler for Git processes spawned in the Integrated Terminal. Note: Terminals need to be restarted to pick up a change in this setting.
  "git.terminalAuthentication": true,

  // 🇷🇺 - Определяет, следует ли включить VS Code в качестве редактора Git для процессов Git, созданных во встроенном терминале. Примечание. Терминалы необходимо перезапустить, чтобы изменения в этом параметре вступили в силу.
  // 🇺🇸 - Controls whether to enable VS Code to be the Git editor for Git processes spawned in the integrated terminal. Note: Terminals need to be restarted to pick up a change in this setting.
  "git.terminalGitEditor": false,

  // 🇷🇺 - Определяет, какую дату использовать для элементов на временной шкале.
  // 🇺🇸 - Controls which date to use for items in the Timeline view.
  "git.timeline.date": "committed",

  // 🇷🇺 - Определяет, показывать ли автора коммита в представлении временной шкалы.
  // 🇺🇸 - Controls whether to show the commit author in the Timeline view.
  "git.timeline.showAuthor": true,

  // 🇷🇺 - Определяет, отображать ли незафиксированные изменения в представлении временной шкалы.
  // 🇺🇸 - Controls whether to show uncommitted changes in the Timeline view.
  "git.timeline.showUncommitted": false,

  // 🇷🇺 - Управляет поведением неотслеживаемых изменений.
  // 🇺🇸 - Controls how untracked changes behave.
  "git.untrackedChanges": "mixed",

  // 🇷🇺 - Определяет, следует ли использовать сообщение из поля ввода фиксации в качестве сообщения тайника по умолчанию.
  // 🇺🇸 - Controls whether to use the message from the commit input box as the default stash message.
  "git.useCommitInputAsStashMessage": false,

  // 🇷🇺 - Определяет, будет ли использоваться полнотекстовый редактор для создания сообщений фиксации, когда в поле ввода фиксации не указано сообщение.
  // 🇺🇸 - Controls whether a full text editor will be used to author commit messages, whenever no message is provided in the commit input box.
  "git.useEditorAsCommitInput": true,

  // 🇷🇺 - Определяет, использует ли принудительное нажатие более безопасный вариант принудительного использования с арендой.
  // 🇺🇸 - Controls whether force pushing uses the safer force-with-lease variant.
  "git.useForcePushWithLease": true,

  // 🇷🇺 - Определяет, следует ли перезаписывать GIT_ASKPASS для использования интегрированной версии.
  // 🇺🇸 - Controls whether GIT_ASKPASS should be overwritten to use the integrated version.
  "git.useIntegratedAskPass": true,

  // 🇷🇺 - Включить подробный вывод, когда включен `git.useEditorAsCommitInput`.
  // 🇺🇸 - Enable verbose output when `git.useEditorAsCommitInput` is enabled.
  "git.verboseCommit": false
}
