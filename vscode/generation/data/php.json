{
  // 🟢 PHP

  // 🇷🇺 - Определяет, включены ли встроенные языковые предложения PHP. Поддержка предлагает глобальные и переменные PHP.
  // 🇺🇸 - Controls whether the built-in PHP language suggestions are enabled. The support suggests PHP globals and variables.
  "php.suggest.basic": true,

  // 🇷🇺 - Включить/отключить встроенную проверку PHP.
  // 🇺🇸 - Enable/disable built-in PHP validation.
  "php.validate.enable": true,

  // 🇷🇺 - Указывает на исполняемый файл PHP.
  // 🇺🇸 - Points to the PHP executable.
  "php.validate.executablePath": null,

  // 🇷🇺 - Запускается ли линтер при сохранении или при типе.
  // 🇺🇸 - Whether the linter is run on save or on type.
  "php.validate.run": "onSave"
}
