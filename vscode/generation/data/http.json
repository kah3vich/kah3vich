{
  // 🟢 HTTP

  // 🇷🇺 - Используемый параметр прокси. Если не задано, будет унаследовано от переменных среды `http_proxy` и `https_proxy`.
  // 🇺🇸 - The proxy setting to use. If not set, will be inherited from the `http_proxy` and `https_proxy` environment variables.
  "http.proxy": "",

  // 🇷🇺 - Значение для отправки в качестве заголовка Proxy-Authorization для каждого сетевого запроса.
  // 🇺🇸 - The value to send as the `Proxy-Authorization` header for every network request.
  "http.proxyAuthorization": null,

  // 🇷🇺 - Определяет, должен ли сертификат прокси-сервера проверяться по списку предоставленных ЦС.
  // 🇺🇸 - Controls whether the proxy server certificate should be verified against the list of supplied CAs.
  "http.proxyStrictSSL": true,

  // 🇷🇺 - Используйте поддержку прокси для расширений.
  // 🇺🇸 - Use the proxy support for extensions.
  "http.proxySupport": "override",

  // 🇷🇺 - Определяет, следует ли загружать сертификаты ЦС из ОС. (В Windows и macOS после отключения этой функции требуется перезагрузка окна.)
  // 🇺🇸 - Controls whether CA certificates should be loaded from the OS. (On Windows and macOS, a reload of the window is required after turning this off.)
  "http.systemCertificates": true
}
