{
	//| 🔥 Config Kah3vich - https://github.com/kah3vich 

	//? 🧨 Info - https://code.visualstudio.com/docs/editor/codebasics 
	//? 🤔 Config - https://code.visualstudio.com/docs/getstarted/settings 

	//! ✅ Audio Cues

	//* 💡 ru - Воспроизводит звук, когда фокус перемещается на удаленную строку в режиме просмотра различий.
	//* 💡 en - Plays a sound when the focus moves to a deleted line in diff review mode.
	"audioCues.diffLineDeleted": "auto",

	//* 💡 ru - Воспроизводит звук, когда фокус перемещается на вставленную строку в режиме просмотра различий.
	//* 💡 en - Plays a sound when the focus moves to an inserted line in diff review mode.
	"audioCues.diffLineInserted": "auto",

	//* 💡 ru - Воспроизводит звук, когда в активной строке есть точка останова.
	//* 💡 en - Plays a sound when the active line has a breakpoint.
	"audioCues.lineHasBreakpoint": "auto",

	//* 💡 ru - Воспроизводит звук, когда активная линия имеет ошибку.
	//* 💡 en - Plays a sound when the active line has an error.
	"audioCues.lineHasError": "auto",

	//* 💡 ru - Воспроизводит звук, когда активная линия имеет свернутую область, которую можно развернуть.
	//* 💡 en - Plays a sound when the active line has a folded area that can be unfolded.
	"audioCues.lineHasFoldedArea": "auto",

	//* 💡 ru - Воспроизводит звук, когда в активной строке есть встроенное предложение.
	//* 💡 en - Plays a sound when the active line has an inline suggestion.
	"audioCues.lineHasInlineSuggestion": "auto",

	//* 💡 ru - Воспроизводит звук, когда на активной линии есть предупреждение.
	//* 💡 en - Plays a sound when the active line has a warning.
	"audioCues.lineHasWarning": "off",

	//* 💡 ru - Воспроизводит звук при попытке прочитать строку с подсказками вкладки, которая не имеет подсказок вкладки.
	//* 💡 en - Plays a sound when trying to read a line with inlay hints that has no inlay hints.
	"audioCues.noInlayHints": "auto",

	//* 💡 ru - Воспроизводит звук, когда выполнение ячейки блокнота успешно завершено.
	//* 💡 en - Plays a sound when a notebook cell execution is successfully completed.
	"audioCues.notebookCellCompleted": "auto",

	//* 💡 ru - Воспроизводит звук при сбое выполнения ячейки записной книжки.
	//* 💡 en - Plays a sound when a notebook cell execution fails.
	"audioCues.notebookCellFailed": "auto",

	//* 💡 ru - Воспроизводит звук, когда отладчик остановился на точке останова.
	//* 💡 en - Plays a sound when the debugger stopped on a breakpoint.
	"audioCues.onDebugBreak": "auto",

	//* 💡 ru - Воспроизводит звук, когда задача выполнена.
	//* 💡 en - Plays a sound when a task is completed.
	"audioCues.taskCompleted": "auto",

	//* 💡 ru - Воспроизводит звук при сбое задачи (ненулевой код выхода).
	//* 💡 en - Plays a sound when a task fails (non-zero exit code).
	"audioCues.taskFailed": "auto",

	//* 💡 ru - Воспроизводит звук, когда доступны быстрые исправления терминала.
	//* 💡 en - Plays a sound when terminal Quick Fixes are available.
	"audioCues.terminalQuickFix": "auto",

	//* 💡 ru - Громкость звуковых сигналов в процентах (0-100).
	//* 💡 en - The volume of the audio cues in percent (0-100).,
	"audioCues.volume": 0,

	//! ✅ Better

	//* 💡 ru - Таги для комментариев.
	//* 💡 en - Tags for comments.
	"better-comments.tags": [
		{
			//* 💡 ru - Тег для вкл расширения.
			//* 💡 en - Tag to enable the extension.
			"tag": "!",

			//* 💡 ru - Цвет строки.
			//* 💡 en - Line color.
			"color": "#FF2D00",

			//* 💡 ru - Зачеркнутый текст.
			//* 💡 en - Strikethrough text.
			"strikethrough": false,

			//* 💡 ru - Нижние подчеркивание.
			//* 💡 en - Underscores.
			"underline": false,

			//* 💡 ru - Задний цвет.
			//* 💡 en - Back color.
			"backgroundColor": "transparent",

			//* 💡 ru - Жирное начертание.
			//* 💡 en - Bold font.
			"bold": false,

			//* 💡 ru - Стиль шрифта.
			//* 💡 en - Font style.
			"italic": false
		},
		{
			"tag": "|",
			"color": "#0FFD00",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "?",
			"color": "#3498DB",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "//",
			"color": "#474747",
			"strikethrough": true,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "todo",
			"color": "#FF8C00",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "*",
			"color": "#98C379",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		}
	],

	//* 💡 ru - Этот параметр определяет, оформляются ли комментарии в текстовом файле с использованием тегов аннотаций. При значении true теги (по умолчанию: ! * ? //) будут обнаружены, если они являются первым символом в строке.
	//* 💡 en - This setting determines whether comments in a text file are formatted using annotation tags. If set to true, tags (default: ! * ? //) will be detected if they are the first character in the string.,
	"better-comments.highlightPlainText": true,

	//! ✅ Breadcrumbs

	//* 💡 ru - Рендеринг элементов навигации с помощью значков.
	//* 💡 en - Rendering navigation elements using icons.
	"breadcrumbs.icons": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы `ключей`.
	//* 💡 en - When breadcrumbs are enabled, `key` symbols are displayed.
	"breadcrumbs.showKeys": false,

	//* 💡 ru - Когда хлебные крошки включены, они показывают символы `file`.
	//* 💡 en - When enabled, breadcrumbs show the `file` characters.
	"breadcrumbs.showFiles": false,

	//* 💡 ru - Управляет тем, отображаются ли символы в представлении навигационных крошек и каким образом.
	//* 💡 en - Controls whether and how symbols are displayed in the navigation crumbs view.
	"breadcrumbs.symbolPath": "off",

	//* 💡 ru - Когда хлебные крошки включены, они показывают символы массива.
	//* 💡 en - When breadcrumbs are enabled, they show array characters.
	"breadcrumbs.showArrays": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы «события».
	//* 💡 en - When breadcrumbs are turned on, "event" symbols are displayed.
	"breadcrumbs.showEvents": false,

	//* 💡 ru - При включении хлебные крошки показывают символы `поля`.
	//* 💡 en - When enabled, breadcrumbs show `field` symbols.
	"breadcrumbs.showFields": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы класса.
	//* 💡 en - When breadcrumbs are enabled, class symbols are displayed.
	"breadcrumbs.showClasses": false,

	//* 💡 ru - Когда хлебные крошки включены, они показывают `метод` - символы.
	//* 💡 en - When breadcrumbs are enabled, they show the `method` symbols.
	"breadcrumbs.showMethods": false,

	//* 💡 ru - Когда хлебные крошки включены, они показывают логические символы.
	//* 💡 en - When breadcrumbs are on, they show boolean symbols.
	"breadcrumbs.showBooleans": false,

	//* 💡 ru - Когда хлебные крошки включены, они показывают `функциональные` - символы.
	//* 💡 en - When breadcrumbs are enabled, they show `functional` symbols.
	"breadcrumbs.showFunctions": false,

	//* 💡 ru - При включении хлебных крошек отображаются `постоянные` - символы.
	//* 💡 en - When breadcrumbs are enabled, `permanent` characters are displayed.
	"breadcrumbs.showConstants": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы `enumMember`.
	//* 💡 en - When breadcrumbs are enabled, `enumMember` characters are displayed.
	"breadcrumbs.showEnumMembers": false,

	//* 💡 ru - При включении хлебных крошек отображаются символы-конструкторы.
	//* 💡 en - When breadcrumbs are enabled, constructor symbols are displayed.
	"breadcrumbs.showConstructors": false,

	//* 💡 ru - Включить/отключить навигационные крошки.
	//* 💡 en - Enable/disable navigation breadcrumbs.
	"breadcrumbs.enabled": true,

	//* 💡 ru - Определяет, будут ли и каким образом пути к файлам отображаться в представлении «хлебных крошек».
	//* 💡 en - Controls whether and how file paths are shown in the breadcrumbs view.
	"breadcrumbs.filePath": "on",

	//* 💡 ru - Когда хлебные крошки включены, они показывают `enum`-символы.
	//* 💡 en - When enabled breadcrumbs show `enum`-symbols.
	"breadcrumbs.showEnums": true,

	//* 💡 ru - При включении хлебных крошек отображаются символы `module`.
	//* 💡 en - When enabled breadcrumbs show `interface`-symbols.
	"breadcrumbs.showInterfaces": true,

	//* 💡 ru - При включении хлебных крошек отображаются символы `module`.
	//* 💡 en - When enabled breadcrumbs show `module`-symbols.
	"breadcrumbs.showModules": true,

	//* 💡 ru - Когда хлебные крошки включены, они показывают символы пространства имен.
	//* 💡 en - When enabled breadcrumbs show `namespace`-symbols.
	"breadcrumbs.showNamespaces": true,

	//* 💡 ru - При включении хлебных крошек отображаются нулевые символы.
	//* 💡 en - When enabled breadcrumbs show `null`-symbols.
	"breadcrumbs.showNull": true,

	//* 💡 ru - Когда хлебные крошки включены, они показывают числовые символы.
	//* 💡 en - When enabled breadcrumbs show `number`-symbols.
	"breadcrumbs.showNumbers": true,

	//* 💡 ru - Когда хлебные крошки включены, они показывают `объектные` символы.
	//* 💡 en - When enabled breadcrumbs show `object`-symbols.
	"breadcrumbs.showObjects": true,

	//* 💡 ru - При включении хлебные крошки показывают символы оператора.
	//* 💡 en - When enabled breadcrumbs show `operator`-symbols.
	"breadcrumbs.showOperators": true,

	//* 💡 ru - При включении хлебных крошек отображаются символы `package`.
	//* 💡 en - When enabled breadcrumbs show `package`-symbols.
	"breadcrumbs.showPackages": true,

	//* 💡 ru - Когда хлебные крошки включены, они показывают `property`-символы.
	//* 💡 en - When enabled breadcrumbs show `property`-symbols.
	"breadcrumbs.showProperties": true,

	//* 💡 ru - При включении хлебные крошки показывают `строковые` символы.
	//* 💡 en - When enabled breadcrumbs show `string`-symbols.
	"breadcrumbs.showStrings": true,

	//* 💡 ru - Когда хлебные крошки включены, они показывают `struct`-символы.
	//* 💡 en - When enabled breadcrumbs show `struct`-symbols.
	"breadcrumbs.showStructs": true,

	//* 💡 ru - При включении хлебные крошки показывают символы `typeParameter`.
	//* 💡 en - When enabled breadcrumbs show `typeParameter`-symbols.
	"breadcrumbs.showTypeParameters": true,

	//* 💡 ru - При включении хлебных крошек отображаются `переменные`-символы.
	//* 💡 en - When enabled breadcrumbs show `variable`-symbols.
	"breadcrumbs.showVariables": true,

	//* 💡 ru - Управляет сортировкой символов в представлении схемы навигационных крошек.
	//* 💡 en - Controls how symbols are sorted in the breadcrumbs outline view.,
	"breadcrumbs.symbolSortOrder": "position",

	//! ✅ Default Configuration Overrides

	//* 💡 ru - Настройте параметры для переопределения языка csharp.
	//* 💡 en - Configure settings to be overridden for the csharp language.
	"[csharp]": {
		"editor.maxTokenizationLineLength": 2500
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка css.
	//* 💡 en - Configure settings to be overridden for the css language.
	"[css]": {
		"editor.suggest.insertMode": "replace"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка компоновки докеров.
	//* 💡 en - Configure settings to be overridden for the dockercompose language.
	"[dockercompose]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка dockerfile.
	//* 💡 en - Configure settings to be overridden for the dockerfile language.
	"[dockerfile]": {
		"editor.quickSuggestions": {
			"strings": true
		}
	},

	//* 💡 ru - Настройте параметры для переопределения языка git-commit.
	//* 💡 en - Configure settings to be overridden for the git-commit language.
	"[git-commit]": {
		"editor.rulers": [72],
		"workbench.editor.restoreViewState": false
	},

	//* 💡 ru - Настройте параметры для переопределения языка git-rebase.
	//* 💡 en - Configure settings to be overridden for the git-rebase language.
	"[git-rebase]": {
		"workbench.editor.restoreViewState": false
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка go.
	//* 💡 en - Configure settings to be overridden for the go language.
	"[go]": {
		"editor.insertSpaces": false
	},

	//* 💡 ru - Настройте параметры для переопределения языка руля.
	//* 💡 en - Configure settings to be overridden for the handlebars language.
	"[handlebars]": {
		"editor.suggest.insertMode": "replace"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка html.
	//* 💡 en - Configure settings to be overridden for the html language.
	"[html]": {
		"editor.suggest.insertMode": "replace"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка javascript.
	//* 💡 en - Configure settings to be overridden for the javascript language.
	"[javascript]": {
		"editor.maxTokenizationLineLength": 2500
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка json.
	//* 💡 en - Configure settings to be overridden for the json language.
	"[json]": {
		"editor.quickSuggestions": {
			"strings": true
		},
		"editor.suggest.insertMode": "replace"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка jsonc.
	//* 💡 en - Configure settings to be overridden for the jsonc language.
	"[jsonc]": {
		"editor.quickSuggestions": {
			"strings": true
		},
		"editor.suggest.insertMode": "replace"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для меньшего языка.
	//* 💡 en - Configure settings to be overridden for the less language.
	"[less]": {
		"editor.suggest.insertMode": "replace"
	},

	//* 💡 ru - Настройте параметры для переопределения языка make-файла.
	//* 💡 en - Configure settings to be overridden for the makefile language.
	"[makefile]": {
		"editor.insertSpaces": false
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка уценки.
	//* 💡 en - Configure settings to be overridden for the markdown language.
	"[markdown]": {
		"editor.unicodeHighlight.ambiguousCharacters": false,
		"editor.unicodeHighlight.invisibleCharacters": false,
		"editor.wordWrap": "on",
		"editor.quickSuggestions": {
			"comments": "off",
			"strings": "off",
			"other": "off"
		}
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка открытого текста.
	//* 💡 en - Configure settings to be overridden for the plaintext language.
	"[plaintext]": {
		"editor.unicodeHighlight.ambiguousCharacters": false,
		"editor.unicodeHighlight.invisibleCharacters": false
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка scss.
	//* 💡 en - Configure settings to be overridden for the scss language.
	"[scss]": {
		"editor.suggest.insertMode": "replace"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка результатов поиска.
	//* 💡 en - Configure settings to be overridden for the search-result language.
	"[search-result]": {
		"editor.lineNumbers": "off"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка сценария оболочки.
	//* 💡 en - Configure settings to be overridden for the shellscript language.
	"[shellscript]": {
		"files.eol": "\n"
	},

	//* 💡 ru - Настройте параметры, которые будут переопределены для языка yaml.
	//* 💡 en - Configure settings to be overridden for the yaml language.
	"[yaml]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced",
	},

	//! ✅ Сhecker Spell

	//* 💡 ru - Виды языков.
	//* 💡 en - Types of languages.
	"cSpell.language": "en,ru",

	//* 💡 ru - Список слов исключения.
	//* 💡 en - Exception word list.
	"cSpell.userWords": [],

	//* 💡 ru - Включить в определенных языка.
	//* 💡 en - Enable in certain languages.
	"cSpell.enabled": true,

	//* 💡 ru - Список расширений файлов, в которых будет работать cSpell.
	//* 💡 en - List of file extensions in which cSpell.,
	"cSpell.enableFiletypes": ["jsx", "js", "css", "scss", "pug", "html", "php"],

	//! ✅ CSS

	//* 💡 ru - Вставьте точку с запятой в конце строки при заполнении свойств CSS.
	//* 💡 en - Insert semicolon at end of line when completing CSS properties.
	"css.completion.completePropertyWithSemicolon": true,

	//* 💡 ru - По умолчанию VS Code инициирует завершение значения свойства после выбора свойства CSS. Используйте этот параметр, чтобы отключить это поведение.
	//* 💡 en - By default, VS Code triggers property value completion after selecting a CSS property. Use this setting to disable this behavior.
	"css.completion.triggerPropertyValueCompletion": true,

	//* 💡 ru - Список относительных путей к файлам, указывающих на файлы JSON в пользовательском формате данных.
	//* 💡 en - A list of relative file paths pointing to JSON files following the custom data format.
	"css.customData": [],

	//* 💡 ru - Ставьте фигурные скобки на той же строке, что и правила (`collapse`), или ставьте фигурные скобки на отдельной строке (`expand`).
	//* 💡 en - Put braces on the same line as rules (`collapse`) or put braces on own line (`expand`).
	"css.format.braceStyle": "collapse",

	//* 💡 ru - Включить/отключить средство форматирования CSS по умолчанию.
	//* 💡 en - Enable/disable default CSS formatter.
	"css.format.enable": true,

	//* 💡 ru - Максимальное количество разрывов строк, которое должно быть сохранено в одном фрагменте, когда включено `css.format.preserve NewLines`.
	//* 💡 en - Maximum number of line breaks to be preserved in one chunk, when `css.format.preserveNewLines` is enabled.
	"css.format.maxPreserveNewLines": null,

	//* 💡 ru - Разделяйте наборы правил пустой строкой.
	//* 💡 en - Separate rulesets by a blank line.
	"css.format.newlineBetweenRules": true,

	//* 💡 ru - Разделяйте селекторы новой строкой.
	//* 💡 en - Separate selectors with a new line.
	"css.format.newlineBetweenSelectors": true,

	//* 💡 ru - Следует ли сохранять существующие разрывы строк перед элементами.
	//* 💡 en - Whether existing line breaks before elements should be preserved.
	"css.format.preserveNewLines": true,

	//* 💡 ru - Обеспечьте наличие пробела вокруг разделителей селекторов '>', '+', '~' (например, `a > b`).
	//* 💡 en - Ensure a space character around selector separators '>', '+', '~' (e.g. `a > b`).
	"css.format.spaceAroundSelectorSeparator": false,

	//* 💡 ru - Показать документацию по тегам и атрибутам при наведении курсора CSS.
	//* 💡 en - Show tag and attribute documentation in CSS hovers.
	"css.hover.documentation": true,

	//* 💡 ru - Показывать ссылки на MDN при наведении CSS.
	//* 💡 en - Show references to MDN in CSS hovers.
	"css.hover.references": true,

	//* 💡 ru - Недопустимое количество параметров.
	//* 💡 en - Invalid number of parameters.
	"css.lint.argumentsInColorFunction": "error",

	//* 💡 ru - Не используйте `width` или `height` при использовании `padding` или `border`.
	//* 💡 en - Do not use `width` or `height` when using `padding` or `border`.
	"css.lint.boxModel": "ignore",

	//* 💡 ru - При использовании префикса, специфичного для поставщика, не забудьте также включить все другие свойства, зависящие от поставщика.
	//* 💡 en - When using a vendor-specific prefix make sure to also include all other vendor-specific properties.
	"css.lint.compatibleVendorPrefixes": "ignore",

	//* 💡 ru - Не используйте повторяющиеся определения стилей.
	//* 💡 en - Do not use duplicate style definitions.
	"css.lint.duplicateProperties": "ignore",

	//* 💡 ru - Не используйте пустые наборы правил.
	//* 💡 en - Do not use empty rulesets.
	"css.lint.emptyRules": "warning",

	//* 💡 ru - Избегайте использования `float`. Поплавки приводят к хрупкому CSS, который легко сломать, если изменится один аспект макета.
	//* 💡 en - Avoid using `float`. Floats lead to fragile CSS that is easy to break if one aspect of the layout changes.
	"css.lint.float": "ignore",

	//* 💡 ru - Правило `@font-face` должно определять свойства `src` и `font-family`.
	//* 💡 en - `@font-face` rule must define `src` and `font-family` properties.
	"css.lint.fontFaceProperties": "warning",

	//* 💡 ru - Шестнадцатеричные цвета должны состоять из трех или шести шестнадцатеричных чисел.
	//* 💡 en - Hex colors must consist of three or six hex numbers.
	"css.lint.hexColorLength": "error",

	//* 💡 ru - Селекторы не должны содержать идентификаторы, потому что эти правила слишком тесно связаны с HTML.
	//* 💡 en - Selectors should not contain IDs because these rules are too tightly coupled with the HTML.
	"css.lint.idSelector": "ignore",

	//* 💡 ru - Взломы IE необходимы только при поддержке IE7 и старше.
	//* 💡 en - IE hacks are only necessary when supporting IE7 and older.
	"css.lint.ieHack": "ignore",

	//* 💡 ru - Избегайте использования `!important`. Это указывает на то, что специфика всего CSS вышла из-под контроля и нуждается в рефакторинг.
	//* 💡 en - Avoid using `!important`. It is an indication that the specificity of the entire CSS has gotten out of control and needs to be refactored.
	"css.lint.important": "ignore",

	//* 💡 ru - Операторы импорта не загружаются параллельно.
	//* 💡 en - Import statements do not load in parallel.
	"css.lint.importStatement": "ignore",

	//* 💡 ru - Свойство игнорируется из-за отображения. Например. с display: inline свойства width, height, margin-top, margin-bottom и float не действуют.
	//* 💡 en - Property is ignored due to the display. E.g. with `display: inline`, the `width`, `height`, `margin-top`, `margin-bottom`, and `float` properties have no effect.
	"css.lint.propertyIgnoredDueToDisplay": "warning",

	//* 💡 ru - Известно, что универсальный селектор (`*`) медленный.
	//* 💡 en - The universal selector (`*`) is known to be slow.
	"css.lint.universalSelector": "ignore",

	//* 💡 ru - Неизвестное at-правило.
	//* 💡 en - Unknown at-rule.
	"css.lint.unknownAtRules": "warning",

	//* 💡 ru - Неизвестное свойство.
	//* 💡 en - Unknown property.
	"css.lint.unknownProperties": "warning",

	//* 💡 ru - Свойство неизвестного поставщика.
	//* 💡 en - Unknown vendor specific property.
	"css.lint.unknownVendorSpecificProperties": "ignore",

	//* 💡 ru - Список свойств, которые не проверяются на соответствие правилу `unknownProperties`.
	//* 💡 en - A list of properties that are not validated against the `unknownProperties` rule.
	"css.lint.validProperties": [],

	//* 💡 ru - При использовании префикса, зависящего от поставщика, также включите стандартное свойство.
	//* 💡 en - When using a vendor-specific prefix, also include the standard property.
	"css.lint.vendorPrefix": "warning",

	//* 💡 ru - Единица для нуля не нужна.
	//* 💡 en - No unit for zero needed.
	"css.lint.zeroUnits": "ignore",

	//* 💡 ru - Отслеживает связь между VS Code и языковым сервером CSS.
	//* 💡 en - Traces the communication between VS Code and the CSS language server.
	"css.trace.server": "off",

	//* 💡 ru - Включает или отключает все проверки.
	//* 💡 en - Enables or disables all validations.,
	"css.validate": true,

	//! ✅ Debug

	//* 💡 ru - Управляет расположением панели инструментов отладки. Либо «плавающий» во всех представлениях, либо «закрепленный» в представлении отладки, либо «скрытый».
	//* 💡 en - Controls the location of the debug toolbar. Either "floating" in all views, or "pinned" in debug view, or "hidden".
	"debug.toolBarLocation": "hidden",

	//* 💡 ru - Определяет, должно ли окно рабочей среды быть сфокусировано при остановке отладчика.
	//* 💡 en - Specifies whether the workbench window should be focused when the debugger is stopped.
	"debug.focusWindowOnBreak": false,

	//* 💡 ru - Определяет, следует ли отображать в редакторе украшения-кандидаты встроенных точек останова во время отладки.
	//* 💡 en - Controls whether to display inline breakpoint decoration candidates in the editor during debugging.
	"debug.showInlineBreakpointCandidates": false,

	//* 💡 ru - Определяет, должны ли точки останова отображаться на обзорной линейке.
	//* 💡 en - Specifies whether breakpoints should be displayed on the overview ruler.
	"debug.showBreakpointsInOverviewRuler": false,

	//* 💡 ru - Разрешить установку точек останова в любом файле.
	//* 💡 en - Allow setting breakpoints in any file.
	"debug.allowBreakpointsEverywhere": false,

	//* 💡 ru - Автоматически показывать значения для переменных, которые лениво разрешаются отладчиком, например геттеры.
	//* 💡 en - Automatically show values for variables that are lazily resolved by the debugger, such as getters.
	"debug.autoExpandLazyVariables": false,

	//* 💡 ru - Определяет, следует ли подтверждать закрытие окна при наличии активных сеансов отладки.
	//* 💡 en - Controls whether to confirm when the window closes if there are active debug sessions.
	"debug.confirmOnExit": "never",

	//* 💡 ru - Определяет, следует ли принимать предложения при нажатии Enter в консоли отладки. Enter также используется для оценки того, что набирается в консоли отладки.
	//* 💡 en - Controls whether suggestions should be accepted on Enter in the Debug Console. Enter is also used to evaluate whatever is typed in the Debug Console.
	"debug.console.acceptSuggestionOnEnter": "off",

	//* 💡 ru - Определяет, должна ли консоль отладки автоматически закрываться после завершения сеанса отладки.
	//* 💡 en - Controls if the Debug Console should be automatically closed when the debug session ends.
	"debug.console.closeOnEnd": false,

	//* 💡 ru - Определяет, должна ли консоль отладки сворачивать идентичные строки и показывать количество вхождений со значком.
	//* 💡 en - Controls if the Debug Console should collapse identical lines and show a number of occurrences with a badge.
	"debug.console.collapseIdenticalLines": true,

	//* 💡 ru - Управляет семейством шрифтов в консоли отладки.
	//* 💡 en - Controls the font family in the Debug Console.
	"debug.console.fontFamily": "default",

	//* 💡 ru - Управляет размером шрифта в пикселях в консоли отладки.
	//* 💡 en - Controls the font size in pixels in the Debug Console.
	"debug.console.fontSize": 14,

	//* 💡 ru - Определяет, должна ли консоль отладки предлагать введенные ранее данные.
	//* 💡 en - Controls if the Debug Console should suggest previously typed input.
	"debug.console.historySuggestions": true,

	//* 💡 ru - Управляет высотой строки в пикселях в консоли отладки. Используйте 0, чтобы вычислить высоту строки по размеру шрифта.
	//* 💡 en - Controls the line height in pixels in the Debug Console. Use 0 to compute the line height from the font size.
	"debug.console.lineHeight": 0,

	//* 💡 ru - Определяет, должны ли строки переноситься в консоли отладки.
	//* 💡 en - Controls if the lines should wrap in the Debug Console.
	"debug.console.wordWrap": true,

	//* 💡 ru - Показать исходный код в режиме дизассемблирования.
	//* 💡 en - Show Source Code in Disassembly View.
	"debug.disassemblyView.showSourceCode": true,

	//* 💡 ru - Определяет, должен ли редактор быть в фокусе, когда отладчик ломается.
	//* 💡 en - Controls whether the editor should be focused when the debugger breaks.
	"debug.focusEditorOnBreak": true,

	//* 💡 ru - Показывать значения переменных в редакторе во время отладки.
	//* 💡 en - Show variable values inline in editor while debugging.
	"debug.inlineValues": "auto",

	//* 💡 ru - Определяет, когда должна открываться внутренняя консоль отладки.
	//* 💡 en - Controls when the internal Debug Console should open.
	"debug.internalConsoleOptions": "openOnFirstSessionStart",

	//* 💡 ru - Управляет действиями при возникновении ошибок после запуска preLaunchTask.
	//* 💡 en - Controls what to do when errors are encountered after running a preLaunchTask.
	"debug.onTaskErrors": "prompt",

	//* 💡 ru - Определяет, когда должно открываться представление отладки.
	//* 💡 en - Controls when the debug view should open.
	"debug.openDebug": "openOnDebugBreak",

	//* 💡 ru - Автоматически открывать представление проводника в конце сеанса отладки.
	//* 💡 en - Automatically open the explorer view at the end of a debug session.
	"debug.openExplorerOnEnd": false,

	//* 💡 ru - Определяет, какие редакторы сохранять перед запуском сеанса отладки.
	//* 💡 en - Controls what editors to save before starting a debug session.
	"debug.saveBeforeStart": "allEditorsInActiveGroup",

	//* 💡 ru - Определяет, когда должна быть видна строка состояния отладки.
	//* 💡 en - Controls when the debug Status bar should be visible.
	"debug.showInStatusBar": "onFirstSessionStart",

	//* 💡 ru - Управляет отображением подсеансов отладки на панели инструментов отладки. Если для этого параметра установлено значение false, команда остановки в подсеансе также остановит родительский сеанс.
	//* 💡 en - Controls whether the debug sub-sessions are shown in the debug tool bar. When this setting is false the stop command on a sub-session will also stop the parent session.
	"debug.showSubSessionsInToolBar": false,

	//* 💡 ru - Перед запуском нового сеанса отладки во встроенном или внешнем терминале очистите терминал.
	//* 💡 en - Before starting a new debug session in an integrated or external terminal, clear the terminal.
	"debug.terminal.clearBeforeReusing": false,

	//* 💡 ru - Конфигурация запуска глобальной отладки. Следует использовать в качестве альтернативы файлу «launch.json», который является общим для всех рабочих областей.
	//* 💡 en - Global debug launch configuration. Should be used as an alternative to 'launch.json' that is shared across workspaces.
	"launch": {
		"configurations": [],
		"compounds": []
	},

	//* 💡 ru - Настраивает процессы для автоматического подключения и отладки, когда `debug.node.autoAttach` включен. Процесс Node, запущенный с флагом `--inspect`, всегда будет присоединен к независимо от этого параметра.
	//* 💡 en - Configures which processes to automatically attach and debug when `debug.node.autoAttach` is on. A Node process launched with the `--inspect` flag will always be attached to, regardless of this setting.
	"debug.javascript.autoAttachFilter": "disabled",

	//* 💡 ru - Настраивает шаблоны глобусов для определения момента подключения в «умном» режиме `debug.javascript.autoAttachFilter`. `$KNOWN_TOOLS$` заменяется списком имен общих тестов и исполнителей кода.
	//* 💡 en - Configures glob patterns for determining when to attach in "smart" `debug.javascript.autoAttachFilter` mode. `$KNOWN_TOOLS$` is replaced with a list of names of common test and code runners.
	"debug.javascript.autoAttachSmartPattern": [
		"${workspaceFolder}/**",
		"!**/node_modules/**",
		"**/$KNOWN_TOOLS$/**"
	],

	//* 💡 ru - При отладке удаленного веб-приложения настраивает, следует ли автоматически туннелировать удаленный сервер на локальный компьютер.
	//* 💡 en - When debugging a remote web app, configures whether to automatically tunnel the remote server to your local machine.
	"debug.javascript.automaticallyTunnelRemoteServer": true,

	//* 💡 ru - Следует ли останавливаться, когда условные точки останова вызывают ошибку.
	//* 💡 en - Whether to stop when conditional breakpoints throw an error.
	"debug.javascript.breakOnConditionalError": false,

	//* 💡 ru - Где в ваших сценариях npm должны отображаться линзы кода «Выполнение» и «Отладка». Это может быть «все», сценарии, «верхняя часть» раздела сценариев или «никогда».
	//* 💡 en - Where a "Run" and "Debug" code lens should be shown in your npm scripts. It may be on "all", scripts, on "top" of the script section, or "never".
	"debug.javascript.codelens.npmScripts": "top",

	//* 💡 ru - Параметры, используемые при отладке открытых ссылок, нажимаемых внутри терминала отладки JavaScript. Можно установить «выкл.», чтобы отключить это поведение, или «всегда», чтобы включить отладку во всех терминалах.
	//* 💡 en - Options used when debugging open links clicked from inside the JavaScript Debug Terminal. Can be set to "off" to disable this behavior, or "always" to enable debugging in all terminals.
	"debug.javascript.debugByLinkOptions": "on",

	//* 💡 ru - `runtimeExecutable` по умолчанию, используемый для конфигураций запуска, если он не указан. Это можно использовать для настройки пользовательских путей к Node.js или установкам браузера.
	//* 💡 en - The default `runtimeExecutable` used for launch configurations, if unspecified. This can be used to config custom paths to Node.js or browser installations.
	"debug.javascript.defaultRuntimeExecutable": {
		"pwa-node": "node"
	},

	//* 💡 ru - Параметры по умолчанию, используемые при отладке процесса с помощью команды «Отладка: присоединение к процессу Node.js».
	//* 💡 en - Default options used when debugging a process through the `Debug: Attach to Node.js Process` command.
	"debug.javascript.pickAndAttachOptions": {},

	//* 💡 ru - Параметры запроса для использования при загрузке ресурсов, таких как исходные карты, в отладчике. Вам может потребоваться настроить это, например, если ваши исходные карты требуют аутентификации или используют самозаверяющий сертификат. Опции используются для создания запроса с использованием библиотеки got. Обычный случай отключения проверки сертификата можно выполнить, передав `{ "https": { "rejectUnauthorized": false } }`.
	//* 💡 en - Request options to use when loading resources, such as source maps, in the debugger. You may need to configure this if your sourcemaps require authentication or use a self-signed certificate, for instance. Options are used to create a request using the `got` library. A common case to disable certificate verification can be done by passing `{ "https": { "rejectUnauthorized": false } }`.
	"debug.javascript.resourceRequestOptions": {},

	//* 💡 ru - Параметры запуска по умолчанию для терминала отладки JavaScript и скриптов npm.
	//* 💡 en - Default launch options for the JavaScript debug terminal and npm scripts.
	"debug.javascript.terminalOptions": {},

	//* 💡 ru - Настраивает, будет ли файл с исходным сопоставлением, где исходный файл не может быть прочитан, автоматически удален. Если это значение равно false (по умолчанию), отображается подсказка.
	//* 💡 en - Configures whether sourcemapped file where the original file can't be read will automatically be unmapped. If this is false (default), a prompt is shown.,
	"debug.javascript.unmapMissingSources": false,

	//! ✅ Editor

	//* 💡 ru - Размер Таба.
	//* 💡 en - Taba size.
	"editor.tabSize": 4,

	//* 💡 ru - Включение переноса слов.
	//* 💡 en - Enable word wrap.
	"editor.wordWrap": "on",

	//* 💡 ru - Сворачивание кусков кода.
	//* 💡 en - Folding pieces of code.
	"editor.folding": true,

	//* 💡 ru - Отступы Табом.
	//* 💡 en - Tab indents.
	"editor.insertSpaces": true,

	//* 💡 ru - Плавная прокрутка.
	//* 💡 en - Smooth scrolling.
	"editor.smoothScrolling": true,

	//* 💡 ru - Мини-карта кода.
	//* 💡 en - Code minimap.
	"editor.minimap.enabled": true,

	//* 💡 ru - Тип размера мини-карты.
	//* 💡 en - Minimap size type.
	"editor.minimap.size": "fill",

	//* 💡 ru - Удаление всего Таба.
	//* 💡 en - Minimap size type.
	"editor.detectIndentation": true,

	//* 💡 ru - Позволяет прокручивать редактор дальше последний строки.
	//* 💡 en - Allows the editor to scroll beyond the last line.
	"editor.scrollBeyondLastLine": true,

	//* 💡 ru - Отображение кастомным сниппетов в самом верху.
	//* 💡 en - Display custom snippets at the very top.
	"editor.snippetSuggestions": "bottom",

	//* 💡 ru - Включение мультикурсора на указанную кнопку.
	//* 💡 en - Turn on the multicursor on the specified button.
	"editor.multiCursorModifier": "alt",

	//* 💡 ru - Определяет, должен ли редактор отображать управляющие символы.
	//* 💡 en - Specifies whether the editor should display control characters.
	"editor.renderControlCharacters": false,

	//* 💡 ru - Определяет, выделяются ли символы, которые можно спутать с основными символами ASCII, за исключением тех, которые распространены в текущем языковом стандарте пользователя.
	//* 💡 en - Determines whether characters that can be confused with basic ASCII characters, other than those common in the user's current locale, are highlighted.
	"editor.unicodeHighlight.ambiguousCharacters": true,

	//* 💡 ru - Переключение по snippet`y кнопкой Tab.
	//* 💡 en - Switching by snippet`y with the Tab button.
	"editor.tabCompletion": "on",

	//* 💡 ru - Включить форматирование при сохранение файла.
	//* 💡 en - Enable formatting when saving a file.
	"editor.formatOnSave": true,

	//* 💡 ru - Определяет, должен ли редактор автоматически форматировать вставленное содержимое. Модуль форматирования должен быть доступен, и модуль форматирования должен иметь возможность форматировать диапазон в документе.
	//* 💡 en - Specifies whether the editor should automatically format pasted content. The formatter must be available, and the formatter must be able to format the range in the document.
	"editor.formatOnPaste": false,

	//* 💡 ru - Определяет, должен ли редактор автоматически форматировать строку после ввода.
	//* 💡 en - Specifies whether the editor should automatically format the string after input.
	"editor.formatOnType": false,

	//* 💡 ru - Определяет, форматирует ли формат при сохранении весь файл или только его модификации. Применяется только тогда, когда включен `editor.formatOnSave`.
	//* 💡 en - Specifies whether the format formats the entire file or only modifications of the file when saved. Applies only when `editor.formatOnSave` is enabled.
	"editor.formatOnSaveMode": "file",

	//* 💡 ru - Установка дефолтного расширения для vscode.
	//* 💡 en - Installing the default extension for vscode.
	"editor.defaultFormatter": "esbenp.prettier-vscode",

	//* 💡 ru - Действия при сохранение файла.
	//* 💡 en - Actions when saving a file.
	"editor.codeActionsOnSave": {
		//* 💡 ru - Использование приводит к удалению неиспользуемых инструкций импорта и к размещению команд импорта таким образом, чтобы сначала шли бы команды, в которых используются абсолютные пути.
		//* 💡 en - Use causes unused import statements to be removed and import commands to be placed so that commands that use absolute paths come first.
		"source.organizeImports": true
	},

	//* 💡 ru - Определяет, распределяются ли запомненные варианты выбора между несколькими рабочими пространствами и окнами (требуется `editor.suggestSelection`).
	//* 💡 en - Determines whether learned choices are shared across multiple workspaces and windows (requires `editor.suggestSelection`).
	"editor.suggestSelection": "first",

	//* 💡 ru - Управляет миганием курсора терминала.
	//* 💡 en - Controls the blinking of the terminal cursor.
	"editor.cursorBlinking": "expand",

	//* 💡 ru - Определяет, включена ли раскраска пары скобок или нет. Используйте `workbench.colorCustomizations`, чтобы переопределить цвета подсветки скобок.
	//* 💡 en - Specifies whether brace pair coloring is enabled or not. Use `workbench.colorCustomizations` to override bracket highlight colors.
	"editor.bracketPairColorization.enabled": false,

	//* 💡 ru - Настраивает лигатуры шрифта или функции шрифта. Может быть либо логическим значением для включения/отключения лигатур, либо строкой для значения свойства CSS 'font-feature-settings'.
	//* 💡 en - Customizes font ligatures or font features. Can be either a boolean to enable/disable ligatures, or a string for the value of the 'font-feature-settings' CSS property.
	"editor.fontLigatures": true,

	//* 💡 ru - Начертание шрифта.
	//* 💡 en - Font style.
	"editor.fontWeight": "500",

	//* 💡 ru - Размер шрифта.
	//* 💡 en - Font size.
	"editor.fontSize": 16,

	//* 💡 ru - Высота строки.
	//* 💡 en - Line height.
	"editor.lineHeight": 24,

	//* 💡 ru - Установка шрифта - https://github.com/kah3vich/Gulp-RS/tree/font/fonts/JetBrainsMono.
	//* 💡 en - Font installation - https://github.com/kah3vich/Gulp-RS/tree/font/fonts/JetBrainsMono.
	"editor.fontFamily": "JetBrains Mono, monospace",

	//* 💡 ru - Определяет, должен ли редактор отображать вертикальное поле глифа.
	//* 💡 en - Specifies whether the editor should display the glyph's vertical margin.
	"editor.glyphMargin": false,

	//* 💡 ru - Определяет, показывает ли редактор CodeLens.
	//* 💡 en - Controls whether the editor shows CodeLens.
	"diffEditor.codeLens": false,

	//* 💡 ru - Когда включено, редактор различий игнорирует изменения в начальных или конечных пробелах.
	//* 💡 en - When enabled, the diff editor ignores changes in leading or trailing whitespace.
	"diffEditor.ignoreTrimWhitespace": true,

	//* 💡 ru - Тайм-аут в миллисекундах, по истечении которого расчет различий отменяется. Используйте 0 для отсутствия тайм-аута.
	//* 💡 en - Timeout in milliseconds after which diff computation is cancelled. Use 0 for no timeout.
	"diffEditor.maxComputationTime": 5000,

	//* 💡 ru - Управляет отображением в редакторе различий индикаторов +/- для добавленных/удаленных изменений.
	//* 💡 en - Controls whether the diff editor shows +/- indicators for added/removed changes.
	"diffEditor.renderIndicators": true,

	//* 💡 ru - Если этот параметр включен, редактор различий показывает стрелки на полях глифов, чтобы отменить изменения.
	//* 💡 en - When enabled, the diff editor shows arrows in its glyph margin to revert changes.
	"diffEditor.renderMarginRevertIcon": true,

	//* 💡 ru - Определяет, будет ли редактор различий отображать различия рядом или в строке.
	//* 💡 en - Controls whether the diff editor shows the diff side by side or inline.
	"diffEditor.renderSideBySide": true,

	//* 💡 ru - Строки будут переноситься в соответствии с настройкой `editor.wordWrap`.
	//* 💡 en - Lines will wrap according to the `editor.wordWrap` setting.
	"diffEditor.wordWrap": "inherit",

	//* 💡 ru - Определяет, следует ли принимать предложения для символов фиксации. Например, в JavaScript точка с запятой (`; `) может быть символом фиксации, который принимает предложение и вводит этот символ.
	//* 💡 en - Controls whether suggestions should be accepted on commit characters. For example, in JavaScript, the semi-colon (`; `) can be a commit character that accepts a suggestion and types that character.
	"editor.acceptSuggestionOnCommitCharacter": true,

	//* 💡 ru - Определяет, следует ли принимать предложения при нажатии клавиши «Enter» в дополнение к «Tab». Помогает избежать двусмысленности между вставкой новых строк или принятием предложений.
	//* 💡 en - Controls whether suggestions should be accepted on `Enter`, in addition to `Tab`. Helps to avoid ambiguity between inserting new lines or accepting suggestions.
	"editor.acceptSuggestionOnEnter": "on",

	//* 💡 ru - Определяет, должен ли редактор работать в режиме, оптимизированном для чтения с экрана.
	//* 💡 en - Controls whether the editor should run in a mode where it is optimized for screen readers.
	"editor.accessibilitySupport": "auto",

	//* 💡 ru - Определяет, должен ли редактор автоматически закрывать скобки после того, как пользователь добавляет открывающую скобку.
	//* 💡 en - Controls whether the editor should automatically close brackets after the user adds an opening bracket.
	"editor.autoClosingBrackets": "languageDefined",

	//* 💡 ru - Определяет, должен ли редактор удалять соседние закрывающие кавычки или квадратные скобки при удалении.
	//* 💡 en - Controls whether the editor should remove adjacent closing quotes or brackets when deleting.
	"editor.autoClosingDelete": "auto",

	//* 💡 ru - Определяет, должен ли редактор печатать с закрывающими кавычками или скобками.
	//* 💡 en - Controls whether the editor should type over closing quotes or brackets.
	"editor.autoClosingOvertype": "auto",

	//* 💡 ru - Определяет, должен ли редактор автоматически закрывать кавычки после добавления пользователем открывающей кавычки.
	//* 💡 en - Controls whether the editor should automatically close quotes after the user adds an opening quote.
	"editor.autoClosingQuotes": "languageDefined",

	//* 💡 ru - Определяет, должен ли редактор автоматически регулировать отступ, когда пользователи печатают, вставляют, перемещают или делают отступы строк.
	//* 💡 en - Controls whether the editor should automatically adjust the indentation when users type, paste, move or indent lines.
	"editor.autoIndent": "full",

	//* 💡 ru - Определяет, должен ли редактор автоматически окружать выделение при вводе кавычек или квадратных скобок.
	//* 💡 en - Controls whether the editor should automatically surround selections when typing quotes or brackets.
	"editor.autoSurround": "languageDefined",

	//* 💡 ru - Определяет, имеет ли каждый тип скобки собственный независимый набор цветов.
	//* 💡 en - Controls whether each bracket type has its own independent color pool.
	"editor.bracketPairColorization.independentColorPoolPerBracketType": false,

	//* 💡 ru - Включить/отключить отображение заголовков групп в меню «Действие кода».
	//* 💡 en - Enable/disable showing group headers in the Code Action menu.
	"editor.codeActionWidget.showHeaders": true,

	//* 💡 ru - Определяет, показывает ли редактор CodeLens.
	//* 💡 en - Controls whether the editor shows CodeLens.
	"editor.codeLens": true,

	//* 💡 ru - Управляет семейством шрифтов для CodeLens.
	//* 💡 en - Controls the font family for CodeLens.
	"editor.codeLensFontFamily": "",

	//* 💡 ru - Управляет размером шрифта в пикселях для CodeLens. При значении 0 используется 90% `editor.fontSize`.
	//* 💡 en - Controls the font size in pixels for CodeLens. When set to 0, 90% of `editor.fontSize` is used.
	"editor.codeLensFontSize": 0,

	//* 💡 ru - Определяет, должен ли редактор отображать встроенные декораторы цвета и палитру цветов.
	//* 💡 en - Controls whether the editor should render the inline color decorators and color picker.
	"editor.colorDecorators": true,

	//* 💡 ru - Включите, чтобы выбор с помощью мыши и клавиш выполнял выбор столбца.
	//* 💡 en - Enable that the selection with the mouse and keys is doing column selection.
	"editor.columnSelection": false,

	//* 💡 ru - Определяет, следует ли игнорировать пустые строки с помощью переключения, добавления или удаления действий для комментариев строки.
	//* 💡 en - Controls if empty lines should be ignored with toggle, add or remove actions for line comments.
	"editor.comments.ignoreEmptyLines": true,

	//* 💡 ru - Определяет, вставляется ли пробел при комментировании.
	//* 💡 en - Controls whether a space character is inserted when commenting.
	"editor.comments.insertSpace": true,

	//* 💡 ru - Определяет, следует ли копировать подсветку синтаксиса в буфер обмена.
	//* 💡 en - Controls whether syntax highlighting should be copied into the clipboard.
	"editor.copyWithSyntaxHighlighting": true,

	//* 💡 ru - Определяет, должна ли быть включена плавная анимация курсора.
	//* 💡 en - Controls whether the smooth caret animation should be enabled.
	"editor.cursorSmoothCaretAnimation": "off",

	//* 💡 ru - Управляет стилем курсора.
	//* 💡 en - Controls the cursor style.
	"editor.cursorStyle": "line",

	//* 💡 ru - Управляет минимальным количеством видимых начальных и конечных строк, окружающих курсор. В некоторых других редакторах известен как «scrollOff» или «scrollOffset».
	//* 💡 en - Controls the minimal number of visible leading and trailing lines surrounding the cursor. Known as 'scrollOff' or 'scrollOffset' in some other editors.
	"editor.cursorSurroundingLines": 0,

	//* 💡 ru - Контролирует, когда должны применяться `cursorSurroundingLines`.
	//* 💡 en - Controls when `cursorSurroundingLines` should be enforced.
	"editor.cursorSurroundingLinesStyle": "default",

	//* 💡 ru - Управляет шириной курсора, когда для `editor.cursorStyle` установлено значение `line`.
	//* 💡 en - Controls the width of the cursor when `editor.cursorStyle` is set to `line`.
	"editor.cursorWidth": 0,

	//* 💡 ru - Определяет поставщика диапазона сворачивания по умолчанию, который имеет приоритет над всеми другими поставщиками диапазона сворачивания. Должен быть идентификатором расширения, вносящего поставщики диапазона свертки.
	//* 💡 en - Defines a default folding range provider that takes precedence over all other folding range provider. Must be the identifier of an extension contributing a folding range providers.
	"editor.defaultFoldingRangeProvider": null,

	//* 💡 ru - Определяет, всегда ли жест мыши «Переход к определению» открывает виджет просмотра.
	//* 💡 en - Controls whether the Go to Definition mouse gesture always opens the peek widget.
	"editor.definitionLinkOpensInPeek": false,

	//* 💡 ru - Определяет, должен ли редактор разрешать перемещение выделения с помощью перетаскивания.
	//* 💡 en - Controls whether the editor should allow moving selections via drag and drop.
	"editor.dragAndDrop": true,

	//* 💡 ru - Определяет, можете ли вы перетаскивать файл в текстовый редактор, удерживая нажатой клавишу `shift` (вместо открытия файла в редакторе).
	//* 💡 en - Controls whether you can drag and drop a file into a text editor by holding down `shift` (instead of opening the file in an editor).
	"editor.dropIntoEditor.enabled": true,

	//* 💡 ru - Определяет, копирует ли копирование без выделения текущую строку.
	//* 💡 en - Controls whether copying without a selection copies the current line.
	"editor.emptySelectionClipboard": true,

	//* 💡 ru - Множитель скорости прокрутки при нажатии Alt.
	//* 💡 en - Scrolling speed multiplier when pressing `Alt`.
	"editor.fastScrollSensitivity": 5,

	//* 💡 ru - Определяет, должен ли виджет «Найти» добавлять дополнительные строки поверх редактора. Если установлено значение true, вы можете прокручивать дальше первой строки, когда отображается виджет «Найти».
	//* 💡 en - Controls whether the Find Widget should add extra lines on top of the editor. When true, you can scroll beyond the first line when the Find Widget is visible.
	"editor.find.addExtraSpaceOnTop": true,

	//* 💡 ru - Управляет условием автоматического включения функции «Найти в выделенном».
	//* 💡 en - Controls the condition for turning on Find in Selection automatically.
	"editor.find.autoFindInSelection": "never",

	//* 💡 ru - Определяет, должен ли курсор прыгать, чтобы найти совпадения во время ввода.
	//* 💡 en - Controls whether the cursor should jump to find matches while typing.
	"editor.find.cursorMoveOnType": true,

	//* 💡 ru - Определяет, должен ли виджет «Найти» читать или изменять общий буфер поиска в macOS.
	//* 💡 en - Controls whether the Find Widget should read or modify the shared find clipboard on macOS.
	"editor.find.globalFindClipboard": false,

	//* 💡 ru - Определяет, будет ли поиск автоматически перезапускаться с начала (или с конца), когда больше не будет найдено совпадений.
	//* 💡 en - Controls whether the search automatically restarts from the beginning (or the end) when no further matches can be found.
	"editor.find.loop": true,

	//* 💡 ru - Определяет, берется ли строка поиска в виджет поиска из выбора редактора.
	//* 💡 en - Controls whether the search string in the Find Widget is seeded from the editor selection.
	"editor.find.seedSearchStringFromSelection": "always",

	//* 💡 ru - Определяет, должен ли редактор выделять свернутые диапазоны.
	//* 💡 en - Controls whether the editor should highlight folded ranges.
	"editor.foldingHighlight": true,

	//* 💡 ru - Определяет, будет ли редактор автоматически сворачивать диапазоны импорта.
	//* 💡 en - Controls whether the editor automatically collapses import ranges.
	"editor.foldingImportsByDefault": false,

	//* 💡 ru - Управляет стратегией расчета диапазонов фолда.
	//* 💡 en - Controls the strategy for computing folding ranges.
	"editor.foldingStrategy": "auto",

	//* 💡 ru - Настраивает варианты шрифта. Может быть либо логическим значением для включения/выключения перевода из font-weight в font-variation-settings, либо строкой для значения свойства CSS 'font-variation-settings'.
	//* 💡 en - Configures font variations. Can be either a boolean to enable/disable the translation from font-weight to font-variation-settings or a string for the value of the CSS 'font-variation-settings' property.
	"editor.fontVariations": false,

	//* 💡 ru - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к объявлению» является текущее местоположение.
	//* 💡 en - Alternative command id that is being executed when the result of 'Go to Declaration' is the current location.
	"editor.gotoLocation.alternativeDeclarationCommand": "editor.action.goToReferences",

	//* 💡 ru - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к определению» является текущее местоположение.
	//* 💡 en - Alternative command id that is being executed when the result of 'Go to Definition' is the current location.
	"editor.gotoLocation.alternativeDefinitionCommand": "editor.action.goToReferences",

	//* 💡 ru - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к реализации» является текущее местоположение.
	//* 💡 en - Alternative command id that is being executed when the result of 'Go to Implementation' is the current location.
	"editor.gotoLocation.alternativeImplementationCommand": "",

	//* 💡 ru - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к ссылке» является текущее местоположение.
	//* 💡 en - Alternative command id that is being executed when the result of 'Go to Reference' is the current location.
	"editor.gotoLocation.alternativeReferenceCommand": "",

	//* 💡 ru - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к определению типа» является текущее местоположение.
	//* 💡 en - Alternative command id that is being executed when the result of 'Go to Type Definition' is the current location.
	"editor.gotoLocation.alternativeTypeDefinitionCommand": "editor.action.goToReferences",

	//* 💡 ru - Управляет поведением команды «Перейти к объявлению», когда существует несколько целевых местоположений.
	//* 💡 en - Controls the behavior the 'Go to Declaration'-command when multiple target locations exist.
	"editor.gotoLocation.multipleDeclarations": "peek",

	//* 💡 ru - Управляет поведением команды «Перейти к определению», когда существует несколько целевых местоположений.
	//* 💡 en - Controls the behavior the 'Go to Definition'-command when multiple target locations exist.
	"editor.gotoLocation.multipleDefinitions": "peek",

	//* 💡 ru - Управляет поведением команды «Перейти к реализациям», когда существует несколько целевых местоположений.
	//* 💡 en - Controls the behavior the 'Go to Implementations'-command when multiple target locations exist.
	"editor.gotoLocation.multipleImplementations": "peek",

	//* 💡 ru - Controls the behavior the 'Go to References'-command when multiple target locations exist.
	//* 💡 en - Controls the behavior the 'Go to References'-command when multiple target locations exist.
	"editor.gotoLocation.multipleReferences": "peek",

	//* 💡 ru - Управляет поведением команды «Перейти к определению типа», когда существует несколько целевых местоположений.
	//* 💡 en - Controls the behavior the 'Go to Type Definition'-command when multiple target locations exist.
	"editor.gotoLocation.multipleTypeDefinitions": "peek",

	//* 💡 ru - Определяет, включены ли направляющие пары скобок.
	//* 💡 en - Controls whether bracket pair guides are enabled or not.
	"editor.guides.bracketPairs": false,

	//* 💡 ru - Определяет, включены ли направляющие пар горизонтальных скобок или нет.
	//* 💡 en - Controls whether horizontal bracket pair guides are enabled or not.
	"editor.guides.bracketPairsHorizontal": "active",

	//* 💡 ru - Определяет, должен ли редактор выделять активную пару скобок.
	//* 💡 en - Controls whether the editor should highlight the active bracket pair.
	"editor.guides.highlightActiveBracketPair": true,

	//* 💡 ru - Определяет, должен ли редактор выделять активную направляющую отступа.
	//* 💡 en - Controls whether the editor should highlight the active indent guide.
	"editor.guides.highlightActiveIndentation": true,

	//* 💡 ru - Определяет, должен ли редактор отображать направляющие отступов.
	//* 💡 en - Controls whether the editor should render indent guides.
	"editor.guides.indentation": true,

	//* 💡 ru - Определяет, должен ли курсор быть скрыт в обзорной линейке.
	//* 💡 en - Controls whether the cursor should be hidden in the overview ruler.
	"editor.hideCursorInOverviewRuler": false,

	//* 💡 ru - Предпочитаю показывать ховеры над линией, если есть место.
	//* 💡 en - Prefer showing hovers above the line, if there's space.
	"editor.hover.above": true,

	//* 💡 ru - Управляет задержкой в миллисекундах, после которой отображается наведение.
	//* 💡 en - Controls the delay in milliseconds after which the hover is shown.
	"editor.hover.delay": 300,

	//* 💡 ru - Определяет, отображается ли наведение.
	//* 💡 en - Controls whether the hover is shown.
	"editor.hover.enabled": true,

	//* 💡 ru - Определяет, должно ли наведение оставаться видимым при наведении на него мыши.
	//* 💡 en - Controls whether the hover should remain visible when mouse is moved over it.
	"editor.hover.sticky": true,

	//* 💡 ru - Количество пробелов, используемых для отступа или `"tabSize"`, чтобы использовать значение из `editor.tabSize#`. Этот параметр переопределяется на основе содержимого файла, когда включен параметр `#editor.detectIndentation`.
	//* 💡 en - The number of spaces used for indentation or `"tabSize"` to use the value from `editor.tabSize#`. This setting is overridden based on the file contents when `#editor.detectIndentation` is on.
	"editor.indentSize": "tabSize",

	//* 💡 ru - Включает подсказки вкладок в редакторе.
	//* 💡 en - Enables the inlay hints in the editor.
	"editor.inlayHints.enabled": "on",

	//* 💡 ru - Управляет семейством шрифтов подсказок вкладок в редакторе. Если установлено пустое, используется `editor.fontFamily`.
	//* 💡 en - Controls font family of inlay hints in the editor. When set to empty, the `editor.fontFamily` is used.
	"editor.inlayHints.fontFamily": "",

	//* 💡 ru - Управляет размером шрифта подсказок вкладок в редакторе. По умолчанию `editor.fontSize` используется, когда настроенное значение меньше 5 или больше размера шрифта редактора.
	//* 💡 en - Controls font size of inlay hints in the editor. As default the `editor.fontSize` is used when the configured value is less than `5` or greater than the editor font size.
	"editor.inlayHints.fontSize": 0,

	//* 💡 ru - Включает отступы вокруг подсказок вкладок в редакторе.
	//* 💡 en - Enables the padding around the inlay hints in the editor.
	"editor.inlayHints.padding": false,

	//* 💡 ru - Включает отступы вокруг подсказок вкладок в редакторе.
	//* 💡 en - Controls whether to automatically show inline suggestions in the editor.
	"editor.inlineSuggest.enabled": true,

	//* 💡 ru - Определяет символы скобок, которые увеличивают или уменьшают отступ.
	//* 💡 en - Defines the bracket symbols that increase or decrease the indentation.
	"editor.language.brackets": null,

	//* 💡 ru - Определяет пары скобок, которые окрашиваются в соответствии с их уровнем вложенности, если включено раскрашивание пар скобок.
	//* 💡 en - Defines the bracket pairs that are colorized by their nesting level if bracket pair colorization is enabled.
	"editor.language.colorizedBracketPairs": null,

	//* 💡 ru - Управляет расстоянием между буквами в пикселях.
	//* 💡 en - Controls the letter spacing in pixels.
	"editor.letterSpacing": 0,

	//* 💡 ru - Включает лампочку Code Action в редакторе.
	//* 💡 en - Enables the Code Action lightbulb in the editor.
	"editor.lightbulb.enabled": true,

	//* 💡 ru - Управляет отображением номеров строк.
	//* 💡 en - Controls the display of line numbers.
	"editor.lineNumbers": "on",

	//* 💡 ru - Определяет, включено ли в редакторе связанное редактирование. В зависимости от языка связанные символы, такие как теги HTML, обновляются при редактировании.
	//* 💡 en - Controls whether the editor has linked editing enabled. Depending on the language, related symbols such as HTML tags, are updated while editing.
	"editor.linkedEditing": false,

	//* 💡 ru - Определяет, должен ли редактор обнаруживать ссылки и делать их активными.
	//* 💡 en - Controls whether the editor should detect links and make them clickable.
	"editor.links": true,

	//* 💡 ru - Выделите соответствующие скобки.
	//* 💡 en - Highlight matching brackets.
	"editor.matchBrackets": "always",

	//* 💡 ru - Определяет, скрывается ли миникарта автоматически.
	//* 💡 en - Controls whether the minimap is hidden automatically.
	"editor.minimap.autohide": false,

	//* 💡 ru - Ограничьте ширину миникарты, чтобы отобразить не более определенного количества столбцов.
	//* 💡 en - Limit the width of the minimap to render at most a certain number of columns.
	"editor.minimap.maxColumn": 120,

	//* 💡 ru - Визуализируйте фактические символы в строке, а не цветные блоки.
	//* 💡 en - Render the actual characters on a line as opposed to color blocks.
	"editor.minimap.renderCharacters": true,

	//* 💡 ru - Масштаб отрисовываемого на миникарте контента: 1, 2 или 3.
	//* 💡 en - Scale of content drawn in the minimap: 1, 2 or 3.
	"editor.minimap.scale": 1,

	//* 💡 ru - Управляет отображением ползунка миникарты.
	//* 💡 en - Controls when the minimap slider is shown.
	"editor.minimap.showSlider": "mouseover",

	//* 💡 ru - Управляет стороной, на которой должна отображаться мини-карта.
	//* 💡 en - Controls the side where to render the minimap.
	"editor.minimap.side": "right",

	//* 💡 ru - Множитель, который будет использоваться для `deltaX` и `deltaY` событий прокрутки колеса мыши.
	//* 💡 en - A multiplier to be used on the `deltaX` and `deltaY` of mouse wheel scroll events.
	"editor.mouseWheelScrollSensitivity": 1,

	//* 💡 ru - Масштабирование шрифта редактора при использовании колесика мыши и удерживании `Ctrl`.
	//* 💡 en - Zoom the font of the editor when using mouse wheel and holding `Ctrl`.
	"editor.mouseWheelZoom": false,

	//* 💡 ru - Управляет вставкой, когда количество строк вставляемого текста совпадает с количеством строк курсора.
	//* 💡 en - Controls pasting when the line count of the pasted text matches the cursor count.
	"editor.multiCursorPaste": "spread",

	//* 💡 ru - Определяет, должен ли редактор выделять вхождения семантических символов.
	//* 💡 en - Controls whether the editor should highlight semantic symbol occurrences.
	"editor.occurrencesHighlight": true,

	//* 💡 ru - Определяет, следует ли рисовать границу вокруг линейки обзора.
	//* 💡 en - Controls whether a border should be drawn around the overview ruler.
	"editor.overviewRulerBorder": true,

	//* 💡 ru - Управляет расстоянием между нижним краем редактора и последней строкой.
	//* 💡 en - Controls the amount of space between the bottom edge of the editor and the last line.
	"editor.padding.bottom": 0,

	//* 💡 ru - Управляет расстоянием между верхним краем редактора и первой строкой.
	//* 💡 en - Controls the amount of space between the top edge of the editor and the first line.
	"editor.padding.top": 0,

	//* 💡 ru - Определяет, намекает ли параметр на циклы меню или закрывается при достижении конца списка.
	//* 💡 en - Controls whether the parameter hints menu cycles or closes when reaching the end of the list.
	"editor.parameterHints.cycle": false,

	//* 💡 ru - Включает всплывающее окно, в котором отображается документация по параметрам и информация о типе по мере ввода.
	//* 💡 en - Enables a pop-up that shows parameter documentation and type information as you type.
	"editor.parameterHints.enabled": true,

	//* 💡 ru - Определяет, следует ли сфокусировать встроенный редактор или дерево в виджете просмотра.
	//* 💡 en - Controls whether to focus the inline editor or the tree in the peek widget.
	"editor.peekWidgetDefaultFocus": "tree",

	//* 💡 ru - Определяет, должны ли предложения автоматически отображаться при наборе текста.
	//* 💡 en - Controls whether suggestions should automatically show up while typing.
	"editor.quickSuggestions": {
		"other": "on",
		"comments": "off",
		"strings": "off"
	},

	//* 💡 ru - Управляет задержкой в миллисекундах, после которой будут отображаться быстрые предложения.
	//* 💡 en - Controls the delay in milliseconds after which quick suggestions will show up.
	"editor.quickSuggestionsDelay": 10,

	//* 💡 ru - Включить/отключить возможность предварительного просмотра изменений перед переименованием.
	//* 💡 en - Enable/disable the ability to preview changes before renaming.
	"editor.rename.enablePreview": true,

	//* 💡 ru - Отображать номер последней строки, когда файл заканчивается новой строкой.
	//* 💡 en - Render last line number when the file ends with a newline.
	"editor.renderFinalNewline": "on",

	//* 💡 ru - Управляет тем, как редактор должен отображать текущую подсветку строки.
	//* 💡 en - Controls how the editor should render the current line highlight.
	"editor.renderLineHighlight": "line",

	//* 💡 ru - Определяет, должен ли редактор отображать текущую подсветку строки только тогда, когда редактор находится в фокусе.
	//* 💡 en - Controls if the editor should render the current line highlight only when the editor is focused.
	"editor.renderLineHighlightOnlyWhenFocus": false,

	//* 💡 ru - Управляет тем, как редактор должен отображать пробельные символы.
	//* 💡 en - Controls how the editor should render whitespace characters.
	"editor.renderWhitespace": "selection",

	//* 💡 ru - Определяет, должны ли выделенные области иметь закругленные углы.
	//* 💡 en - Controls whether selections should have rounded corners.
	"editor.roundedSelection": true,

	//* 💡 ru - Отображать вертикальные линейки после определенного количества моноширинных символов. Используйте несколько значений для нескольких линеек. Если массив пуст, линейки не рисуются.
	//* 💡 en - Render vertical rulers after a certain number of monospace characters. Use multiple values for multiple rulers. No rulers are drawn if array is empty.
	"editor.rulers": [],

	//* 💡 ru - Управляет видимостью горизонтальной полосы прокрутки.
	//* 💡 en - Controls the visibility of the horizontal scrollbar.
	"editor.scrollbar.horizontal": "auto",

	//* 💡 ru - Высота горизонтальной полосы прокрутки.
	//* 💡 en - The height of the horizontal scrollbar.
	"editor.scrollbar.horizontalScrollbarSize": 12,

	//* 💡 ru - Определяет, будут ли щелчки прокручиваться по странице или переходить к месту щелчка.
	//* 💡 en - Controls whether clicks scroll by page or jump to click position.
	"editor.scrollbar.scrollByPage": false,

	//* 💡 ru - Управляет видимостью вертикальной полосы прокрутки.
	//* 💡 en - Controls the visibility of the vertical scrollbar.
	"editor.scrollbar.vertical": "auto",

	//* 💡 ru - Ширина вертикальной полосы прокрутки.
	//* 💡 en - The width of the vertical scrollbar.
	"editor.scrollbar.verticalScrollbarSize": 14,

	//* 💡 ru - Управляет количеством дополнительных символов, после которых редактор будет прокручиваться по горизонтали.
	//* 💡 en - Controls the number of extra characters beyond which the editor will scroll horizontally.
	"editor.scrollBeyondLastColumn": 4,

	//* 💡 ru - Определяет, должен ли поддерживаться основной буфер обмена Linux.
	//* 💡 en - Controls whether the Linux primary clipboard should be supported.
	"editor.selectionClipboard": true,

	//* 💡 ru - Прокручивайте только вдоль преобладающей оси при одновременной прокрутке и по вертикали, и по горизонтали. Предотвращает смещение по горизонтали при вертикальной прокрутке на трекпаде.
	//* 💡 en - Scroll only along the predominant axis when scrolling both vertically and horizontally at the same time. Prevents horizontal drift when scrolling vertically on a trackpad.
	"editor.scrollPredominantAxis": true,

	//* 💡 ru - Определяет, должен ли редактор выделять совпадения, похожие на выделение.
	//* 💡 en - Controls whether the editor should highlight matches similar to the selection.
	"editor.selectionHighlight": true,

	//* 💡 ru - Определяет, отображается ли семантическая подсветка для языков, которые ее поддерживают.
	//* 💡 en - Controls whether the semanticHighlighting is shown for the languages that support it.
	"editor.semanticHighlighting.enabled": "configuredByTheme",

	//* 💡 ru - Переопределяет цвет и стили семантического маркера редактора из текущей выбранной цветовой темы.
	//* 💡 en - Overrides editor semantic token color and styles from the currently selected color theme.
	"editor.semanticTokenColorCustomizations": {},

	//* 💡 ru - Управляет зачеркнутыми устаревшими переменными.
	//* 💡 en - Controls strikethrough deprecated variables.
	"editor.showDeprecated": true,

	//* 💡 ru - Элементы управления, когда отображаются элементы управления складыванием желоба.
	//* 💡 en - Controls when the folding controls on the gutter are shown.
	"editor.showFoldingControls": "mouseover",

	//* 💡 ru - Контролирует исчезновение неиспользуемого кода.
	//* 💡 en - Controls fading out of unused code.
	"editor.showUnused": true,

	//* 💡 ru - Следует ли всегда выбирать начальные и конечные пробелы.
	//* 💡 en - Whether leading and trailing whitespace should always be selected.
	"editor.smartSelect.selectLeadingAndTrailingWhitespace": true,

	//* 💡 ru - Определяет, будут ли фрагменты окружения фрагментами или фрагменты шаблонов файлов отображаться как действия кода.
	//* 💡 en - Controls if surround-with-snippets or file template snippets show as Code Actions.
	"editor.snippets.codeActions.enabled": true,

	//* 💡 ru - Держите редакторы просмотра открытыми, даже если дважды щелкнете по их содержимому или нажмете «Escape».
	//* 💡 en - Keep peek editors open even when double clicking their content or when hitting `Escape`.
	"editor.stablePeek": false,

	//* 💡 ru - Показывает вложенные текущие области во время прокрутки в верхней части редактора.
	//* 💡 en - Shows the nested current scopes during the scroll at the top of the editor.
	"editor.stickyScroll.enabled": false,

	//* 💡 ru - Определяет максимальное количество липких строк для отображения.
	//* 💡 en - Defines the maximum number of sticky lines to show.
	"editor.stickyScroll.maxLineCount": 5,

	//* 💡 ru - Эмулируйте поведение выбора символов табуляции при использовании пробелов для отступа. Выбор будет придерживаться позиций табуляции.
	//* 💡 en - Emulate selection behavior of tab characters when using spaces for indentation. Selection will stick to tab stops.
	"editor.stickyTabStops": false,

	//* 💡 ru - Определяет, учитывают ли предложения фильтрации и сортировки небольшие опечатки.
	//* 💡 en - Controls whether filtering and sorting suggestions accounts for small typos.
	"editor.suggest.filterGraceful": true,

	//* 💡 ru - Управляет перезаписью слов при принятии завершения. Обратите внимание, что это зависит от расширений, использующих эту функцию.
	//* 💡 en - Controls whether words are overwritten when accepting completions. Note that this depends on extensions opting into this feature.
	"editor.suggest.insertMode": "insert",

	//* 💡 ru - Определяет, будут ли при сортировке отдавать предпочтение слова, расположенные рядом с курсором.
	//* 💡 en - Controls whether sorting favors words that appear close to the cursor.
	"editor.suggest.localityBonus": false,

	//* 💡 ru - При включенной фильтрации IntelliSense требуется, чтобы первый символ совпадал с началом слова. Например, `c` в `Console` или `WebContext`, но не в `description`.
	//* 💡 en - When enabled IntelliSense filtering requires that the first character matches on a word start. For example, `c` on `Console` or `WebContext` but not on `description`.
	"editor.suggest.matchOnWordStartOnly": true,

	//* 💡 ru - Определяет, следует ли предварительно просмотреть результат предложения в редакторе.
	//* 💡 en - Controls whether to preview the suggestion outcome in the editor.
	"editor.suggest.preview": false,

	//* 💡 ru - Определяет, распределяются ли запомненные варианты выбора между несколькими рабочими пространствами и окнами (требуется `editor.suggestSelection`).
	//* 💡 en - Controls whether remembered suggestion selections are shared between multiple workspaces and windows (needs `editor.suggestSelection`).
	"editor.suggest.shareSuggestSelections": false,

	//* 💡 ru - При включении IntelliSense показывает `классовые`-предложения.
	//* 💡 en - When enabled IntelliSense shows `class`-suggestions.
	"editor.suggest.showClasses": true,

	//* 💡 ru - При включении IntelliSense показывает «цветовые» предложения.
	//* 💡 en - When enabled IntelliSense shows `color`-suggestions.
	"editor.suggest.showColors": true,

	//* 💡 ru - При включении IntelliSense показывает «постоянные» предложения.
	//* 💡 en - When enabled IntelliSense shows `constant`-suggestions.
	"editor.suggest.showConstants": true,

	//* 💡 ru - При включении IntelliSense показывает «постоянные» предложения.
	//* 💡 en - При включении IntelliSense показывает «постоянные» предложения.
	"editor.suggest.showConstructors": true,

	//* 💡 ru - При включении IntelliSense показывает «постоянные» предложения.
	//* 💡 en - При включении IntelliSense показывает «постоянные» предложения.
	"editor.suggest.showCustomcolors": true,

	//* 💡 ru - При включении IntelliSense показывает «постоянные» предложения.
	//* 💡 en - При включении IntelliSense показывает «постоянные» предложения.
	"editor.suggest.showDeprecated": true,

	//* 💡 ru - При включении IntelliSense показывает `enumMember`-предложения.
	//* 💡 en - When enabled IntelliSense shows `enumMember`-suggestions.
	"editor.suggest.showEnumMembers": true,

	//* 💡 ru - При включении IntelliSense показывает `enum`-предложения.
	//* 💡 en - When enabled IntelliSense shows `enum`-suggestions.
	"editor.suggest.showEnums": true,

	//* 💡 ru - При включении IntelliSense показывает "события"-предложения.
	//* 💡 en - When enabled IntelliSense shows `event`-suggestions.
	"editor.suggest.showEvents": true,

	//* 💡 ru - При включении IntelliSense показывает «предложения полей».
	//* 💡 en - When enabled IntelliSense shows `field`-suggestions.
	"editor.suggest.showFields": true,

	//* 💡 ru - При включении IntelliSense показывает «файловые» предложения.
	//* 💡 en - When enabled IntelliSense shows `file`-suggestions.
	"editor.suggest.showFiles": true,

	//* 💡 ru - При включении IntelliSense показывает «папки»-предложения.
	//* 💡 en - When enabled IntelliSense shows `folder`-suggestions.
	"editor.suggest.showFolders": true,

	//* 💡 ru - При включении IntelliSense показывает `функции`-предложения.
	//* 💡 en - When enabled IntelliSense shows `function`-suggestions.
	"editor.suggest.showFunctions": true,

	//* 💡 ru - Определяет, показывать или скрывать значки в предложениях.
	//* 💡 en - Controls whether to show or hide icons in suggestions.
	"editor.suggest.showIcons": true,

	//* 💡 ru - Определяет, будут ли предлагаться подробные сведения вместе с меткой или только в виджете сведений.
	//* 💡 en - Controls whether suggest details show inline with the label or only in the details widget.
	"editor.suggest.showInlineDetails": true,

	//* 💡 ru - При включении IntelliSense показывает предложения интерфейса.
	//* 💡 en - When enabled IntelliSense shows `interface`-suggestions.
	"editor.suggest.showInterfaces": true,

	//* 💡 ru - При включении IntelliSense показывает "проблемы"-предложения.
	//* 💡 en - When enabled IntelliSense shows `issues`-suggestions.
	"editor.suggest.showIssues": true,

	//* 💡 ru - При включении IntelliSense показывает предложения по ключевым словам.
	//* 💡 en - When enabled IntelliSense shows `keyword`-suggestions.
	"editor.suggest.showKeywords": true,

	//* 💡 ru - При включении IntelliSense показывает «методы»-предложения.
	//* 💡 en - When enabled IntelliSense shows `method`-suggestions.
	"editor.suggest.showMethods": true,

	//* 💡 ru - При включении IntelliSense показывает «модульные» предложения.
	//* 💡 en - When enabled IntelliSense shows `module`-suggestions.
	"editor.suggest.showModules": true,

	//* 💡 ru - При включении IntelliSense показывает «предложения оператора».
	//* 💡 en - When enabled IntelliSense shows `operator`-suggestions.
	"editor.suggest.showOperators": true,

	//* 💡 ru - При включении IntelliSense показывает «свойства»-предложения.
	//* 💡 en - When enabled IntelliSense shows `property`-suggestions.
	"editor.suggest.showProperties": true,

	//* 💡 ru - При включении IntelliSense показывает «справочные» предложения.
	//* 💡 en - When enabled IntelliSense shows `reference`-suggestions.
	"editor.suggest.showReferences": true,

	//* 💡 ru - При включении IntelliSense показывает «сниппеты»-предложения.
	//* 💡 en - When enabled IntelliSense shows `snippet`-suggestions.
	"editor.suggest.showSnippets": true,

	//* 💡 ru - Управляет видимостью строки состояния в нижней части виджета предложения.
	//* 💡 en - Controls the visibility of the status bar at the bottom of the suggest widget.
	"editor.suggest.showStatusBar": false,

	//* 💡 ru - При включении IntelliSense показывает предложения `struct`.
	//* 💡 en - When enabled IntelliSense shows `struct`-suggestions.
	"editor.suggest.showStructs": true,

	//* 💡 ru - При включении IntelliSense показывает «тип параметра» — предложения.
	//* 💡 en - When enabled IntelliSense shows `typeParameter`-suggestions.
	"editor.suggest.showTypeParameters": true,

	//* 💡 ru - Когда включено, IntelliSense показывает «единицы»-предложения.
	//* 💡 en - When enabled IntelliSense shows `unit`-suggestions.
	"editor.suggest.showUnits": true,

	//* 💡 ru - При включении IntelliSense показывает предложения пользователя.
	//* 💡 en - When enabled IntelliSense shows `user`-suggestions.
	"editor.suggest.showUsers": true,

	//* 💡 ru - При включении IntelliSense показывает «значения»-предложения.
	//* 💡 en - When enabled IntelliSense shows `value`-suggestions.
	"editor.suggest.showValues": true,

	//* 💡 ru - При включении IntelliSense показывает `переменные`-предложения.
	//* 💡 en - When enabled IntelliSense shows `variable`-suggestions.
	"editor.suggest.showVariables": true,

	//* 💡 ru - При включении IntelliSense показывает «текстовые» предложения.
	//* 💡 en - When enabled IntelliSense shows `text`-suggestions.
	"editor.suggest.showWords": true,

	//* 💡 ru - Определяет, предотвращает ли активный фрагмент быстрые предложения.
	//* 💡 en - Controls whether an active snippet prevents quick suggestions.
	"editor.suggest.snippetsPreventQuickSuggestions": true,

	//* 💡 ru - Размер шрифта для виджета предложений. Если установлено значение «0», используется значение «editor.fontSize».
	//* 💡 en - Font size for the suggest widget. When set to `0`, the value of `editor.fontSize` is used.
	"editor.suggestFontSize": 0,

	//* 💡 ru - Высота строки для виджета предложения. Если установлено значение «0», используется значение «editor.lineHeight». Минимальное значение равно 8.
	//* 💡 en - Line height for the suggest widget. When set to `0`, the value of `editor.lineHeight` is used. The minimum value is 8.
	"editor.suggestLineHeight": 0,

	//* 💡 ru - Определяет, должны ли автоматически появляться предложения при вводе триггерных символов.
	//* 💡 en - Controls whether suggestions should automatically show up when typing trigger characters.
	"editor.suggestOnTriggerCharacters": true,

	//* 💡 ru - Переопределяет цвета синтаксиса редактора и стиль шрифта из текущей выбранной цветовой темы.
	//* 💡 en - Overrides editor syntax colors and font style from the currently selected color theme.
	"editor.tokenColorCustomizations": {},

	//* 💡 ru - Удалить завершающие автоматически вставленные пробелы.
	//* 💡 en - Remove trailing auto inserted whitespace.
	"editor.trimAutoWhitespace": true,

	//* 💡 ru - Определяет, будет ли щелчок по пустому содержимому после свернутой строки разворачивать строку.
	//* 💡 en - Controls whether clicking on the empty content after a folded line will unfold the line.
	"editor.unfoldOnClickAfterEndOfLine": false,

	//* 💡 ru - Определяет разрешенные символы, которые не выделяются.
	//* 💡 en - Defines allowed characters that are not being highlighted.
	"editor.unicodeHighlight.allowedCharacters": {},

	//* 💡 ru - Символы Unicode, распространенные в разрешенных локалях, не выделяются.
	//* 💡 en - Unicode characters that are common in allowed locales are not being highlighted.
	"editor.unicodeHighlight.allowedLocales": {
		"_os": true,
		"_vscode": true
	},

	//* 💡 ru - Определяет, должны ли символы в комментариях также подсвечиваться Unicode.
	//* 💡 en - Controls whether characters in comments should also be subject to Unicode highlighting.
	"editor.unicodeHighlight.includeComments": "inUntrustedWorkspace",

	//* 💡 ru - Определяет, должны ли символы в строках также подсвечиваться Unicode.
	//* 💡 en - Controls whether characters in strings should also be subject to Unicode highlighting.
	"editor.unicodeHighlight.includeStrings": true,

	//* 💡 ru - Определяет, выделяются ли символы, которые просто резервируют пространство или вообще не имеют ширины.
	//* 💡 en - Controls whether characters that just reserve space or have no width at all are highlighted.
	"editor.unicodeHighlight.invisibleCharacters": true,

	//* 💡 ru - Определяет, будут ли выделены все неосновные символы ASCII. Только символы между U+0020 и U+007E, символы табуляции, перевода строки и возврата каретки считаются базовыми ASCII.
	//* 💡 en - Controls whether all non-basic ASCII characters are highlighted. Only characters between U+0020 and U+007E, tab, line-feed and carriage-return are considered basic ASCII.
	"editor.unicodeHighlight.nonBasicASCII": "inUntrustedWorkspace",

	//* 💡 ru - Удалите необычные разделители строк, которые могут вызвать проблемы.
	//* 💡 en - Remove unusual line terminators that might cause problems.
	"editor.unusualLineTerminators": "prompt",

	//* 💡 ru - Вставка и удаление пробелов следует за позициями табуляции.
	//* 💡 en - Inserting and deleting whitespace follows tab stops.
	"editor.useTabStops": true,

	//* 💡 ru - Определяет, должны ли завершения вычисляться на основе слов в документе.
	//* 💡 en - Controls whether completions should be computed based on words in the document.
	"editor.wordBasedSuggestions": true,

	//* 💡 ru - Определяет, из каких документов вычисляются завершения на основе слов.
	//* 💡 en - Controls from which documents word based completions are computed.
	"editor.wordBasedSuggestionsMode": "matchingDocuments",

	//* 💡 ru - Управляет правилами разрыва слов, используемыми для текста на китайском, японском и корейском языках (CJK).
	//* 💡 en - Controls the word break rules used for Chinese/Japanese/Korean (CJK) text.
	"editor.wordBreak": "normal",

	//* 💡 ru - Символы, которые будут использоваться в качестве разделителей слов при навигации или операциях, связанных со словами.
	//* 💡 en - Characters that will be used as word separators when doing word related navigations or operations.
	"editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\|;:'\",.<>/?",

	//* 💡 ru - Управляет столбцом переноса редактора, когда `editor.wordWrap` имеет значение `wordWrapColumn` или `bounded`.
	//* 💡 en - Controls the wrapping column of the editor when `editor.wordWrap` is `wordWrapColumn` or `bounded`.
	"editor.wordWrapColumn": 80,

	//* 💡 ru - Управляет отступом переносимых строк.
	//* 💡 en - Controls the indentation of wrapped lines.
	"editor.wrappingIndent": "same",

	//* 💡 ru - Управляет алгоритмом, вычисляющим точки переноса.
	//* 💡 en - Controls the algorithm that computes wrapping points.,
	"editor.wrappingStrategy": "simple",

	//! ✅ Emmet
	//? 🧨 Info - https://code.visualstudio.com/docs/editor/emmet

	//* 💡 ru - Укажите местоположение каталога, в котором находится snippets.json файл, который, в свою очередь, содержит ваши пользовательские фрагменты.
	//* 💡 en - Specify the directory location that contains the snippets.json file, which in turn contains your custom snippets.
	"emmet.triggerExpansionOnTab": true,

	//* 💡 ru - Если вы вообще не хотите видеть аббревиатуры Emmet в предложениях.
	//* 💡 en - If you don't want to see Emmet abbreviations in sentences at all.
	"emmet.showExpandedAbbreviation": "never",

	//* 💡 ru - Если есть язык, для которого вы не хотите видеть расширения Emmet, добавьте его в этот параметр, который принимает массив строк идентификатора языка.
	//* 💡 en - If there is a language for which you don't want to see Emmet extensions, add it to this parameter, which takes an array of language ID strings.
	"emmet.excludeLanguages": ["html", "css", "markdown", "javascript"],

	//* 💡 ru - Чтобы включить расширение аббревиатуры Emmet в типах файлов, где оно недоступно по умолчанию.
	//* 💡 en - To enable the Emmet abbreviation extension in file types where it is not available by default.
	"emmet.includeLanguages": {
		"javascript": "javascriptreact",
		"html": "html",
		"php": "html",
		"blade": "html",
		"postcss": "css"
	},

	//* 💡 ru - Массив языков, на которых не следует раскрывать аббревиатуры Emmet.
	//* 💡 en - An array of languages where Emmet abbreviations should not be expanded.
	"emmet.excludeLanguages": ["markdown"],

	//* 💡 ru - Массив путей, где каждый путь может содержать синтаксические профили Emmet и/или файлы фрагментов. В случае конфликтов профили/фрагменты более поздних путей переопределяют профили/фрагменты более ранних путей.
	//* 💡 en - An array of paths, where each path can contain Emmet syntaxProfiles and/or snippet files. In case of conflicts, the profiles/snippets of later paths will override those of earlier paths.
	"emmet.extensionsPath": [],

	//* 💡 ru - Включите сокращения Emmet на языках, которые не поддерживаются по умолчанию. Добавьте здесь сопоставление между языком и языком, поддерживаемым Emmet.
	//* 💡 en - Enable Emmet abbreviations in languages that are not supported by default. Add a mapping here between the language and Emmet supported language.
	"emmet.includeLanguages": {},
	//| For example: `{"vue-html": "html", "javascript": "javascriptreact"}`

	//* 💡 ru - Если установлено значение «false», весь файл анализируется, чтобы определить, допустима ли текущая позиция для расширения аббревиатур Emmet. Если установлено значение «true», анализируется только содержимое вокруг текущей позиции в файлах CSS/SCSS/Less.
	//* 💡 en - When set to `false`, the whole file is parsed to determine if current position is valid for expanding Emmet abbreviations. When set to `true`, only the content around the current position in CSS/SCSS/Less files is parsed.
	"emmet.optimizeStylesheetParsing": true,

	//* 💡 ru - Настройки, используемые для изменения поведения некоторых действий и преобразователей Emmet.
	//* 💡 en - Preferences used to modify behavior of some actions and resolvers of Emmet.
	"emmet.preferences": {},

	//* 💡 ru - Показывает возможные сокращения Emmet в качестве предложений. Неприменимо в таблицах стилей или когда для расширенного сокращения emmet.show установлено значение «никогда».
	//* 💡 en - Shows possible Emmet abbreviations as suggestions. Not applicable in stylesheets or when emmet.showExpandedAbbreviation is set to `"never"`.
	"emmet.showAbbreviationSuggestions": true,

	//* 💡 ru - Показывает расширенные сокращения Emmet в качестве предложений.
	//* 💡 en - Shows expanded Emmet abbreviations as suggestions.
	"emmet.showExpandedAbbreviation": "always",

	//* 💡 ru - Если установлено значение «true», предложения Emmet будут отображаться в виде фрагментов, что позволит вам упорядочить их в соответствии с настройкой «Предложения Editor.snippet».
	//* 💡 en - If `true`, then Emmet suggestions will show up as snippets allowing you to order them as per `editor.snippetSuggestions` setting.
	"emmet.showSuggestionsAsSnippets": false,

	//* 💡 ru - Определите профиль для указанного синтаксиса или используйте свой собственный профиль с определенными правилами.
	//* 💡 en - Define profile for specified syntax or use your own profile with specific rules.
	"emmet.syntaxProfiles": {},

	//* 💡 ru - Если `true`, Эммет будет использовать встроенные дополнения, чтобы предлагать расширения.
	//* 💡 en - If `true`, Emmet will use inline completions to suggest expansions.
	"emmet.useInlineCompletions": false,

	//* 💡 ru - Переменные, которые будут использоваться во фрагментах Emmet.
	//* 💡 en - Variables to be used in Emmet snippets.,
	"emmet.variables": {},

	//! ✅ ESLint

	//* 💡 ru - Включение eslint форматор.
	//* 💡 en - Enable eslint formatter.,
	"eslint.format.enable": true,

	//! ✅ Explorer

	//* 💡 ru - Убираем алерты с предупреждениями при удалении и перетаскивании файлов и директорий.
	//* 💡 en - We remove alerts with warnings when deleting and dragging files and directories.
	"explorer.confirmDelete": false,

	//* 💡 ru - Отображение дочерних папок в компактной форме.
	//* 💡 en - Display child folders in a compact form.
	"explorer.compactFolders": false,

	//* 💡 ru - Убираем алерты с предупреждениями при удалении и перетаскивании файлов и директорий.
	//* 💡 en - We remove alerts with warnings when deleting and dragging files and directories.
	"explorer.confirmDragAndDrop": true,

	//* 💡 ru - Определяет, должен ли проводник автоматически отображать и выбирать файлы при их открытии.
	//* 💡 en - Controls whether the Explorer should automatically reveal and select files when opening them.
	"explorer.autoReveal": true,

	//* 💡 ru - Настройте шаблоны глобусов для исключения файлов и папок из раскрытия и выбора в проводнике при их открытии.
	//* 💡 en - Configure glob patterns for excluding files and folders from being revealed and selected in the Explorer when they are opened.
	"explorer.autoRevealExclude": {
		"**/node_modules": true,
		"**/bower_components": true
	},

	//* 💡 ru - Определяет, должен ли проводник запрашивать подтверждение при отмене.
	//* 💡 en - Controls whether the Explorer should ask for confirmation when undoing.
	"explorer.confirmUndo": "default",

	//* 💡 ru - Символ разделителя пути, используемый при копировании относительных путей к файлам.
	//* 💡 en - The path separation character used when copying relative file paths.
	"explorer.copyRelativePathSeparator": "auto",

	//* 💡 ru - Определяет, должны ли украшения файлов использовать значки.
	//* 💡 en - Controls whether file decorations should use badges.
	"explorer.decorations.badges": true,

	//* 💡 ru - Определяет, должны ли украшения файлов использовать цвета.
	//* 💡 en - Controls whether file decorations should use colors.
	"explorer.decorations.colors": true,

	//* 💡 ru - Определяет, должен ли проводник разрешать перемещение файлов и папок с помощью перетаскивания. Этот параметр влияет только на перетаскивание внутри проводника.
	//* 💡 en - Controls whether the Explorer should allow to move files and folders via drag and drop. This setting only effects drag and drop from inside the Explorer.
	"explorer.enableDragAndDrop": true,

	//* 💡 ru - Определяет, должен ли Проводник поддерживать отмену операций с файлами и папками.
	//* 💡 en - Controls whether the Explorer should support undoing file and folder operations.
	"explorer.enableUndo": true,

	//* 💡 ru - Определяет, следует ли анализировать записи в .gitignore и исключать их из проводника. Похоже на `files.exclude`.
	//* 💡 en - Controls whether entries in .gitignore should be parsed and excluded from the Explorer. Similar to `files.exclude`.
	"explorer.excludeGitIgnore": false,

	//* 💡 ru - Определяет, должен ли Проводник расширять многокорневые рабочие пространства, содержащие только одну папку, во время инициализации.
	//* 💡 en - Controls whether the Explorer should expand multi-root workspaces containing only one folder during initialization.
	"explorer.expandSingleFolderWorkspaces": true,

	//* 💡 ru - Определяет, включена ли вложенность файлов в проводнике. Вложенность файлов позволяет визуально сгруппировать связанные файлы в каталоге в одном родительском файле.
	//* 💡 en - Controls whether file nesting is enabled in the Explorer. File nesting allows for related files in a directory to be visually grouped together under a single parent file.
	"explorer.fileNesting.enabled": false,

	//* 💡 ru - Управляет автоматическим развертыванием вложенных файлов. `explorer.file Nesting.enabled` должен быть установлен, чтобы это вступило в силу.
	//* 💡 en - Controls whether file nests are automatically expanded. `explorer.fileNesting.enabled` must be set for this to take effect.
	"explorer.fileNesting.expand": true,

	//* 💡 ru - Управляет вложенностью файлов в проводнике. `explorer.fileNesting.enabled` должен быть установлен, чтобы это вступило в силу. Каждый __Item__ представляет родительский шаблон и может содержать один символ `*`, соответствующий любой строке. Каждое __Value__ представляет собой список разделенных запятыми дочерних шаблонов, которые должны отображаться вложенными под данным родителем. Дочерние шаблоны могут содержать несколько специальных токенов:
	//* 💡 en - Controls nesting of files in the Explorer. `explorer.fileNesting.enabled` must be set for this to take effect. Each __Item__ represents a parent pattern and may contain a single `*` character that matches any string. Each __Value__ represents a comma separated list of the child patterns that should be shown nested under a given parent. Child patterns may contain several special tokens:
	"explorer.fileNesting.patterns": {
		"*.ts": "${capture}.js",
		"*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
		"*.jsx": "${capture}.js",
		"*.tsx": "${capture}.ts",
		"tsconfig.json": "tsconfig.*.json",
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml"
	},

	//* 💡 ru - Определяет, какую стратегию именования использовать при присвоении нового имени дублированному элементу проводника при вставке.
	//* 💡 en - Controls what naming strategy to use when a giving a new name to a duplicated Explorer item on paste.
	"explorer.incrementalNaming": "simple",

	//* 💡 ru - Минимальное количество слотов редактора, отображаемое на панели «Открыть редакторы». Если установлено значение 0, размер панели «Открыть редакторы» будет динамически изменяться в зависимости от количества редакторов.
	//* 💡 en - The minimum number of editor slots shown in the Open Editors pane. If set to 0 the Open Editors pane will dynamically resize based on the number of editors.
	"explorer.openEditors.minVisible": 0,

	//* 💡 ru - Управляет порядком сортировки редакторов на панели «Открыть редакторы».
	//* 💡 en - Controls the sorting order of editors in the Open Editors pane.
	"explorer.openEditors.sortOrder": "editorOrder",

	//* 💡 ru - Максимальное количество редакторов, отображаемых на панели «Открыть редакторы». Установка этого параметра на 0 скрывает панель «Открытые редакторы».
	//* 💡 en - The maximum number of editors shown in the Open Editors pane. Setting this to 0 hides the Open Editors pane.
	"explorer.openEditors.visible": 9,

	//* 💡 ru - Управляет сортировкой файлов и папок в проводнике на основе свойств.
	//* 💡 en - Controls the property-based sorting of files and folders in the Explorer.
	"explorer.sortOrder": "default",

	//* 💡 ru - Управляет лексикографической сортировкой имен файлов и папок в Проводнике.
	//* 💡 en - Controls the lexicographic sorting of file and folder names in the Explorer.,
	"explorer.sortOrderLexicographicOptions": "default",

	//! ✅ Extensions

	//* 💡 ru - Когда включено, автоматически проверяет расширения на наличие обновлений. Если расширение имеет обновление, оно помечается как устаревшее в представлении «Расширения». Обновления загружаются из онлайн-сервиса Microsoft.
	//* 💡 en - When enabled, automatically checks extensions for updates. If an extension has an update, it is marked as outdated in the Extensions view. The updates are fetched from a Microsoft online service.
	"extensions.autoCheckUpdates": true,

	//* 💡 ru - Управляет поведением автоматического обновления расширений. Обновления загружаются из онлайн-сервиса Microsoft.
	//* 💡 en - Controls the automatic update behavior of extensions. The updates are fetched from a Microsoft online service.
	"extensions.autoUpdate": true,

	//* 💡 ru - Если этот параметр включен, редакторы с подробной информацией о расширении будут автоматически закрываться при выходе из представления расширений.
	//* 💡 en - When enabled, editors with extension details will be automatically closed upon navigating away from the Extensions View.
	"extensions.closeExtensionDetailsOnViewChange": false,

	//* 💡 ru - Когда здесь указано расширение, запрос подтверждения не будет отображаться, когда это расширение обрабатывает URI.
	//* 💡 en - When an extension is listed here, a confirmation prompt will not be shown when that extension handles a URI.
	"extensions.confirmedUriHandlerExtensionIds": [],

	//* 💡 ru - Если этот параметр включен, уведомления о рекомендациях по расширению не будут отображаться.
	//* 💡 en - When enabled, the notifications for extension recommendations will not be shown.
	"extensions.ignoreRecommendations": false,

	//* 💡 ru - Переопределить поддержку ненадежной рабочей области расширения. Расширения, использующие true, всегда будут включены. Расширения, использующие `limited`, всегда будут включены, и расширение будет скрывать функциональность, требующую доверия. Расширения, использующие false, будут включены только в том случае, если рабочая область является доверенной.
	//* 💡 en - Override the untrusted workspace support of an extension. Extensions using `true` will always be enabled. Extensions using `limited` will always be enabled, and the extension will hide functionality that requires trust. Extensions using `false` will only be enabled only when the workspace is trusted.
	"extensions.supportUntrustedWorkspaces": {},

	//* 💡 ru - Переопределить поддержку виртуальных рабочих пространств расширения.
	//* 💡 en - Override the virtual workspaces support of an extension.,
	"extensions.supportVirtualWorkspaces": {},

    //! ✅ Files

    //* 💡 ru - Настройте ассоциации файлов с языками (например, `"*.extension": "html"`). Они имеют приоритет над ассоциациями установленных языков по умолчанию.
    //* 💡 en - Configure file associations to languages (for example `"*.extension": "html"`). These have precedence over the default associations of the languages installed.
    "files.associations": {
		"*.scss": "postcss",
		"*.json": "jsonc"
    },

    //* 💡 ru - Если этот параметр включен, редактор попытается угадать кодировку набора символов при открытии файлов. Этот параметр также можно настроить для каждого языка. Обратите внимание, что этот параметр не учитывается при текстовом поиске. Учитывается только `files.encoding`.
    //* 💡 en - When enabled, the editor will attempt to guess the character set encoding when opening files. This setting can also be configured per language. Note, this setting is not respected by text search. Only `files.encoding` is respected.
    "files.autoGuessEncoding": false,

    //* 💡 ru - Управляет автоматическим сохранением редакторов с несохраненными изменениями.
    //* 💡 en - Controls auto save of editors that have unsaved changes.
    "files.autoSave": "off",

    //* 💡 ru - Управляет задержкой в миллисекундах, после которой редактор с несохраненными изменениями автоматически сохраняется. Применяется только тогда, когда для `files.autoSave` установлено значение `afterDelay`.
    //* 💡 en - Controls the delay in milliseconds after which an editor with unsaved changes is saved automatically. Only applies when `files.autoSave` is set to `afterDelay`.
    "files.autoSaveDelay": 1000,

    //* 💡 ru - Идентификатор языка по умолчанию, который назначается новым файлам. Если настроено на `${activeEditorLanguage}`, будет использоваться идентификатор языка текущего активного текстового редактора, если таковой имеется.
    //* 💡 en - The default language identifier that is assigned to new files. If configured to `${activeEditorLanguage}`, will use the language identifier of the currently active text editor if any.
    "files.defaultLanguage": "",

    //* 💡 ru - При удалении перемещает файлы/папки в корзину ОС (корзину в Windows). Отключение этого параметра приведет к безвозвратному удалению файлов/папок.
    //* 💡 en - Moves files/folders to the OS trash (recycle bin on Windows) when deleting. Disabling this will delete files/folders permanently.
    "files.enableTrash": true,

    //* 💡 ru - Кодировка набора символов по умолчанию для использования при чтении и записи файлов. Этот параметр также можно настроить для каждого языка.
    //* 💡 en - The default character set encoding to use when reading and writing files. This setting can also be configured per language.
    "files.encoding": "utf8",

    //* 💡 ru - Символ конца строки по умолчанию.
    //* 💡 en - The default end of line character.
    "files.eol": "auto",

    //* 💡 ru - Настройте шаблоны глобусов для исключения файлов и папок. Например, File Explorer решает, какие файлы и папки показывать или скрывать, на основе этого параметра. Обратитесь к настройке `search.exclude`, чтобы определить исключения для поиска.
    //* 💡 en - Configure glob patterns for excluding files and folders. For example, the File Explorer decides which files and folders to show or hide based on this setting. Refer to the `search.exclude` setting to define search-specific excludes.
    "files.exclude": {
      "**/.git": true,
      "**/.svn": true,
      "**/.hg": true,
      "**/CVS": true,
      "**/.DS_Store": true,
      "**/Thumbs.db": true
    },

    //* 💡 ru - Определяет, запоминаются ли несохраненные файлы между сеансами, позволяя пропустить запрос на сохранение при выходе из редактора.
    //* 💡 en - Controls whether unsaved files are remembered between sessions, allowing the save prompt when exiting the editor to be skipped.
    "files.hotExit": "onExit",

    //* 💡 ru - Если этот параметр включен, вставляйте последнюю новую строку в конец файла при его сохранении.
    //* 💡 en - When enabled, insert a final new line at the end of the file when saving it.
    "files.insertFinalNewline": false,

    //* 💡 ru - Управляет памятью, доступной для VS Code после перезапуска при попытке открыть большие файлы. Тот же эффект, что и при указании `--max-memory=NEWSIZE` в командной строке.
    //* 💡 en - Controls the memory available to VS Code after restart when trying to open large files. Same effect as specifying `--max-memory=NEWSIZE` on the command line.
    "files.maxMemoryForLargeFilesMB": 4096,

    //* 💡 ru - Тайм-аут в миллисекундах, по истечении которого участники файла для создания, переименования и удаления отменяются. Используйте `0`, чтобы отключить участников.
    //* 💡 en - Timeout in milliseconds after which file participants for create, rename, and delete are cancelled. Use `0` to disable participants.
    "files.participants.timeout": 60000,

    //* 💡 ru - Управляет автоматическим сохранением файлов, которые были частью рефакторинг.
    //* 💡 en - Controls if files that were part of a refactoring are saved automatically.
    "files.refactoring.autoSave": true,

    //* 💡 ru - Восстановление стека отмены при повторном открытии файла.
    //* 💡 en - Restore the undo stack when a file is reopened.
    "files.restoreUndoStack": true,

    //* 💡 ru - Конфликт сохранения может возникнуть, когда файл сохраняется на диск, который тем временем был изменен другой программой. Во избежание потери данных пользователю предлагается сравнить изменения в редакторе с версией на диске. Этот параметр следует изменять только в том случае, если вы часто сталкиваетесь с ошибками сохранения конфликта и может привести к потере данных, если использовать его без осторожности.
    //* 💡 en - A save conflict can occur when a file is saved to disk that was changed by another program in the meantime. To prevent data loss, the user is asked to compare the changes in the editor with the version on disk. This setting should only be changed if you frequently encounter save conflict errors and may result in data loss if used without caution.
    "files.saveConflictResolution": "askUser",

    //* 💡 ru - Включает простой файловый диалог. Простое диалоговое окно файла заменяет диалоговое окно системного файла, когда оно включено.
    //* 💡 en - Enables the simple file dialog. The simple file dialog replaces the system file dialog when enabled.
    "files.simpleDialog.enable": false,

    //* 💡 ru - Если этот параметр включен, все новые строки будут обрезаться после последней новой строки в конце файла при его сохранении.
    //* 💡 en - When enabled, will trim all new lines after the final new line at the end of the file when saving it.
    "files.trimFinalNewlines": false,

    //* 💡 ru - Если этот параметр включен, при сохранении файла будут обрезаны конечные пробелы.
    //* 💡 en - When enabled, will trim trailing whitespace when saving a file.
    "files.trimTrailingWhitespace": false,

    //* 💡 ru - Настройте пути или шаблоны глобусов, чтобы исключить их из просмотра файлов.
    //* 💡 en - Configure paths or glob patterns to exclude from file watching.
    "files.watcherExclude": {
      "**/.git/objects/**": true,
      "**/.git/subtree-cache/**": true,
      "**/node_modules/*/**": true,
      "**/.hg/store/**": true
    },

    //* 💡 ru - Настройте дополнительные пути для отслеживания изменений внутри рабочей области.
    //* 💡 en - Configure extra paths to watch for changes inside the workspace.,
    "files.watcherInclude": [],

	//! ✅ Git

	//* 💡 ru - Подтвердите перед синхронизацией репозиториев git.
	//* 💡 en - Confirm before syncing git repositories.
	"git.confirmSync": false,

	//* 💡 ru - Определяет, включена ли принудительная отправка (с арендой или без нее).
	//* 💡 en - Controls whether force push (with or without lease) is enabled.
	"git.allowForcePush": false,

	//* 💡 ru - Определяет, разрешены ли коммиты без запуска перехватчиков pre-commit и commit-msg.
	//* 💡 en - Controls whether commits without running pre-commit and commit-msg hooks are allowed.
	"git.allowNoVerifyCommit": false,

	//* 💡 ru - Всегда показывать группу ресурсов поэтапных изменений.
	//* 💡 en - Always show the Staged Changes resource group.
	"git.alwaysShowStagedChangesResourceGroup": false,

	//* 💡 ru - Управляет флагом выхода для всех коммитов.
	//* 💡 en - Controls the signoff flag for all commits.
	"git.alwaysSignOff": false,

	//* 💡 ru - Если установлено значение true, коммиты будут автоматически извлекаться из удаленного по умолчанию текущего репозитория Git. Установка на «все» будет получать данные со всех пультов.
	//* 💡 en - When set to true, commits will automatically be fetched from the default remote of the current Git repository. Setting to `all` will fetch from all remotes.
	"git.autofetch": false,

	//* 💡 ru - Продолжительность в секундах между каждой автоматической выборкой git, когда `git.autofetch` включен.
	//* 💡 en - Duration in seconds between each automatic git fetch, when `git.autofetch` is enabled.
	"git.autofetchPeriod": 180,

	//* 💡 ru - Включено ли автоматическое обновление.
	//* 💡 en - Whether auto refreshing is enabled.
	"git.autorefresh": true,

	//* 💡 ru - Настраивает, когда репозитории должны автоматически обнаруживаться.
	//* 💡 en - Configures when repositories should be automatically detected.
	"git.autoRepositoryDetection": true,

	//* 💡 ru - Спрячьте любые изменения перед извлечением и восстановите их после успешного извлечения.
	//* 💡 en - Stash any changes before pulling and restore them after successful pull.
	"git.autoStash": false,

	//* 💡 ru - Префикс, используемый при создании новой ветки.
	//* 💡 en - Prefix used when creating a new branch.
	"git.branchPrefix": "",

	//* 💡 ru - Список защищенных ветвей. По умолчанию перед фиксацией изменений в защищенной ветке отображается запрос. Подсказкой можно управлять с помощью параметра «Подсказка защиты git.branch».
	//* 💡 en - List of protected branches. By default, a prompt is shown before changes are committed to a protected branch. The prompt can be controlled using the `git.branchProtectionPrompt`  setting.
	"git.branchProtection": [],

	//* 💡 ru - Управляет отображением подсказки перед фиксацией изменений в защищенной ветке.
	//* 💡 en - Controls whether a prompt is being shown before changes are committed to a protected branch.
	"git.branchProtectionPrompt": "alwaysPrompt",

	//* 💡 ru - Список словарей, используемых для случайно сгенерированного названия ветки. Каждое значение представляет словарь, используемый для создания сегмента имени ветки. Поддерживаемые словари: «прилагательные», «животные», «цвета» и «числа».
	//* 💡 en - List of dictionaries used for the randomly generated branch name. Each value represents the dictionary used to generate the segment of the branch name. Supported dictionaries: `adjectives`, `animals`, `colors` and `numbers`.
	"git.branchRandomName.dictionary": ["adjectives", "animals"],

	//* 💡 ru - Определяет, генерируется ли случайное имя при создании новой ветки.
	//* 💡 en - Controls whether a random name is generated when creating a new branch.
	"git.branchRandomName.enable": false,

	//* 💡 ru - Управляет порядком сортировки ветвей.
	//* 💡 en - Controls the sort order for branches.
	"git.branchSortOrder": "committerdate",

	//* 💡 ru - Регулярное выражение для проверки имен новых ветвей.
	//* 💡 en - A regular expression to validate new branch names.
	"git.branchValidationRegex": "",

	//* 💡 ru - Символ для замены пробелов в новых именах веток и для разделения сегментов случайно сгенерированного имени ветки.
	//* 💡 en - The character to replace whitespace in new branch names, and to separate segments of a randomly generated branch name.
	"git.branchWhitespaceChar": "-",

	//* 💡 ru - Определяет, какой тип git refs будет отображаться при запуске Checkout to....
	//* 💡 en - Controls what type of git refs are listed when running `Checkout to...`.
	"git.checkoutType": ["local", "remote", "tags"],

	//* 💡 ru - Определяет, должен ли редактор различий автоматически закрываться при сохранении, фиксации, отбрасывании, промежуточном или неустановленном изменении.
	//* 💡 en - Controls whether the diff editor should be automatically closed when changes are stashed, committed, discarded, staged, or unstaged.
	"git.closeDiffOnOperation": false,

	//* 💡 ru - Список команд git (например: commit, push), `stdout` которых будет записан в вывод git. Если для команды git настроен хук на стороне клиента, `stdout` этого хука на стороне клиента также будет записан в вывод git.
	//* 💡 en - List of git commands (ex: commit, push) that would have their `stdout` logged to the git output. If the git command has a client-side hook configured, the client-side hook's `stdout` will also be logged to the git output.
	"git.commandsToLog": [],

	//* 💡 ru - Всегда подтверждайте создание пустых коммитов для команды «Git: Commit Empty».
	//* 💡 en - Always confirm the creation of empty commits for the 'Git: Commit Empty' command.
	"git.confirmEmptyCommits": true,

	//* 💡 ru - Определяет, запрашивать ли подтверждение перед принудительной отправкой.
	//* 💡 en - Controls whether to ask for confirmation before force-pushing.
	"git.confirmForcePush": true,

	//* 💡 ru - Определяет, запрашивать ли подтверждение перед фиксацией без проверки.
	//* 💡 en - Controls whether to ask for confirmation before committing without verification.
	"git.confirmNoVerifyCommit": true,

	//* 💡 ru - Управляет значком счетчика Git.
	//* 💡 en - Controls the Git count badge.
	"git.countBadge": "all",

	//* 💡 ru - Определяет, добавляет ли Git цвета и значки в проводник и представление открытых редакторов.
	//* 💡 en - Controls whether Git contributes colors and badges to the Explorer and the Open Editors view.
	"git.decorations.enabled": true,

	//* 💡 ru - Расположение по умолчанию для клонирования репозитория git.
	//* 💡 en - The default location to clone a git repository.
	"git.defaultCloneDirectory": null,

	//* 💡 ru - Определяет, следует ли автоматически обнаруживать подмодули git.
	//* 💡 en - Controls whether to automatically detect git submodules.
	"git.detectSubmodules": true,

	//* 💡 ru - Управляет пределом обнаруженных подмодулей git.
	//* 💡 en - Controls the limit of git submodules detected.
	"git.detectSubmodulesLimit": 10,

	//* 💡 ru - Включает подписание фиксации с помощью GPG или X.509.
	//* 💡 en - Enables commit signing with GPG or X.509.
	"git.enableCommitSigning": false,

	//* 💡 ru - Включен ли git.
	//* 💡 en - Whether git is enabled.
	"git.enabled": true,

	//* 💡 ru - Зафиксируйте все изменения, если нет поэтапных изменений.
	//* 💡 en - Commit all changes when there are no staged changes.
	"git.enableSmartCommit": false,

	//* 💡 ru - Определяет, отображается ли команда Git Sync в строке состояния.
	//* 💡 en - Controls whether the Git Sync command appears in the status bar.
	"git.enableStatusBarSync": true,

	//* 💡 ru - Если включено, извлекать все ветки при извлечении. В противном случае выберите только текущий.
	//* 💡 en - When enabled, fetch all branches when pulling. Otherwise, fetch just the current one.
	"git.fetchOnPull": false,

	//* 💡 ru - Следуйте push all tags при выполнении команды синхронизации.
	//* 💡 en - Follow push all tags when running the sync command.
	"git.followTagsWhenSync": false,

	//* 💡 ru - Список репозиториев git, которые следует игнорировать.
	//* 💡 en - List of git repositories to ignore.
	"git.ignoredRepositories": [],

	//* 💡 ru - Игнорирует устаревшее предупреждение Git.
	//* 💡 en - Ignores the legacy Git warning.
	"git.ignoreLegacyWarning": false,

	//* 💡 ru - Игнорирует предупреждение, когда в репозитории слишком много изменений.
	//* 💡 en - Ignores the warning when there are too many changes in a repository.
	"git.ignoreLimitWarning": false,

	//* 💡 ru - Игнорирует предупреждение, когда Git отсутствует.
	//* 💡 en - Ignores the warning when Git is missing.
	"git.ignoreMissingGitWarning": false,

	//* 💡 ru - Игнорирует предупреждение, когда кажется, что ветвь могла быть перебазирована при извлечении.
	//* 💡 en - Ignores the warning when it looks like the branch might have been rebased when pulling.
	"git.ignoreRebaseWarning": false,

	//* 💡 ru - Игнорировать изменения подмодулей в дереве файлов.
	//* 💡 en - Ignore modifications to submodules in the file tree.
	"git.ignoreSubmodules": false,

	//* 💡 ru - Игнорирует предупреждение, если Git 2.25–2.26 установлен в Windows.
	//* 💡 en - Ignores the warning when Git 2.25 - 2.26 is installed on Windows.
	"git.ignoreWindowsGit27Warning": false,

	//* 💡 ru - Определяет, когда отображать подтверждение ввода сообщения фиксации.
	//* 💡 en - Controls when to show commit message input validation.
	"git.inputValidation": "warn",

	//* 💡 ru - Управляет порогом длины сообщения фиксации для отображения предупреждения.
	//* 💡 en - Controls the commit message length threshold for showing a warning.
	"git.inputValidationLength": 72,

	//* 💡 ru - Управляет порогом длины темы сообщения фиксации для отображения предупреждения. Снимите его, чтобы унаследовать значение `config.input Validation Length`.
	//* 💡 en - Controls the commit message subject length threshold for showing a warning. Unset it to inherit the value of `config.inputValidationLength`.
	"git.inputValidationSubjectLength": 50,

	//* 💡 ru - Откройте редактор слияния для файлов, которые в данный момент конфликтуют.
	//* 💡 en - Open the merge editor for files that are currently under conflict.
	"git.mergeEditor": false,

	//* 💡 ru - Определяет, открывать ли репозиторий автоматически после клонирования.
	//* 💡 en - Controls whether to open a repository automatically after cloning.
	"git.openAfterClone": "prompt",

	//* 💡 ru - Определяет, должен ли открываться редактор различий при нажатии на изменение. В противном случае будет открыт обычный редактор.
	//* 💡 en - Controls whether the diff editor should be opened when clicking a change. Otherwise the regular editor will be opened.
	"git.openDiffOnClick": true,

	//* 💡 ru - Определяет, следует ли оптимистично обновлять состояние представления системы управления версиями после выполнения команд git.
	//* 💡 en - Controls whether to optimistically update the state of the Source Control view after running git commands.
	"git.optimisticUpdate": true,

	//* 💡 ru - Путь и имя исполняемого файла git, например. `C:\Program Files\Git\bin\git.exe` (Windows). Это также может быть массив строковых значений, содержащий несколько путей для поиска.
	//* 💡 en - Path and filename of the git executable, e.g. `C:\Program Files\Git\bin\git.exe` (Windows). This can also be an array of string values containing multiple paths to look up.
	"git.path": null,

	//* 💡 ru - Запустите команду git после успешной фиксации.
	//* 💡 en - Run a git command after a successful commit.
	"git.postCommitCommand": "none",

	//* 💡 ru - Определяет, должен ли Git проверять несохраненные файлы перед фиксацией.
	//* 💡 en - Controls whether Git should check for unsaved files before committing.
	"git.promptToSaveFilesBeforeCommit": "always",

	//* 💡 ru - Определяет, должен ли Git проверять наличие несохраненных файлов перед сохранением изменений.
	//* 💡 en - Controls whether Git should check for unsaved files before stashing changes.
	"git.promptToSaveFilesBeforeStash": "always",

	//* 💡 ru - Обрезать при извлечении.
	//* 💡 en - Prune when fetching.
	"git.pruneOnFetch": false,

	//* 💡 ru - Определяет, будет ли ветвь, не имеющая исходящих коммитов, перемотаться вперед перед ее извлечением.
	//* 💡 en - Controls whether a branch that does not have outgoing commits is fast-forwarded before it is checked out.
	"git.pullBeforeCheckout": false,

	//* 💡 ru - Получить все теги при вытягивании.
	//* 💡 en - Fetch all tags when pulling.
	"git.pullTags": true,

	//* 💡 ru - Заставьте git использовать rebase при выполнении команды синхронизации.
	//* 💡 en - Force git to use rebase when running the sync command.
	"git.rebaseWhenSync": false,

	//* 💡 ru - Вспомните последнюю команду git, которая выполнялась после коммита.
	//* 💡 en - Remember the last git command that ran after a commit.
	"git.rememberPostCommitCommand": false,

	//* 💡 ru - Список папок, которые игнорируются при сканировании репозиториев Git в git.auto Repository Detection, имеет значение true или subFolders.
	//* 💡 en - List of folders that are ignored while scanning for Git repositories when `git.autoRepositoryDetection` is set to `true` or `subFolders`.
	"git.repositoryScanIgnoredFolders": ["node_modules"],

	//* 💡 ru - Управляет глубиной, используемой при сканировании папок рабочей области для репозиториев Git, когда для параметра «Обнаружение репозитория git.auto» установлено значение «true» или «подпапки». Может быть установлено на `-1` без ограничений.
	//* 💡 en - Controls the depth used when scanning workspace folders for Git repositories when `git.autoRepositoryDetection` is set to `true` or `subFolders`. Can be set to `-1` for no limit.
	"git.repositoryScanMaxDepth": 1,

	//* 💡 ru - Определяет, требуется ли явная пользовательская конфигурация Git или позволяет Git угадывать ее отсутствие.
	//* 💡 en - Controls whether to require explicit Git user configuration or allow Git to guess if missing.
	"git.requireGitUserConfig": true,

	//* 💡 ru - Список путей для поиска git-репозиториев.
	//* 💡 en - List of paths to search for git repositories in.
	"git.scanRepositories": [],

	//* 💡 ru - Определяет, отображается ли кнопка действия в представлении системы управления версиями.
	//* 💡 en - Controls whether an action button is shown in the Source Control view.
	"git.showActionButton": {
		"commit": true,
		"publish": true,
		"sync": true
	},

	//* 💡 ru - Определяет, отображать ли ввод фиксации в панели управления исходным кодом Git.
	//* 💡 en - Controls whether to show the commit input in the Git source control panel.
	"git.showCommitInput": true,

	//* 💡 ru - Определяет, отображать ли встроенное действие «Открыть файл» в представлении изменений Git.
	//* 💡 en - Controls whether to show an inline Open File action in the Git changes view.
	"git.showInlineOpenFileAction": true,

	//* 💡 ru - Определяет, должны ли действия git отображать ход выполнения.
	//* 💡 en - Controls whether git actions should show progress.
	"git.showProgress": true,

	//* 💡 ru - Определяет, отображать ли уведомление при успешной отправке.
	//* 💡 en - Controls whether to show a notification when a push is successful.
	"git.showPushSuccessNotification": false,

	//* 💡 ru - Управляйте тем, какие изменения автоматически размещаются с помощью Smart Commit.
	//* 💡 en - Control which changes are automatically staged by Smart Commit.
	"git.smartCommitChanges": "all",

	//* 💡 ru - Определяет, как ограничить количество изменений, которые можно проанализировать с помощью команды Git status. Можно установить на 0 без ограничений.
	//* 💡 en - Controls how to limit the number of changes that can be parsed from Git status command. Can be set to 0 for no limit.
	"git.statusLimit": 10000,

	//* 💡 ru - Предлагает включить умную фиксацию (фиксировать все изменения, когда нет поэтапных изменений).
	//* 💡 en - Suggests to enable smart commit (commit all changes when there are no staged changes).
	"git.suggestSmartCommit": true,

	//* 💡 ru - Определяет, появляется ли уведомление при выполнении действия синхронизации, которое позволяет пользователю отменить операцию.
	//* 💡 en - Controls whether a notification comes up when running the Sync action, which allows the user to cancel the operation.
	"git.supportCancellation": false,

