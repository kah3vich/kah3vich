{
  // 🟢 Editor

  // 🇷🇺 - Размер Таба.
  // 🇺🇸 - Taba size.
  "editor.tabSize": 4,

  // 🇷🇺 - Включение переноса слов.
  // 🇺🇸 - Enable word wrap.
  "editor.wordWrap": "on",

  // 🇷🇺 - Сворачивание кусков кода.
  // 🇺🇸 - Folding pieces of code.
  "editor.folding": true,

  // 🇷🇺 - Отступы Табом.
  // 🇺🇸 - Tab indents.
  "editor.insertSpaces": true,

  // 🇷🇺 - Плавная прокрутка.
  // 🇺🇸 - Smooth scrolling.
  "editor.smoothScrolling": true,

  // 🇷🇺 - Мини-карта кода.
  // 🇺🇸 - Code minimap.
  "editor.minimap.enabled": true,

  // 🇷🇺 - Тип размера мини-карты.
  // 🇺🇸 - Minimap size type.
  "editor.minimap.size": "fill",

  // 🇷🇺 - Удаление всего Таба.
  // 🇺🇸 - Minimap size type.
  "editor.detectIndentation": true,

  // 🇷🇺 - Позволяет прокручивать редактор дальше последний строки.
  // 🇺🇸 - Allows the editor to scroll beyond the last line.
  "editor.scrollBeyondLastLine": true,

  // 🇷🇺 - Отображение кастомным сниппетов в самом верху.
  // 🇺🇸 - Display custom snippets at the very top.
  "editor.snippetSuggestions": "bottom",

  // 🇷🇺 - Включение мультикурсора на указанную кнопку.
  // 🇺🇸 - Turn on the multicursor on the specified button.
  "editor.multiCursorModifier": "alt",

  // 🇷🇺 - Определяет, должен ли редактор отображать управляющие символы.
  // 🇺🇸 - Specifies whether the editor should display control characters.
  "editor.renderControlCharacters": false,

  // 🇷🇺 - Определяет, выделяются ли символы, которые можно спутать с основными символами ASCII, за исключением тех, которые распространены в текущем языковом стандарте пользователя.
  // 🇺🇸 - Determines whether characters that can be confused with basic ASCII characters, other than those common in the user's current locale, are highlighted.
  "editor.unicodeHighlight.ambiguousCharacters": true,

  // 🇷🇺 - Переключение по snippet`y кнопкой Tab.
  // 🇺🇸 - Switching by snippet`y with the Tab button.
  "editor.tabCompletion": "on",

  // 🇷🇺 - Включить форматирование при сохранение файла.
  // 🇺🇸 - Enable formatting when saving a file.
  "editor.formatOnSave": true,

  // 🇷🇺 - Определяет, должен ли редактор автоматически форматировать вставленное содержимое. Модуль форматирования должен быть доступен, и модуль форматирования должен иметь возможность форматировать диапазон в документе.
  // 🇺🇸 - Specifies whether the editor should automatically format pasted content. The formatter must be available, and the formatter must be able to format the range in the document.
  "editor.formatOnPaste": false,

  // 🇷🇺 - Определяет, должен ли редактор автоматически форматировать строку после ввода.
  // 🇺🇸 - Specifies whether the editor should automatically format the string after input.
  "editor.formatOnType": false,

  // 🇷🇺 - Определяет, форматирует ли формат при сохранении весь файл или только его модификации. Применяется только тогда, когда включен `editor.formatOnSave`.
  // 🇺🇸 - Specifies whether the format formats the entire file or only modifications of the file when saved. Applies only when `editor.formatOnSave` is enabled.
  "editor.formatOnSaveMode": "file",

  // 🇷🇺 - Установка дефолтного расширения для vscode.
  // 🇺🇸 - Installing the default extension for vscode.
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // 🇷🇺 - Действия при сохранение файла.
  // 🇺🇸 - Actions when saving a file.
  "editor.codeActionsOnSave": {
    // 🇷🇺 - Использование приводит к удалению неиспользуемых инструкций импорта и к размещению команд импорта таким образом, чтобы сначала шли бы команды, в которых используются абсолютные пути.
    // 🇺🇸 - Use causes unused import statements to be removed and import commands to be placed so that commands that use absolute paths come first.
    "source.organizeImports": true
  },

  // 🇷🇺 - Определяет, распределяются ли запомненные варианты выбора между несколькими рабочими пространствами и окнами (требуется `editor.suggestSelection`).
  // 🇺🇸 - Determines whether learned choices are shared across multiple workspaces and windows (requires `editor.suggestSelection`).
  "editor.suggestSelection": "first",

  // 🇷🇺 - Управляет миганием курсора терминала.
  // 🇺🇸 - Controls the blinking of the terminal cursor.
  "editor.cursorBlinking": "expand",

  // 🇷🇺 - Определяет, включена ли раскраска пары скобок или нет. Используйте `workbench.colorCustomizations`, чтобы переопределить цвета подсветки скобок.
  // 🇺🇸 - Specifies whether brace pair coloring is enabled or not. Use `workbench.colorCustomizations` to override bracket highlight colors.
  "editor.bracketPairColorization.enabled": false,

  // 🇷🇺 - Настраивает лигатуры шрифта или функции шрифта. Может быть либо логическим значением для включения/отключения лигатур, либо строкой для значения свойства CSS 'font-feature-settings'.
  // 🇺🇸 - Customizes font ligatures or font features. Can be either a boolean to enable/disable ligatures, or a string for the value of the 'font-feature-settings' CSS property.
  "editor.fontLigatures": true,

  // 🇷🇺 - Начертание шрифта.
  // 🇺🇸 - Font style.
  "editor.fontWeight": 400,

  // 🇷🇺 - Размер шрифта.
  // 🇺🇸 - Font size.
  "editor.fontSize": 16,

  // 🇷🇺 - Высота строки.
  // 🇺🇸 - Line height.
  "editor.lineHeight": 24,

  // 🇷🇺 - Установка семейство шрифтов.
  // 🇺🇸 - Font family installation.
  "editor.fontFamily": "Zed Mono, JetBrains Mono, monospace",

  // 🇷🇺 - Определяет, должен ли редактор отображать вертикальное поле глифа.
  // 🇺🇸 - Specifies whether the editor should display the glyph's vertical margin.
  "editor.glyphMargin": false,

  // 🇷🇺 - Определяет, показывает ли редактор CodeLens.
  // 🇺🇸 - Controls whether the editor shows CodeLens.
  "diffEditor.codeLens": false,

  // 🇷🇺 - Когда включено, редактор различий игнорирует изменения в начальных или конечных пробелах.
  // 🇺🇸 - When enabled, the diff editor ignores changes in leading or trailing whitespace.
  "diffEditor.ignoreTrimWhitespace": true,

  // 🇷🇺 - Тайм-аут в миллисекундах, по истечении которого расчет различий отменяется. Используйте 0 для отсутствия тайм-аута.
  // 🇺🇸 - Timeout in milliseconds after which diff computation is cancelled. Use 0 for no timeout.
  "diffEditor.maxComputationTime": 5000,

  // 🇷🇺 - Управляет отображением в редакторе различий индикаторов +/- для добавленных/удаленных изменений.
  // 🇺🇸 - Controls whether the diff editor shows +/- indicators for added/removed changes.
  "diffEditor.renderIndicators": true,

  // 🇷🇺 - Если этот параметр включен, редактор различий показывает стрелки на полях глифов, чтобы отменить изменения.
  // 🇺🇸 - When enabled, the diff editor shows arrows in its glyph margin to revert changes.
  "diffEditor.renderMarginRevertIcon": true,

  // 🇷🇺 - Определяет, будет ли редактор различий отображать различия рядом или в строке.
  // 🇺🇸 - Controls whether the diff editor shows the diff side by side or inline.
  "diffEditor.renderSideBySide": true,

  // 🇷🇺 - Строки будут переноситься в соответствии с настройкой `editor.wordWrap`.
  // 🇺🇸 - Lines will wrap according to the `editor.wordWrap` setting.
  "diffEditor.wordWrap": "inherit",

  // 🇷🇺 - Определяет, следует ли принимать предложения для символов фиксации. Например, в JavaScript точка с запятой (`; `) может быть символом фиксации, который принимает предложение и вводит этот символ.
  // 🇺🇸 - Controls whether suggestions should be accepted on commit characters. For example, in JavaScript, the semi-colon (`; `) can be a commit character that accepts a suggestion and types that character.
  "editor.acceptSuggestionOnCommitCharacter": true,

  // 🇷🇺 - Определяет, следует ли принимать предложения при нажатии клавиши «Enter» в дополнение к «Tab». Помогает избежать двусмысленности между вставкой новых строк или принятием предложений.
  // 🇺🇸 - Controls whether suggestions should be accepted on `Enter`, in addition to `Tab`. Helps to avoid ambiguity between inserting new lines or accepting suggestions.
  "editor.acceptSuggestionOnEnter": "on",

  // 🇷🇺 - Определяет, должен ли редактор работать в режиме, оптимизированном для чтения с экрана.
  // 🇺🇸 - Controls whether the editor should run in a mode where it is optimized for screen readers.
  "editor.accessibilitySupport": "auto",

  // 🇷🇺 - Определяет, должен ли редактор автоматически закрывать скобки после того, как пользователь добавляет открывающую скобку.
  // 🇺🇸 - Controls whether the editor should automatically close brackets after the user adds an opening bracket.
  "editor.autoClosingBrackets": "languageDefined",

  // 🇷🇺 - Определяет, должен ли редактор удалять соседние закрывающие кавычки или квадратные скобки при удалении.
  // 🇺🇸 - Controls whether the editor should remove adjacent closing quotes or brackets when deleting.
  "editor.autoClosingDelete": "auto",

  // 🇷🇺 - Определяет, должен ли редактор печатать с закрывающими кавычками или скобками.
  // 🇺🇸 - Controls whether the editor should type over closing quotes or brackets.
  "editor.autoClosingOvertype": "auto",

  // 🇷🇺 - Определяет, должен ли редактор автоматически закрывать кавычки после добавления пользователем открывающей кавычки.
  // 🇺🇸 - Controls whether the editor should automatically close quotes after the user adds an opening quote.
  "editor.autoClosingQuotes": "languageDefined",

  // 🇷🇺 - Определяет, должен ли редактор автоматически регулировать отступ, когда пользователи печатают, вставляют, перемещают или делают отступы строк.
  // 🇺🇸 - Controls whether the editor should automatically adjust the indentation when users type, paste, move or indent lines.
  "editor.autoIndent": "full",

  // 🇷🇺 - Определяет, должен ли редактор автоматически окружать выделение при вводе кавычек или квадратных скобок.
  // 🇺🇸 - Controls whether the editor should automatically surround selections when typing quotes or brackets.
  "editor.autoSurround": "languageDefined",

  // 🇷🇺 - Определяет, имеет ли каждый тип скобки собственный независимый набор цветов.
  // 🇺🇸 - Controls whether each bracket type has its own independent color pool.
  "editor.bracketPairColorization.independentColorPoolPerBracketType": false,

  // 🇷🇺 - Включить/отключить отображение заголовков групп в меню «Действие кода».
  // 🇺🇸 - Enable/disable showing group headers in the Code Action menu.
  "editor.codeActionWidget.showHeaders": true,

  // 🇷🇺 - Определяет, показывает ли редактор CodeLens.
  // 🇺🇸 - Controls whether the editor shows CodeLens.
  "editor.codeLens": true,

  // 🇷🇺 - Управляет семейством шрифтов для CodeLens.
  // 🇺🇸 - Controls the font family for CodeLens.
  "editor.codeLensFontFamily": "",

  // 🇷🇺 - Управляет размером шрифта в пикселях для CodeLens. При значении 0 используется 90% `editor.fontSize`.
  // 🇺🇸 - Controls the font size in pixels for CodeLens. When set to 0, 90% of `editor.fontSize` is used.
  "editor.codeLensFontSize": 0,

  // 🇷🇺 - Определяет, должен ли редактор отображать встроенные декораторы цвета и палитру цветов.
  // 🇺🇸 - Controls whether the editor should render the inline color decorators and color picker.
  "editor.colorDecorators": true,

  // 🇷🇺 - Включите, чтобы выбор с помощью мыши и клавиш выполнял выбор столбца.
  // 🇺🇸 - Enable that the selection with the mouse and keys is doing column selection.
  "editor.columnSelection": false,

  // 🇷🇺 - Определяет, следует ли игнорировать пустые строки с помощью переключения, добавления или удаления действий для комментариев строки.
  // 🇺🇸 - Controls if empty lines should be ignored with toggle, add or remove actions for line comments.
  "editor.comments.ignoreEmptyLines": true,

  // 🇷🇺 - Определяет, вставляется ли пробел при комментировании.
  // 🇺🇸 - Controls whether a space character is inserted when commenting.
  "editor.comments.insertSpace": true,

  // 🇷🇺 - Определяет, следует ли копировать подсветку синтаксиса в буфер обмена.
  // 🇺🇸 - Controls whether syntax highlighting should be copied into the clipboard.
  "editor.copyWithSyntaxHighlighting": true,

  // 🇷🇺 - Определяет, должна ли быть включена плавная анимация курсора.
  // 🇺🇸 - Controls whether the smooth caret animation should be enabled.
  "editor.cursorSmoothCaretAnimation": false,

  // 🇷🇺 - Управляет стилем курсора.
  // 🇺🇸 - Controls the cursor style.
  "editor.cursorStyle": "line",

  // 🇷🇺 - Управляет минимальным количеством видимых начальных и конечных строк, окружающих курсор. В некоторых других редакторах известен как «scrollOff» или «scrollOffset».
  // 🇺🇸 - Controls the minimal number of visible leading and trailing lines surrounding the cursor. Known as 'scrollOff' or 'scrollOffset' in some other editors.
  "editor.cursorSurroundingLines": 0,

  // 🇷🇺 - Контролирует, когда должны применяться `cursorSurroundingLines`.
  // 🇺🇸 - Controls when `cursorSurroundingLines` should be enforced.
  "editor.cursorSurroundingLinesStyle": "default",

  // 🇷🇺 - Управляет шириной курсора, когда для `editor.cursorStyle` установлено значение `line`.
  // 🇺🇸 - Controls the width of the cursor when `editor.cursorStyle` is set to `line`.
  "editor.cursorWidth": 0,

  // 🇷🇺 - Определяет поставщика диапазона сворачивания по умолчанию, который имеет приоритет над всеми другими поставщиками диапазона сворачивания. Должен быть идентификатором расширения, вносящего поставщики диапазона свертки.
  // 🇺🇸 - Defines a default folding range provider that takes precedence over all other folding range provider. Must be the identifier of an extension contributing a folding range providers.
  "editor.defaultFoldingRangeProvider": null,

  // 🇷🇺 - Определяет, всегда ли жест мыши «Переход к определению» открывает виджет просмотра.
  // 🇺🇸 - Controls whether the Go to Definition mouse gesture always opens the peek widget.
  "editor.definitionLinkOpensInPeek": false,

  // 🇷🇺 - Определяет, должен ли редактор разрешать перемещение выделения с помощью перетаскивания.
  // 🇺🇸 - Controls whether the editor should allow moving selections via drag and drop.
  "editor.dragAndDrop": true,

  // 🇷🇺 - Определяет, можете ли вы перетаскивать файл в текстовый редактор, удерживая нажатой клавишу `shift` (вместо открытия файла в редакторе).
  // 🇺🇸 - Controls whether you can drag and drop a file into a text editor by holding down `shift` (instead of opening the file in an editor).
  "editor.dropIntoEditor.enabled": true,

  // 🇷🇺 - Определяет, копирует ли копирование без выделения текущую строку.
  // 🇺🇸 - Controls whether copying without a selection copies the current line.
  "editor.emptySelectionClipboard": true,

  // 🇷🇺 - Множитель скорости прокрутки при нажатии Alt.
  // 🇺🇸 - Scrolling speed multiplier when pressing `Alt`.
  "editor.fastScrollSensitivity": 5,

  // 🇷🇺 - Определяет, должен ли виджет «Найти» добавлять дополнительные строки поверх редактора. Если установлено значение true, вы можете прокручивать дальше первой строки, когда отображается виджет «Найти».
  // 🇺🇸 - Controls whether the Find Widget should add extra lines on top of the editor. When true, you can scroll beyond the first line when the Find Widget is visible.
  "editor.find.addExtraSpaceOnTop": true,

  // 🇷🇺 - Управляет условием автоматического включения функции «Найти в выделенном».
  // 🇺🇸 - Controls the condition for turning on Find in Selection automatically.
  "editor.find.autoFindInSelection": "never",

  // 🇷🇺 - Определяет, должен ли курсор прыгать, чтобы найти совпадения во время ввода.
  // 🇺🇸 - Controls whether the cursor should jump to find matches while typing.
  "editor.find.cursorMoveOnType": true,

  // 🇷🇺 - Определяет, должен ли виджет «Найти» читать или изменять общий буфер поиска в macOS.
  // 🇺🇸 - Controls whether the Find Widget should read or modify the shared find clipboard on macOS.
  "editor.find.globalFindClipboard": false,

  // 🇷🇺 - Определяет, будет ли поиск автоматически перезапускаться с начала (или с конца), когда больше не будет найдено совпадений.
  // 🇺🇸 - Controls whether the search automatically restarts from the beginning (or the end) when no further matches can be found.
  "editor.find.loop": true,

  // 🇷🇺 - Определяет, берется ли строка поиска в виджет поиска из выбора редактора.
  // 🇺🇸 - Controls whether the search string in the Find Widget is seeded from the editor selection.
  "editor.find.seedSearchStringFromSelection": "always",

  // 🇷🇺 - Определяет, должен ли редактор выделять свернутые диапазоны.
  // 🇺🇸 - Controls whether the editor should highlight folded ranges.
  "editor.foldingHighlight": true,

  // 🇷🇺 - Определяет, будет ли редактор автоматически сворачивать диапазоны импорта.
  // 🇺🇸 - Controls whether the editor automatically collapses import ranges.
  "editor.foldingImportsByDefault": false,

  // 🇷🇺 - Управляет стратегией расчета диапазонов фолда.
  // 🇺🇸 - Controls the strategy for computing folding ranges.
  "editor.foldingStrategy": "auto",

  // 🇷🇺 - Настраивает варианты шрифта. Может быть либо логическим значением для включения/выключения перевода из font-weight в font-variation-settings, либо строкой для значения свойства CSS 'font-variation-settings'.
  // 🇺🇸 - Configures font variations. Can be either a boolean to enable/disable the translation from font-weight to font-variation-settings or a string for the value of the CSS 'font-variation-settings' property.
  "editor.fontVariations": false,

  // 🇷🇺 - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к объявлению» является текущее местоположение.
  // 🇺🇸 - Alternative command id that is being executed when the result of 'Go to Declaration' is the current location.
  "editor.gotoLocation.alternativeDeclarationCommand": "editor.action.goToReferences",

  // 🇷🇺 - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к определению» является текущее местоположение.
  // 🇺🇸 - Alternative command id that is being executed when the result of 'Go to Definition' is the current location.
  "editor.gotoLocation.alternativeDefinitionCommand": "editor.action.goToReferences",

  // 🇷🇺 - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к реализации» является текущее местоположение.
  // 🇺🇸 - Alternative command id that is being executed when the result of 'Go to Implementation' is the current location.
  "editor.gotoLocation.alternativeImplementationCommand": "",

  // 🇷🇺 - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к ссылке» является текущее местоположение.
  // 🇺🇸 - Alternative command id that is being executed when the result of 'Go to Reference' is the current location.
  "editor.gotoLocation.alternativeReferenceCommand": "",

  // 🇷🇺 - Идентификатор альтернативной команды, которая выполняется, когда результатом «Перейти к определению типа» является текущее местоположение.
  // 🇺🇸 - Alternative command id that is being executed when the result of 'Go to Type Definition' is the current location.
  "editor.gotoLocation.alternativeTypeDefinitionCommand": "editor.action.goToReferences",

  // 🇷🇺 - Управляет поведением команды «Перейти к объявлению», когда существует несколько целевых местоположений.
  // 🇺🇸 - Controls the behavior the 'Go to Declaration'-command when multiple target locations exist.
  "editor.gotoLocation.multipleDeclarations": "peek",

  // 🇷🇺 - Управляет поведением команды «Перейти к определению», когда существует несколько целевых местоположений.
  // 🇺🇸 - Controls the behavior the 'Go to Definition'-command when multiple target locations exist.
  "editor.gotoLocation.multipleDefinitions": "peek",

  // 🇷🇺 - Управляет поведением команды «Перейти к реализациям», когда существует несколько целевых местоположений.
  // 🇺🇸 - Controls the behavior the 'Go to Implementations'-command when multiple target locations exist.
  "editor.gotoLocation.multipleImplementations": "peek",

  // 🇷🇺 - Controls the behavior the 'Go to References'-command when multiple target locations exist.
  // 🇺🇸 - Controls the behavior the 'Go to References'-command when multiple target locations exist.
  "editor.gotoLocation.multipleReferences": "peek",

  // 🇷🇺 - Управляет поведением команды «Перейти к определению типа», когда существует несколько целевых местоположений.
  // 🇺🇸 - Controls the behavior the 'Go to Type Definition'-command when multiple target locations exist.
  "editor.gotoLocation.multipleTypeDefinitions": "peek",

  // 🇷🇺 - Определяет, включены ли направляющие пары скобок.
  // 🇺🇸 - Controls whether bracket pair guides are enabled or not.
  "editor.guides.bracketPairs": false,

  // 🇷🇺 - Определяет, включены ли направляющие пар горизонтальных скобок или нет.
  // 🇺🇸 - Controls whether horizontal bracket pair guides are enabled or not.
  "editor.guides.bracketPairsHorizontal": "active",

  // 🇷🇺 - Определяет, должен ли редактор выделять активную пару скобок.
  // 🇺🇸 - Controls whether the editor should highlight the active bracket pair.
  "editor.guides.highlightActiveBracketPair": true,

  // 🇷🇺 - Определяет, должен ли редактор выделять активную направляющую отступа.
  // 🇺🇸 - Controls whether the editor should highlight the active indent guide.
  "editor.guides.highlightActiveIndentation": true,

  // 🇷🇺 - Определяет, должен ли редактор отображать направляющие отступов.
  // 🇺🇸 - Controls whether the editor should render indent guides.
  "editor.guides.indentation": true,

  // 🇷🇺 - Определяет, должен ли курсор быть скрыт в обзорной линейке.
  // 🇺🇸 - Controls whether the cursor should be hidden in the overview ruler.
  "editor.hideCursorInOverviewRuler": false,

  // 🇷🇺 - Предпочитаю показывать ховеры над линией, если есть место.
  // 🇺🇸 - Prefer showing hovers above the line, if there's space.
  "editor.hover.above": true,

  // 🇷🇺 - Управляет задержкой в миллисекундах, после которой отображается наведение.
  // 🇺🇸 - Controls the delay in milliseconds after which the hover is shown.
  "editor.hover.delay": 300,

  // 🇷🇺 - Определяет, отображается ли наведение.
  // 🇺🇸 - Controls whether the hover is shown.
  "editor.hover.enabled": true,

  // 🇷🇺 - Определяет, должно ли наведение оставаться видимым при наведении на него мыши.
  // 🇺🇸 - Controls whether the hover should remain visible when mouse is moved over it.
  "editor.hover.sticky": true,

  // 🇷🇺 - Количество пробелов, используемых для отступа или `"tabSize"`, чтобы использовать значение из `editor.tabSize#`. Этот параметр переопределяется на основе содержимого файла, когда включен параметр `#editor.detectIndentation`.
  // 🇺🇸 - The number of spaces used for indentation or `"tabSize"` to use the value from `editor.tabSize#`. This setting is overridden based on the file contents when `#editor.detectIndentation` is on.
  "editor.indentSize": "tabSize",

  // 🇷🇺 - Включает подсказки вкладок в редакторе.
  // 🇺🇸 - Enables the inlay hints in the editor.
  "editor.inlayHints.enabled": "on",

  // 🇷🇺 - Управляет семейством шрифтов подсказок вкладок в редакторе. Если установлено пустое, используется `editor.fontFamily`.
  // 🇺🇸 - Controls font family of inlay hints in the editor. When set to empty, the `editor.fontFamily` is used.
  "editor.inlayHints.fontFamily": "",

  // 🇷🇺 - Управляет размером шрифта подсказок вкладок в редакторе. По умолчанию `editor.fontSize` используется, когда настроенное значение меньше 5 или больше размера шрифта редактора.
  // 🇺🇸 - Controls font size of inlay hints in the editor. As default the `editor.fontSize` is used when the configured value is less than `5` or greater than the editor font size.
  "editor.inlayHints.fontSize": 0,

  // 🇷🇺 - Включает отступы вокруг подсказок вкладок в редакторе.
  // 🇺🇸 - Enables the padding around the inlay hints in the editor.
  "editor.inlayHints.padding": false,

  // 🇷🇺 - Включает отступы вокруг подсказок вкладок в редакторе.
  // 🇺🇸 - Controls whether to automatically show inline suggestions in the editor.
  "editor.inlineSuggest.enabled": true,

  // 🇷🇺 - Определяет символы скобок, которые увеличивают или уменьшают отступ.
  // 🇺🇸 - Defines the bracket symbols that increase or decrease the indentation.
  "editor.language.brackets": null,

  // 🇷🇺 - Определяет пары скобок, которые окрашиваются в соответствии с их уровнем вложенности, если включено раскрашивание пар скобок.
  // 🇺🇸 - Defines the bracket pairs that are colorized by their nesting level if bracket pair colorization is enabled.
  "editor.language.colorizedBracketPairs": null,

  // 🇷🇺 - Управляет расстоянием между буквами в пикселях.
  // 🇺🇸 - Controls the letter spacing in pixels.
  "editor.letterSpacing": 0,

  // 🇷🇺 - Включает лампочку Code Action в редакторе.
  // 🇺🇸 - Enables the Code Action lightbulb in the editor.
  "editor.lightbulb.enabled": true,

  // 🇷🇺 - Управляет отображением номеров строк.
  // 🇺🇸 - Controls the display of line numbers.
  "editor.lineNumbers": "on",

  // 🇷🇺 - Определяет, включено ли в редакторе связанное редактирование. В зависимости от языка связанные символы, такие как теги HTML, обновляются при редактировании.
  // 🇺🇸 - Controls whether the editor has linked editing enabled. Depending on the language, related symbols such as HTML tags, are updated while editing.
  "editor.linkedEditing": false,

  // 🇷🇺 - Определяет, должен ли редактор обнаруживать ссылки и делать их активными.
  // 🇺🇸 - Controls whether the editor should detect links and make them clickable.
  "editor.links": true,

  // 🇷🇺 - Выделите соответствующие скобки.
  // 🇺🇸 - Highlight matching brackets.
  "editor.matchBrackets": "always",

  // 🇷🇺 - Определяет, скрывается ли миникарта автоматически.
  // 🇺🇸 - Controls whether the minimap is hidden automatically.
  "editor.minimap.autohide": false,

  // 🇷🇺 - Ограничьте ширину миникарты, чтобы отобразить не более определенного количества столбцов.
  // 🇺🇸 - Limit the width of the minimap to render at most a certain number of columns.
  "editor.minimap.maxColumn": 120,

  // 🇷🇺 - Визуализируйте фактические символы в строке, а не цветные блоки.
  // 🇺🇸 - Render the actual characters on a line as opposed to color blocks.
  "editor.minimap.renderCharacters": true,

  // 🇷🇺 - Масштаб отрисовываемого на миникарте контента: 1, 2 или 3.
  // 🇺🇸 - Scale of content drawn in the minimap: 1, 2 or 3.
  "editor.minimap.scale": 1,

  // 🇷🇺 - Управляет отображением ползунка миникарты.
  // 🇺🇸 - Controls when the minimap slider is shown.
  "editor.minimap.showSlider": "mouseover",

  // 🇷🇺 - Управляет стороной, на которой должна отображаться мини-карта.
  // 🇺🇸 - Controls the side where to render the minimap.
  "editor.minimap.side": "right",

  // 🇷🇺 - Множитель, который будет использоваться для `deltaX` и `deltaY` событий прокрутки колеса мыши.
  // 🇺🇸 - A multiplier to be used on the `deltaX` and `deltaY` of mouse wheel scroll events.
  "editor.mouseWheelScrollSensitivity": 1,

  // 🇷🇺 - Масштабирование шрифта редактора при использовании колесика мыши и удерживании `Ctrl`.
  // 🇺🇸 - Zoom the font of the editor when using mouse wheel and holding `Ctrl`.
  "editor.mouseWheelZoom": false,

  // 🇷🇺 - Управляет вставкой, когда количество строк вставляемого текста совпадает с количеством строк курсора.
  // 🇺🇸 - Controls pasting when the line count of the pasted text matches the cursor count.
  "editor.multiCursorPaste": "spread",

  // 🇷🇺 - Определяет, должен ли редактор выделять вхождения семантических символов.
  // 🇺🇸 - Controls whether the editor should highlight semantic symbol occurrences.
  "editor.occurrencesHighlight": true,

  // 🇷🇺 - Определяет, следует ли рисовать границу вокруг линейки обзора.
  // 🇺🇸 - Controls whether a border should be drawn around the overview ruler.
  "editor.overviewRulerBorder": true,

  // 🇷🇺 - Управляет расстоянием между нижним краем редактора и последней строкой.
  // 🇺🇸 - Controls the amount of space between the bottom edge of the editor and the last line.
  "editor.padding.bottom": 0,

  // 🇷🇺 - Управляет расстоянием между верхним краем редактора и первой строкой.
  // 🇺🇸 - Controls the amount of space between the top edge of the editor and the first line.
  "editor.padding.top": 0,

  // 🇷🇺 - Определяет, намекает ли параметр на циклы меню или закрывается при достижении конца списка.
  // 🇺🇸 - Controls whether the parameter hints menu cycles or closes when reaching the end of the list.
  "editor.parameterHints.cycle": false,

  // 🇷🇺 - Включает всплывающее окно, в котором отображается документация по параметрам и информация о типе по мере ввода.
  // 🇺🇸 - Enables a pop-up that shows parameter documentation and type information as you type.
  "editor.parameterHints.enabled": true,

  // 🇷🇺 - Определяет, следует ли сфокусировать встроенный редактор или дерево в виджете просмотра.
  // 🇺🇸 - Controls whether to focus the inline editor or the tree in the peek widget.
  "editor.peekWidgetDefaultFocus": "tree",

  // 🇷🇺 - Определяет, должны ли предложения автоматически отображаться при наборе текста.
  // 🇺🇸 - Controls whether suggestions should automatically show up while typing.
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "off"
  },

  // 🇷🇺 - Управляет задержкой в миллисекундах, после которой будут отображаться быстрые предложения.
  // 🇺🇸 - Controls the delay in milliseconds after which quick suggestions will show up.
  "editor.quickSuggestionsDelay": 10,

  // 🇷🇺 - Включить/отключить возможность предварительного просмотра изменений перед переименованием.
  // 🇺🇸 - Enable/disable the ability to preview changes before renaming.
  "editor.rename.enablePreview": true,

  // 🇷🇺 - Отображать номер последней строки, когда файл заканчивается новой строкой.
  // 🇺🇸 - Render last line number when the file ends with a newline.
  "editor.renderFinalNewline": true,

  // 🇷🇺 - Управляет тем, как редактор должен отображать текущую подсветку строки.
  // 🇺🇸 - Controls how the editor should render the current line highlight.
  "editor.renderLineHighlight": "line",

  // 🇷🇺 - Определяет, должен ли редактор отображать текущую подсветку строки только тогда, когда редактор находится в фокусе.
  // 🇺🇸 - Controls if the editor should render the current line highlight only when the editor is focused.
  "editor.renderLineHighlightOnlyWhenFocus": false,

  // 🇷🇺 - Управляет тем, как редактор должен отображать пробельные символы.
  // 🇺🇸 - Controls how the editor should render whitespace characters.
  "editor.renderWhitespace": "selection",

  // 🇷🇺 - Определяет, должны ли выделенные области иметь закругленные углы.
  // 🇺🇸 - Controls whether selections should have rounded corners.
  "editor.roundedSelection": true,

  // 🇷🇺 - Отображать вертикальные линейки после определенного количества моноширинных символов. Используйте несколько значений для нескольких линеек. Если массив пуст, линейки не рисуются.
  // 🇺🇸 - Render vertical rulers after a certain number of monospace characters. Use multiple values for multiple rulers. No rulers are drawn if array is empty.
  "editor.rulers": [],

  // 🇷🇺 - Управляет видимостью горизонтальной полосы прокрутки.
  // 🇺🇸 - Controls the visibility of the horizontal scrollbar.
  "editor.scrollbar.horizontal": "auto",

  // 🇷🇺 - Высота горизонтальной полосы прокрутки.
  // 🇺🇸 - The height of the horizontal scrollbar.
  "editor.scrollbar.horizontalScrollbarSize": 12,

  // 🇷🇺 - Определяет, будут ли щелчки прокручиваться по странице или переходить к месту щелчка.
  // 🇺🇸 - Controls whether clicks scroll by page or jump to click position.
  "editor.scrollbar.scrollByPage": false,

  // 🇷🇺 - Управляет видимостью вертикальной полосы прокрутки.
  // 🇺🇸 - Controls the visibility of the vertical scrollbar.
  "editor.scrollbar.vertical": "auto",

  // 🇷🇺 - Ширина вертикальной полосы прокрутки.
  // 🇺🇸 - The width of the vertical scrollbar.
  "editor.scrollbar.verticalScrollbarSize": 14,

  // 🇷🇺 - Управляет количеством дополнительных символов, после которых редактор будет прокручиваться по горизонтали.
  // 🇺🇸 - Controls the number of extra characters beyond which the editor will scroll horizontally.
  "editor.scrollBeyondLastColumn": 4,

  // 🇷🇺 - Определяет, должен ли поддерживаться основной буфер обмена Linux.
  // 🇺🇸 - Controls whether the Linux primary clipboard should be supported.
  "editor.selectionClipboard": true,

  // 🇷🇺 - Прокручивайте только вдоль преобладающей оси при одновременной прокрутке и по вертикали, и по горизонтали. Предотвращает смещение по горизонтали при вертикальной прокрутке на трекпаде.
  // 🇺🇸 - Scroll only along the predominant axis when scrolling both vertically and horizontally at the same time. Prevents horizontal drift when scrolling vertically on a trackpad.
  "editor.scrollPredominantAxis": true,

  // 🇷🇺 - Определяет, должен ли редактор выделять совпадения, похожие на выделение.
  // 🇺🇸 - Controls whether the editor should highlight matches similar to the selection.
  "editor.selectionHighlight": true,

  // 🇷🇺 - Определяет, отображается ли семантическая подсветка для языков, которые ее поддерживают.
  // 🇺🇸 - Controls whether the semanticHighlighting is shown for the languages that support it.
  "editor.semanticHighlighting.enabled": "configuredByTheme",

  // 🇷🇺 - Переопределяет цвет и стили семантического маркера редактора из текущей выбранной цветовой темы.
  // 🇺🇸 - Overrides editor semantic token color and styles from the currently selected color theme.
  "editor.semanticTokenColorCustomizations": {},

  // 🇷🇺 - Управляет зачеркнутыми устаревшими переменными.
  // 🇺🇸 - Controls strikethrough deprecated variables.
  "editor.showDeprecated": true,

  // 🇷🇺 - Элементы управления, когда отображаются элементы управления складыванием желоба.
  // 🇺🇸 - Controls when the folding controls on the gutter are shown.
  "editor.showFoldingControls": "mouseover",

  // 🇷🇺 - Контролирует исчезновение неиспользуемого кода.
  // 🇺🇸 - Controls fading out of unused code.
  "editor.showUnused": true,

  // 🇷🇺 - Следует ли всегда выбирать начальные и конечные пробелы.
  // 🇺🇸 - Whether leading and trailing whitespace should always be selected.
  "editor.smartSelect.selectLeadingAndTrailingWhitespace": true,

  // 🇷🇺 - Определяет, будут ли фрагменты окружения фрагментами или фрагменты шаблонов файлов отображаться как действия кода.
  // 🇺🇸 - Controls if surround-with-snippets or file template snippets show as Code Actions.
  "editor.snippets.codeActions.enabled": true,

  // 🇷🇺 - Держите редакторы просмотра открытыми, даже если дважды щелкнете по их содержимому или нажмете «Escape».
  // 🇺🇸 - Keep peek editors open even when double clicking their content or when hitting `Escape`.
  "editor.stablePeek": false,

  // 🇷🇺 - Показывает вложенные текущие области во время прокрутки в верхней части редактора.
  // 🇺🇸 - Shows the nested current scopes during the scroll at the top of the editor.
  "editor.stickyScroll.enabled": false,

  // 🇷🇺 - Определяет максимальное количество липких строк для отображения.
  // 🇺🇸 - Defines the maximum number of sticky lines to show.
  "editor.stickyScroll.maxLineCount": 5,

  // 🇷🇺 - Эмулируйте поведение выбора символов табуляции при использовании пробелов для отступа. Выбор будет придерживаться позиций табуляции.
  // 🇺🇸 - Emulate selection behavior of tab characters when using spaces for indentation. Selection will stick to tab stops.
  "editor.stickyTabStops": false,

  // 🇷🇺 - Определяет, учитывают ли предложения фильтрации и сортировки небольшие опечатки.
  // 🇺🇸 - Controls whether filtering and sorting suggestions accounts for small typos.
  "editor.suggest.filterGraceful": true,

  // 🇷🇺 - Управляет перезаписью слов при принятии завершения. Обратите внимание, что это зависит от расширений, использующих эту функцию.
  // 🇺🇸 - Controls whether words are overwritten when accepting completions. Note that this depends on extensions opting into this feature.
  "editor.suggest.insertMode": "insert",

  // 🇷🇺 - Определяет, будут ли при сортировке отдавать предпочтение слова, расположенные рядом с курсором.
  // 🇺🇸 - Controls whether sorting favors words that appear close to the cursor.
  "editor.suggest.localityBonus": false,

  // 🇷🇺 - При включенной фильтрации IntelliSense требуется, чтобы первый символ совпадал с началом слова. Например, `c` в `Console` или `WebContext`, но не в `description`.
  // 🇺🇸 - When enabled IntelliSense filtering requires that the first character matches on a word start. For example, `c` on `Console` or `WebContext` but not on `description`.
  "editor.suggest.matchOnWordStartOnly": true,

  // 🇷🇺 - Определяет, следует ли предварительно просмотреть результат предложения в редакторе.
  // 🇺🇸 - Controls whether to preview the suggestion outcome in the editor.
  "editor.suggest.preview": false,

  // 🇷🇺 - Определяет, распределяются ли запомненные варианты выбора между несколькими рабочими пространствами и окнами (требуется `editor.suggestSelection`).
  // 🇺🇸 - Controls whether remembered suggestion selections are shared between multiple workspaces and windows (needs `editor.suggestSelection`).
  "editor.suggest.shareSuggestSelections": false,

  // 🇷🇺 - При включении IntelliSense показывает `классовые`-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `class`-suggestions.
  "editor.suggest.showClasses": true,

  // 🇷🇺 - При включении IntelliSense показывает «цветовые» предложения.
  // 🇺🇸 - When enabled IntelliSense shows `color`-suggestions.
  "editor.suggest.showColors": true,

  // 🇷🇺 - При включении IntelliSense показывает «постоянные» предложения.
  // 🇺🇸 - When enabled IntelliSense shows `constant`-suggestions.
  "editor.suggest.showConstants": true,

  // 🇷🇺 - При включении IntelliSense показывает «постоянные» предложения.
  // 🇺🇸 - При включении IntelliSense показывает «постоянные» предложения.
  "editor.suggest.showConstructors": true,

  // 🇷🇺 - При включении IntelliSense показывает «постоянные» предложения.
  // 🇺🇸 - При включении IntelliSense показывает «постоянные» предложения.
  "editor.suggest.showCustomcolors": true,

  // 🇷🇺 - При включении IntelliSense показывает «постоянные» предложения.
  // 🇺🇸 - При включении IntelliSense показывает «постоянные» предложения.
  "editor.suggest.showDeprecated": true,

  // 🇷🇺 - При включении IntelliSense показывает `enumMember`-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `enumMember`-suggestions.
  "editor.suggest.showEnumMembers": true,

  // 🇷🇺 - При включении IntelliSense показывает `enum`-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `enum`-suggestions.
  "editor.suggest.showEnums": true,

  // 🇷🇺 - При включении IntelliSense показывает "события"-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `event`-suggestions.
  "editor.suggest.showEvents": true,

  // 🇷🇺 - При включении IntelliSense показывает «предложения полей».
  // 🇺🇸 - When enabled IntelliSense shows `field`-suggestions.
  "editor.suggest.showFields": true,

  // 🇷🇺 - При включении IntelliSense показывает «файловые» предложения.
  // 🇺🇸 - When enabled IntelliSense shows `file`-suggestions.
  "editor.suggest.showFiles": true,

  // 🇷🇺 - При включении IntelliSense показывает «папки»-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `folder`-suggestions.
  "editor.suggest.showFolders": true,

  // 🇷🇺 - При включении IntelliSense показывает `функции`-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `function`-suggestions.
  "editor.suggest.showFunctions": true,

  // 🇷🇺 - Определяет, показывать или скрывать значки в предложениях.
  // 🇺🇸 - Controls whether to show or hide icons in suggestions.
  "editor.suggest.showIcons": true,

  // 🇷🇺 - Определяет, будут ли предлагаться подробные сведения вместе с меткой или только в виджете сведений.
  // 🇺🇸 - Controls whether suggest details show inline with the label or only in the details widget.
  "editor.suggest.showInlineDetails": true,

  // 🇷🇺 - При включении IntelliSense показывает предложения интерфейса.
  // 🇺🇸 - When enabled IntelliSense shows `interface`-suggestions.
  "editor.suggest.showInterfaces": true,

  // 🇷🇺 - При включении IntelliSense показывает "проблемы"-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `issues`-suggestions.
  "editor.suggest.showIssues": true,

  // 🇷🇺 - При включении IntelliSense показывает предложения по ключевым словам.
  // 🇺🇸 - When enabled IntelliSense shows `keyword`-suggestions.
  "editor.suggest.showKeywords": true,

  // 🇷🇺 - При включении IntelliSense показывает «методы»-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `method`-suggestions.
  "editor.suggest.showMethods": true,

  // 🇷🇺 - При включении IntelliSense показывает «модульные» предложения.
  // 🇺🇸 - When enabled IntelliSense shows `module`-suggestions.
  "editor.suggest.showModules": true,

  // 🇷🇺 - При включении IntelliSense показывает «предложения оператора».
  // 🇺🇸 - When enabled IntelliSense shows `operator`-suggestions.
  "editor.suggest.showOperators": true,

  // 🇷🇺 - При включении IntelliSense показывает «свойства»-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `property`-suggestions.
  "editor.suggest.showProperties": true,

  // 🇷🇺 - При включении IntelliSense показывает «справочные» предложения.
  // 🇺🇸 - When enabled IntelliSense shows `reference`-suggestions.
  "editor.suggest.showReferences": true,

  // 🇷🇺 - При включении IntelliSense показывает «сниппеты»-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `snippet`-suggestions.
  "editor.suggest.showSnippets": true,

  // 🇷🇺 - Управляет видимостью строки состояния в нижней части виджета предложения.
  // 🇺🇸 - Controls the visibility of the status bar at the bottom of the suggest widget.
  "editor.suggest.showStatusBar": false,

  // 🇷🇺 - При включении IntelliSense показывает предложения `struct`.
  // 🇺🇸 - When enabled IntelliSense shows `struct`-suggestions.
  "editor.suggest.showStructs": true,

  // 🇷🇺 - При включении IntelliSense показывает «тип параметра» — предложения.
  // 🇺🇸 - When enabled IntelliSense shows `typeParameter`-suggestions.
  "editor.suggest.showTypeParameters": true,

  // 🇷🇺 - Когда включено, IntelliSense показывает «единицы»-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `unit`-suggestions.
  "editor.suggest.showUnits": true,

  // 🇷🇺 - При включении IntelliSense показывает предложения пользователя.
  // 🇺🇸 - When enabled IntelliSense shows `user`-suggestions.
  "editor.suggest.showUsers": true,

  // 🇷🇺 - При включении IntelliSense показывает «значения»-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `value`-suggestions.
  "editor.suggest.showValues": true,

  // 🇷🇺 - При включении IntelliSense показывает `переменные`-предложения.
  // 🇺🇸 - When enabled IntelliSense shows `variable`-suggestions.
  "editor.suggest.showVariables": true,

  // 🇷🇺 - При включении IntelliSense показывает «текстовые» предложения.
  // 🇺🇸 - When enabled IntelliSense shows `text`-suggestions.
  "editor.suggest.showWords": true,

  // 🇷🇺 - Определяет, предотвращает ли активный фрагмент быстрые предложения.
  // 🇺🇸 - Controls whether an active snippet prevents quick suggestions.
  "editor.suggest.snippetsPreventQuickSuggestions": true,

  // 🇷🇺 - Размер шрифта для виджета предложений. Если установлено значение «0», используется значение «editor.fontSize».
  // 🇺🇸 - Font size for the suggest widget. When set to `0`, the value of `editor.fontSize` is used.
  "editor.suggestFontSize": 0,

  // 🇷🇺 - Высота строки для виджета предложения. Если установлено значение «0», используется значение «editor.lineHeight». Минимальное значение равно 8.
  // 🇺🇸 - Line height for the suggest widget. When set to `0`, the value of `editor.lineHeight` is used. The minimum value is 8.
  "editor.suggestLineHeight": 0,

  // 🇷🇺 - Определяет, должны ли автоматически появляться предложения при вводе триггерных символов.
  // 🇺🇸 - Controls whether suggestions should automatically show up when typing trigger characters.
  "editor.suggestOnTriggerCharacters": true,

  // 🇷🇺 - Переопределяет цвета синтаксиса редактора и стиль шрифта из текущей выбранной цветовой темы.
  // 🇺🇸 - Overrides editor syntax colors and font style from the currently selected color theme.
  "editor.tokenColorCustomizations": {},

  // 🇷🇺 - Удалить завершающие автоматически вставленные пробелы.
  // 🇺🇸 - Remove trailing auto inserted whitespace.
  "editor.trimAutoWhitespace": true,

  // 🇷🇺 - Определяет, будет ли щелчок по пустому содержимому после свернутой строки разворачивать строку.
  // 🇺🇸 - Controls whether clicking on the empty content after a folded line will unfold the line.
  "editor.unfoldOnClickAfterEndOfLine": false,

  // 🇷🇺 - Определяет разрешенные символы, которые не выделяются.
  // 🇺🇸 - Defines allowed characters that are not being highlighted.
  "editor.unicodeHighlight.allowedCharacters": {},

  // 🇷🇺 - Символы Unicode, распространенные в разрешенных локалях, не выделяются.
  // 🇺🇸 - Unicode characters that are common in allowed locales are not being highlighted.
  "editor.unicodeHighlight.allowedLocales": {
    "_os": true,
    "_vscode": true
  },

  // 🇷🇺 - Определяет, должны ли символы в комментариях также подсвечиваться Unicode.
  // 🇺🇸 - Controls whether characters in comments should also be subject to Unicode highlighting.
  "editor.unicodeHighlight.includeComments": "inUntrustedWorkspace",

  // 🇷🇺 - Определяет, должны ли символы в строках также подсвечиваться Unicode.
  // 🇺🇸 - Controls whether characters in strings should also be subject to Unicode highlighting.
  "editor.unicodeHighlight.includeStrings": true,

  // 🇷🇺 - Определяет, выделяются ли символы, которые просто резервируют пространство или вообще не имеют ширины.
  // 🇺🇸 - Controls whether characters that just reserve space or have no width at all are highlighted.
  "editor.unicodeHighlight.invisibleCharacters": true,

  // 🇷🇺 - Определяет, будут ли выделены все неосновные символы ASCII. Только символы между U+0020 и U+007E, символы табуляции, перевода строки и возврата каретки считаются базовыми ASCII.
  // 🇺🇸 - Controls whether all non-basic ASCII characters are highlighted. Only characters between U+0020 and U+007E, tab, line-feed and carriage-return are considered basic ASCII.
  "editor.unicodeHighlight.nonBasicASCII": "inUntrustedWorkspace",

  // 🇷🇺 - Удалите необычные разделители строк, которые могут вызвать проблемы.
  // 🇺🇸 - Remove unusual line terminators that might cause problems.
  "editor.unusualLineTerminators": "prompt",

  // 🇷🇺 - Вставка и удаление пробелов следует за позициями табуляции.
  // 🇺🇸 - Inserting and deleting whitespace follows tab stops.
  "editor.useTabStops": true,

  // 🇷🇺 - Определяет, должны ли завершения вычисляться на основе слов в документе.
  // 🇺🇸 - Controls whether completions should be computed based on words in the document.
  "editor.wordBasedSuggestions": true,

  // 🇷🇺 - Определяет, из каких документов вычисляются завершения на основе слов.
  // 🇺🇸 - Controls from which documents word based completions are computed.
  "editor.wordBasedSuggestionsMode": "matchingDocuments",

  // 🇷🇺 - Управляет правилами разрыва слов, используемыми для текста на китайском, японском и корейском языках (CJK).
  // 🇺🇸 - Controls the word break rules used for Chinese/Japanese/Korean (CJK) text.
  "editor.wordBreak": "normal",

  // 🇷🇺 - Символы, которые будут использоваться в качестве разделителей слов при навигации или операциях, связанных со словами.
  // 🇺🇸 - Characters that will be used as word separators when doing word related navigations or operations.
  "editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\|;:'\",.<>/?",

  // 🇷🇺 - Управляет столбцом переноса редактора, когда `editor.wordWrap` имеет значение `wordWrapColumn` или `bounded`.
  // 🇺🇸 - Controls the wrapping column of the editor when `editor.wordWrap` is `wordWrapColumn` or `bounded`.
  "editor.wordWrapColumn": 80,

  // 🇷🇺 - Управляет отступом переносимых строк.
  // 🇺🇸 - Controls the indentation of wrapped lines.
  "editor.wrappingIndent": "same",

  // 🇷🇺 - Управляет алгоритмом, вычисляющим точки переноса.
  // 🇺🇸 - Controls the algorithm that computes wrapping points.
  "editor.wrappingStrategy": "simple"
}
