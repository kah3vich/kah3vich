{
	//! ✅ GitHub

	//* 💡 ru - Определяет, следует ли включать автоматическую аутентификацию GitHub для команд git в VS Code.
	//* 💡 en - Controls whether to enable automatic GitHub authentication for git commands within VS Code.
	"github.gitAuthentication": true,

	//* 💡 ru - Определяет, какой протокол используется для клонирования репозитория GitHub.
	//* 💡 en - Controls which protocol is used to clone a GitHub repository.
	"github.gitProtocol": "https",

	//* 💡 ru - URI корпоративного сервера GitHub.
	//* 💡 en - GitHub Enterprise Server URI.
	"github-enterprise.uri": ""
}
