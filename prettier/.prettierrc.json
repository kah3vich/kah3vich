{
    //* 💡 ru - Размер таба.
    //* 💡 en - Size tabs.
    "tabWidth": 4,

    //* 💡 ru - Использовать одинарные кавычки вместо двойных кавычек.
    //* 💡 en - Single quotes are used instead of double quotes.
    "singleQuote": true,

    //* 💡 ru - Использовать одинарные кавычки вместо двойных в JSX.
    //* 💡 en - Single quotes are used instead of double quotes in JSX.
    "jsxSingleQuote": true,

    //* 💡 ru - Включить круглые скобки вокруг единственного параметра функции стрелки.
    //* 💡 en - Includes parentheses around the single parameter of the arrow function.
    "arrowParens": "avoid",

    //* 💡 ru - Писать точки с запятой в конце операторов.
    //* 💡 en - Writes semicolons at the end of statements.
    "semi": true,

    //* 💡 ru - Писать в конце запятые везде, где это возможно, в многострочных синтаксических структурах, разделенных запятыми.
    //* 💡 en - Use trailing commas wherever possible, in comma-separated multi-line syntax structures.
    "trailingComma": "none",

    //* 💡 ru - Использовать отступы с помощью табуляции вместо пробелов.
    //* 💡 en - Indent with tabs instead of spaces.
    "useTabs": true,

    //* 💡 ru - Используется, когда свойства в объектах заключены в кавычки.
    //* 💡 en - beta.
    "quoteProps": "as-needed",

    //* 💡 ru - Печатать пробелы между скобками в литералах объекта. 
    //* 💡 en - Печатать пробелы между скобками в литералах объекта. 
    "bracketSpacing": true,

    //* 💡 ru - Поместите >элемент многострочного HTML (HTML, JSX, Vue, Angular) в конец последней строки, а не в одиночку на следующей строке (не относится к самозакрывающимся элементам).
    //* 💡 en - Put the multi-line HTML (HTML, JSX, Vue, Angular) element at the end of the last line, not alone on the next line (does not apply to self-closing elements).
    "bracketSameLine": false,

    //* 💡 ru - Используйте один атрибут в строке в HTML, Vue и JSX.
    //* 💡 en - Use one attribute per line in HTML, Vue and JSX.
    "singleAttributePerLine": true
}
