{
  // 🟢 Breadcrumbs

  // 🇷🇺 - Рендеринг элементов навигации с помощью значков.
  // 🇺🇸 - Rendering navigation elements using icons.
  "breadcrumbs.icons": false,

  // 🇷🇺 - При включении хлебных крошек отображаются символы `ключей`.
  // 🇺🇸 - When breadcrumbs are enabled, `key` symbols are displayed.
  "breadcrumbs.showKeys": false,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают символы `file`.
  // 🇺🇸 - When enabled, breadcrumbs show the `file` characters.
  "breadcrumbs.showFiles": false,

  // 🇷🇺 - Управляет тем, отображаются ли символы в представлении навигационных крошек и каким образом.
  // 🇺🇸 - Controls whether and how symbols are displayed in the navigation crumbs view.
  "breadcrumbs.symbolPath": "off",

  // 🇷🇺 - Когда хлебные крошки включены, они показывают символы массива.
  // 🇺🇸 - When breadcrumbs are enabled, they show array characters.
  "breadcrumbs.showArrays": false,

  // 🇷🇺 - При включении хлебных крошек отображаются символы «события».
  // 🇺🇸 - When breadcrumbs are turned on, "event" symbols are displayed.
  "breadcrumbs.showEvents": false,

  // 🇷🇺 - При включении хлебные крошки показывают символы `поля`.
  // 🇺🇸 - When enabled, breadcrumbs show `field` symbols.
  "breadcrumbs.showFields": false,

  // 🇷🇺 - При включении хлебных крошек отображаются символы класса.
  // 🇺🇸 - When breadcrumbs are enabled, class symbols are displayed.
  "breadcrumbs.showClasses": false,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают `метод` - символы.
  // 🇺🇸 - When breadcrumbs are enabled, they show the `method` symbols.
  "breadcrumbs.showMethods": false,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают логические символы.
  // 🇺🇸 - When breadcrumbs are on, they show boolean symbols.
  "breadcrumbs.showBooleans": false,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают `функциональные` - символы.
  // 🇺🇸 - When breadcrumbs are enabled, they show `functional` symbols.
  "breadcrumbs.showFunctions": false,

  // 🇷🇺 - При включении хлебных крошек отображаются `постоянные` - символы.
  // 🇺🇸 - When breadcrumbs are enabled, `permanent` characters are displayed.
  "breadcrumbs.showConstants": false,

  // 🇷🇺 - При включении хлебных крошек отображаются символы `enumMember`.
  // 🇺🇸 - When breadcrumbs are enabled, `enumMember` characters are displayed.
  "breadcrumbs.showEnumMembers": false,

  // 🇷🇺 - При включении хлебных крошек отображаются символы-конструкторы.
  // 🇺🇸 - When breadcrumbs are enabled, constructor symbols are displayed.
  "breadcrumbs.showConstructors": false,

  // 🇷🇺 - Включить/отключить навигационные крошки.
  // 🇺🇸 - Enable/disable navigation breadcrumbs.
  "breadcrumbs.enabled": true,

  // 🇷🇺 - Определяет, будут ли и каким образом пути к файлам отображаться в представлении «хлебных крошек».
  // 🇺🇸 - Controls whether and how file paths are shown in the breadcrumbs view.
  "breadcrumbs.filePath": "on",

  // 🇷🇺 - Когда хлебные крошки включены, они показывают `enum`-символы.
  // 🇺🇸 - When enabled breadcrumbs show `enum`-symbols.
  "breadcrumbs.showEnums": true,

  // 🇷🇺 - При включении хлебных крошек отображаются символы `module`.
  // 🇺🇸 - When enabled breadcrumbs show `interface`-symbols.
  "breadcrumbs.showInterfaces": true,

  // 🇷🇺 - При включении хлебных крошек отображаются символы `module`.
  // 🇺🇸 - When enabled breadcrumbs show `module`-symbols.
  "breadcrumbs.showModules": true,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают символы пространства имен.
  // 🇺🇸 - When enabled breadcrumbs show `namespace`-symbols.
  "breadcrumbs.showNamespaces": true,

  // 🇷🇺 - При включении хлебных крошек отображаются нулевые символы.
  // 🇺🇸 - When enabled breadcrumbs show `null`-symbols.
  "breadcrumbs.showNull": true,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают числовые символы.
  // 🇺🇸 - When enabled breadcrumbs show `number`-symbols.
  "breadcrumbs.showNumbers": true,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают `объектные` символы.
  // 🇺🇸 - When enabled breadcrumbs show `object`-symbols.
  "breadcrumbs.showObjects": true,

  // 🇷🇺 - При включении хлебные крошки показывают символы оператора.
  // 🇺🇸 - When enabled breadcrumbs show `operator`-symbols.
  "breadcrumbs.showOperators": true,

  // 🇷🇺 - При включении хлебных крошек отображаются символы `package`.
  // 🇺🇸 - When enabled breadcrumbs show `package`-symbols.
  "breadcrumbs.showPackages": true,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают `property`-символы.
  // 🇺🇸 - When enabled breadcrumbs show `property`-symbols.
  "breadcrumbs.showProperties": true,

  // 🇷🇺 - При включении хлебные крошки показывают `строковые` символы.
  // 🇺🇸 - When enabled breadcrumbs show `string`-symbols.
  "breadcrumbs.showStrings": true,

  // 🇷🇺 - Когда хлебные крошки включены, они показывают `struct`-символы.
  // 🇺🇸 - When enabled breadcrumbs show `struct`-symbols.
  "breadcrumbs.showStructs": true,

  // 🇷🇺 - При включении хлебные крошки показывают символы `typeParameter`.
  // 🇺🇸 - When enabled breadcrumbs show `typeParameter`-symbols.
  "breadcrumbs.showTypeParameters": true,

  // 🇷🇺 - При включении хлебных крошек отображаются `переменные`-символы.
  // 🇺🇸 - When enabled breadcrumbs show `variable`-symbols.
  "breadcrumbs.showVariables": true,

  // 🇷🇺 - Управляет сортировкой символов в представлении схемы навигационных крошек.
  // 🇺🇸 - Controls how symbols are sorted in the breadcrumbs outline view.
  "breadcrumbs.symbolSortOrder": "position"
}
