	//! ✅ VS Intelli Code

	//* 💡 ru - Управляет предварительным выбором предложений при отображении списка предложений.
	//* 💡 en - Controls the pre-selection of offers when displaying a list of offers.
	"vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",

	//! ✅ VS Code Pets

	//* 💡 ru - Tема заднего фона.
