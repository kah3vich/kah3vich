	//* 💡 en - Integrated Terminal

	//* 💡 ru - 123
	//* 💡 en - Whether or not to allow chord keybindings in the terminal. Note that when this is true and the keystroke results in a chord it will bypass `terminal.integrated.commandsToSkipShell`, setting this to false is particularly useful when you want ctrl+k to go to your shell (not VS Code).
	"terminal.integrated.allowChords": true,

	//* 💡 ru - 123
	//* 💡 en - Whether to allow menubar mnemonics (for example Alt+F) to trigger the open of the menubar. Note that this will cause all alt keystrokes to skip the shell when true. This does nothing on macOS.
	"terminal.integrated.allowMnemonics": false,

	//* 💡 ru - 123
	//* 💡 en - If enabled, alt/option + click will reposition the prompt cursor to underneath the mouse when `editor.multiCursorModifier` is set to `'alt'` (the default value). This may not work reliably depending on your shell.
	"terminal.integrated.altClickMovesCursor": true,

	//* 💡 ru - 123
	//* 💡 en - The terminal profile to use on Linux for automation-related terminal usage like tasks and debug.
	"terminal.integrated.automationProfile.linux": null,

	//* 💡 ru - 123
	//* 💡 en - The terminal profile to use on macOS for automation-related terminal usage like tasks and debug.
	"terminal.integrated.automationProfile.osx": null,

	//* 💡 ru - 123
	//* 💡 en - The terminal profile to use for automation-related terminal usage like tasks and debug.
	"terminal.integrated.automationProfile.windows": null,

	//* 💡 ru - 123
	//* 💡 en - A set of messages that when encountered in the terminal will be automatically responded to. Provided the message is specific enough, this can help automate away common responses.
	"terminal.integrated.autoReplies": {},

	//* 💡 ru - 123
	//* 💡 en - The number of milliseconds to show the bell within a terminal tab when triggered.
	"terminal.integrated.bellDuration": 1000,

	//* 💡 ru - 123
	//* 💡 en - A set of command IDs whose keybindings will not be sent to the shell but instead always be handled by VS Code. This allows keybindings that would normally be consumed by the shell to act instead the same as when the terminal is not focused, for example `Ctrl+P` to launch Quick Open.
	"terminal.integrated.commandsToSkipShell": [],

	//* 💡 ru - 123
	//* 💡 en - Controls whether to confirm when the window closes if there are active terminal sessions.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never confirm.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always confirm if there are terminals.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - hasChildProcesses: Confirm if there are any terminals that have child processes.
	"terminal.integrated.confirmOnExit": "never",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to confirm killing terminals when they have child processes. When set to editor, terminals in the editor area will be marked as changed when they have child processes. Note that child process detection may not work well for shells like Git Bash which don't run their processes as child processes of the shell.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never confirm.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - editor: Confirm if the terminal is in the editor.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - panel: Confirm if the terminal is in the panel.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Confirm if the terminal is either in the editor or panel.
	"terminal.integrated.confirmOnKill": "editor",

	//* 💡 ru - 123
	//* 💡 en - Controls whether text selected in the terminal will be copied to the clipboard.
	"terminal.integrated.copyOnSelection": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the terminal cursor blinks.
	"terminal.integrated.cursorBlinking": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the style of terminal cursor.
	"terminal.integrated.cursorStyle": "block",

	//* 💡 ru - 123
	//* 💡 en - Controls the width of the cursor when `terminal.integrated.cursorStyle` is set to `line`.
	"terminal.integrated.cursorWidth": 1,

	//* 💡 ru - 123
	//* 💡 en - Whether to draw custom glyphs for block element and box drawing characters instead of using the font, which typically yields better rendering with continuous lines. Note that this doesn't work with the DOM renderer.
	"terminal.integrated.customGlyphs": true,

	//* 💡 ru - 123
	//* 💡 en - An explicit start path where the terminal will be launched, this is used as the current working directory (cwd) for the shell process. This may be particularly useful in workspace settings if the root directory is not a convenient cwd.
	"terminal.integrated.cwd": "",

	//* 💡 ru - 123
	//* 💡 en - Controls where newly created terminals will appear.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - editor: Create terminals in the editor
	//* 💡 ru - 123
	//* 💡 en - 123
	// - view: Create terminals in the terminal view
	"terminal.integrated.defaultLocation": "view",

	//* 💡 ru - 123
	//* 💡 en - The default profile used on Linux. This setting will currently be ignored if either `terminal.integrated.shell.linux` or `terminal.integrated.shellArgs.linux` are set.
	"terminal.integrated.defaultProfile.linux": null,

	//* 💡 ru - 123
	//* 💡 en - The default profile used on macOS. This setting will currently be ignored if either `terminal.integrated.shell.osx` or `terminal.integrated.shellArgs.osx` are set.
	"terminal.integrated.defaultProfile.osx": null,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to detect and set the `$LANG` environment variable to a UTF-8 compliant option since VS Code's terminal only supports UTF-8 encoded data coming from the shell.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Set the `$LANG` environment variable if the existing variable does not exist or it does not end in `'.UTF-8'`.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Do not set the `$LANG` environment variable.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Always set the `$LANG` environment variable.
	"terminal.integrated.detectLocale": "auto",

	//* 💡 ru - 123
	//* 💡 en - Controls whether bold text in the terminal will always use the "bright" ANSI color variant.
	"terminal.integrated.drawBoldTextInBrightColors": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the terminal bell is enabled. This shows up as a visual bell next to the terminal's name.
	"terminal.integrated.enableBell": false,

	//* 💡 ru - 123
	//* 💡 en - Whether to enable file links in the terminal. Links can be slow when working on a network drive in particular because each file link is verified against the file system. Changing this will take effect only in new terminals.
	"terminal.integrated.enableFileLinks": true,

	//* 💡 ru - 123
	//* 💡 en - Show a warning dialog when pasting multiple lines into the terminal. The dialog does not show when:
	//* 💡 ru - 123
	//* 💡 en - 123
	//- Bracketed paste mode is enabled (the shell supports multi-line paste natively)
	//* 💡 ru - 123
	//* 💡 en - 123
	//- The paste is handled by the shell's readline (in the case of pwsh)
	"terminal.integrated.enableMultiLinePasteWarning": true,

	//* 💡 ru - 123
	//* 💡 en - Persist terminal sessions/history for the workspace across window reloads.
	"terminal.integrated.enablePersistentSessions": true,

	//* 💡 ru - 123
	//* 💡 en - Object with environment variables that will be added to the VS Code process to be used by the terminal on Linux. Set to `null` to delete the environment variable.
	"terminal.integrated.env.linux": {},

	//* 💡 ru - 123
	//* 💡 en - Object with environment variables that will be added to the VS Code process to be used by the terminal on macOS. Set to `null` to delete the environment variable.
	"terminal.integrated.env.osx": {},

	//* 💡 ru - 123
	//* 💡 en - Object with environment variables that will be added to the VS Code process to be used by the terminal on Windows. Set to `null` to delete the environment variable.
	"terminal.integrated.env.windows": {},

	//* 💡 ru - 123
	//* 💡 en - Whether to display the environment changes indicator on each terminal which explains whether extensions have made, or want to make changes to the terminal's environment.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Disable the indicator.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Enable the indicator.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - warnonly: Only show the warning indicator when a terminal's environment is 'stale', not the information indicator that shows a terminal has had its environment modified by an extension.
	"terminal.integrated.environmentChangesIndicator": "warnonly",

	//* 💡 ru - 123
	//* 💡 en - Whether to relaunch terminals automatically if extension want to contribute to their environment and have not been interacted with yet.
	"terminal.integrated.environmentChangesRelaunch": true,

	//* 💡 ru - 123
	//* 💡 en - Scrolling speed multiplier when pressing `Alt`.
	"terminal.integrated.fastScrollSensitivity": 5,

	//* 💡 ru - 123
	//* 💡 en - The font weight to use within the terminal for bold text. Accepts "normal" and "bold" keywords or numbers between 1 and 1000.
	"terminal.integrated.fontWeightBold": "bold",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the terminal will leverage the GPU to do its rendering.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Let VS Code detect which renderer will give the best experience.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Enable GPU acceleration within the terminal.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Disable GPU acceleration within the terminal.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - canvas: Use the terminal's fallback canvas renderer which uses a 2d context instead of webgl which may perform better on some systems.
	"terminal.integrated.gpuAcceleration": "auto",

	//* 💡 ru - 123
	//* 💡 en - A set of process names to ignore when using the `terminal.integrated.confirmOnKill` setting.
	"terminal.integrated.ignoreProcessNames": [],

	//* 💡 ru - 123
	//* 💡 en - Whether new shells should inherit their environment from VS Code, which may source a login shell to ensure $PATH and other development variables are initialized. This has no effect on Windows.
	"terminal.integrated.inheritEnv": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the letter spacing of the terminal. This is an integer value which represents the number of additional pixels to add between characters.
	"terminal.integrated.letterSpacing": 0,

	//* 💡 ru - 123
	//* 💡 en - Controls the line height of the terminal. This number is multiplied by the terminal font size to get the actual line-height in pixels.
	"terminal.integrated.lineHeight": 1,

	//* 💡 ru - 123
	//* 💡 en - When local echo should be enabled. This will override `terminal.integrated.localEchoLatencyThreshold`
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Always enabled
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Always disabled
	//* 💡 ru - 123
	//* 💡 en - 123
	// - auto: Enabled only for remote workspaces
	"terminal.integrated.localEchoEnabled": "auto",

	//* 💡 ru - 123
	//* 💡 en - Local echo will be disabled when any of these program names are found in the terminal title.
	"terminal.integrated.localEchoExcludePrograms": ["vim", "vi", "nano", "tmux"],

	//* 💡 ru - 123
	//* 💡 en - Length of network delay, in milliseconds, where local edits will be echoed on the terminal without waiting for server acknowledgement. If '0', local echo will always be on, and if '-1' it will be disabled.
	"terminal.integrated.localEchoLatencyThreshold": 30,

	//* 💡 ru - 123
	//* 💡 en - Terminal style of locally echoed text; either a font style or an RGB color.
	"terminal.integrated.localEchoStyle": "dim",

	//* 💡 ru - 123
	//* 💡 en - Controls whether to force selection when using Option+click on macOS. This will force a regular (line) selection and disallow the use of column selection mode. This enables copying and pasting using the regular terminal selection, for example, when mouse mode is enabled in tmux.
	"terminal.integrated.macOptionClickForcesSelection": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to treat the option key as the meta key in the terminal on macOS.
	"terminal.integrated.macOptionIsMeta": false,

	//* 💡 ru - 123
	//* 💡 en - When set, the foreground color of each cell will change to try meet the contrast ratio specified. Example values:
	//* 💡 ru - 123
	//* 💡 en - 123
	//- 1: Do nothing and use the standard theme colors.
	//* 💡 ru - 123
	//* 💡 en - 123
	//- 4.5: WCAG AA compliance (minimum).
	//* 💡 ru - 123
	//* 💡 en - 123
	//- 7: WCAG AAA compliance (enhanced).
	//* 💡 ru - 123
	//* 💡 en - 123
	//- 21: White on black or black on white.
	"terminal.integrated.minimumContrastRatio": 4.5,

	//* 💡 ru - 123
	//* 💡 en - A multiplier to be used on the `deltaY` of mouse wheel scroll events.
	"terminal.integrated.mouseWheelScrollSensitivity": 1,

	//* 💡 ru - 123
	//* 💡 en - When the terminal process must be shut down (for example on window or application close), this determines when the previous terminal session contents/history should be restored and processes be recreated when the workspace is next opened.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onExit: Revive the processes after the last window is closed on Windows/Linux or when the `workbench.action.quit` command is triggered (command palette, keybinding, menu).
	//* 💡 ru - 123
	//* 💡 en - 123
	// - onExitAndWindowClose: Revive the processes after the last window is closed on Windows/Linux or when the `workbench.action.quit` command is triggered (command palette, keybinding, menu), or when the window is closed.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never restore the terminal buffers or recreate the process.
	"terminal.integrated.persistentSessionReviveProcess": "onExit",

	//* 💡 ru - 123
	//* 💡 en - Controls the maximum amount of lines that will be restored when reconnecting to a persistent terminal session. Increasing this will restore more lines of scrollback at the cost of more memory and increase the time it takes to connect to terminals on start up. This setting requires a restart to take effect and should be set to a value less than or equal to `terminal.integrated.scrollback`.
	"terminal.integrated.persistentSessionScrollback": 100,

	//* 💡 ru - 123
	//* 💡 en - The Linux profiles to present when creating a new terminal via the terminal dropdown. Set the `path` property manually with an optional `args`.
	//* 💡 ru - 123
	//* 💡 en - Set an existing profile to `null` to hide the profile from the list, for example: `"bash": null`.
	"terminal.integrated.profiles.linux": {},

	//* 💡 ru - 123
	//* 💡 en - The macOS profiles to present when creating a new terminal via the terminal dropdown.
	"terminal.integrated.profiles.osx": {},

	//* 💡 ru - 123
	//* 💡 en - The Windows profiles to present when creating a new terminal via the terminal dropdown.
	"terminal.integrated.profiles.windows": {},

	//* 💡 ru - 123
	//* 💡 en - Controls how terminal reacts to right click.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - default: Show the context menu.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - copyPaste: Copy when there is a selection, otherwise paste.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - paste: Paste on right click.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - selectWord: Select the word under the cursor and show the context menu.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - nothing: Do nothing and pass event to terminal.
	"terminal.integrated.rightClickBehavior": "copyPaste",

	//* 💡 ru - 123
	//* 💡 en - Controls the maximum number of lines the terminal keeps in its buffer.
	"terminal.integrated.scrollback": 1000,

	//* 💡 ru - 123
	//* 💡 en - Dispatches most keybindings to the terminal instead of the workbench, overriding `terminal.integrated.commandsToSkipShell`, which can be used alternatively for fine tuning.
	"terminal.integrated.sendKeybindingsToShell": false,

	//* 💡 ru - 123
	//* 💡 en - When shell integration is enabled, adds a decoration for each command.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - both: Show decorations in the gutter (left) and overview ruler (right)
	//* 💡 ru - 123
	//* 💡 en - 123
	// - gutter: Show gutter decorations to the left of the terminal
	//* 💡 ru - 123
	//* 💡 en - 123
	// - overviewRuler: Show overview ruler decorations to the right of the terminal
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Do not show decorations
	"terminal.integrated.shellIntegration.decorationsEnabled": "both",

	//* 💡 ru - 123
	//* 💡 en - Determines whether or not shell integration is auto-injected to support features like enhanced command tracking and current working directory detection.
	"terminal.integrated.shellIntegration.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the number of recently used commands to keep in the terminal command history. Set to 0 to disable terminal command history.
	"terminal.integrated.shellIntegration.history": 100,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show the alert "The terminal process terminated with exit code" when exit code is non-zero.
	"terminal.integrated.showExitAlert": true,

	//* 💡 ru - 123
	//* 💡 en - Whether to show hovers for links in the terminal output.
	"terminal.integrated.showLinkHover": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the terminal will scroll using an animation.
	"terminal.integrated.smoothScrolling": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the working directory a split terminal starts with.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - workspaceRoot: A new split terminal will use the workspace root as the working directory. In a multi-root workspace a choice for which root folder to use is offered.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - initial: A new split terminal will use the working directory that the parent terminal started with.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - inherited: On macOS and Linux, a new split terminal will use the working directory of the parent terminal. On Windows, this behaves the same as initial.
	"terminal.integrated.splitCwd": "inherited",

	//* 💡 ru - 123
	//* 💡 en - A theme color ID to associate with terminal icons by default.
	"terminal.integrated.tabs.defaultColor": null,

	//* 💡 ru - 123
	//* 💡 en - A codicon ID to associate with terminal icons by default.
	"terminal.integrated.tabs.defaultIcon": "terminal",

	//* 💡 ru - 123
	//* 💡 en - Controls the terminal description, which appears to the right of the title. Variables are substituted based on the context:
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${cwd}`: the terminal's current working directory
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${cwdFolder}`: the terminal's current working directory, displayed for multi-root workspaces or in a single root workspace when the value differs from the initial working directory. On Windows, this will only be displayed when shell integration is enabled.
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${workspaceFolder}`: the workspace in which the terminal was launched
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${local}`: indicates a local terminal in a remote workspace
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${process}`: the name of the terminal process
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${separator}`: a conditional separator (" - ") that only shows when surrounded by variables with values or static text.
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${sequence}`: the name provided to the terminal by the process
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${task}`: indicates this terminal is associated with a task
	"terminal.integrated.tabs.description": "${task}${separator}${local}${separator}${cwdFolder}",

	//* 💡 ru - 123
	//* 💡 en - Controls whether terminal tab statuses support animation (eg. in progress tasks).
	"terminal.integrated.tabs.enableAnimation": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether terminal tabs display as a list to the side of the terminal. When this is disabled a dropdown will display instead.
	"terminal.integrated.tabs.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether focusing the terminal of a tab happens on double or single click.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - singleClick: Focus the terminal when clicking a terminal tab
	//* 💡 ru - 123
	//* 💡 en - 123
	// - doubleClick: Focus the terminal when double clicking a terminal tab
	"terminal.integrated.tabs.focusMode": "doubleClick",

	//* 💡 ru - 123
	//* 💡 en - Controls whether the terminal tabs view will hide under certain conditions.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never hide the terminal tabs view
	//* 💡 ru - 123
	//* 💡 en - 123
	// - singleTerminal: Hide the terminal tabs view when there is only a single terminal opened
	//* 💡 ru - 123
	//* 💡 en - 123
	// - singleGroup: Hide the terminal tabs view when there is only a single terminal group opened
	"terminal.integrated.tabs.hideCondition": "singleTerminal",

	//* 💡 ru - 123
	//* 💡 en - Controls the location of the terminal tabs, either to the left or right of the actual terminal(s).
	//* 💡 ru - 123
	//* 💡 en - 123
	// - left: Show the terminal tabs view to the left of the terminal
	//* 💡 ru - 123
	//* 💡 en - 123
	// - right: Show the terminal tabs view to the right of the terminal
	"terminal.integrated.tabs.location": "right",

	//* 💡 ru - 123
	//* 💡 en - Separator used by `terminal.integrated.tabs.title` and `terminal.integrated.tabs.title`.
	"terminal.integrated.tabs.separator": " - ",

	//* 💡 ru - 123
	//* 💡 en - Controls whether terminal split and kill buttons are displays next to the new terminal button.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always show the actions
	//* 💡 ru - 123
	//* 💡 en - 123
	// - singleTerminal: Show the actions when it is the only terminal opened
	//* 💡 ru - 123
	//* 💡 en - 123
	// - singleTerminalOrNarrow: Show the actions when it is the only terminal opened or when the tabs view is in its narrow textless state
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never show the actions
	"terminal.integrated.tabs.showActions": "singleTerminalOrNarrow",

	//* 💡 ru - 123
	//* 💡 en - Shows the active terminal information in the view.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always show the active terminal
	//* 💡 ru - 123
	//* 💡 en - 123
	// - singleTerminal: Show the active terminal when it is the only terminal opened
	//* 💡 ru - 123
	//* 💡 en - 123
	// - singleTerminalOrNarrow: Show the active terminal when it is the only terminal opened or when the tabs view is in its narrow textless state
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never show the active terminal
	"terminal.integrated.tabs.showActiveTerminal": "singleTerminalOrNarrow",

	//* 💡 ru - 123
	//* 💡 en - Controls the terminal title. Variables are substituted based on the context:
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${cwd}`: the terminal's current working directory
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${cwdFolder}`: the terminal's current working directory, displayed for multi-root workspaces or in a single root workspace when the value differs from the initial working directory.
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${workspaceFolder}`: the workspace in which the terminal was launched
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${local}`: indicates a local terminal in a remote workspace
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${process}`: the name of the terminal process
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${separator}`: a conditional separator (" - ") that only shows when surrounded by variables with values or static text.
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${sequence}`: the name provided to the terminal by the process
	//* 💡 ru - 123
	//* 💡 en - 123
	//- `${task}`: indicates this terminal is associated with a task
	"terminal.integrated.tabs.title": "${process}",

	//* 💡 ru - 123
	//* 💡 en - Controls what version of Unicode to use when evaluating the width of characters in the terminal. If you experience emoji or other wide characters not taking up the right amount of space or backspace either deleting too much or too little then you may want to try tweaking this setting.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - 6: Version 6 of Unicode. This is an older version which should work better on older systems.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - 11: Version 11 of Unicode. This version provides better support on modern systems that use modern versions of Unicode.
	"terminal.integrated.unicodeVersion": "11",

	//* 💡 ru - 123
	//* 💡 en - Controls whether or not WSL distros are shown in the terminal dropdown
	"terminal.integrated.useWslProfiles": true,

	//* 💡 ru - 123
	//* 💡 en - Whether to use ConPTY for Windows terminal process communication (requires Windows 10 build number 18309+). Winpty will be used if this is false.
	"terminal.integrated.windowsEnableConpty": true,

	//* 💡 ru - 123
	//* 💡 en - A string containing all characters to be considered word separators by the double click to select word feature.
	"terminal.integrated.wordSeparators": " ()[]{}',\"`─‘’",

	//* 💡 ru - 123
	//* 💡 en - Tasks

	//* 💡 ru - 123
	//* 💡 en - Enable automatic tasks.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Always
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Never
	"task.allowAutomaticTasks": "on",

	//* 💡 ru - 123
	//* 💡 en - Controls enablement of `provideTasks` for all task provider extension. If the Tasks: Run Task command is slow, disabling auto detect for task providers may help. Individual extensions may also provide settings that disable auto detection.
	"task.autoDetect": "on",

	//* 💡 ru - 123
	//* 💡 en - Configures whether to show the problem matcher prompt when running a task. Set to `true` to never prompt, or use a dictionary of task types to turn off prompting only for specific task types.
	"task.problemMatchers.neverPrompt": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether to show the task detail for tasks that have a detail in task quick picks, such as Run Task.
	"task.quickOpen.detail": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the number of recent items tracked in task quick open dialog.
	"task.quickOpen.history": 30,

	//* 💡 ru - 123
	//* 💡 en - Causes the Tasks: Run Task command to use the slower "show all" behavior instead of the faster two level picker where tasks are grouped by provider.
	"task.quickOpen.showAll": false,

	//* 💡 ru - 123
	//* 💡 en - Controls whether the task quick pick is skipped when there is only one task to pick from.
	"task.quickOpen.skip": false,

	//* 💡 ru - 123
	//* 💡 en - On window reload, reconnect to tasks that have problem matchers.
	"task.reconnection": true,

	//* 💡 ru - 123
	//* 💡 en - Save all dirty editors before running a task.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - always: Always saves all editors before running.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - never: Never saves editors before running.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - prompt: Prompts whether to save editors before running.
	"task.saveBeforeRun": "always",

	//* 💡 ru - 123
	//* 💡 en - Shows decorations at points of interest in the terminal buffer such as the first problem found via a watch task.
	"task.showDecorations": true,

	//* 💡 ru - 123
	//* 💡 en - Configures whether a warning is shown when a provider is slow
	"task.slowProviderWarning": true,

	//* 💡 ru - 123
	//* 💡 en - Problems

	//* 💡 ru - 123
	//* 💡 en - Controls whether Problems view should automatically reveal files when opening them.
	"problems.autoReveal": true,

	//* 💡 ru - 123
	//* 💡 en - Show Errors & Warnings on files and folder.
	"problems.decorations.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls the default view mode of the Problems view.
	"problems.defaultViewMode": "tree",

	//* 💡 ru - 123
	//* 💡 en - When enabled shows the current problem in the status bar.
	"problems.showCurrentInStatus": false,

	//* 💡 ru - 123
	//* 💡 en - Controls the order in which problems are navigated.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - severity: Navigate problems ordered by severity
	//* 💡 ru - 123
	//* 💡 en - 123
	// - position: Navigate problems ordered by position
	"problems.sortOrder": "severity",

	//* 💡 ru - 123
	//* 💡 en - 123
	//Breadcrumb Navigation

	//* 💡 ru - 123
	//* 💡 en - Enable/disable navigation breadcrumbs.
	"breadcrumbs.enabled": true,

	//* 💡 ru - 123
	//* 💡 en - Controls whether and how file paths are shown in the breadcrumbs view.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - on: Show the file path in the breadcrumbs view.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - off: Do not show the file path in the breadcrumbs view.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - last: Only show the last element of the file path in the breadcrumbs view.
	"breadcrumbs.filePath": "on",

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `enum`-symbols.
	"breadcrumbs.showEnums": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `interface`-symbols.
	"breadcrumbs.showInterfaces": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `module`-symbols.
	"breadcrumbs.showModules": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `namespace`-symbols.
	"breadcrumbs.showNamespaces": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `null`-symbols.
	"breadcrumbs.showNull": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `number`-symbols.
	"breadcrumbs.showNumbers": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `object`-symbols.
	"breadcrumbs.showObjects": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `operator`-symbols.
	"breadcrumbs.showOperators": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `package`-symbols.
	"breadcrumbs.showPackages": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `property`-symbols.
	"breadcrumbs.showProperties": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `string`-symbols.
	"breadcrumbs.showStrings": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `struct`-symbols.
	"breadcrumbs.showStructs": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `typeParameter`-symbols.
	"breadcrumbs.showTypeParameters": true,

	//* 💡 ru - 123
	//* 💡 en - When enabled breadcrumbs show `variable`-symbols.
	"breadcrumbs.showVariables": true,

	//* 💡 ru - 123
	//* 💡 en - Controls how symbols are sorted in the breadcrumbs outline view.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - position: Show symbol outline in file position order.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - name: Show symbol outline in alphabetical order.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - type: Show symbol outline in symbol type order.
	"breadcrumbs.symbolSortOrder": "position",

	//* 💡 ru - 123
	//* 💡 en - Telemetry

	//* 💡 ru - 123
	//* 💡 en - If this setting is false, no telemetry will be sent regardless of the new setting's value. Deprecated in favor of the `telemetry.telemetryLevel` setting.
	//* 💡 ru - 123
	//* 💡 en - Enable diagnostic data to be collected.
	"telemetry.enableTelemetry": true,

	//* 💡 ru - 123
	//* 💡 en - Controls all core, first-party extension, and participating third-party extension telemetry.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - all: Sends usage data, errors, and crash reports.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - error: Sends general error telemetry and crash reports.
	//* 💡 ru - 123
	//* 💡 en - 123
	// - crash: Sends OS level crash reports.
	//* 💡 ru - 123
	//* 💡 en - 123
