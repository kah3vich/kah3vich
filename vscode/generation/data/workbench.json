{
	//! ✅ Workbench

	//* 💡 ru - Указывает цветовую тему, используемую в рабочей среде.
	//* 💡 en - Specifies the color theme used in the working environment.
	"workbench.colorTheme": "Holdesher Theme",

	//* 💡 ru - Управляет размером вкладок редактора.
	//* 💡 en - Controls the size of the editor tabs.
	"workbench.editor.tabSizing": "shrink",

	//* 💡 ru - Указывает тему значков файлов, используемую в рабочей среде, или значение null, чтобы значки файлов не отображались.
	//* 💡 en - Specifies the file icon theme to use in the workbench, or null to not display file icons.
	"workbench.iconTheme": "material-icon-theme",

	//* 💡 ru - Управляет видимостью панели действий в рабочей среде.
	//* 💡 en - Controls the visibility of the action bar in the workbench.
	"workbench.activityBar.visible": true,

	//* 💡 ru - Управляет тем, какой редактор отображается при запуске, если ни один из них не был восстановлен из предыдущего сеанса.
	//* 💡 en - Controls which editor is displayed at startup if none of them have been restored from a previous session.
	"workbench.startupEditor": "newUntitledFile",

	//* 💡 ru - Настройте шаблоны шаблонов для редакторов (например, `'*.hex': 'hexEditor.hexEdit'`). Они имеют приоритет над поведением по умолчанию.
	//* 💡 en - Set up template templates for editors (eg `'*.hex': 'hexEditor.hexEdit'`). They take precedence over the default behavior.
	"workbench.editorAssociations": {
		"*.ipynb": "jupyter.notebook.ipynb"
	},

	//* 💡 ru - Управляет поведением щелчка по значку панели действий в рабочей среде.
	//* 💡 en - Controls the behavior of clicking an activity bar icon in the workbench.
	"workbench.activityBar.iconClickBehavior": "toggle",

	//* 💡 ru - Определяет, следует ли автоматически возобновлять доступные рабочие изменения, хранящиеся в облаке, для текущей рабочей области.
	//* 💡 en - Controls whether to automatically resume available working changes stored in the cloud for the current workspace.
	"workbench.cloudChanges.autoResume": "onReload",

	//* 💡 ru - Определяет, следует ли запрашивать у пользователя сохранение рабочих изменений в облаке при использовании команды «Продолжить работу».
	//* 💡 en - Controls whether to prompt the user to store working changes in the cloud when using Continue Working On.
	"workbench.cloudChanges.continueOn": "prompt",

	//* 💡 ru - Переопределяет цвета из текущей выбранной цветовой темы.
	//* 💡 en - Overrides colors from the currently selected color theme.
	"workbench.colorCustomizations": {},

	//* 💡 ru - Управляет количеством недавно использовавшихся команд для сохранения в истории для палитры команд. Установите 0, чтобы отключить историю команд.
	//* 💡 en - Controls the number of recently used commands to keep in history for the command palette. Set to 0 to disable command history.
	"workbench.commandPalette.history": 50,

	//* 💡 ru - Controls whether the last typed input to the command palette should be restored when opening it the next time.
	//* 💡 en - Controls whether the last typed input to the command palette should be restored when opening it the next time.
	"workbench.commandPalette.preserveInput": false,

	//* 💡 ru - Если редактор, соответствующий одному из перечисленных типов, открывается первым в группе редакторов и открыто более одной группы, группа автоматически блокируется. Заблокированные группы будут использоваться для открытия редакторов только в том случае, если они явно выбраны жестом пользователя (например, перетаскиванием), но не по умолчанию. Следовательно, маловероятно, что активный редактор в заблокированной группе будет случайно заменен другим редактором.
	//* 💡 en - If an editor matching one of the listed types is opened as the first in an editor group and more than one group is open, the group is automatically locked. Locked groups will only be used for opening editors when explicitly chosen by a user gesture (for example drag and drop), but not by default. Consequently, the active editor in a locked group is less likely to be replaced accidentally with a different editor.
	"workbench.editor.autoLockGroups": {
		"default": false,
		"workbench.editorinputs.searchEditorInput": false,
		"jupyter-notebook": false,
		"imagePreview.previewEditor": false,
		"vscode.audioPreview": false,
		"vscode.videoPreview": false,
		"jsProfileVisualizer.cpuprofile.table": false,
		"jsProfileVisualizer.heapprofile.table": false,
		"terminalEditor": true,
		"workbench.input.interactive": false,
		"mainThreadWebview-markdown.preview": false
	},

	//* 💡 ru - Определяет, должен ли центрированный макет автоматически изменять размер до максимальной ширины, когда открыто более одной группы. Как только будет открыта только одна группа, ее размер вернется к исходной ширине по центру.
	//* 💡 en - Controls if the centered layout should automatically resize to maximum width when more than one group is open. Once only one group is open it will resize back to the original centered width.
	"workbench.editor.centeredLayoutAutoResize": true,

	//* 💡 ru - Управляет поведением пустых групп редакторов при закрытии последней вкладки в группе. При включении пустые группы автоматически закрываются. При отключении пустые группы останутся частью сетки.
	//* 💡 en - Controls the behavior of empty editor groups when the last tab in the group is closed. When enabled, empty groups will automatically close. When disabled, empty groups will remain part of the grid.
	"workbench.editor.closeEmptyGroups": true,

	//* 💡 ru - Определяет, должны ли редакторы, показывающие файл, который был открыт во время сеанса, автоматически закрываться при удалении или переименовании каким-либо другим процессом. Отключив это, редактор останется открытым при таком событии. Обратите внимание, что удаление из приложения всегда приводит к закрытию редактора, а редакторы с несохраненными изменениями никогда не закрываются для сохранения ваших данных.
	//* 💡 en - Controls whether editors showing a file that was opened during the session should close automatically when getting deleted or renamed by some other process. Disabling this will keep the editor open  on such an event. Note that deleting from within the application will always close the editor and that editors with unsaved changes will never close to preserve your data.
	"workbench.editor.closeOnFileDelete": false,

	//* 💡 ru - Определяет, должны ли декорации файлов редактора использовать значки.
	//* 💡 en - Controls whether editor file decorations should use badges.
	"workbench.editor.decorations.badges": true,

	//* 💡 ru - Определяет, должны ли декорации файлов редактора использовать цвета.
	//* 💡 en - Controls whether editor file decorations should use colors.
	"workbench.editor.decorations.colors": true,

	//* 💡 ru - Редактор по умолчанию для файлов, определенных как двоичные. Если не определено, пользователю будет представлен инструмент выбора.
	//* 💡 en - The default editor for files detected as binary. If undefined, the user will be presented with a picker.
	"workbench.editor.defaultBinaryEditor": "",

	//* 💡 ru - Определяет, будут ли открытые редакторы отображаться как редакторы предварительного просмотра. Редакторы предварительного просмотра не остаются открытыми, используются повторно до тех пор, пока явным образом не будут настроены на то, чтобы оставаться открытыми (с помощью двойного щелчка или редактирования), и отображают имена файлов курсивом.
	//* 💡 en - Controls whether opened editors show as preview editors. Preview editors do not stay open, are reused until explicitly set to be kept open (via double click or editing), and show file names in italics.
	"workbench.editor.enablePreview": true,

	//* 💡 ru - Определяет, остаются ли редакторы в режиме предварительного просмотра, когда из них запускается навигация по коду. Редакторы предварительного просмотра не остаются открытыми и используются повторно до тех пор, пока явно не будет указано, что они должны оставаться открытыми (через двойной щелчок или редактирование). Это значение игнорируется, если `workbench.editor.enablePreview` отключен.
	//* 💡 en - Controls whether editors remain in preview when a code navigation is started from them. Preview editors do not stay open, and are reused until explicitly set to be kept open (via double click or editing). This value is ignored when `workbench.editor.enablePreview` is disabled.
	"workbench.editor.enablePreviewFromCodeNavigation": false,

	//* 💡 ru - Определяет, будут ли редакторы, открытые из быстрого открытия, отображаться как редакторы предварительного просмотра. Редакторы предварительного просмотра не остаются открытыми и используются повторно до тех пор, пока явно не будет указано, что они должны оставаться открытыми (через двойной щелчок или редактирование). Это значение игнорируется, если `workbench.editor.enablePreview` отключен.
	//* 💡 en - Controls whether editors opened from Quick Open show as preview editors. Preview editors do not stay open, and are reused until explicitly set to be kept open (via double click or editing). This value is ignored when `workbench.editor.enablePreview` is disabled.
	"workbench.editor.enablePreviewFromQuickOpen": false,

	//* 💡 ru - Определяет, закрываются ли вкладки в последнем использовавшемся порядке или слева направо.
	//* 💡 en - Controls whether tabs are closed in most recently used order or from left to right.
	"workbench.editor.focusRecentEditorAfterClose": true,

	//* 💡 ru - Определяет, рисуется ли верхняя граница на вкладках для редакторов с несохраненными изменениями. Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls whether a top border is drawn on tabs for editors that have unsaved changes. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.highlightModifiedTabs": false,

	//* 💡 ru - Включает использование истории редактора при определении языка. Это приводит к тому, что автоматическое определение языка отдает предпочтение языкам, которые были недавно открыты, и позволяет автоматическому распознаванию языка работать с меньшими входными данными.
	//* 💡 en - Enables use of editor history in language detection. This causes automatic language detection to favor languages that have been recently opened and allows for automatic language detection to operate with smaller inputs.
	"workbench.editor.historyBasedLanguageDetection": true,

	//* 💡 ru - Управляет форматом метки для редактора.
	//* 💡 en - Controls the format of the label for an editor.
	"workbench.editor.labelFormat": "default",

	//* 💡 ru - Определяет, будет ли автоматически определяться язык в текстовом редакторе, если язык не был явно задан средством выбора языка. Это также может быть ограничено языком, поэтому вы можете указать, какие языки вы не хотите отключать. Это полезно для таких языков, как Markdown, которые часто содержат другие языки, которые могут обмануть обнаружение языка, заставив его думать, что это встроенный язык, а не Markdown.
	//* 💡 en - Controls whether the language in a text editor is automatically detected unless the language has been explicitly set by the language picker. This can also be scoped by language so you can specify which languages you do not want to be switched off of. This is useful for languages like Markdown that often contain other languages that might trick language detection into thinking it's the embedded language and not Markdown.
	"workbench.editor.languageDetection": true,

	//* 💡 ru - Если этот параметр включен, показывает быстрое исправление в строке состояния, когда язык редактора не соответствует обнаруженному языку содержимого.
	//* 💡 en - When enabled, shows a Status bar Quick Fix when the editor language doesn't match detected content language.
	"workbench.editor.languageDetectionHints": {
		"untitledEditors": true,
		"notebookEditors": true
	},

	//* 💡 ru - Определяет, должно ли быть ограничено количество открытых редакторов. Если этот параметр включен, редко используемые редакторы будут закрываться, чтобы освободить место для новых открывающихся редакторов.
	//* 💡 en - Controls if the number of opened editors should be limited or not. When enabled, less recently used editors will close to make space for newly opening editors.
	"workbench.editor.limit.enabled": false,

	//* 💡 ru - Определяет, должно ли максимальное количество открытых редакторов исключать грязные редакторы для подсчета настроенного предела.
	//* 💡 en - Controls if the maximum number of opened editors should exclude dirty editors for counting towards the configured limit.
	"workbench.editor.limit.excludeDirty": false,

	//* 💡 ru - Определяет, должно ли ограничение на максимальное количество открытых редакторов применяться к группе редакторов или ко всем группам редакторов.
	//* 💡 en - Controls if the limit of maximum opened editors should apply per editor group or across all editor groups.
	"workbench.editor.limit.perEditorGroup": false,

	//* 💡 ru - Управляет максимальным количеством открытых редакторов. Используйте настройку `workbench.editor.limit.perEditorGroup`, чтобы управлять этим ограничением для группы редакторов или для всех групп.
	//* 💡 en - Controls the maximum number of opened editors. Use the `workbench.editor.limit.perEditorGroup` setting to control this limit per editor group or across all groups.
	"workbench.editor.limit.value": 10,

	//* 💡 ru - Позволяет использовать четвертую и пятую кнопки мыши для команд «Назад» и «Вперед».
	//* 💡 en - Enables the use of mouse buttons four and five for commands 'Go Back' and 'Go Forward'.
	"workbench.editor.mouseBackForwardToNavigate": true,

	//* 💡 ru - Управляет областью навигации по истории в редакторах для таких команд, как «Назад» и «Вперед».
	//* 💡 en - Controls the scope of history navigation in editors for commands such as 'Go Back' and 'Go Forward'.
	"workbench.editor.navigationScope": "default",

	//* 💡 ru - Определяет, где открываются редакторы. Выберите «влево» или «вправо», чтобы открыть редакторы слева или справа от текущего активного. Выберите «первый» или «последний», чтобы открывать редакторы независимо от текущего активного.
	//* 💡 en - Controls where editors open. Select `left` or `right` to open editors to the left or right of the currently active one. Select `first` or `last` to open editors independently from the currently active one.
	"workbench.editor.openPositioning": "right",

	//* 💡 ru - Управляет направлением по умолчанию для редакторов, которые открываются рядом (например, из проводника). По умолчанию редакторы открываются справа от активного в данный момент. Если изменить на «вниз», редакторы будут открываться ниже активного в данный момент.
	//* 💡 en - Controls the default direction of editors that are opened side by side (for example, from the Explorer). By default, editors will open on the right hand side of the currently active one. If changed to `down`, the editors will open below the currently active one.
	"workbench.editor.openSideBySideDirection": "right",

	//* 💡 ru - Управляет размером закрепленных вкладок редактора. Закрепленные вкладки сортируются по началу всех открытых вкладок и обычно не закрываются до тех пор, пока не будут откреплены. Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls the sizing of pinned editor tabs. Pinned tabs are sorted to the beginning of all opened tabs and typically do not close until unpinned. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.pinnedTabSizing": "normal",

	//* 💡 ru - Если эта функция включена, модель определения языка, учитывающая историю редактирования, будет иметь более высокий приоритет.
	//* 💡 en - When enabled, a language detection model that takes into account editor history will be given higher precedence.
	"workbench.editor.preferHistoryBasedLanguageDetection": true,

	//* 💡 ru - Восстанавливает последнее состояние просмотра редактора (например, положение прокрутки) при повторном открытии редакторов после того, как они были закрыты. Состояние просмотра редактора сохраняется для каждой группы редакторов и сбрасывается при закрытии группы. Используйте параметр `workbench.editor.sharedViewState`, чтобы использовать последнее известное состояние просмотра во всех группах редакторов, если предыдущее состояние просмотра не было найдено для группы редакторов.
	//* 💡 en - Restores the last editor view state (such as scroll position) when re-opening editors after they have been closed. Editor view state is stored per editor group and discarded when a group closes. Use the `workbench.editor.sharedViewState` setting to use the last known view state across all editor groups in case no previous view state was found for a editor group.
	"workbench.editor.restoreViewState": true,

	//* 💡 ru - Определяет, отображается ли редактор в любой из видимых групп, если он открыт. Если отключено, редактор предпочтет открываться в текущей активной группе редакторов. Если этот параметр включен, уже открытый редактор будет отображаться, а не открываться снова в текущей активной группе редакторов. Обратите внимание, что в некоторых случаях этот параметр игнорируется, например, при принудительном открытии редактора в определенной группе или на стороне текущей активной группы.
	//* 💡 en - Controls whether an editor is revealed in any of the visible groups if opened. If disabled, an editor will prefer to open in the currently active editor group. If enabled, an already opened editor will be revealed instead of opened again in the currently active editor group. Note that there are some cases where this setting is ignored, such as when forcing an editor to open in a specific group or to the side of the currently active group.
	"workbench.editor.revealIfOpen": false,

	//* 💡 ru - Определяет, будут ли открываться вкладки при прокрутке. По умолчанию вкладки отображаются только при прокрутке, но не открываются. Вы можете нажать и удерживать клавишу Shift при прокрутке, чтобы изменить это поведение на указанное время. Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls whether scrolling over tabs will open them or not. By default tabs will only reveal upon scrolling, but not open. You can press and hold the Shift-key while scrolling to change this behavior for that duration. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.scrollToSwitchTabs": false,

	//* 💡 ru - Сохраняет самое последнее состояние просмотра редактора (например, положение прокрутки) во всех группах редакторов и восстанавливает его, если для группы редакторов не найдено конкретное состояние просмотра редактора.
	//* 💡 en - Preserves the most recent editor view state (such as scroll position) across all editor groups and restores that if no specific editor view state is found for the editor group.
	"workbench.editor.sharedViewState": false,

	//* 💡 ru - Определяет, должны ли открытые редакторы отображаться со значком или нет. Для этого также необходимо включить тему значков файлов.
	//* 💡 en - Controls whether opened editors should show with an icon or not. This requires a file icon theme to be enabled as well.
	"workbench.editor.showIcons": true,

	//* 💡 ru - Определяет, должны ли открытые редакторы отображаться во вкладках или нет.
	//* 💡 en - Controls whether opened editors should show in tabs or not.
	"workbench.editor.showTabs": true,

	//* 💡 ru - Управляет макетом, когда редактор разделен в группе редакторов на вертикальный или горизонтальный.
	//* 💡 en - Controls the layout for when an editor is split in an editor group to be either vertical or horizontal.
	"workbench.editor.splitInGroupLayout": "horizontal",

	//* 💡 ru - Определяет, можно ли отделять группы редакторов от операций перетаскивания путем перетаскивания редактора или файла по краям области редактора.
	//* 💡 en - Controls if editor groups can be split from drag and drop operations by dropping an editor or file on the edges of the editor area.
	"workbench.editor.splitOnDragAndDrop": true,

	//* 💡 ru - Управляет размером групп редакторов при их разделении.
	//* 💡 en - Controls the sizing of editor groups when splitting them.
	"workbench.editor.splitSizing": "distribute",

	//* 💡 ru - Управляет положением кнопок закрытия вкладок редактора или отключает их, если установлено значение «Выкл.». Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls the position of the editor's tabs close buttons, or disables them when set to 'off'. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.tabCloseButton": "right",

	//* 💡 ru - Управляет высотой полос прокрутки, используемых для вкладок и навигационных цепочек в области заголовка редактора.
	//* 💡 en - Controls the height of the scrollbars used for tabs and breadcrumbs in the editor title area.
	"workbench.editor.titleScrollbarSizing": "default",

	//* 💡 ru - Определяет, должна ли текстовая подсказка без названия отображаться в редакторе.
	//* 💡 en - Controls if the untitled text hint should be visible in the editor.
	"workbench.editor.untitled.hint": "text",

	//* 💡 ru - Управляет форматом метки для безымянного редактора.
	//* 💡 en - Controls the format of the label for an untitled editor.
	"workbench.editor.untitled.labelFormat": "content",

	//* 💡 ru - Определяет, должны ли вкладки переноситься на несколько строк при превышении доступного места или вместо этого должна отображаться полоса прокрутки. Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls whether tabs should be wrapped over multiple lines when exceeding available space or whether a scrollbar should appear instead. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.wrapTabs": false,

	//* 💡 ru - Настройте средство открытия для использования с внешними URI (http, https).
	//* 💡 en - Configure the opener to use for external URIs (http, https).
	"workbench.externalUriOpeners": {},

	//* 💡 ru - Управляет методом псевдонима шрифта в рабочей среде.
	//* 💡 en - Controls font aliasing method in the workbench.
	"workbench.fontAliasing": "default",

	//* 💡 ru - Управляет задержкой в миллисекундах, после которой отображается наведение для элементов рабочей среды (например, некоторые элементы представления дерева, предоставленные расширением). Для уже видимых элементов может потребоваться обновление перед отражением этого изменения настройки.
	//* 💡 en - Controls the delay in milliseconds after which the hover is shown for workbench items (ex. some extension provided tree view items). Already visible items may require a refresh before reflecting this setting change.
	"workbench.hover.delay": 500,

	//* 💡 ru - Определяет, отображается ли элемент управления макетом в настраиваемой строке заголовка. Этот параметр действует только тогда, когда для `window.titleBarStyle` установлено значение `custom`.
	//* 💡 en - Controls whether the layout control is shown in the custom title bar. This setting only has an effect when `window.titleBarStyle` is set to `custom`.
	"workbench.layoutControl.enabled": true,

	//* 💡 ru - Определяет, отображается ли элемент управления макетом в настраиваемой строке заголовка в виде одной кнопки меню или с несколькими переключателями пользовательского интерфейса.
	//* 💡 en - Controls whether the layout control in the custom title bar is displayed as a single menu button or with multiple UI toggles.
	"workbench.layoutControl.type": "both",

	//* 💡 ru - Управляет режимом поиска по умолчанию для списков и деревьев в рабочей среде.
	//* 💡 en - Controls the default find mode for lists and trees in the workbench.
	"workbench.list.defaultFindMode": "highlight",

	//* 💡 ru - Множитель скорости прокрутки при нажатии Alt.
	//* 💡 en - Scrolling speed multiplier when pressing `Alt`.
	"workbench.list.fastScrollSensitivity": 5,

	//* 💡 ru - Определяет, поддерживают ли списки и деревья горизонтальную прокрутку в рабочей среде. Предупреждение: включение этого параметра влияет на производительность.
	//* 💡 en - Controls whether lists and trees support horizontal scrolling in the workbench. Warning: turning on this setting has a performance implication.
	"workbench.list.horizontalScrolling": false,

	//* 💡 ru - Множитель, который будет использоваться для `deltaX` и `deltaY` событий прокрутки колеса мыши.
	//* 💡 en - A multiplier to be used on the `deltaX` and `deltaY` of mouse wheel scroll events.
	"workbench.list.mouseWheelScrollSensitivity": 1,

	//* 💡 ru - Модификатор, который будет использоваться для добавления элемента в деревья и списки к множественному выбору с помощью мыши (например, в проводнике, открытых редакторах и представлении scm). Жесты мыши «Открыть в сторону» — если они поддерживаются — будут адаптироваться таким образом, чтобы они не конфликтовали с модификатором множественного выбора.
	//* 💡 en - The modifier to be used to add an item in trees and lists to a multi-selection with the mouse (for example in the explorer, open editors and scm view). The 'Open to Side' mouse gestures - if supported - will adapt such that they do not conflict with the multiselect modifier.
	"workbench.list.multiSelectModifier": "ctrlCmd",

	//* 💡 ru - Управляет тем, как открывать элементы в деревьях и списках с помощью мыши (если поддерживается). Обратите внимание, что некоторые деревья и списки могут игнорировать этот параметр, если он неприменим.
	//* 💡 en - Controls how to open items in trees and lists using the mouse (if supported). Note that some trees and lists might choose to ignore this setting if it is not applicable.
	"workbench.list.openMode": "singleClick",

	//* 💡 ru - Управляет плавной прокруткой списков и деревьев.
	//* 💡 en - Controls whether lists and trees have smooth scrolling.
	"workbench.list.smoothScrolling": false,

	//* 💡 ru - Определяет, включена ли локальная история файлов. Если этот параметр включен, содержимое файла сохраненного редактора будет сохранено в резервной копии, чтобы его можно было восстановить или просмотреть позже. Изменение этого параметра не влияет на существующие записи истории локальных файлов.
	//* 💡 en - Controls whether local file history is enabled. When enabled, the file contents of an editor that is saved will be stored to a backup location to be able to restore or review the contents later. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.enabled": true,

	//* 💡 ru - Настройте шаблоны универсальных объектов для исключения файлов из локальной истории файлов. Изменение этого параметра не влияет на существующие записи истории локальных файлов.
	//* 💡 en - Configure glob patterns for excluding files from the local file history. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.exclude": {},

	//* 💡 ru - Управляет максимальным количеством записей локальной истории файлов на файл. Когда количество записей в локальной файловой истории превышает это число для файла, самые старые записи будут удалены.
	//* 💡 en - Controls the maximum number of local file history entries per file. When the number of local file history entries exceeds this number for a file, the oldest entries will be discarded.
	"workbench.localHistory.maxFileEntries": 50,

	//* 💡 ru - Управляет максимальным размером файла (в КБ), который должен учитываться для локальной файловой истории. Файлы большего размера не будут добавлены в локальную историю файлов. Изменение этого параметра не влияет на существующие записи истории локальных файлов.
	//* 💡 en - Controls the maximum size of a file (in KB) to be considered for local file history. Files that are larger will not be added to the local file history. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.maxFileSize": 256,

	//* 💡 ru - Настройте интервал в секундах, в течение которого последняя запись в локальной файловой истории заменяется добавляемой записью. Это помогает уменьшить общее количество добавляемых записей, например, когда включено автоматическое сохранение. Этот параметр применяется только к записям, имеющим один и тот же источник происхождения. Изменение этого параметра не влияет на существующие записи истории локальных файлов.
	//* 💡 en - Configure an interval in seconds during which the last entry in local file history is replaced with the entry that is being added. This helps reduce the overall number of entries that are added, for example when auto save is enabled. This setting is only applied to entries that have the same source of origin. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.mergeWindow": 10,

	//* 💡 ru - Управляет расположением панели по умолчанию (Терминал, Консоль отладки, Вывод, Проблемы) в новой рабочей области. Он может отображаться внизу, справа или слева от области редактора.
	//* 💡 en - Controls the default location of the panel (Terminal, Debug Console, Output, Problems) in a new workspace. It can either show at the bottom, right, or left of the editor area.
	"workbench.panel.defaultLocation": "bottom",

	//* 💡 ru - Определяет, открывается ли панель в развернутом виде. Он может либо всегда открываться в развернутом виде, никогда не открываться в развернутом виде, либо открываться в последнем состоянии, в котором он находился перед закрытием.
	//* 💡 en - Controls whether the panel opens maximized. It can either always open maximized, never open maximized, or open to the last state it was in before being closed.
	"workbench.panel.opensMaximized": "preserve",

	//* 💡 ru - Указывает предпочтительную цветовую тему для темного внешнего вида ОС, когда включен `window.autoDetectColorScheme`.
	//* 💡 en - Specifies the preferred color theme for dark OS appearance when `window.autoDetectColorScheme` is enabled.
	"workbench.preferredDarkColorTheme": "Default Dark+",

	//* 💡 ru - Указывает предпочтительную цветовую тему, используемую в высококонтрастном темном режиме, когда включен `window.autoDetectHighContrast`.
	//* 💡 en - Specifies the preferred color theme used in high contrast dark mode when `window.autoDetectHighContrast` is enabled.
	"workbench.preferredHighContrastColorTheme": "Default High Contrast",

	//* 💡 ru - Указывает предпочтительную цветовую тему, используемую в режиме высококонтрастного освещения, когда включен `window.autoDetectHighContrast`.
	//* 💡 en - Specifies the preferred color theme used in high contrast light mode when `window.autoDetectHighContrast` is enabled.
	"workbench.preferredHighContrastLightColorTheme": "Default High Contrast Light",

	//* 💡 ru - Определяет предпочтительную цветовую тему для светлой ОС, когда включено `window.autoDetectColorScheme`.
	//* 💡 en - Specifies the preferred color theme for light OS appearance when `window.autoDetectColorScheme` is enabled.
	"workbench.preferredLightColorTheme": "Default Light+",

	//* 💡 ru - Указывает используемую тему значка продукта.
	//* 💡 en - Specifies the product icon theme used.
	"workbench.productIconTheme": "Default",

	//* 💡 ru - Определяет, должно ли быстрое открытие автоматически закрываться после потери фокуса.
	//* 💡 en - Controls whether Quick Open should close automatically once it loses focus.
	"workbench.quickOpen.closeOnFocusLost": true,

	//* 💡 ru - Определяет, следует ли восстанавливать последний введенный ввод для быстрого открытия при открытии в следующий раз.
	//* 💡 en - Controls whether the last typed input to Quick Open should be restored when opening it the next time.
	"workbench.quickOpen.preserveInput": false,

	//* 💡 ru - Определяет, должно ли рабочее место отображаться с меньшим количеством анимаций.
	//* 💡 en - Controls whether the workbench should render with fewer animations.
	"workbench.reduceMotion": "auto",

	//* 💡 ru - Управляет задержкой обратной связи при наведении в миллисекундах области перетаскивания между представлениями/редакторами.
	//* 💡 en - Controls the hover feedback delay in milliseconds of the dragging area in between views/editors.
	"workbench.sash.hoverDelay": 300,

	//* 💡 ru - Управляет размером области обратной связи в пикселях области перетаскивания между представлениями/редакторами. Установите большее значение, если вам сложно изменить размер представлений с помощью мыши.
	//* 💡 en - Controls the feedback area size in pixels of the dragging area in between views/editors. Set it to a larger value if you feel it's hard to resize views using the mouse.
	"workbench.sash.size": 4,

	//* 💡 ru - Определяет, какой редактор настроек использовать по умолчанию.
	//* 💡 en - Determines which settings editor to use by default.
	"workbench.settings.editor": "ui",

	//* 💡 ru - Определяет, следует ли включать режим поиска на естественном языке для настроек. Поиск на естественном языке обеспечивается онлайн-сервисом Microsoft.
	//* 💡 en - Controls whether to enable the natural language search mode for settings. The natural language search is provided by a Microsoft online service.
	"workbench.settings.enableNaturalLanguageSearch": true,

	//* 💡 ru - Определяет, будет ли открытие настроек привязки клавиш также открывать редактор, показывающий все привязки клавиш по умолчанию.
	//* 💡 en - Controls whether opening keybinding settings also opens an editor showing all default keybindings.
	"workbench.settings.openDefaultKeybindings": false,

	//* 💡 ru - Определяет, будет ли при открытии настроек открываться редактор, показывающий все настройки по умолчанию.
	//* 💡 en - Controls whether opening settings also opens an editor showing all default settings.
	"workbench.settings.openDefaultSettings": false,

	//* 💡 ru - Управляет поведением редактора настроек Table of Contents при поиске.
	//* 💡 en - Controls the behavior of the settings editor Table of Contents while searching.
	"workbench.settings.settingsSearchTocBehavior": "filter",

	//* 💡 ru - Определяет, следует ли использовать разделенный редактор JSON при редактировании настроек в формате JSON.
	//* 💡 en - Controls whether to use the split JSON editor when editing settings as JSON.
	"workbench.settings.useSplitJSON": false,

	//* 💡 ru - Управляет расположением основной боковой панели и панели активности. Они могут отображаться слева или справа от верстака. Второстепенная боковая панель появится на противоположной стороне верстака.
	//* 💡 en - Controls the location of the primary side bar and activity bar. They can either show on the left or right of the workbench. The secondary side bar will show on the opposite side of the workbench.
	"workbench.sideBar.location": "left",

	//* 💡 ru - Управляет видимостью строки состояния в нижней части рабочего места.
	//* 💡 en - Controls the visibility of the status bar at the bottom of the workbench.
	"workbench.statusBar.visible": true,

	//* 💡 ru - Когда включено, будут отображаться подсказки с водяными знаками, когда редактор не открыт.
	//* 💡 en - When enabled, will show the watermark tips when no editor is open.
	"workbench.tips.enabled": true,

	//* 💡 ru - Управляет расширением папок дерева при нажатии на имена папок. Обратите внимание, что некоторые деревья и списки могут игнорировать этот параметр, если он неприменим.
	//* 💡 en - Controls how tree folders are expanded when clicking the folder names. Note that some trees and lists might choose to ignore this setting if it is not applicable.
	"workbench.tree.expandMode": "singleClick",

	//* 💡 ru - Управляет отступом дерева в пикселях.
	//* 💡 en - Controls tree indentation in pixels.
	"workbench.tree.indent": 8,

	//* 💡 ru - Определяет, должно ли дерево отображать направляющие отступов.
	//* 💡 en - Controls whether the tree should render indent guides.
	"workbench.tree.renderIndentGuides": "onHover",

	//* 💡 ru - Если этот параметр включен, при открытии ссылок в доверенных рабочих областях будут появляться подсказки о доверенном домене.
	//* 💡 en - When enabled, trusted domain prompts will appear when opening links in trusted workspaces.
	"workbench.trustedDomains.promptInTrustedWorkspace": false,

	//* 💡 ru - Управляет видимостью действий заголовка представления. Действия заголовка представления могут быть либо всегда видны, либо видны только тогда, когда это представление находится в фокусе или наведено на него.
	//* 💡 en - Controls the visibility of view header actions. View header actions may either be always visible, or only visible when that view is focused or hovered over.
	"workbench.view.alwaysShowHeaderActions": false,

	//* 💡 ru - Если этот параметр включен, после установки расширения откроется пошаговое руководство.
	//* 💡 en - When enabled, an extension's walkthrough will open upon install of the extension.
	"workbench.welcomePage.walkthroughs.openOnInstall": true
}
