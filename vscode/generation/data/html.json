{
  // 🟢 HTML

  // 🇷🇺 - Включить/отключить автоматическое закрытие тегов HTML.
  // 🇺🇸 - Enable/disable autoclosing of HTML tags.
  "html.autoClosingTags": true,

  // 🇷🇺 - Включить/выключить автоматическое создание кавычек для присвоения атрибутов HTML. Тип кавычек можно настроить с помощью `html.completion.attribute Default Value`.
  // 🇺🇸 - Enable/disable auto creation of quotes for HTML attribute assignment. The type of quotes can be configured by `html.completion.attributeDefaultValue`.
  "html.autoCreateQuotes": true,

  // 🇷🇺 - Управляет значением по умолчанию для атрибутов, когда завершение принимается.
  // 🇺🇸 - Controls the default value for attributes when completion is accepted.
  "html.completion.attributeDefaultValue": "doublequotes",

  // 🇷🇺 - Список относительных путей к файлам, указывающих на файлы JSON в пользовательском формате данных.
  // 🇺🇸 - A list of relative file paths pointing to JSON files following the custom data format.
  "html.customData": [],

  // 🇷🇺 - Список тегов, разделенных запятыми, в которых содержимое не следует переформатировать. `null` по умолчанию равен тегу `pre`.
  // 🇺🇸 - List of tags, comma separated, where the content shouldn't be reformatted. `null` defaults to the `pre` tag.
  "html.format.contentUnformatted": "pre,code,textarea",

  // 🇷🇺 - Включить/отключить средство форматирования HTML по умолчанию.
  // 🇺🇸 - Enable/disable default HTML formatter.
  "html.format.enable": true,

  // 🇷🇺 - Список тегов, разделенных запятыми, перед которыми должен быть дополнительный символ новой строки. `null` по умолчанию имеет значение `"head, body, /html"`.
  // 🇺🇸 - List of tags, comma separated, that should have an extra newline before them. `null` defaults to `"head, body, /html"`.
  "html.format.extraLiners": "head, body, /html",

  // 🇷🇺 - Формат и отступ ``.
  // 🇺🇸 - Format and indent ``.
  "html.format.indentHandlebars": false,

  // 🇷🇺 - Отступ разделов `<head>` и `<body>`.
  // 🇺🇸 - Indent `<head>` and `<body>` sections.
  "html.format.indentInnerHtml": false,

  // 🇷🇺 - Максимальное количество разрывов строк, которое должно быть сохранено в одном фрагменте. Используйте `null` для неограниченного количества.
  // 🇺🇸 - Maximum number of line breaks to be preserved in one chunk. Use `null` for unlimited.
  "html.format.maxPreserveNewLines": null,

  // 🇷🇺 - Определяет, следует ли сохранять существующие разрывы строк перед сохранением элементов. Работает только перед элементами, а не внутри тегов или для текста.
  // 🇺🇸 - Controls whether existing line breaks before elements should be preserved. Only works before elements, not inside tags or for text.
  "html.format.preserveNewLines": true,

  // 🇷🇺 - Уважайте теги языка шаблонов django, erb, handlebars и php.
  // 🇺🇸 - Honor django, erb, handlebars and php templating language tags.
  "html.format.templating": false,

  // 🇷🇺 - Список тегов, разделенных запятыми, которые не следует переформатировать.
  // 🇺🇸 - List of tags, comma separated, that shouldn't be reformatted.
  "html.format.unformatted": "wbr",

  // 🇷🇺 - Держите текстовое содержимое вместе между этой строкой.
  // 🇺🇸 - Keep text content together between this string.
  "html.format.unformattedContentDelimiter": "",

  // 🇷🇺 - Обернуть атрибуты.
  // 🇺🇸 - Wrap attributes.
  "html.format.wrapAttributes": "auto",

  // 🇷🇺 - Сделайте отступ для атрибутов после N символов. Используйте `null`, чтобы использовать размер отступа по умолчанию. Игнорируется, если для `html.format.wrapAttributes` установлено значение 'aligned'.
  // 🇺🇸 - Indent wrapped attributes to after N characters. Use `null` to use the default indent size. Ignored if `html.format.wrapAttributes` is set to 'aligned'.
  "html.format.wrapAttributesIndentSize": null,

  // 🇷🇺 - Максимальное количество символов в строке (0 = отключить).
  // 🇺🇸 - Maximum amount of characters per line (0 = disable).
  "html.format.wrapLineLength": 120,

  // 🇷🇺 - Показать документацию по тегам и атрибутам при наведении.
  // 🇺🇸 - Show tag and attribute documentation in hover.
  "html.hover.documentation": true,

  // 🇷🇺 - Показывать ссылки на MDN при наведении.
  // 🇺🇸 - Show references to MDN in hover.
  "html.hover.references": true,

  // 🇷🇺 - Определяет, будет ли встроенная поддержка языка HTML предлагать теги, свойства и значения HTML5.
  // 🇺🇸 - Controls whether the built-in HTML language support suggests HTML5 tags, properties and values.
  "html.suggest.html5": true,

  // 🇷🇺 - Отслеживает связь между VS Code и языковым сервером HTML.
  // 🇺🇸 - Traces the communication between VS Code and the HTML language server.
  "html.trace.server": "off",

  // 🇷🇺 - Определяет, проверяет ли встроенная поддержка языка HTML встроенные скрипты.
  // 🇺🇸 - Controls whether the built-in HTML language support validates embedded scripts.
  "html.validate.scripts": true,

  // 🇷🇺 - Определяет, проверяет ли встроенная поддержка языка HTML встроенные стили.
  // 🇺🇸 - Controls whether the built-in HTML language support validates embedded styles.
  "html.validate.styles": true
}
