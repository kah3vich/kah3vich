	//! ✅ Output

	//* 💡 ru - Включить / отключить возможность интеллектуальной прокрутки в выходном представлении. Интеллектуальная прокрутка позволяет автоматически блокировать прокрутку, когда вы щелкаете в выходном представлении, и разблокирует, когда вы щелкаете в последней строке.
	//* 💡 en - Enable/disable the ability of smart scrolling in the output view. Smart scrolling allows you to lock scrolling automatically when you click in the output view and unlocks when you click in the last line.,
	"output.smartScroll.enabled": true,

	//! ✅ PHP

	//* 💡 ru - Определяет, включены ли встроенные языковые предложения PHP. Поддержка предлагает глобальные и переменные PHP.
	//* 💡 en - Controls whether the built-in PHP language suggestions are enabled. The support suggests PHP globals and variables.
	"php.suggest.basic": true,

	//* 💡 ru - Включить/отключить встроенную проверку PHP.
	//* 💡 en - Enable/disable built-in PHP validation.
	"php.validate.enable": true,

	//* 💡 ru - Указывает на исполняемый файл PHP.
	//* 💡 en - Points to the PHP executable.
	"php.validate.executablePath": null,

	//* 💡 ru - Запускается ли линтер при сохранении или при типе.
	//* 💡 en - Whether the linter is run on save or on type.,
	"php.validate.run": "onSave",

	//! ✅ Prettier
	//? 🧨 Info - https://prettier.io/docs/en/options.html

	//* 💡 ru - Правило устанавливает в конце выражений добавляется точка с запятой.
	//* 💡 en - The rule sets a semicolon is added at the end of expressions.
	"prettier.semi": true,

	//* 💡 ru - Делайте отступы с помощью табуляции вместо пробелов.
	//* 💡 en - Indent with tabs instead of spaces.
	"prettier.useTabs": true,

	//* 💡 ru - Это правило для символа ">" в многострочных JSX-элементах будет помещён в последней строке.
	//* 💡 en - This rule for the ">" character in multiline JSX elements will be placed on the last line.
	"prettier.jsxBracketSameLine": false,

	//* 💡 ru - Отвечает за вставку пробелов между телом объекта и фигурными скобками в объектных литералах.
	//* 💡 en - Responsible for inserting spaces between the object body and curly braces in object literals.
	"prettier.bracketSpacing": true,

	//* 💡 ru - Обеспечивает наличие запятой после последнего свойства объекта.
	//* 💡 en - Ensures that there is a comma after the last object property.
	"prettier.trailingComma": "all",

	//* 💡 ru - Все двойные кавычки будут преобразованы в одинарные.
	//* 💡 en - All double quotes will be converted to single quotes.
	"prettier.singleQuote": true,

	//* 💡 ru - Все двойные кавычки будут преобразованы в одинарные для формата файлов jsx.
	//* 💡 en - All double quotes will be converted to single quotes for the jsx file format.
	"prettier.jsxSingleQuote": true,

	//* 💡 ru - Включите круглые скобки вокруг единственного параметра функции стрелки.
	//* 💡 en - Include parentheses around the single parameter of the arrow function.
	"prettier.arrowParens": "avoid",

	//* 💡 ru - Задаёт количество пробелов на один уровень выравнивания.
	//* 💡 en - Specifies the number of spaces per alignment level.
	"prettier.tabWidth": 2,

	//* 💡 ru - Длина строки не должна превышать 100 символов.
	//* 💡 en - The string length must not exceed 100 characters.,
	"prettier.printWidth": 100,

	//! ✅ Problems

	//* 💡 ru - Определяет, должно ли представление «Проблемы» автоматически отображать файлы при их открытии.
	//* 💡 en - Controls whether Problems view should automatically reveal files when opening them.
	"problems.autoReveal": true,

	//* 💡 ru - Показать ошибки и предупреждения для файлов и папок.
	//* 💡 en - Show Errors & Warnings on files and folder.
	"problems.decorations.enabled": true,

	//* 💡 ru - Управляет режимом просмотра по умолчанию для представления «Проблемы».
	//* 💡 en - Controls the default view mode of the Problems view.
	"problems.defaultViewMode": "tree",

	//* 💡 ru - При включении показывает текущую проблему в строке состояния.
	//* 💡 en - When enabled shows the current problem in the status bar.
	"problems.showCurrentInStatus": false,

	//* 💡 ru - Управляет порядком, в котором перемещаются проблемы.
	//* 💡 en - Controls the order in which problems are navigated.,
	"problems.sortOrder": "severity",

	//! ✅ References Search View

	//* 💡 ru - Определяет, будут ли вызываться «Peek References» или «Find References» при выборе ссылок CodeLens.
	//* 💡 en - Controls whether 'Peek References' or 'Find References' is invoked when selecting CodeLens references.,
	"references.preferredLocation": "peek",

	//! ✅ Remote

	//* 💡 ru - Имя, под которым зарегистрирован доступ к удаленному туннелю. Если не задано, используется имя хоста.
	//* 💡 en - The name under which the remote tunnel access is registered. If not set, the host name is used.
	"remote.tunnels.access.hostNameOverride": "",

	//* 💡 ru - Когда этот параметр включен, обнаруживаются новые запущенные процессы, и порты, которые они прослушивают, автоматически перенаправляются. Отключение этого параметра не предотвратит переадресацию всех портов. Даже если расширения отключены, они по-прежнему могут вызывать переадресацию портов, а открытие некоторых URL-адресов по-прежнему вызывает переадресацию портов.
	//* 💡 en - When enabled, new running processes are detected and ports that they listen on are automatically forwarded. Disabling this setting will not prevent all ports from being forwarded. Even when disabled, extensions will still be able to cause ports to be forwarded, and opening some URLs will still cause ports to forwarded.
	"remote.autoForwardPorts": true,

	//* 💡 ru - Устанавливает источник, из которого автоматически перенаправляются порты, когда `remote.autoForwardPorts` имеет значение true. На удаленных устройствах Windows и Mac параметр «процесс» не действует, и будет использоваться «выход». Требуется перезагрузка для вступления в силу.
	//* 💡 en - Sets the source from which ports are automatically forwarded when `remote.autoForwardPorts` is true. On Windows and Mac remotes, the `process` option has no effect and `output` will be used. Requires a reload to take effect.
	"remote.autoForwardPortsSource": "process",

	//* 💡 ru - При включении расширения загружаются локально и устанавливаются удаленно.
	//* 💡 en - When enabled extensions are downloaded locally and installed on remote.
	"remote.downloadExtensionsLocally": false,

	//* 💡 ru - Переопределить тип расширения. Расширения `ui` устанавливаются и запускаются на локальном компьютере, а расширения `workspace` запускаются на удаленном. Переопределяя вид расширения по умолчанию с помощью этого параметра, вы указываете, следует ли устанавливать и включать это расширение локально или удаленно.
	//* 💡 en - Override the kind of an extension. `ui` extensions are installed and run on the local machine while `workspace` extensions are run on the remote. By overriding an extension's default kind using this setting, you specify if that extension should be installed and enabled locally or remotely.
	"remote.extensionKind": {
		"pub.name": ["ui"]
	},

	//* 💡 ru - Указывает имя локального хоста, которое будет использоваться для переадресации портов.
	//* 💡 en - Specifies the local host name that will be used for port forwarding.
	"remote.localPortHost": "localhost",

	//* 💡 ru - Установите свойства по умолчанию, которые применяются ко всем портам, которые не получают свойства из настройки `remote.portsAttributes`.
	//* 💡 en - Set default properties that are applied to all ports that don't get properties from the setting `remote.portsAttributes`.
	"remote.otherPortsAttributes": {},

	//* 💡 ru - Задайте свойства, которые применяются при переадресации определенного номера порта.
	//* 💡 en - Set properties that are applied when a specific port number is forwarded.
	"remote.portsAttributes": {},

	//* 💡 ru - Восстанавливает порты, которые вы переадресовали в рабочей области.
	//* 💡 en - Restores the ports you forwarded in a workspace.,
	"remote.restoreForwardedPorts": true,

	//! ✅ SCM

	//* 💡 ru - Определяет, всегда ли отображаются встроенные действия в представлении системы управления версиями.
	//* 💡 en - Controls whether inline actions are always visible in the Source Control view.
	"scm.alwaysShowActions": false,

	//* 💡 ru - Определяет, должны ли репозитории всегда отображаться в представлении системы управления версиями.
	//* 💡 en - Controls whether repositories should always be visible in the Source Control view.
	"scm.alwaysShowRepositories": false,

	//* 💡 ru - Определяет, должно ли представление системы управления версиями автоматически отображать и выбирать файлы при их открытии.
	//* 💡 en - Controls whether the Source Control view should automatically reveal and select files when opening them.
	"scm.autoReveal": true,

	//* 💡 ru - Управляет значком счетчика на значке системы управления версиями на панели действий.
	//* 💡 en - Controls the count badge on the Source Control icon on the Activity Bar.
	"scm.countBadge": "all",

	//* 💡 ru - Управляет режимом просмотра репозитория системы управления версиями по умолчанию.
	//* 💡 en - Controls the default Source Control repository view mode.
	"scm.defaultViewMode": "list",

	//* 💡 ru - Управляет порядком сортировки изменений репозитория системы управления версиями по умолчанию при просмотре в виде списка.
	//* 💡 en - Controls the default Source Control repository changes sort order when viewed as a list.
	"scm.defaultViewSortKey": "path",

	//* 💡 ru - Управляет оформлением различий в редакторе.
	//* 💡 en - Controls diff decorations in the editor.
	"scm.diffDecorations": "all",

	//* 💡 ru - Управляет поведением декоративных элементов желоба различий в системе управления версиями.
	//* 💡 en - Controls the behavior of Source Control diff gutter decorations.
	"scm.diffDecorationsGutterAction": "diff",

	//* 💡 ru - Определяет, используется ли шаблон для оформления различий в желобе.
	//* 💡 en - Controls whether a pattern is used for the diff decorations in gutter.
	"scm.diffDecorationsGutterPattern": {
		"added": false,
		"modified": true
	},

	//* 💡 ru - Управляет видимостью декоратора различий системы управления версиями в поле.
	//* 💡 en - Controls the visibility of the Source Control diff decorator in the gutter.
	"scm.diffDecorationsGutterVisibility": "always",

	//* 💡 ru - Контролирует ширину (px) различных украшений в желобе (добавлено или изменено).
	//* 💡 en - Controls the width(px) of diff decorations in gutter (added & modified).
	"scm.diffDecorationsGutterWidth": 3,

	//* 💡 ru - Определяет, игнорируются ли начальные и конечные пробелы в оформлении различительных желобов системы управления версиями.
	//* 💡 en - Controls whether leading and trailing whitespace is ignored in Source Control diff gutter decorations.
	"scm.diffDecorationsIgnoreTrimWhitespace": "false",

	//* 💡 ru - Управляет шрифтом входящего сообщения. Используйте `default` для семейства шрифтов пользовательского интерфейса рабочей среды, `editor` для значения `editor.fontFamily`, или пользовательское семейство шрифтов.
	//* 💡 en - Controls the font for the input message. Use `default` for the workbench user interface font family, `editor` for the `editor.fontFamily`'s value, or a custom font family.
	"scm.inputFontFamily": "default",

	//* 💡 ru - Управляет размером шрифта вводимого сообщения в пикселях.
	//* 💡 en - Controls the font size for the input message in pixels.
	"scm.inputFontSize": 13,

	//* 💡 ru - Управляет значками счетчика в заголовках поставщика управления версиями. Эти заголовки появляются только при наличии нескольких поставщиков.
	//* 💡 en - Controls the count badges on Source Control Provider headers. These headers only appear when there is more than one provider.
	"scm.providerCountBadge": "hidden",

	//* 💡 ru - Управляет порядком сортировки репозиториев в представлении репозиториев системы управления версиями.
	//* 💡 en - Controls the sort order of the repositories in the source control repositories view.
	"scm.repositories.sortOrder": "discovery time",

	//* 💡 ru - Управляет количеством репозиториев, видимых в разделе «Репозитории системы управления версиями». Установите значение 0, чтобы иметь возможность вручную изменять размер представления.
	//* 💡 en - Controls how many repositories are visible in the Source Control Repositories section. Set to 0, to be able to manually resize the view.
	"scm.repositories.visible": 10,

	//* 💡 ru - Определяет, может ли кнопка действия отображаться в представлении системы управления версиями.
	//* 💡 en - Controls whether an action button can be shown in the Source Control view.,
	"scm.showActionButton": true,

	//! ✅ Screencast Mode

	//* 💡 ru - Управляет размером шрифта (в пикселях) клавиатуры в режиме скринкаста.
	//* 💡 en - Controls the font size (in pixels) of the screencast mode keyboard.
	"screencastMode.fontSize": 56,

	//* 💡 ru - Определяет, как долго (в миллисекундах) отображается наложение клавиатуры в режиме скринкаста.
	//* 💡 en - Controls how long (in milliseconds) the keyboard overlay is shown in screencast mode.
	"screencastMode.keyboardOverlayTimeout": 800,

	//* 💡 ru - Управляет тем, что отображается на клавиатуре при отображении ярлыков.
	//* 💡 en - Controls what is displayed in the keyboard overlay when showing shortcuts.
	"screencastMode.keyboardShortcutsFormat": "commandAndKeys",

	//* 💡 ru - Управляет цветом в шестнадцатеричном формате (#_RGB, #RGBA, #RRGGBB или #RRGGBBAA) индикатора мыши в режиме скринкаста.
	//* 💡 en - Controls the color in hex (#_RGB, #RGBA, #RRGGBB or #RRGGBBAA) of the mouse indicator in screencast mode.
	"screencastMode.mouseIndicatorColor": "#FF0000",

	//* 💡 ru - Управляет размером (в пикселях) индикатора мыши в режиме скринкаста.
	//* 💡 en - Controls the size (in pixels) of the mouse indicator in screencast mode.
	"screencastMode.mouseIndicatorSize": 20,

	//* 💡 ru - Показывать сочетания клавиш только в режиме скринкаста.
	//* 💡 en - Only show keyboard shortcuts in screencast mode.
	"screencastMode.onlyKeyboardShortcuts": false,

	//* 💡 ru - Управляет вертикальным смещением наложения режима скринкаста снизу в процентах от высоты рабочего места.
	//* 💡 en - Controls the vertical offset of the screencast mode overlay from the bottom as a percentage of the workbench height.,
	"screencastMode.verticalOffset": 20,

	//! ✅ SCSS (Sass)

	//* 💡 ru - Вставьте точку с запятой в конце строки при заполнении свойств CSS.
	//* 💡 en - Insert semicolon at end of line when completing CSS properties.
	"scss.completion.completePropertyWithSemicolon": true,

	//* 💡 ru - По умолчанию VS Code инициирует завершение значения свойства после выбора свойства CSS. Используйте этот параметр, чтобы отключить это поведение.
	//* 💡 en - By default, VS Code triggers property value completion after selecting a CSS property. Use this setting to disable this behavior.
	"scss.completion.triggerPropertyValueCompletion": true,

	//* 💡 ru - Ставьте фигурные скобки на той же строке, что и правила (`collapse`), или ставьте фигурные скобки на отдельной строке (`expand`).
	//* 💡 en - Put braces on the same line as rules (`collapse`) or put braces on own line (`expand`).
	"scss.format.braceStyle": "collapse",

	//* 💡 ru - Включить/отключить средство форматирования SCSS по умолчанию.
	//* 💡 en - Enable/disable default SCSS formatter.
	"scss.format.enable": true,

	//* 💡 ru - Максимальное количество разрывов строк, которое должно быть сохранено в одном фрагменте, когда включен параметр `scss.format.preserveNewLines`.
	//* 💡 en - Maximum number of line breaks to be preserved in one chunk, when `scss.format.preserveNewLines` is enabled.
	"scss.format.maxPreserveNewLines": null,

	//* 💡 ru - Разделяйте наборы правил пустой строкой.
	//* 💡 en - Separate rulesets by a blank line.
	"scss.format.newlineBetweenRules": true,

	//* 💡 ru - Разделяйте селекторы новой строкой.
	//* 💡 en - Separate selectors with a new line.
	"scss.format.newlineBetweenSelectors": true,

	//* 💡 ru - Следует ли сохранять существующие разрывы строк перед элементами.
	//* 💡 en - Whether existing line breaks before elements should be preserved.
	"scss.format.preserveNewLines": true,

	//* 💡 ru - Обеспечьте наличие пробела вокруг разделителей селекторов '>', '+', '~' (например, `a > b`).
	//* 💡 en - Ensure a space character around selector separators '>', '+', '~' (e.g. `a > b`).
	"scss.format.spaceAroundSelectorSeparator": false,

	//* 💡 ru - Показать документацию по тегам и атрибутам при наведении курсора SCSS.
	//* 💡 en - Show tag and attribute documentation in SCSS hovers.
	"scss.hover.documentation": true,

	//* 💡 ru - Показывать ссылки на MDN в всплывающих окнах SCSS.
	//* 💡 en - Show references to MDN in SCSS hovers.
	"scss.hover.references": true,

	//* 💡 ru - Недопустимое количество параметров.
	//* 💡 en - Invalid number of parameters.
	"scss.lint.argumentsInColorFunction": "error",

	//* 💡 ru - Не используйте `width` или `height` при использовании `padding` или `border`.
	//* 💡 en - Do not use `width` or `height` when using `padding` or `border`.
	"scss.lint.boxModel": "ignore",

	//* 💡 ru - При использовании префикса, специфичного для поставщика, не забудьте также включить все другие свойства, зависящие от поставщика.
	//* 💡 en - When using a vendor-specific prefix make sure to also include all other vendor-specific properties.
	"scss.lint.compatibleVendorPrefixes": "ignore",

	//* 💡 ru - Не используйте повторяющиеся определения стилей.
	//* 💡 en - Do not use duplicate style definitions.
	"scss.lint.duplicateProperties": "ignore",

	//* 💡 ru - Не используйте пустые наборы правил.
	//* 💡 en - Do not use empty rulesets.
	"scss.lint.emptyRules": "warning",

	//* 💡 ru - Избегайте использования `float`. Поплавки приводят к хрупкому CSS, который легко сломать, если изменится один аспект макета.
	//* 💡 en - Avoid using `float`. Floats lead to fragile CSS that is easy to break if one aspect of the layout changes.
	"scss.lint.float": "ignore",

	//* 💡 ru - Правило `@font-face` должно определять свойства `src` и `font-family`.
	//* 💡 en - `@font-face` rule must define `src` and `font-family` properties.
	"scss.lint.fontFaceProperties": "warning",

	//* 💡 ru - Шестнадцатеричные цвета должны состоять из трех или шести шестнадцатеричных чисел.
	//* 💡 en - Hex colors must consist of three or six hex numbers.
	"scss.lint.hexColorLength": "error",

	//* 💡 ru - Селекторы не должны содержать идентификаторы, потому что эти правила слишком тесно связаны с HTML.
	//* 💡 en - Selectors should not contain IDs because these rules are too tightly coupled with the HTML.
	"scss.lint.idSelector": "ignore",

	//* 💡 ru - Взломы IE необходимы только при поддержке IE7 и старше.
	//* 💡 en - IE hacks are only necessary when supporting IE7 and older.
	"scss.lint.ieHack": "ignore",

	//* 💡 ru - Избегайте использования `!important`. Это указывает на то, что специфика всего CSS вышла из-под контроля и нуждается в рефакторинге.
	//* 💡 en - Avoid using `!important`. It is an indication that the specificity of the entire CSS has gotten out of control and needs to be refactored.
	"scss.lint.important": "ignore",

	//* 💡 ru - Операторы импорта не загружаются параллельно.
	//* 💡 en - Import statements do not load in parallel.
	"scss.lint.importStatement": "ignore",

	//* 💡 ru - Свойство игнорируется из-за отображения. Например. с display: inline свойства width, height, margin-top, margin-bottom и float не действуют.
	//* 💡 en - Property is ignored due to the display. E.g. with `display: inline`, the `width`, `height`, `margin-top`, `margin-bottom`, and `float` properties have no effect.
	"scss.lint.propertyIgnoredDueToDisplay": "warning",

	//* 💡 ru - Известно, что универсальный селектор (`*`) медленный.
	//* 💡 en - The universal selector (`*`) is known to be slow.
	"scss.lint.universalSelector": "ignore",

	//* 💡 ru - Неизвестное at-правило.
	//* 💡 en - Unknown at-rule.
	"scss.lint.unknownAtRules": "warning",

	//* 💡 ru - Неизвестное свойство.
	//* 💡 en - Unknown property.
	"scss.lint.unknownProperties": "warning",

	//* 💡 ru - Свойство неизвестного поставщика.
	//* 💡 en - Unknown vendor specific property.
	"scss.lint.unknownVendorSpecificProperties": "ignore",

	//* 💡 ru - Список свойств, которые не проверяются на соответствие правилу `unknownProperties`.
	//* 💡 en - A list of properties that are not validated against the `unknownProperties` rule.
	"scss.lint.validProperties": [],

	//* 💡 ru - При использовании префикса, зависящего от поставщика, также включите стандартное свойство.
	//* 💡 en - When using a vendor-specific prefix, also include the standard property.
	"scss.lint.vendorPrefix": "warning",

	//* 💡 ru - Единица для нуля не нужна.
	//* 💡 en - No unit for zero needed.
	"scss.lint.zeroUnits": "ignore",

	//* 💡 ru - Включает или отключает все проверки.
	//* 💡 en - Enables or disables all validations.,
	"scss.validate": true,

	//! ✅ Search

	//* 💡 ru - Управляет расположением панели действий в строках в представлении поиска.
	//* 💡 en - Controls the positioning of the actionbar on rows in the search view.
	"search.actionsPosition": "right",

	//* 💡 ru - Определяет, будут ли результаты поиска свернуты или развернуты.
	//* 💡 en - Controls whether the search results will be collapsed or expanded.
	"search.collapseResults": "alwaysExpand",

	//* 💡 ru - Определяет, должны ли декорации файлов поиска использовать значки.
	//* 💡 en - Controls whether search file decorations should use badges.
	"search.decorations.badges": true,

	//* 💡 ru - Определяет, должны ли украшения файла поиска использовать цвета.
	//* 💡 en - Controls whether search file decorations should use colors.
	"search.decorations.colors": true,

	//* 💡 ru - Управляет режимом просмотра результатов поиска по умолчанию.
	//* 💡 en - Controls the default search result view mode.
	"search.defaultViewMode": "list",

	//* 💡 ru - Настройте шаблоны глобусов для исключения файлов и папок при полнотекстовом поиске и быстром открытии. Наследует все шаблоны глобусов из настройки `files.exclude`.
	//* 💡 en - Configure glob patterns for excluding files and folders in fulltext searches and quick open. Inherits all glob patterns from the `files.exclude` setting.
	"search.exclude": {
		"**/node_modules": true,
		"**/bower_components": true,
		"**/*.code-search": true
	},

	//* 💡 ru - Определяет, следует ли следовать символическим ссылкам во время поиска.
	//* 💡 en - Controls whether to follow symlinks while searching.
	"search.followSymlinks": true,

	//* 💡 ru - Определяет, должно ли представление поиска читать или изменять общий буфер поиска в macOS.
	//* 💡 en - Controls whether the search view should read or modify the shared find clipboard on macOS.
	"search.globalFindClipboard": false,

	//* 💡 ru - Определяет, где будут выполняться новые операции «Поиск: найти в файлах» и «Найти в папке»: либо в представлении поиска, либо в редакторе поиска.
	//* 💡 en - Controls where new `Search: Find in Files` and `Find in Folder` operations occur: either in the search view, or in a search editor.
	"search.mode": "view",

	//* 💡 ru - Управляет порядком сортировки истории редактора при быстром открытии при фильтрации.
	//* 💡 en - Controls sorting order of editor history in quick open when filtering.
	"search.quickOpen.history.filterSortOrder": "default",

	//* 💡 ru - Следует ли включать результаты недавно открытых файлов в результаты файлов для быстрого открытия.
	//* 💡 en - Whether to include results from recently opened files in the file results for Quick Open.
	"search.quickOpen.includeHistory": true,

	//* 💡 ru - Следует ли включать результаты глобального поиска символов в результаты файлов для быстрого открытия.
	//* 💡 en - Whether to include results from a global symbol search in the file results for Quick Open.
	"search.quickOpen.includeSymbols": false,

	//* 💡 ru - Количество окружающих контекстных строк по умолчанию для использования при создании новых редакторов поиска. При использовании `search.searchEditor.reusePriorSearchConfiguration` можно установить значение `null` (пусто), чтобы использовать предыдущую конфигурацию редактора поиска.
	//* 💡 en - The default number of surrounding context lines to use when creating new Search Editors. If using `search.searchEditor.reusePriorSearchConfiguration`, this can be set to `null` (empty) to use the prior Search Editor's configuration.
	"search.searchEditor.defaultNumberOfContextLines": 1,

	//* 💡 ru - Настройте эффект двойного щелчка по результату в поисковом редакторе.
	//* 💡 en - Configure effect of double clicking a result in a search editor.
	"search.searchEditor.doubleClickBehaviour": "goToLocation",

	//* 💡 ru - Если этот параметр включен, новые редакторы поиска будут повторно использовать включения, исключения и флаги ранее открытого редактора поиска.
	//* 💡 en - When enabled, new Search Editors will reuse the includes, excludes, and flags of the previously opened Search Editor.
	"search.searchEditor.reusePriorSearchConfiguration": false,

	//* 💡 ru - Ищите все файлы по мере ввода.
	//* 💡 en - Search all files as you type.
	"search.searchOnType": true,

	//* 💡 ru - Когда `search.search Type` включен, контролирует время ожидания в миллисекундах между вводом символа и началом поиска. Не действует, если `search.search Type` отключен.
	//* 💡 en - When `search.searchOnType` is enabled, controls the timeout in milliseconds between a character being typed and the search starting. Has no effect when `search.searchOnType` is disabled.
	"search.searchOnTypeDebouncePeriod": 300,

	//* 💡 ru - Обновите поисковый запрос до выбранного редактором текста при фокусировке представления поиска. Это происходит либо по клику, либо при запуске команды workbench.views.search.focus.
	//* 💡 en - Update the search query to the editor's selected text when focusing the search view. This happens either on click or when triggering the `workbench.views.search.focus` command.
	"search.seedOnFocus": false,

	//* 💡 ru - Включить поиск с начальным значением от слова, ближайшего к курсору, когда в активном редакторе нет выбора.
	//* 💡 en - Enable seeding search from the word nearest the cursor when the active editor has no selection.
	"search.seedWithNearestWord": false,

	//* 💡 ru - Определяет, показывать ли номера строк для результатов поиска.
	//* 💡 en - Controls whether to show line numbers for search results.
	"search.showLineNumbers": false,

	//* 💡 ru - Поиск без учета регистра, если все шаблоны написаны строчными буквами, в противном случае поиск с учетом регистра.
	//* 💡 en - Search case-insensitively if the pattern is all lowercase, otherwise, search case-sensitively.
	"search.smartCase": false,

	//* 💡 ru - Управляет порядком сортировки результатов поиска.
	//* 💡 en - Controls sorting order of search results.
	"search.sortOrder": "default",

	//* 💡 ru - Определяет, использовать ли глобальные файлы `.gitignore` и `.ignore` при поиске файлов. Требуется включить `search.useIgnoreFiles`.
	//* 💡 en - Controls whether to use global `.gitignore` and `.ignore` files when searching for files. Requires `search.useIgnoreFiles` to be enabled.
	"search.useGlobalIgnoreFiles": false,

	//* 💡 ru - Определяет, использовать ли файлы `.gitignore` и `.ignore` при поиске файлов.
	//* 💡 en - Controls whether to use `.gitignore` and `.ignore` files when searching for files.
	"search.useIgnoreFiles": true,

	//* 💡 ru - Определяет, использовать ли файлы `.gitignore` и `.ignore` в родительских каталогах при поиске файлов. Требуется включить `search.useIgnoreFiles`.
	//* 💡 en - Controls whether to use `.gitignore` and `.ignore` files in parent directories when searching for files. Requires `search.useIgnoreFiles` to be enabled.
	"search.useParentIgnoreFiles": false,

	//* 💡 ru - Определяет, следует ли открывать «Заменить предварительный просмотр» при выборе или замене совпадения.
	//* 💡 en - Controls whether to open Replace Preview when selecting or replacing a match.,
	"search.useReplacePreview": true,

	//! ✅ Security

	//* 💡 ru - Управляет отображением баннера ограниченного режима.
	//* 💡 en - Controls when the restricted mode banner is shown.
	"security.workspace.trust.banner": "untilDismissed",

	//* 💡 ru - Определяет, является ли пустое окно доверенным по умолчанию в VS Code. При использовании с `security.workspace.trust.untrustedFiles` вы можете включить полную функциональность VS Code без запроса в пустом окне.
	//* 💡 en - Controls whether or not the empty window is trusted by default within VS Code. When used with `security.workspace.trust.untrustedFiles`, you can enable the full functionality of VS Code without prompting in an empty window.
	"security.workspace.trust.emptyWindow": true,

	//* 💡 ru - Определяет, включено ли доверие рабочей области в VS Code.
	//* 💡 en - Controls whether or not Workspace Trust is enabled within VS Code.
	"security.workspace.trust.enabled": true,

	//* 💡 ru - Определяет, когда отображается приглашение при запуске доверять рабочей области.
	//* 💡 en - Controls when the startup prompt to trust a workspace is shown.
	"security.workspace.trust.startupPrompt": "once",

	//* 💡 ru - Определяет, как обрабатывать открытие ненадежных файлов в доверенной рабочей области. Этот параметр также применяется к открытию файлов в пустом окне, которому доверяют через `security.workspace.trust.emptyWindow`.
	//* 💡 en - Controls how to handle opening untrusted files in a trusted workspace. This setting also applies to opening files in an empty window which is trusted via `security.workspace.trust.emptyWindow`.,
	"security.workspace.trust.untrustedFiles": "prompt",

	//! ✅ Settings Sync

	//* 💡 ru - Список расширений, которые следует игнорировать при синхронизации. Идентификатор расширения всегда `${publisher}.${name}`. Например: `vscode.csharp`.
	//* 💡 en - List of extensions to be ignored while synchronizing. The identifier of an extension is always `${publisher}.${name}`. For example: `vscode.csharp`.
	"settingsSync.ignoredExtensions": [],

	//* 💡 ru - Настройте параметры, которые будут игнорироваться при синхронизации.
	//* 💡 en - Configure settings to be ignored while synchronizing.
	"settingsSync.ignoredSettings": [],

	//* 💡 ru - Синхронизируйте привязки клавиш для каждой платформы.
	//* 💡 en - Synchronize keybindings for each platform.,
	"settingsSync.keybindingsPerPlatform": true,

	//! ✅ Sync

	//* 💡 ru - ID ключ sync
	//* 💡 en - ID key sync,
	"sync.gist": "",

	//! ✅ Tasks

	//* 💡 ru - Включите автоматические задачи.
	//* 💡 en - Enable automatic tasks.
	"task.allowAutomaticTasks": "on",

	//* 💡 ru - Управляет включением `provideTasks` для всех расширений поставщика задач. Если команда «Задачи: выполнить задачу» работает медленно, может помочь отключение автоматического определения поставщиков задач. Отдельные расширения также могут предоставлять настройки, отключающие автоматическое обнаружение.
	//* 💡 en - Controls enablement of `provideTasks` for all task provider extension. If the Tasks: Run Task command is slow, disabling auto detect for task providers may help. Individual extensions may also provide settings that disable auto detection.
	"task.autoDetect": "on",

	//* 💡 ru - Настраивает, показывать ли подсказку средства сопоставления проблем при выполнении задачи. Установите значение «true», чтобы никогда не запрашивать, или используйте словарь типов задач, чтобы отключить запросы только для определенных типов задач.
	//* 💡 en - Configures whether to show the problem matcher prompt when running a task. Set to `true` to never prompt, or use a dictionary of task types to turn off prompting only for specific task types.
	"task.problemMatchers.neverPrompt": false,

	//* 💡 ru - Определяет, показывать ли сведения о задаче для задач, сведения о которых есть в быстром выборе задачи, например «Выполнить задачу».
	//* 💡 en - Controls whether to show the task detail for tasks that have a detail in task quick picks, such as Run Task.
	"task.quickOpen.detail": true,

	//* 💡 ru - Управляет количеством последних элементов, отслеживаемых в диалоговом окне быстрого открытия задачи.
	//* 💡 en - Controls the number of recent items tracked in task quick open dialog.
	"task.quickOpen.history": 30,

	//* 💡 ru - Приводит к тому, что команда «Задачи: выполнить задачу» использует более медленное поведение «показать все» вместо более быстрого двухуровневого средства выбора, в котором задачи группируются по поставщику.
	//* 💡 en - Causes the Tasks: Run Task command to use the slower "show all" behavior instead of the faster two level picker where tasks are grouped by provider.
	"task.quickOpen.showAll": false,

	//* 💡 ru - Определяет, пропускается ли быстрый выбор задачи, когда есть только одна задача, из которой можно выбрать.
	//* 💡 en - Controls whether the task quick pick is skipped when there is only one task to pick from.
	"task.quickOpen.skip": false,

	//* 💡 ru - При перезагрузке окна повторно подключитесь к задачам, в которых есть средства сопоставления проблем.
	//* 💡 en - On window reload, reconnect to tasks that have problem matchers.
	"task.reconnection": true,

	//* 💡 ru - Сохраните все грязные редакторы перед запуском задачи.
	//* 💡 en - Save all dirty editors before running a task.
	"task.saveBeforeRun": "always",

	//* 💡 ru - Показывает украшения в точках интереса в буфере терминала, такие как первая проблема, обнаруженная с помощью задачи наблюдения.
	//* 💡 en - Shows decorations at points of interest in the terminal buffer such as the first problem found via a watch task.
	"task.showDecorations": true,

	//* 💡 ru - Настраивает, будет ли отображаться предупреждение, когда провайдер работает медленно.
	//* 💡 en - Configures whether a warning is shown when a provider is slow.,
	"task.slowProviderWarning": true,

	//! ✅ Telemetry

	//* 💡 ru - Если этот параметр имеет значение false, телеметрия не будет отправляться независимо от значения нового параметра. Устарело в пользу параметра `telemetry.telemetryLevel`. Включите сбор диагностических данных.
	//* 💡 en - If this setting is false, no telemetry will be sent regardless of the new setting's value. Deprecated in favor of the `telemetry.telemetryLevel` setting. Enable diagnostic data to be collected.
	"telemetry.enableTelemetry": true,

	//* 💡 ru - Контролирует всю телеметрию ядра, собственных расширений и участвующих сторонних расширений.
	//* 💡 en - Controls all core, first-party extension, and participating third-party extension telemetry.,
	"telemetry.telemetryLevel": "all",

	//! ✅ Terminal

	//* 💡 ru - Размер шрифта.
	//* 💡 en - Font size.
	"terminal.integrated.fontSize": 16,

	//* 💡 ru - Начертание шрифта.
	//* 💡 en - Font style.
	"terminal.integrated.fontWeight": "600",

	//* 💡 ru - Установка шрифта - https://github.com/kah3vich/Gulp-RS/tree/font/fonts/JetBrainsMono.
	//* 💡 en - Installing the font - https://github.com/kah3vich/Gulp-RS/tree/font/fonts/JetBrainsMono.
	"terminal.integrated.fontFamily": "JetBrains Mono, monospace",

	//* 💡 ru - Стартовая командная строка.
	//* 💡 en - Start command line.
	"terminal.integrated.defaultProfile.windows": "Git Bash",

	//* 💡 ru - Путь для командной строки git-bash.
	//* 💡 en - Path for git-bash command line.
	"terminal.integrated.automationShell.windows": "C:\\Program Files\\Git\\git-bash.exe",

	//* 💡 ru - При открытии файла из проводника в терминале определяет, какой терминал будет запущен.
	//* 💡 en - When opening a file from the Explorer in a terminal, determines what kind of terminal will be launched.
	"terminal.explorerKind": "integrated",

	//* 💡 ru - Внешний терминал. Настраивает, какой терминал запускать в Linux.
	//* 💡 en - External Terminal. Customizes which terminal to run on Linux.
	"terminal.external.linuxExec": "xterm",

	//* 💡 ru - Настраивает терминальное приложение для запуска в macOS.
	//* 💡 en - Customizes which terminal application to run on macOS.
	"terminal.external.osxExec": "Terminal.app",

	//* 💡 ru - Настраивает, какой терминал запускать в Windows.
	//* 💡 en - Customizes which terminal to run on Windows.
	"terminal.external.windowsExec": "C:\\Windows\\System32\\cmd.exe",

	//* 💡 ru - Разрешать или не разрешать сочетания клавиш аккордов в терминале. Обратите внимание, что когда это верно, и нажатие клавиши приводит к аккорду, он будет обходить `terminal.integrated.commandsToSkipShell`, установка этого значения в false особенно полезна, когда вы хотите, чтобы Ctrl + k переходил в вашу оболочку (не VS Code).
	//* 💡 en - Whether or not to allow chord keybindings in the terminal. Note that when this is true and the keystroke results in a chord it will bypass `terminal.integrated.commandsToSkipShell`, setting this to false is particularly useful when you want ctrl+k to go to your shell (not VS Code).
	"terminal.integrated.allowChords": true,

	//* 💡 ru - Разрешить ли мнемонику строки меню (например, Alt+F) запускать открытие строки меню. Обратите внимание, что это приведет к тому, что все нажатия клавиш alt будут пропускать оболочку, если установлено значение true. Это ничего не делает в macOS.
	//* 💡 en - Whether to allow menubar mnemonics (for example Alt+F) to trigger the open of the menubar. Note that this will cause all alt keystrokes to skip the shell when true. This does nothing on macOS.
	"terminal.integrated.allowMnemonics": false,

	//* 💡 ru - Если включено, сочетание клавиш alt/option + щелчок перемещает курсор подсказки под мышь, когда для `editor.multiCursorModifier` установлено значение `'alt'` (значение по умолчанию). Это может работать ненадежно в зависимости от вашей оболочки.
	//* 💡 en - If enabled, alt/option + click will reposition the prompt cursor to underneath the mouse when `editor.multiCursorModifier` is set to `'alt'` (the default value). This may not work reliably depending on your shell.
	"terminal.integrated.altClickMovesCursor": true,

	//* 💡 ru - Профиль терминала для использования в Linux для использования терминала, связанного с автоматизацией, например задач и отладки.
	//* 💡 en - The terminal profile to use on Linux for automation-related terminal usage like tasks and debug.
	"terminal.integrated.automationProfile.linux": null,

	//* 💡 ru - Профиль терминала для использования в macOS для использования терминала, связанного с автоматизацией, например задач и отладки.
	//* 💡 en - The terminal profile to use on macOS for automation-related terminal usage like tasks and debug.
	"terminal.integrated.automationProfile.osx": null,

	//* 💡 ru - Профиль терминала, используемый для использования терминала, связанного с автоматизацией, например задач и отладки.
	//* 💡 en - The terminal profile to use for automation-related terminal usage like tasks and debug.
	"terminal.integrated.automationProfile.windows": null,

	//* 💡 ru - Набор сообщений, на которые при обнаружении в терминале будет автоматически дан ответ. Если сообщение достаточно конкретное, это может помочь автоматизировать стандартные ответы.
	//* 💡 en - A set of messages that when encountered in the terminal will be automatically responded to. Provided the message is specific enough, this can help automate away common responses.
	"terminal.integrated.autoReplies": {},

	//* 💡 ru - Количество миллисекунд для отображения звонка на вкладке терминала при срабатывании.
	//* 💡 en - The number of milliseconds to show the bell within a terminal tab when triggered.
	"terminal.integrated.bellDuration": 1000,

	//* 💡 ru - Набор идентификаторов команд, сочетания клавиш которых не будут отправляться в оболочку, а вместо этого всегда будут обрабатываться VS Code. Это позволяет сочетаниям клавиш, которые обычно используются оболочкой, вместо этого действовать так же, как когда терминал не сфокусирован, например, `Ctrl + P`, чтобы запустить Quick Open.
	//* 💡 en - A set of command IDs whose keybindings will not be sent to the shell but instead always be handled by VS Code. This allows keybindings that would normally be consumed by the shell to act instead the same as when the terminal is not focused, for example `Ctrl+P` to launch Quick Open.
	"terminal.integrated.commandsToSkipShell": [],

	//* 💡 ru - Определяет, следует ли подтверждать закрытие окна при наличии активных сеансов терминала.
	//* 💡 en - Controls whether to confirm when the window closes if there are active terminal sessions.
	"terminal.integrated.confirmOnExit": "never",

	//* 💡 ru - Определяет, следует ли подтверждать уничтожение терминалов, если у них есть дочерние процессы. Если установлено значение editor, терминалы в области редактора будут помечены как измененные, если у них есть дочерние процессы. Обратите внимание, что обнаружение дочерних процессов может плохо работать для таких оболочек, как Git Bash, которые не запускают свои процессы как дочерние процессы оболочки.
	//* 💡 en - Controls whether to confirm killing terminals when they have child processes. When set to editor, terminals in the editor area will be marked as changed when they have child processes. Note that child process detection may not work well for shells like Git Bash which don't run their processes as child processes of the shell.
	"terminal.integrated.confirmOnKill": "editor",

	//* 💡 ru - Определяет, будет ли текст, выделенный в терминале, скопирован в буфер обмена.
	//* 💡 en - Controls whether text selected in the terminal will be copied to the clipboard.
	"terminal.integrated.copyOnSelection": false,

	//* 💡 ru - Управляет миганием курсора терминала.
	//* 💡 en - Controls whether the terminal cursor blinks.
	"terminal.integrated.cursorBlinking": false,

	//* 💡 ru - Управляет стилем терминального курсора.
	//* 💡 en - Controls the style of terminal cursor.
	"terminal.integrated.cursorStyle": "block",

	//* 💡 ru - Управляет шириной курсора, когда для `terminal.integrated.cursorStyle` установлено значение `line`.
	//* 💡 en - Controls the width of the cursor when `terminal.integrated.cursorStyle` is set to `line`.
	"terminal.integrated.cursorWidth": 1,

	//* 💡 ru - Следует ли рисовать пользовательские глифы для блочных элементов и символов рисования блоков вместо использования шрифта, который обычно обеспечивает лучшую визуализацию с непрерывными линиями. Обратите внимание, что это не работает с средством визуализации DOM.
	//* 💡 en - Whether to draw custom glyphs for block element and box drawing characters instead of using the font, which typically yields better rendering with continuous lines. Note that this doesn't work with the DOM renderer.
	"terminal.integrated.customGlyphs": true,

	//* 💡 ru - Явный начальный путь, по которому будет запущен терминал, он используется в качестве текущего рабочего каталога (cwd) для процесса оболочки. Это может быть особенно полезно в настройках рабочего пространства, если корневой каталог не является удобным cwd.
	//* 💡 en - An explicit start path where the terminal will be launched, this is used as the current working directory (cwd) for the shell process. This may be particularly useful in workspace settings if the root directory is not a convenient cwd.
	"terminal.integrated.cwd": "",

	//* 💡 ru - Определяет, где будут появляться вновь созданные терминалы.
	//* 💡 en - Controls where newly created terminals will appear.
	"terminal.integrated.defaultLocation": "view",

	//* 💡 ru - Профиль по умолчанию, используемый в Linux. Этот параметр в настоящее время будет игнорироваться, если установлен либо `terminal.integrated.shell.linux`, либо `terminal.integrated.shellArgs.linux`.
	//* 💡 en - The default profile used on Linux. This setting will currently be ignored if either `terminal.integrated.shell.linux` or `terminal.integrated.shellArgs.linux` are set.
	"terminal.integrated.defaultProfile.linux": null,

	//* 💡 ru - Профиль по умолчанию, используемый в macOS. Этот параметр в настоящее время будет игнорироваться, если установлен либо `terminal.integrated.shell.osx`, либо `terminal.integrated.shellArgs.osx`.
	//* 💡 en - The default profile used on macOS. This setting will currently be ignored if either `terminal.integrated.shell.osx` or `terminal.integrated.shellArgs.osx` are set.
	"terminal.integrated.defaultProfile.osx": null,

	//* 💡 ru - Определяет, следует ли обнаруживать и устанавливать для переменной среды `$LANG` параметр, совместимый с UTF-8, поскольку терминал VS Code поддерживает только данные в кодировке UTF-8, поступающие из оболочки.
	//* 💡 en - Controls whether to detect and set the `$LANG` environment variable to a UTF-8 compliant option since VS Code's terminal only supports UTF-8 encoded data coming from the shell.
	"terminal.integrated.detectLocale": "auto",

	//* 💡 ru - Определяет, будет ли полужирный текст в терминале всегда использовать «яркий» вариант цвета ANSI.
	//* 💡 en - Controls whether bold text in the terminal will always use the "bright" ANSI color variant.
	"terminal.integrated.drawBoldTextInBrightColors": true,

	//* 💡 ru - Определяет, включен ли звонок терминала. Это отображается в виде звонка рядом с названием терминала.
	//* 💡 en - Controls whether the terminal bell is enabled. This shows up as a visual bell next to the terminal's name.
	"terminal.integrated.enableBell": false,

	//* 💡 ru - Включить ли ссылки на файлы в терминале. Ссылки могут работать медленно при работе на сетевом диске, в частности потому, что каждая ссылка на файл проверяется на соответствие файловой системе. Изменение этого вступит в силу только в новых терминалах.
	//* 💡 en - Whether to enable file links in the terminal. Links can be slow when working on a network drive in particular because each file link is verified against the file system. Changing this will take effect only in new terminals.
	"terminal.integrated.enableFileLinks": true,

	//* 💡 ru - Показывать диалоговое окно с предупреждением при вставке нескольких строк в терминал. Диалог не показывает, когда.
	//* 💡 en - Show a warning dialog when pasting multiple lines into the terminal. The dialog does not show when.
	"terminal.integrated.enableMultiLinePasteWarning": true,

	//* 💡 ru - Сохранять терминальные сеансы/историю для рабочей области при перезагрузке окна.
	//* 💡 en - Persist terminal sessions/history for the workspace across window reloads.
	"terminal.integrated.enablePersistentSessions": true,

	//* 💡 ru - Объект с переменными среды, которые будут добавлены в процесс VS Code для использования терминалом в Linux. Установите значение «null», чтобы удалить переменную среды.
	//* 💡 en - Object with environment variables that will be added to the VS Code process to be used by the terminal on Linux. Set to `null` to delete the environment variable.
	"terminal.integrated.env.linux": {},

	//* 💡 ru - Объект с переменными среды, которые будут добавлены в процесс VS Code для использования терминалом в macOS. Установите значение «null», чтобы удалить переменную среды.
	//* 💡 en - Object with environment variables that will be added to the VS Code process to be used by the terminal on macOS. Set to `null` to delete the environment variable.
	"terminal.integrated.env.osx": {},

	//* 💡 ru - Объект с переменными среды, которые будут добавлены в процесс VS Code для использования терминалом в Windows. Установите значение «null», чтобы удалить переменную среды.
	//* 💡 en - Object with environment variables that will be added to the VS Code process to be used by the terminal on Windows. Set to `null` to delete the environment variable.
	"terminal.integrated.env.windows": {},

	//* 💡 ru - Отображать ли индикатор изменения среды на каждом терминале, который объясняет, были ли сделаны расширения или хотите внести изменения в среду терминала.
	//* 💡 en - Whether to display the environment changes indicator on each terminal which explains whether extensions have made, or want to make changes to the terminal's environment.
	"terminal.integrated.environmentChangesIndicator": "warnonly",

	//* 💡 ru - Следует ли автоматически перезапускать терминалы, если расширение хочет внести свой вклад в свою среду и с ним еще не взаимодействовали.
	//* 💡 en - Whether to relaunch terminals automatically if extension want to contribute to their environment and have not been interacted with yet.
	"terminal.integrated.environmentChangesRelaunch": true,

	//* 💡 ru - Множитель скорости прокрутки при нажатии Alt.
	//* 💡 en - Scrolling speed multiplier when pressing `Alt`.
	"terminal.integrated.fastScrollSensitivity": 5,

	//* 💡 ru - Толщина шрифта, используемая в терминале для полужирного текста. Принимает «обычные» и «жирные» ключевые слова или числа от 1 до 1000.
	//* 💡 en - The font weight to use within the terminal for bold text. Accepts "normal" and "bold" keywords or numbers between 1 and 1000.
	"terminal.integrated.fontWeightBold": "bold",

	//* 💡 ru - Определяет, будет ли терминал использовать GPU для рендеринга.
	//* 💡 en - Controls whether the terminal will leverage the GPU to do its rendering.
	"terminal.integrated.gpuAcceleration": "auto",

	//* 💡 ru - Набор имен процессов, которые следует игнорировать при использовании параметра `terminal.integrated.confirmOnKill`.
	//* 💡 en - A set of process names to ignore when using the `terminal.integrated.confirmOnKill` setting.
	"terminal.integrated.ignoreProcessNames": [],

	//* 💡 ru - Должны ли новые оболочки наследовать свою среду от VS Code, которая может использовать оболочку входа в систему, чтобы обеспечить инициализацию $PATH и других переменных разработки. Это не влияет на Windows.
	//* 💡 en - Whether new shells should inherit their environment from VS Code, which may source a login shell to ensure $PATH and other development variables are initialized. This has no effect on Windows.
	"terminal.integrated.inheritEnv": true,

	//* 💡 ru - Управляет межбуквенным интервалом терминала. Это целочисленное значение, которое представляет количество дополнительных пикселей, добавляемых между символами.
	//* 💡 en - Controls the letter spacing of the terminal. This is an integer value which represents the number of additional pixels to add between characters.
	"terminal.integrated.letterSpacing": 0,

	//* 💡 ru - Управляет высотой строки терминала. Это число умножается на размер шрифта терминала, чтобы получить реальную высоту строки в пикселях.
	//* 💡 en - Controls the line height of the terminal. This number is multiplied by the terminal font size to get the actual line-height in pixels.
	"terminal.integrated.lineHeight": 1,

	//* 💡 ru - Когда локальное эхо должно быть включено. Это переопределит `terminal.integrated.localEchoLatencyThreshold`.
	//* 💡 en - When local echo should be enabled. This will override `terminal.integrated.localEchoLatencyThreshold`.
	"terminal.integrated.localEchoEnabled": "auto",

	//* 💡 ru - Локальное эхо будет отключено, если любое из этих имен программ будет найдено в заголовке терминала.
	//* 💡 en - Local echo will be disabled when any of these program names are found in the terminal title.
	"terminal.integrated.localEchoExcludePrograms": ["vim", "vi", "nano", "tmux"],

	//* 💡 ru - Продолжительность сетевой задержки в миллисекундах, когда локальные изменения будут отображаться на терминале без ожидания подтверждения сервера. Если '0', локальное эхо всегда будет включено, а если '-1', оно будет отключено.
	//* 💡 en - Length of network delay, in milliseconds, where local edits will be echoed on the terminal without waiting for server acknowledgement. If '0', local echo will always be on, and if '-1' it will be disabled.
	"terminal.integrated.localEchoLatencyThreshold": 30,

	//* 💡 ru - Терминальный стиль локального эхо-текста; либо стиль шрифта, либо цвет RGB.
	//* 💡 en - Terminal style of locally echoed text; either a font style or an RGB color.
	"terminal.integrated.localEchoStyle": "dim",

	//* 💡 ru - Определяет, следует ли принудительно выбирать при использовании Option+щелчка в macOS. Это приведет к обычному (линейному) выбору и запретит использование режима выбора столбца. Это позволяет копировать и вставлять с помощью обычного выбора терминала, например, когда режим мыши включен в tmux.
	//* 💡 en - Controls whether to force selection when using Option+click on macOS. This will force a regular (line) selection and disallow the use of column selection mode. This enables copying and pasting using the regular terminal selection, for example, when mouse mode is enabled in tmux.
	"terminal.integrated.macOptionClickForcesSelection": false,

	//* 💡 ru - Определяет, следует ли рассматривать клавишу параметра как метаключ в терминале на macOS.
	//* 💡 en - Controls whether to treat the option key as the meta key in the terminal on macOS.
	"terminal.integrated.macOptionIsMeta": false,

	//* 💡 ru - Если установлено, цвет переднего плана каждой ячейки будет изменяться, чтобы соответствовать заданному коэффициенту контрастности. Примерные значения.
	//* 💡 en - When set, the foreground color of each cell will change to try meet the contrast ratio specified. Example values.
	"terminal.integrated.minimumContrastRatio": 4.5,

	//* 💡 ru - Множитель, который будет использоваться для `deltaY` событий прокрутки колеса мыши.
	//* 💡 en - A multiplier to be used on the `deltaY` of mouse wheel scroll events.
	"terminal.integrated.mouseWheelScrollSensitivity": 1,

	//* 💡 ru - Когда процесс терминала должен быть завершен (например, при закрытии окна или приложения), это определяет, когда следует восстановить содержимое/историю предыдущего сеанса терминала и воссоздать процессы при следующем открытии рабочей области.
	//* 💡 en - When the terminal process must be shut down (for example on window or application close), this determines when the previous terminal session contents/history should be restored and processes be recreated when the workspace is next opened.
	"terminal.integrated.persistentSessionReviveProcess": "onExit",

	//* 💡 ru - Управляет максимальным количеством строк, которые будут восстановлены при повторном подключении к постоянному сеансу терминала. Увеличение этого значения восстановит больше строк прокрутки за счет большего объема памяти и увеличит время, необходимое для подключения к терминалам при запуске. Этот параметр требует перезагрузки, чтобы он вступил в силу, и его значение должно быть меньше или равно `terminal.integrated.scrollback`.
	//* 💡 en - Controls the maximum amount of lines that will be restored when reconnecting to a persistent terminal session. Increasing this will restore more lines of scrollback at the cost of more memory and increase the time it takes to connect to terminals on start up. This setting requires a restart to take effect and should be set to a value less than or equal to `terminal.integrated.scrollback`.
	"terminal.integrated.persistentSessionScrollback": 100,

	//* 💡 ru - Профили Linux для представления при создании нового терминала через раскрывающийся список терминалов. Установите свойство `path` вручную с помощью необязательных `args`. Установите для существующего профиля значение `null`, чтобы скрыть профиль из списка, например: `"bash": null`.
	//* 💡 en - The Linux profiles to present when creating a new terminal via the terminal dropdown. Set the `path` property manually with an optional `args`. Set an existing profile to `null` to hide the profile from the list, for example: `"bash": null`.
	"terminal.integrated.profiles.linux": {},

	//* 💡 ru - Профили macOS для представления при создании нового терминала через раскрывающийся список терминалов.
	//* 💡 en - The macOS profiles to present when creating a new terminal via the terminal dropdown.
	"terminal.integrated.profiles.osx": {},

	//* 💡 ru - Профили Windows для представления при создании нового терминала через раскрывающийся список терминалов.
	//* 💡 en - The Windows profiles to present when creating a new terminal via the terminal dropdown.
	"terminal.integrated.profiles.windows": {},

	//* 💡 ru - Управляет реакцией терминала на щелчок правой кнопкой мыши.
	//* 💡 en - Controls how terminal reacts to right click.
	"terminal.integrated.rightClickBehavior": "copyPaste",

	//* 💡 ru - Управляет максимальным количеством строк, которые терминал хранит в своем буфере.
	//* 💡 en - Controls the maximum number of lines the terminal keeps in its buffer.
	"terminal.integrated.scrollback": 1000,

	//* 💡 ru - Отправляет большинство привязок клавиш на терминал вместо рабочей среды, переопределяя `terminal.integrated.commandsToSkipShell`, который можно использовать в качестве альтернативы для тонкой настройки.
	//* 💡 en - Dispatches most keybindings to the terminal instead of the workbench, overriding `terminal.integrated.commandsToSkipShell`, which can be used alternatively for fine tuning.
	"terminal.integrated.sendKeybindingsToShell": false,

	//* 💡 ru - Когда включена интеграция с оболочкой, добавляет украшение для каждой команды.
	//* 💡 en - When shell integration is enabled, adds a decoration for each command.
	"terminal.integrated.shellIntegration.decorationsEnabled": "both",

	//* 💡 ru - Определяет, будет ли автоматически внедрена интеграция с оболочкой для поддержки таких функций, как расширенное отслеживание команд и обнаружение текущего рабочего каталога.
	//* 💡 en - Determines whether or not shell integration is auto-injected to support features like enhanced command tracking and current working directory detection.
	"terminal.integrated.shellIntegration.enabled": true,

	//* 💡 ru - Управляет количеством недавно использованных команд, которые должны храниться в истории команд терминала. Установите 0, чтобы отключить историю команд терминала.
	//* 💡 en - Controls the number of recently used commands to keep in the terminal command history. Set to 0 to disable terminal command history.
	"terminal.integrated.shellIntegration.history": 100,

	//* 💡 ru - Определяет, показывать ли предупреждение «Процесс терминала завершен с кодом выхода», когда код выхода не равен нулю.
	//* 💡 en - Controls whether to show the alert "The terminal process terminated with exit code" when exit code is non-zero.
	"terminal.integrated.showExitAlert": true,

	//* 💡 ru - Показывать ли всплывающие окна для ссылок в выводе терминала.
	//* 💡 en - Whether to show hovers for links in the terminal output.
	"terminal.integrated.showLinkHover": true,

	//* 💡 ru - Определяет, будет ли терминал прокручиваться с помощью анимации.
	//* 💡 en - Controls whether the terminal will scroll using an animation.
	"terminal.integrated.smoothScrolling": false,

	//* 💡 ru - Управляет рабочим каталогом, с которого начинается разделенный терминал.
	//* 💡 en - Controls the working directory a split terminal starts with.
	"terminal.integrated.splitCwd": "inherited",

	//* 💡 ru - Идентификатор цвета темы, который по умолчанию ассоциируется со значками терминала.
	//* 💡 en - A theme color ID to associate with terminal icons by default.
	"terminal.integrated.tabs.defaultColor": null,

	//* 💡 ru - Идентификатор кодикона, который по умолчанию ассоциируется со значками терминала.
	//* 💡 en - A codicon ID to associate with terminal icons by default.
	"terminal.integrated.tabs.defaultIcon": "terminal",

	//* 💡 ru - Управляет описанием терминала, которое отображается справа от заголовка. Переменные заменяются в зависимости от контекста.
	//* 💡 en - Controls the terminal description, which appears to the right of the title. Variables are substituted based on the context.
	"terminal.integrated.tabs.description": "${task}${separator}${local}${separator}${cwdFolder}",

	//* 💡 ru - Определяет, поддерживают ли статусы вкладок терминала анимацию (например, выполняемые задачи).
	//* 💡 en - Controls whether terminal tab statuses support animation (eg. in progress tasks).
	"terminal.integrated.tabs.enableAnimation": true,

	//* 💡 ru - Управляет отображением вкладок терминала в виде списка сбоку от терминала. Когда это отключено, вместо этого будет отображаться раскрывающийся список.
	//* 💡 en - Controls whether terminal tabs display as a list to the side of the terminal. When this is disabled a dropdown will display instead.
	"terminal.integrated.tabs.enabled": true,

	//* 💡 ru - Определяет, происходит ли фокусировка на терминале вкладки двойным или одиночным щелчком.
	//* 💡 en - Controls whether focusing the terminal of a tab happens on double or single click.
	"terminal.integrated.tabs.focusMode": "doubleClick",

	//* 💡 ru - Определяет, будет ли вид вкладок терминала скрываться при определенных условиях.
	//* 💡 en - Controls whether the terminal tabs view will hide under certain conditions.
	"terminal.integrated.tabs.hideCondition": "singleTerminal",

	//* 💡 ru - Управляет расположением вкладок терминала слева или справа от фактического терминала(ов).
	//* 💡 en - Controls the location of the terminal tabs, either to the left or right of the actual terminal(s).
	"terminal.integrated.tabs.location": "right",

	//* 💡 ru - Разделитель, используемый `terminal.integrated.tabs.title` и `terminal.integrated.tabs.title`.
	//* 💡 en - Separator used by `terminal.integrated.tabs.title` and `terminal.integrated.tabs.title`.
	"terminal.integrated.tabs.separator": " - ",

	//* 💡 ru - Определяет, отображаются ли кнопки разделения и уничтожения терминала рядом с новой кнопкой терминала.
	//* 💡 en - Controls whether terminal split and kill buttons are displays next to the new terminal button.
	"terminal.integrated.tabs.showActions": "singleTerminalOrNarrow",

	//* 💡 ru - Показывает информацию об активном терминале в представлении.
	//* 💡 en - Shows the active terminal information in the view.
	"terminal.integrated.tabs.showActiveTerminal": "singleTerminalOrNarrow",

	//* 💡 ru - Управляет заголовком терминала. Переменные заменяются в зависимости от контекста.
	//* 💡 en - Controls the terminal title. Variables are substituted based on the context.
	"terminal.integrated.tabs.title": "${process}",

	//* 💡 ru - Определяет, какую версию Unicode использовать при оценке ширины символов в терминале. Если вы столкнулись с тем, что смайлики или другие широкие символы не занимают нужного места или удаляют слишком много или слишком мало места, вы можете попробовать настроить этот параметр.
	//* 💡 en - Controls what version of Unicode to use when evaluating the width of characters in the terminal. If you experience emoji or other wide characters not taking up the right amount of space or backspace either deleting too much or too little then you may want to try tweaking this setting.
	"terminal.integrated.unicodeVersion": "11",

	//* 💡 ru - Определяет, будут ли дистрибутивы WSL отображаться в раскрывающемся списке терминала.
	//* 💡 en - Controls whether or not WSL distros are shown in the terminal dropdown.
	"terminal.integrated.useWslProfiles": true,

	//* 💡 ru - Следует ли использовать ConPTY для связи процесса терминала Windows (требуется номер сборки Windows 10 18309+). Winpty будет использоваться, если это ложь.
	//* 💡 en - Whether to use ConPTY for Windows terminal process communication (requires Windows 10 build number 18309+). Winpty will be used if this is false.
	"terminal.integrated.windowsEnableConpty": true,

	//* 💡 ru - Строка, содержащая все символы, которые будут считаться разделителями слов при двойном щелчке для выбора функции слова.
	//* 💡 en - A string containing all characters to be considered word separators by the double click to select word feature.,
	"terminal.integrated.wordSeparators": " ()[]{}',\"`─‘’",

	//! ✅ Testing

	//* 💡 ru - Всегда показывать выполненный тест, когда `testing.followRunningTest` включен. Если этот параметр отключен, будут обнаружены только неудачные тесты.
	//* 💡 en - Always reveal the executed test when `testing.followRunningTest` is on. If this setting is turned off, only failed tests will be revealed.
	"testing.alwaysRevealTestOnStateChange": false,

	//* 💡 ru - Настраивает, когда ошибка Peek автоматически открывается.
	//* 💡 en - Configures when the error Peek view is automatically opened.
	"testing.automaticallyOpenPeekView": "failureInVisibleDocument",

	//* 💡 ru - Определяет, следует ли автоматически открывать представление Peek в режиме автозапуска.
	//* 💡 en - Controls whether to automatically open the Peek view during auto-run mode.
	"testing.automaticallyOpenPeekViewDuringAutoRun": false,

	//* 💡 ru - Как долго ждать в миллисекундах после того, как тест помечен как устаревший и начинается новый запуск.
	//* 💡 en - How long to wait, in milliseconds, after a test is marked as outdated and starting a new run.
	"testing.autoRun.delay": 1000,

	//* 💡 ru - Определяет, какие тесты запускаются автоматически.
	//* 💡 en - Controls which tests are automatically run.
	"testing.autoRun.mode": "all",

	//* 💡 ru - Управляет действием, выполняемым при щелчке левой кнопкой мыши по тестовому декору в желобе.
	//* 💡 en - Controls the action to take when left-clicking on a test decoration in the gutter.
	"testing.defaultGutterClickAction": "run",

	//* 💡 ru - Определяет, следует ли отслеживать запущенный тест в представлении обозревателя тестов.
	//* 💡 en - Controls whether the running test should be followed in the Test Explorer view.
	"testing.followRunningTest": true,

	//* 💡 ru - Определяет, будут ли тестовые декорации отображаться в поле редактора.
	//* 💡 en - Controls whether test decorations are shown in the editor gutter.
	"testing.gutterEnabled": true,

	//* 💡 ru - Определяет, когда должно открываться представление тестирования.
	//* 💡 en - Controls when the testing view should open.
	"testing.openTesting": "openOnTestStart",

	//* 💡 ru - Проверьте, нужно ли сохранять все грязные редакторы перед запуском теста.
	//* 💡 en - Control whether save all dirty editors before running a test.,
	"testing.saveBeforeTest": true,

	//! ✅ Timeline

	//* 💡 ru - Количество элементов, отображаемых на временной шкале по умолчанию и при загрузке дополнительных элементов. Установка значения «null» (по умолчанию) автоматически выберет размер страницы на основе видимой области представления временной шкалы.
	//* 💡 en - The number of items to show in the Timeline view by default and when loading more items. Setting to `null` (the default) will automatically choose a page size based on the visible area of the Timeline view.,
	"timeline.pageSize": null,

	//! ✅ Update

	//* 💡 ru - Включите загрузку и установку новых версий VS Code в фоновом режиме в Windows.
	//* 💡 en - Enable to download and install new VS Code versions in the background on Windows.
	"update.enableWindowsBackgroundUpdates": true,

	//* 💡 ru - Настройте получение автоматических обновлений. Требует перезагрузки после изменения. Обновления загружаются из онлайн-сервиса Microsoft.
	//* 💡 en - Configure whether you receive automatic updates. Requires a restart after change. The updates are fetched from a Microsoft online service.
	"update.mode": "default",

	//* 💡 ru - Показать примечания к выпуску после обновления. Примечания к выпуску получены из онлайн-сервиса Microsoft.
	//* 💡 en - Show Release Notes after an update. The Release Notes are fetched from a Microsoft online service.,
	"update.showReleaseNotes": true,

	//! ✅ VS Code Pets

	//* 💡 ru - Фоновая тема.
	//* 💡 en - Background theme.
	"vscode-pets.theme": "forest",

	//* 💡 ru - Расположение анимации.
	//* 💡 en - Animation location.
	"vscode-pets.position": "explorer",

	//* 💡 ru - Тип персонажа.
	//* 💡 en - Character type.
	"vscode-pets.petType": "totoro",

	//* 💡 ru - Размер персонажа.
	//* 💡 en - Character size.,
	"vscode-pets.petSize": "nano",

	//! ✅ VS Intelli Code

	//* 💡 ru - Управляет предварительным выбором предложений при отображении списка предложений.
	//* 💡 en - Controls the pre-selection of offers when displaying a list of offers.,
	"vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",

    //! ✅ WakaTime

    //* 💡 ru - Ключ для доступа к системе фиксации времени работы - wakatime.
    //* 💡 en - Key to access the system for fixing the time of work - wakatime.,
    "wakatime.apiKey": "",

	//! ✅ Window

	//* 💡 ru - Определяет, должны ли файлы открываться в новом окне при использовании командной строки или файлового диалога.
	//* 💡 en - Specifies whether files should open in a new window when using the command line or file dialog.
	"window.openFilesInNewWindow": "off",

	//* 💡 ru - Отрегулируйте уровень масштабирования окна.
	//* 💡 en - Adjust the zoom level of the window.
	"window.zoomLevel": -1,

	//* 💡 ru - Если установлено, автоматически переключаться на предпочтительную цветовую тему в зависимости от внешнего вида ОС. Если внешний вид ОС темный, используется тема, указанная в `workbench.preferredDarkColorTheme`, для светлой `workbench.preferredLightColorTheme`.
	//* 💡 en - If set, automatically switch to the preferred color theme based on the OS appearance. If the OS appearance is dark, the theme specified at `workbench.preferredDarkColorTheme` is used, for light `workbench.preferredLightColorTheme`.
	"window.autoDetectColorScheme": false,

	//* 💡 ru - Если включено, будет автоматически переключаться на высококонтрастную тему, если ОС использует высококонтрастную тему. Используемая высококонтрастная тема определяется параметрами workbench.preferredHighContrastColorTheme и workbench.preferredHighContrastLightColorTheme.
	//* 💡 en - If enabled, will automatically change to high contrast theme if the OS is using a high contrast theme. The high contrast theme to use is specified by `workbench.preferredHighContrastColorTheme` and `workbench.preferredHighContrastLightColorTheme`.
	"window.autoDetectHighContrast": true,

	//* 💡 ru - Если этот параметр включен, щелчок по неактивному окну одновременно активирует окно и запускает элемент под мышью, если на него можно щелкнуть. Если отключено, щелчок в любом месте неактивного окна активирует только его, и требуется второй щелчок по элементу.
	//* 💡 en - If enabled, clicking on an inactive window will both activate the window and trigger the element under the mouse if it is clickable. If disabled, clicking anywhere on an inactive window will activate it only and a second click is required on the element.
	"window.clickThroughInactive": true,

	//* 💡 ru - Определяет, должно ли закрытие последнего редактора также закрывать окно. Этот параметр применяется только к окнам, в которых не отображаются папки.
	//* 💡 en - Controls whether closing the last editor should also close the window. This setting only applies for windows that do not show folders.
	"window.closeWhenEmpty": false,

	//* 💡 ru - Показать средство запуска команд вместе с заголовком окна.
	//* 💡 en - Show command launcher together with the window title.
	"window.commandCenter": false,

	//* 💡 ru - Управляет отображением диалогового окна подтверждения перед закрытием окна или выходом из приложения.
	//* 💡 en - Controls whether to show a confirmation dialog before closing the window or quitting the application.
	"window.confirmBeforeClose": "never",

	//* 💡 ru - Управляет тем, будет ли строка меню сфокусирована нажатием клавиши Alt. Этот параметр не влияет на переключение строки меню с помощью клавиши Alt.
	//* 💡 en - Controls whether the menu bar will be focused by pressing the Alt-key. This setting has no effect on toggling the menu bar with the Alt-key.
	"window.customMenuBarAltFocus": true,

	//* 💡 ru - Настройка внешнего вида диалоговых окон.
	//* 💡 en - Adjust the appearance of dialog windows.
	"window.dialogStyle": "native",

	//* 💡 ru - Если этот параметр включен, двойной щелчок по значку приложения в строке заголовка закроет окно, и окно нельзя будет перетащить за значок. Этот параметр действует только тогда, когда для `window.titleBarStyle` установлено значение `custom`.
	//* 💡 en - If enabled, double clicking the application icon in the title bar will close the window and the window cannot be dragged by the icon. This setting only has an effect when `window.titleBarStyle` is set to `custom`.
	"window.doubleClickIconToClose": false,

	//* 💡 ru - Определяет, следует ли использовать собственный полноэкранный режим в macOS. Отключите этот параметр, чтобы macOS не создавала новое пространство при переходе в полноэкранный режим.
	//* 💡 en - Controls if native full-screen should be used on macOS. Disable this option to prevent macOS from creating a new space when going full-screen.
	"window.nativeFullScreen": true,

	//* 💡 ru - Включает вкладки окна macOS Sierra. Обратите внимание, что изменения требуют полной перезагрузки для применения, а собственные вкладки отключат пользовательский стиль строки заголовка, если он настроен.
	//* 💡 en - Enables macOS Sierra window tabs. Note that changes require a full restart to apply and that native tabs will disable a custom title bar style if configured.
	"window.nativeTabs": false,

	//* 💡 ru - Определяет, можно ли открывать главные меню с помощью сочетаний клавиш Alt. Отключение мнемоники позволяет вместо этого связать эти сочетания клавиш Alt с командами редактора.
	//* 💡 en - Controls whether the main menus can be opened via Alt-key shortcuts. Disabling mnemonics allows to bind these Alt-key shortcuts to editor commands instead.
	"window.enableMenuBarMnemonics": true,

	//* 💡 ru - Управление видимостью строки меню. Настройка «переключатель» означает, что строка меню скрыта, и ее можно отобразить одним нажатием клавиши Alt. Настройка «Компактный» переместит меню на боковую панель.
	//* 💡 en - Control the visibility of the menu bar. A setting of 'toggle' means that the menu bar is hidden and a single press of the Alt key will show it. A setting of 'compact' will move the menu into the side bar.
	"window.menuBarVisibility": "classic",

	//* 💡 ru - Управляет размерами открытия нового окна, когда хотя бы одно окно уже открыто. Обратите внимание, что этот параметр не влияет на первое открытое окно. Первое окно всегда будет восстанавливать размер и расположение, которые вы оставили перед закрытием.
	//* 💡 en - Controls the dimensions of opening a new window when at least one window is already opened. Note that this setting does not have an impact on the first window that is opened. The first window will always restore the size and location as you left it before closing.
	"window.newWindowDimensions": "default",

	//* 💡 ru - Определяет, должны ли папки открываться в новом окне или заменять последнее активное окно.
	//* 💡 en - Controls whether folders should open in a new window or replace the last active window.
	"window.openFoldersInNewWindow": "default",

	//* 💡 ru - Определяет, должно ли открываться новое пустое окно при запуске второго экземпляра без аргументов или фокус должен получить последний запущенный экземпляр.
	//* 💡 en - Controls whether a new empty window should open when starting a second instance without arguments or if the last running instance should get focus.
	"window.openWithoutArgumentsInNewWindow": "on",

	//* 💡 ru - Определяет, должно ли окно восстанавливаться в полноэкранный режим, если оно было закрыто в полноэкранном режиме.
	//* 💡 en - Controls whether a window should restore to full screen mode if it was exited in full screen mode.
	"window.restoreFullscreen": false,

	//* 💡 ru - Управляет повторным открытием окон после первого запуска. Этот параметр не действует, если приложение уже запущено.
	//* 💡 en - Controls how windows are being reopened after starting for the first time. This setting has no effect when the application is already running.
	"window.restoreWindows": "all",

	//* 💡 ru - Управляет заголовком окна на основе активного редактора.
	//* 💡 en - Controls the window title based on the active editor.
	"window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${appName}",

	//* 💡 ru - Настройте внешний вид строки заголовка окна. В Linux и Windows этот параметр также влияет на внешний вид приложения и контекстного меню. Изменения требуют полной перезагрузки для применения.
	//* 💡 en - Adjust the appearance of the window title bar. On Linux and Windows, this setting also affects the application and context menu appearances. Changes require a full restart to apply.
	"window.titleBarStyle": "custom",

	//* 💡 ru - Разделитель, используемый `window.title`.
	//* 💡 en - Separator used by `window.title`.,
	"window.titleSeparator": " - ",

	//! ✅ Workbench

	//* 💡 ru - Указывает цветовую тему, используемую в рабочей среде.
	//* 💡 en - Specifies the color theme used in the working environment.
	"workbench.colorTheme": "Holdesher Theme",

	//* 💡 ru - Управляет размером вкладок редактора.
	//* 💡 en - Controls the size of the editor tabs.
	"workbench.editor.tabSizing": "shrink",

	//* 💡 ru - Указывает тему значков файлов, используемую в рабочей среде, или значение null, чтобы значки файлов не отображались.
	//* 💡 en - Specifies the file icon theme to use in the workbench, or null to not display file icons.
	"workbench.iconTheme": "material-icon-theme",

	//* 💡 ru - Управляет видимостью панели действий в рабочей среде.
	//* 💡 en - Controls the visibility of the action bar in the workbench.
	"workbench.activityBar.visible": true,

	//* 💡 ru - Управляет тем, какой редактор отображается при запуске, если ни один из них не был восстановлен из предыдущего сеанса.
	//* 💡 en - Controls which editor is displayed at startup if none of them have been restored from a previous session.
	"workbench.startupEditor": "newUntitledFile",

	//* 💡 ru - Настройте шаблоны шаблонов для редакторов (например, `'*.hex': 'hexEditor.hexEdit'`). Они имеют приоритет над поведением по умолчанию.
	//* 💡 en - Set up template templates for editors (eg `'*.hex': 'hexEditor.hexEdit'`). They take precedence over the default behavior.
	"workbench.editorAssociations": {
		"*.ipynb": "jupyter.notebook.ipynb"
	},

	//* 💡 ru - Управляет поведением щелчка по значку панели действий в рабочей среде.
	//* 💡 en - Controls the behavior of clicking an activity bar icon in the workbench.
	"workbench.activityBar.iconClickBehavior": "toggle",

	//* 💡 ru - Определяет, следует ли автоматически возобновлять доступные рабочие изменения, хранящиеся в облаке, для текущей рабочей области.
	//* 💡 en - Controls whether to automatically resume available working changes stored in the cloud for the current workspace.
	"workbench.cloudChanges.autoResume": "onReload",

	//* 💡 ru - Определяет, следует ли запрашивать у пользователя сохранение рабочих изменений в облаке при использовании команды «Продолжить работу».
	//* 💡 en - Controls whether to prompt the user to store working changes in the cloud when using Continue Working On.
	"workbench.cloudChanges.continueOn": "prompt",

	//* 💡 ru - Переопределяет цвета из текущей выбранной цветовой темы.
	//* 💡 en - Overrides colors from the currently selected color theme.
	"workbench.colorCustomizations": {},

	//* 💡 ru - Управляет количеством недавно использовавшихся команд для сохранения в истории для палитры команд. Установите 0, чтобы отключить историю команд.
	//* 💡 en - Controls the number of recently used commands to keep in history for the command palette. Set to 0 to disable command history.
	"workbench.commandPalette.history": 50,

	//* 💡 ru - Controls whether the last typed input to the command palette should be restored when opening it the next time.
	//* 💡 en - Controls whether the last typed input to the command palette should be restored when opening it the next time.
	"workbench.commandPalette.preserveInput": false,

	//* 💡 ru - Если редактор, соответствующий одному из перечисленных типов, открывается первым в группе редакторов и открыто более одной группы, группа автоматически блокируется. Заблокированные группы будут использоваться для открытия редакторов только в том случае, если они явно выбраны жестом пользователя (например, перетаскиванием), но не по умолчанию. Следовательно, маловероятно, что активный редактор в заблокированной группе будет случайно заменен другим редактором.
	//* 💡 en - If an editor matching one of the listed types is opened as the first in an editor group and more than one group is open, the group is automatically locked. Locked groups will only be used for opening editors when explicitly chosen by a user gesture (for example drag and drop), but not by default. Consequently, the active editor in a locked group is less likely to be replaced accidentally with a different editor.
	"workbench.editor.autoLockGroups": {
		"default": false,
		"workbench.editorinputs.searchEditorInput": false,
		"jupyter-notebook": false,
		"imagePreview.previewEditor": false,
		"vscode.audioPreview": false,
		"vscode.videoPreview": false,
		"jsProfileVisualizer.cpuprofile.table": false,
		"jsProfileVisualizer.heapprofile.table": false,
		"terminalEditor": true,
		"workbench.input.interactive": false,
		"mainThreadWebview-markdown.preview": false
	},

	//* 💡 ru - Определяет, должен ли центрированный макет автоматически изменять размер до максимальной ширины, когда открыто более одной группы. Как только будет открыта только одна группа, ее размер вернется к исходной ширине по центру.
	//* 💡 en - Controls if the centered layout should automatically resize to maximum width when more than one group is open. Once only one group is open it will resize back to the original centered width.
	"workbench.editor.centeredLayoutAutoResize": true,

	//* 💡 ru - Управляет поведением пустых групп редакторов при закрытии последней вкладки в группе. При включении пустые группы автоматически закрываются. При отключении пустые группы останутся частью сетки.
	//* 💡 en - Controls the behavior of empty editor groups when the last tab in the group is closed. When enabled, empty groups will automatically close. When disabled, empty groups will remain part of the grid.
	"workbench.editor.closeEmptyGroups": true,

	//* 💡 ru - Определяет, должны ли редакторы, показывающие файл, который был открыт во время сеанса, автоматически закрываться при удалении или переименовании каким-либо другим процессом. Отключив это, редактор останется открытым при таком событии. Обратите внимание, что удаление из приложения всегда приводит к закрытию редактора, а редакторы с несохраненными изменениями никогда не закрываются для сохранения ваших данных.
	//* 💡 en - Controls whether editors showing a file that was opened during the session should close automatically when getting deleted or renamed by some other process. Disabling this will keep the editor open  on such an event. Note that deleting from within the application will always close the editor and that editors with unsaved changes will never close to preserve your data.
	"workbench.editor.closeOnFileDelete": false,

	//* 💡 ru - Определяет, должны ли декорации файлов редактора использовать значки.
	//* 💡 en - Controls whether editor file decorations should use badges.
	"workbench.editor.decorations.badges": true,

	//* 💡 ru - Определяет, должны ли декорации файлов редактора использовать цвета.
	//* 💡 en - Controls whether editor file decorations should use colors.
	"workbench.editor.decorations.colors": true,

	//* 💡 ru - Редактор по умолчанию для файлов, определенных как двоичные. Если не определено, пользователю будет представлен инструмент выбора.
	//* 💡 en - The default editor for files detected as binary. If undefined, the user will be presented with a picker.
	"workbench.editor.defaultBinaryEditor": "",

	//* 💡 ru - Определяет, будут ли открытые редакторы отображаться как редакторы предварительного просмотра. Редакторы предварительного просмотра не остаются открытыми, используются повторно до тех пор, пока явным образом не будут настроены на то, чтобы оставаться открытыми (с помощью двойного щелчка или редактирования), и отображают имена файлов курсивом.
	//* 💡 en - Controls whether opened editors show as preview editors. Preview editors do not stay open, are reused until explicitly set to be kept open (via double click or editing), and show file names in italics.
	"workbench.editor.enablePreview": true,

	//* 💡 ru - Определяет, остаются ли редакторы в режиме предварительного просмотра, когда из них запускается навигация по коду. Редакторы предварительного просмотра не остаются открытыми и используются повторно до тех пор, пока явно не будет указано, что они должны оставаться открытыми (через двойной щелчок или редактирование). Это значение игнорируется, если `workbench.editor.enablePreview` отключен.
	//* 💡 en - Controls whether editors remain in preview when a code navigation is started from them. Preview editors do not stay open, and are reused until explicitly set to be kept open (via double click or editing). This value is ignored when `workbench.editor.enablePreview` is disabled.
	"workbench.editor.enablePreviewFromCodeNavigation": false,

	//* 💡 ru - Определяет, будут ли редакторы, открытые из быстрого открытия, отображаться как редакторы предварительного просмотра. Редакторы предварительного просмотра не остаются открытыми и используются повторно до тех пор, пока явно не будет указано, что они должны оставаться открытыми (через двойной щелчок или редактирование). Это значение игнорируется, если `workbench.editor.enablePreview` отключен.
	//* 💡 en - Controls whether editors opened from Quick Open show as preview editors. Preview editors do not stay open, and are reused until explicitly set to be kept open (via double click or editing). This value is ignored when `workbench.editor.enablePreview` is disabled.
	"workbench.editor.enablePreviewFromQuickOpen": false,

	//* 💡 ru - Определяет, закрываются ли вкладки в последнем использовавшемся порядке или слева направо.
	//* 💡 en - Controls whether tabs are closed in most recently used order or from left to right.
	"workbench.editor.focusRecentEditorAfterClose": true,

	//* 💡 ru - Определяет, рисуется ли верхняя граница на вкладках для редакторов с несохраненными изменениями. Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls whether a top border is drawn on tabs for editors that have unsaved changes. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.highlightModifiedTabs": false,

	//* 💡 ru - Включает использование истории редактора при определении языка. Это приводит к тому, что автоматическое определение языка отдает предпочтение языкам, которые были недавно открыты, и позволяет автоматическому распознаванию языка работать с меньшими входными данными.
	//* 💡 en - Enables use of editor history in language detection. This causes automatic language detection to favor languages that have been recently opened and allows for automatic language detection to operate with smaller inputs.
	"workbench.editor.historyBasedLanguageDetection": true,

	//* 💡 ru - Управляет форматом метки для редактора.
	//* 💡 en - Controls the format of the label for an editor.
	"workbench.editor.labelFormat": "default",

	//* 💡 ru - Определяет, будет ли автоматически определяться язык в текстовом редакторе, если язык не был явно задан средством выбора языка. Это также может быть ограничено языком, поэтому вы можете указать, какие языки вы не хотите отключать. Это полезно для таких языков, как Markdown, которые часто содержат другие языки, которые могут обмануть обнаружение языка, заставив его думать, что это встроенный язык, а не Markdown.
	//* 💡 en - Controls whether the language in a text editor is automatically detected unless the language has been explicitly set by the language picker. This can also be scoped by language so you can specify which languages you do not want to be switched off of. This is useful for languages like Markdown that often contain other languages that might trick language detection into thinking it's the embedded language and not Markdown.
	"workbench.editor.languageDetection": true,

	//* 💡 ru - Если этот параметр включен, показывает быстрое исправление в строке состояния, когда язык редактора не соответствует обнаруженному языку содержимого.
	//* 💡 en - When enabled, shows a Status bar Quick Fix when the editor language doesn't match detected content language.
	"workbench.editor.languageDetectionHints": {
		"untitledEditors": true,
		"notebookEditors": true
	},

	//* 💡 ru - Определяет, должно ли быть ограничено количество открытых редакторов. Если этот параметр включен, редко используемые редакторы будут закрываться, чтобы освободить место для новых открывающихся редакторов.
	//* 💡 en - Controls if the number of opened editors should be limited or not. When enabled, less recently used editors will close to make space for newly opening editors.
	"workbench.editor.limit.enabled": false,

	//* 💡 ru - Определяет, должно ли максимальное количество открытых редакторов исключать грязные редакторы для подсчета настроенного предела.
	//* 💡 en - Controls if the maximum number of opened editors should exclude dirty editors for counting towards the configured limit.
	"workbench.editor.limit.excludeDirty": false,

	//* 💡 ru - Определяет, должно ли ограничение на максимальное количество открытых редакторов применяться к группе редакторов или ко всем группам редакторов.
	//* 💡 en - Controls if the limit of maximum opened editors should apply per editor group or across all editor groups.
	"workbench.editor.limit.perEditorGroup": false,

	//* 💡 ru - Управляет максимальным количеством открытых редакторов. Используйте настройку `workbench.editor.limit.perEditorGroup`, чтобы управлять этим ограничением для группы редакторов или для всех групп.
	//* 💡 en - Controls the maximum number of opened editors. Use the `workbench.editor.limit.perEditorGroup` setting to control this limit per editor group or across all groups.
	"workbench.editor.limit.value": 10,

	//* 💡 ru - Позволяет использовать четвертую и пятую кнопки мыши для команд «Назад» и «Вперед».
	//* 💡 en - Enables the use of mouse buttons four and five for commands 'Go Back' and 'Go Forward'.
	"workbench.editor.mouseBackForwardToNavigate": true,

	//* 💡 ru - Управляет областью навигации по истории в редакторах для таких команд, как «Назад» и «Вперед».
	//* 💡 en - Controls the scope of history navigation in editors for commands such as 'Go Back' and 'Go Forward'.
	"workbench.editor.navigationScope": "default",

	//* 💡 ru - Определяет, где открываются редакторы. Выберите «влево» или «вправо», чтобы открыть редакторы слева или справа от текущего активного. Выберите «первый» или «последний», чтобы открывать редакторы независимо от текущего активного.
	//* 💡 en - Controls where editors open. Select `left` or `right` to open editors to the left or right of the currently active one. Select `first` or `last` to open editors independently from the currently active one.
	"workbench.editor.openPositioning": "right",

	//* 💡 ru - Управляет направлением по умолчанию для редакторов, которые открываются рядом (например, из проводника). По умолчанию редакторы открываются справа от активного в данный момент. Если изменить на «вниз», редакторы будут открываться ниже активного в данный момент.
	//* 💡 en - Controls the default direction of editors that are opened side by side (for example, from the Explorer). By default, editors will open on the right hand side of the currently active one. If changed to `down`, the editors will open below the currently active one.
	"workbench.editor.openSideBySideDirection": "right",

	//* 💡 ru - Управляет размером закрепленных вкладок редактора. Закрепленные вкладки сортируются по началу всех открытых вкладок и обычно не закрываются до тех пор, пока не будут откреплены. Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls the sizing of pinned editor tabs. Pinned tabs are sorted to the beginning of all opened tabs and typically do not close until unpinned. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.pinnedTabSizing": "normal",

	//* 💡 ru - Если эта функция включена, модель определения языка, учитывающая историю редактирования, будет иметь более высокий приоритет.
	//* 💡 en - When enabled, a language detection model that takes into account editor history will be given higher precedence.
	"workbench.editor.preferHistoryBasedLanguageDetection": true,

	//* 💡 ru - Восстанавливает последнее состояние просмотра редактора (например, положение прокрутки) при повторном открытии редакторов после того, как они были закрыты. Состояние просмотра редактора сохраняется для каждой группы редакторов и сбрасывается при закрытии группы. Используйте параметр `workbench.editor.sharedViewState`, чтобы использовать последнее известное состояние просмотра во всех группах редакторов, если предыдущее состояние просмотра не было найдено для группы редакторов.
	//* 💡 en - Restores the last editor view state (such as scroll position) when re-opening editors after they have been closed. Editor view state is stored per editor group and discarded when a group closes. Use the `workbench.editor.sharedViewState` setting to use the last known view state across all editor groups in case no previous view state was found for a editor group.
	"workbench.editor.restoreViewState": true,

	//* 💡 ru - Определяет, отображается ли редактор в любой из видимых групп, если он открыт. Если отключено, редактор предпочтет открываться в текущей активной группе редакторов. Если этот параметр включен, уже открытый редактор будет отображаться, а не открываться снова в текущей активной группе редакторов. Обратите внимание, что в некоторых случаях этот параметр игнорируется, например, при принудительном открытии редактора в определенной группе или на стороне текущей активной группы.
	//* 💡 en - Controls whether an editor is revealed in any of the visible groups if opened. If disabled, an editor will prefer to open in the currently active editor group. If enabled, an already opened editor will be revealed instead of opened again in the currently active editor group. Note that there are some cases where this setting is ignored, such as when forcing an editor to open in a specific group or to the side of the currently active group.
	"workbench.editor.revealIfOpen": false,

	//* 💡 ru - Определяет, будут ли открываться вкладки при прокрутке. По умолчанию вкладки отображаются только при прокрутке, но не открываются. Вы можете нажать и удерживать клавишу Shift при прокрутке, чтобы изменить это поведение на указанное время. Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls whether scrolling over tabs will open them or not. By default tabs will only reveal upon scrolling, but not open. You can press and hold the Shift-key while scrolling to change this behavior for that duration. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.scrollToSwitchTabs": false,

	//* 💡 ru - Сохраняет самое последнее состояние просмотра редактора (например, положение прокрутки) во всех группах редакторов и восстанавливает его, если для группы редакторов не найдено конкретное состояние просмотра редактора.
	//* 💡 en - Preserves the most recent editor view state (such as scroll position) across all editor groups and restores that if no specific editor view state is found for the editor group.
	"workbench.editor.sharedViewState": false,

	//* 💡 ru - Определяет, должны ли открытые редакторы отображаться со значком или нет. Для этого также необходимо включить тему значков файлов.
	//* 💡 en - Controls whether opened editors should show with an icon or not. This requires a file icon theme to be enabled as well.
	"workbench.editor.showIcons": true,

	//* 💡 ru - Определяет, должны ли открытые редакторы отображаться во вкладках или нет.
	//* 💡 en - Controls whether opened editors should show in tabs or not.
	"workbench.editor.showTabs": true,

	//* 💡 ru - Управляет макетом, когда редактор разделен в группе редакторов на вертикальный или горизонтальный.
	//* 💡 en - Controls the layout for when an editor is split in an editor group to be either vertical or horizontal.
	"workbench.editor.splitInGroupLayout": "horizontal",

	//* 💡 ru - Определяет, можно ли отделять группы редакторов от операций перетаскивания путем перетаскивания редактора или файла по краям области редактора.
	//* 💡 en - Controls if editor groups can be split from drag and drop operations by dropping an editor or file on the edges of the editor area.
	"workbench.editor.splitOnDragAndDrop": true,

	//* 💡 ru - Управляет размером групп редакторов при их разделении.
	//* 💡 en - Controls the sizing of editor groups when splitting them.
	"workbench.editor.splitSizing": "distribute",

	//* 💡 ru - Управляет положением кнопок закрытия вкладок редактора или отключает их, если установлено значение «Выкл.». Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls the position of the editor's tabs close buttons, or disables them when set to 'off'. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.tabCloseButton": "right",

	//* 💡 ru - Управляет высотой полос прокрутки, используемых для вкладок и навигационных цепочек в области заголовка редактора.
	//* 💡 en - Controls the height of the scrollbars used for tabs and breadcrumbs in the editor title area.
	"workbench.editor.titleScrollbarSizing": "default",

	//* 💡 ru - Определяет, должна ли текстовая подсказка без названия отображаться в редакторе.
	//* 💡 en - Controls if the untitled text hint should be visible in the editor.
	"workbench.editor.untitled.hint": "text",

	//* 💡 ru - Управляет форматом метки для безымянного редактора.
	//* 💡 en - Controls the format of the label for an untitled editor.
	"workbench.editor.untitled.labelFormat": "content",

	//* 💡 ru - Определяет, должны ли вкладки переноситься на несколько строк при превышении доступного места или вместо этого должна отображаться полоса прокрутки. Это значение игнорируется, если `workbench.editor.showTabs` отключен.
	//* 💡 en - Controls whether tabs should be wrapped over multiple lines when exceeding available space or whether a scrollbar should appear instead. This value is ignored when `workbench.editor.showTabs` is disabled.
	"workbench.editor.wrapTabs": false,

	//* 💡 ru - Настройте средство открытия для использования с внешними URI (http, https).
	//* 💡 en - Configure the opener to use for external URIs (http, https).
	"workbench.externalUriOpeners": {},

	//* 💡 ru - Управляет методом псевдонима шрифта в рабочей среде.
	//* 💡 en - Controls font aliasing method in the workbench.
	"workbench.fontAliasing": "default",

	//* 💡 ru - Управляет задержкой в миллисекундах, после которой отображается наведение для элементов рабочей среды (например, некоторые элементы представления дерева, предоставленные расширением). Для уже видимых элементов может потребоваться обновление перед отражением этого изменения настройки.
	//* 💡 en - Controls the delay in milliseconds after which the hover is shown for workbench items (ex. some extension provided tree view items). Already visible items may require a refresh before reflecting this setting change.
	"workbench.hover.delay": 500,

	//* 💡 ru - Определяет, отображается ли элемент управления макетом в настраиваемой строке заголовка. Этот параметр действует только тогда, когда для `window.titleBarStyle` установлено значение `custom`.
	//* 💡 en - Controls whether the layout control is shown in the custom title bar. This setting only has an effect when `window.titleBarStyle` is set to `custom`.
	"workbench.layoutControl.enabled": true,

	//* 💡 ru - Определяет, отображается ли элемент управления макетом в настраиваемой строке заголовка в виде одной кнопки меню или с несколькими переключателями пользовательского интерфейса.
	//* 💡 en - Controls whether the layout control in the custom title bar is displayed as a single menu button or with multiple UI toggles.
	"workbench.layoutControl.type": "both",

	//* 💡 ru - Управляет режимом поиска по умолчанию для списков и деревьев в рабочей среде.
	//* 💡 en - Controls the default find mode for lists and trees in the workbench.
	"workbench.list.defaultFindMode": "highlight",

	//* 💡 ru - Множитель скорости прокрутки при нажатии Alt.
	//* 💡 en - Scrolling speed multiplier when pressing `Alt`.
	"workbench.list.fastScrollSensitivity": 5,

	//* 💡 ru - Определяет, поддерживают ли списки и деревья горизонтальную прокрутку в рабочей среде. Предупреждение: включение этого параметра влияет на производительность.
	//* 💡 en - Controls whether lists and trees support horizontal scrolling in the workbench. Warning: turning on this setting has a performance implication.
	"workbench.list.horizontalScrolling": false,

	//* 💡 ru - Множитель, который будет использоваться для `deltaX` и `deltaY` событий прокрутки колеса мыши.
	//* 💡 en - A multiplier to be used on the `deltaX` and `deltaY` of mouse wheel scroll events.
	"workbench.list.mouseWheelScrollSensitivity": 1,

	//* 💡 ru - Модификатор, который будет использоваться для добавления элемента в деревья и списки к множественному выбору с помощью мыши (например, в проводнике, открытых редакторах и представлении scm). Жесты мыши «Открыть в сторону» — если они поддерживаются — будут адаптироваться таким образом, чтобы они не конфликтовали с модификатором множественного выбора.
	//* 💡 en - The modifier to be used to add an item in trees and lists to a multi-selection with the mouse (for example in the explorer, open editors and scm view). The 'Open to Side' mouse gestures - if supported - will adapt such that they do not conflict with the multiselect modifier.
	"workbench.list.multiSelectModifier": "ctrlCmd",

	//* 💡 ru - Управляет тем, как открывать элементы в деревьях и списках с помощью мыши (если поддерживается). Обратите внимание, что некоторые деревья и списки могут игнорировать этот параметр, если он неприменим.
	//* 💡 en - Controls how to open items in trees and lists using the mouse (if supported). Note that some trees and lists might choose to ignore this setting if it is not applicable.
	"workbench.list.openMode": "singleClick",

	//* 💡 ru - Управляет плавной прокруткой списков и деревьев.
	//* 💡 en - Controls whether lists and trees have smooth scrolling.
	"workbench.list.smoothScrolling": false,

	//* 💡 ru - Определяет, включена ли локальная история файлов. Если этот параметр включен, содержимое файла сохраненного редактора будет сохранено в резервной копии, чтобы его можно было восстановить или просмотреть позже. Изменение этого параметра не влияет на существующие записи истории локальных файлов.
	//* 💡 en - Controls whether local file history is enabled. When enabled, the file contents of an editor that is saved will be stored to a backup location to be able to restore or review the contents later. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.enabled": true,

	//* 💡 ru - Настройте шаблоны универсальных объектов для исключения файлов из локальной истории файлов. Изменение этого параметра не влияет на существующие записи истории локальных файлов.
	//* 💡 en - Configure glob patterns for excluding files from the local file history. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.exclude": {},

	//* 💡 ru - Управляет максимальным количеством записей локальной истории файлов на файл. Когда количество записей в локальной файловой истории превышает это число для файла, самые старые записи будут удалены.
	//* 💡 en - Controls the maximum number of local file history entries per file. When the number of local file history entries exceeds this number for a file, the oldest entries will be discarded.
	"workbench.localHistory.maxFileEntries": 50,

	//* 💡 ru - Управляет максимальным размером файла (в КБ), который должен учитываться для локальной файловой истории. Файлы большего размера не будут добавлены в локальную историю файлов. Изменение этого параметра не влияет на существующие записи истории локальных файлов.
	//* 💡 en - Controls the maximum size of a file (in KB) to be considered for local file history. Files that are larger will not be added to the local file history. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.maxFileSize": 256,

	//* 💡 ru - Настройте интервал в секундах, в течение которого последняя запись в локальной файловой истории заменяется добавляемой записью. Это помогает уменьшить общее количество добавляемых записей, например, когда включено автоматическое сохранение. Этот параметр применяется только к записям, имеющим один и тот же источник происхождения. Изменение этого параметра не влияет на существующие записи истории локальных файлов.
	//* 💡 en - Configure an interval in seconds during which the last entry in local file history is replaced with the entry that is being added. This helps reduce the overall number of entries that are added, for example when auto save is enabled. This setting is only applied to entries that have the same source of origin. Changing this setting has no effect on existing local file history entries.
	"workbench.localHistory.mergeWindow": 10,

	//* 💡 ru - Управляет расположением панели по умолчанию (Терминал, Консоль отладки, Вывод, Проблемы) в новой рабочей области. Он может отображаться внизу, справа или слева от области редактора.
	//* 💡 en - Controls the default location of the panel (Terminal, Debug Console, Output, Problems) in a new workspace. It can either show at the bottom, right, or left of the editor area.
	"workbench.panel.defaultLocation": "bottom",

	//* 💡 ru - Определяет, открывается ли панель в развернутом виде. Он может либо всегда открываться в развернутом виде, никогда не открываться в развернутом виде, либо открываться в последнем состоянии, в котором он находился перед закрытием.
	//* 💡 en - Controls whether the panel opens maximized. It can either always open maximized, never open maximized, or open to the last state it was in before being closed.
	"workbench.panel.opensMaximized": "preserve",

	//* 💡 ru - Указывает предпочтительную цветовую тему для темного внешнего вида ОС, когда включен `window.autoDetectColorScheme`.
	//* 💡 en - Specifies the preferred color theme for dark OS appearance when `window.autoDetectColorScheme` is enabled.
	"workbench.preferredDarkColorTheme": "Default Dark+",

	//* 💡 ru - Указывает предпочтительную цветовую тему, используемую в высококонтрастном темном режиме, когда включен `window.autoDetectHighContrast`.
	//* 💡 en - Specifies the preferred color theme used in high contrast dark mode when `window.autoDetectHighContrast` is enabled.
	"workbench.preferredHighContrastColorTheme": "Default High Contrast",

	//* 💡 ru - Указывает предпочтительную цветовую тему, используемую в режиме высококонтрастного освещения, когда включен `window.autoDetectHighContrast`.
	//* 💡 en - Specifies the preferred color theme used in high contrast light mode when `window.autoDetectHighContrast` is enabled.
	"workbench.preferredHighContrastLightColorTheme": "Default High Contrast Light",

	//* 💡 ru - Определяет предпочтительную цветовую тему для светлой ОС, когда включено `window.autoDetectColorScheme`.
	//* 💡 en - Specifies the preferred color theme for light OS appearance when `window.autoDetectColorScheme` is enabled.
	"workbench.preferredLightColorTheme": "Default Light+",

	//* 💡 ru - Указывает используемую тему значка продукта.
	//* 💡 en - Specifies the product icon theme used.
	"workbench.productIconTheme": "Default",

	//* 💡 ru - Определяет, должно ли быстрое открытие автоматически закрываться после потери фокуса.
	//* 💡 en - Controls whether Quick Open should close automatically once it loses focus.
	"workbench.quickOpen.closeOnFocusLost": true,

	//* 💡 ru - Определяет, следует ли восстанавливать последний введенный ввод для быстрого открытия при открытии в следующий раз.
	//* 💡 en - Controls whether the last typed input to Quick Open should be restored when opening it the next time.
	"workbench.quickOpen.preserveInput": false,

	//* 💡 ru - Определяет, должно ли рабочее место отображаться с меньшим количеством анимаций.
	//* 💡 en - Controls whether the workbench should render with fewer animations.
	"workbench.reduceMotion": "auto",

	//* 💡 ru - Управляет задержкой обратной связи при наведении в миллисекундах области перетаскивания между представлениями/редакторами.
	//* 💡 en - Controls the hover feedback delay in milliseconds of the dragging area in between views/editors.
	"workbench.sash.hoverDelay": 300,

	//* 💡 ru - Управляет размером области обратной связи в пикселях области перетаскивания между представлениями/редакторами. Установите большее значение, если вам сложно изменить размер представлений с помощью мыши.
	//* 💡 en - Controls the feedback area size in pixels of the dragging area in between views/editors. Set it to a larger value if you feel it's hard to resize views using the mouse.
	"workbench.sash.size": 4,

	//* 💡 ru - Определяет, какой редактор настроек использовать по умолчанию.
	//* 💡 en - Determines which settings editor to use by default.
	"workbench.settings.editor": "ui",

	//* 💡 ru - Определяет, следует ли включать режим поиска на естественном языке для настроек. Поиск на естественном языке обеспечивается онлайн-сервисом Microsoft.
	//* 💡 en - Controls whether to enable the natural language search mode for settings. The natural language search is provided by a Microsoft online service.
	"workbench.settings.enableNaturalLanguageSearch": true,

	//* 💡 ru - Определяет, будет ли открытие настроек привязки клавиш также открывать редактор, показывающий все привязки клавиш по умолчанию.
	//* 💡 en - Controls whether opening keybinding settings also opens an editor showing all default keybindings.
	"workbench.settings.openDefaultKeybindings": false,

	//* 💡 ru - Определяет, будет ли при открытии настроек открываться редактор, показывающий все настройки по умолчанию.
	//* 💡 en - Controls whether opening settings also opens an editor showing all default settings.
	"workbench.settings.openDefaultSettings": false,

	//* 💡 ru - Управляет поведением редактора настроек Table of Contents при поиске.
	//* 💡 en - Controls the behavior of the settings editor Table of Contents while searching.
	"workbench.settings.settingsSearchTocBehavior": "filter",

	//* 💡 ru - Определяет, следует ли использовать разделенный редактор JSON при редактировании настроек в формате JSON.
	//* 💡 en - Controls whether to use the split JSON editor when editing settings as JSON.
	"workbench.settings.useSplitJSON": false,

	//* 💡 ru - Управляет расположением основной боковой панели и панели активности. Они могут отображаться слева или справа от верстака. Второстепенная боковая панель появится на противоположной стороне верстака.
	//* 💡 en - Controls the location of the primary side bar and activity bar. They can either show on the left or right of the workbench. The secondary side bar will show on the opposite side of the workbench.
	"workbench.sideBar.location": "left",

	//* 💡 ru - Управляет видимостью строки состояния в нижней части рабочего места.
	//* 💡 en - Controls the visibility of the status bar at the bottom of the workbench.
	"workbench.statusBar.visible": true,

	//* 💡 ru - Когда включено, будут отображаться подсказки с водяными знаками, когда редактор не открыт.
	//* 💡 en - When enabled, will show the watermark tips when no editor is open.
	"workbench.tips.enabled": true,

	//* 💡 ru - Управляет расширением папок дерева при нажатии на имена папок. Обратите внимание, что некоторые деревья и списки могут игнорировать этот параметр, если он неприменим.
	//* 💡 en - Controls how tree folders are expanded when clicking the folder names. Note that some trees and lists might choose to ignore this setting if it is not applicable.
	"workbench.tree.expandMode": "singleClick",

	//* 💡 ru - Управляет отступом дерева в пикселях.
	//* 💡 en - Controls tree indentation in pixels.
	"workbench.tree.indent": 8,

	//* 💡 ru - Определяет, должно ли дерево отображать направляющие отступов.
	//* 💡 en - Controls whether the tree should render indent guides.
	"workbench.tree.renderIndentGuides": "onHover",

	//* 💡 ru - Если этот параметр включен, при открытии ссылок в доверенных рабочих областях будут появляться подсказки о доверенном домене.
	//* 💡 en - When enabled, trusted domain prompts will appear when opening links in trusted workspaces.
	"workbench.trustedDomains.promptInTrustedWorkspace": false,

	//* 💡 ru - Управляет видимостью действий заголовка представления. Действия заголовка представления могут быть либо всегда видны, либо видны только тогда, когда это представление находится в фокусе или наведено на него.
	//* 💡 en - Controls the visibility of view header actions. View header actions may either be always visible, or only visible when that view is focused or hovered over.
	"workbench.view.alwaysShowHeaderActions": false,

	//* 💡 ru - Если этот параметр включен, после установки расширения откроется пошаговое руководство.
	//* 💡 en - When enabled, an extension's walkthrough will open upon install of the extension.,
	"workbench.welcomePage.walkthroughs.openOnInstall": true,

	//! ✅ Zen Mode

	//* 💡 ru - Определяет, будет ли включение режима Zen также центрировать макет.
	//* 💡 en - Controls whether turning on Zen Mode also centers the layout.
	"zenMode.centerLayout": true,

	//* 💡 ru - Определяет, будет ли включение режима Zen также переводить рабочее место в полноэкранный режим.
	//* 💡 en - Controls whether turning on Zen Mode also puts the workbench into full screen mode.
	"zenMode.fullScreen": true,

	//* 💡 ru - Определяет, будет ли включение режима Zen также скрывать панель активности слева или справа от верстака.
	//* 💡 en - Controls whether turning on Zen Mode also hides the activity bar either at the left or right of the workbench.
	"zenMode.hideActivityBar": true,

	//* 💡 ru - Определяет, будет ли включение режима Zen также скрывать номера строк редактора.
	//* 💡 en - Controls whether turning on Zen Mode also hides the editor line numbers.
	"zenMode.hideLineNumbers": true,

	//* 💡 ru - Определяет, будет ли включение режима Zen также скрывать строку состояния в нижней части рабочего места.
	//* 💡 en - Controls whether turning on Zen Mode also hides the status bar at the bottom of the workbench.
	"zenMode.hideStatusBar": true,

	//* 💡 ru - Определяет, будет ли включение режима Zen также скрывать вкладки верстака.
	//* 💡 en - Controls whether turning on Zen Mode also hides workbench tabs.
	"zenMode.hideTabs": true,

	//* 💡 ru - Определяет, должно ли окно возвращаться в режим дзен, если оно было закрыто в режиме дзен.
	//* 💡 en - Controls whether a window should restore to Zen Mode if it was exited in Zen Mode.
	"zenMode.restore": true,

	//* 💡 ru - Определяет, должны ли быть включены уведомления в режиме «Не беспокоить» в режиме дзен. Если true, будут появляться только уведомления об ошибках.
	//* 💡 en - Controls whether notifications do not disturb mode should be enabled while in Zen Mode. If true, only error notifications will pop out.
	"zenMode.silentNotifications": true

}

